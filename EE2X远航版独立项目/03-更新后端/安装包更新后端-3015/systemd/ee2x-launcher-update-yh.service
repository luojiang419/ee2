[Unit]
Description=EE2X Launcher Installer Update Backend
After=network.target

[Service]
Type=simple
WorkingDirectory=__WORKDIR__
Environment=PYTHONUNBUFFERED=1
ExecStart=__WORKDIR__/.venv/bin/uvicorn app.main:app --host 0.0.0.0 --port __PORT__
Restart=always
RestartSec=3
User=root

[Install]
WantedBy=multi-user.target
