///-----------------------------西方船
UnitType WesternBoat2
{
	parent = NavalDeep
	properties {
		rps = FightingSail
		SizeX = 1.5
		SizeY = 0.8
		mass = 4
		displayName = tx_utn_MaChuan_name
		verboseTooltip = vtt_unit_MaChuan
		popCount = 3
		hitpoints = 3000
	}
	abilities = [
		Attack { damage = 200; range = 13; reloadTime = 3; applyDamageTime = 0.5; missileName = "BoatCannonBall"; turretControllerName = GalleonTurret;areaDamageRadius = 2; }
		LOS { range = 5 }
		NavalMove {speed = 1.4; angSpeed = 30; accel = 1.0}
	]
	icon = icon_unit_MaChuan
}
