{
	unitType = UniqueUnitInca1
	name = tx_utn_elite_modify_name
	upgradeRefs = [
		UniqueUnit_Improve_5
	]
}

//------------------------------------------------
//	UNIQUE UNIT MODEL
//------------------------------------------------
UnitModel UniqueUnitInca1
{
	Parent		= LightInfantry_01
        ScaleType	= kScaleUnit
	DefaultModel 	= CIV1_BolaThrower_Incan.nif
	ChildNames 	= [ UnitShadow ]
	States 		= [
		{	StateName = Idle	AnimName = CIV1_BolaThrower_Incan_idle01.KF
                              AnimVariants = [ CIV1_BolaThrower_Incan_idle02.KF ]
                              AnimVariantsWeights = [0.1]
                 }
		{ 	StateName = Walk	AnimName = CIV1_BolaThrower_Incan_walk01.KF }
                { 	StateName = CaptureAttack1	AnimName = CIV1_BolaThrower_Incan_capture01.KF
                              AnimVariants = [ CIV1_BolaThrower_Incan_capture02.KF ]
                              AnimVariantsWeights = [0.3]
                 }     
		{ 	StateName = Run	AnimName = CIV1_BolaThrower_Incan_jog01.KF
		}
		{ 	StateName = Attack1	AnimName = CIV1_BolaThrower_Incan_attack01.KF   }
                { 	StateName = Death	AnimName = CIV1_BolaThrower_Incan_death01.KF	}
		{	StateName = Flinch	AnimName = CIV1_BolaThrower_Incan_protect01.kf }
		{	StateName = BeingThrown	AnimName = CIV1_BolaThrower_Incan_flying01.kf
			AnimVariants = [ CIV1_BolaThrower_Incan_flying02.kf ] AnimVariantsWeights = [ 0.5 ]	}
		{	StateName = ThrownDeath	AnimName = CIV1_BolaThrower_Incan_ground_death01.KF	}
			]
}

