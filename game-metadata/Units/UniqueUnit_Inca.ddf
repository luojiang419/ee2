//------------------------------------------------------------------------------------------------
//	UNIQUE UNIT INCA BOLA THROWER (EPOCHS 1-5)
//------------------------------------------------------------------------------------------------
UnitType UniqueUnitInca1
{
	parent = LightInfantry
	properties {
		DisplayName = tx_utn_UUInca1_name
		DisplayNameScenEdit = tx_utn_UUInca1_sname
		VerboseTooltip = vtt_unit_UUInca1
		HitPoints = 0
		rps = LightInfantry
		SizeX = 0.125
		SizeY = 0.125
		mass = 1
	}
	sounds = {
	}
	abilities = [
		Attack { damage = 0; range = 0; reloadTime = 666; applyDamageTime = 1.5; missileName = "Stone" }
		ConvertAttack { convertTimeModifier = 10.0; range = 5.0; reloadTime = 4.0; applyDamageTime = 1.0; capture = 1 } // capture ability
		LOS { range = 0 }
		Move { speed = 1.3; angSpeed = 720}
	]
}

//------------------------------------------------
//	UNIQUE UNIT IMPROVEMENTS
//------------------------------------------------

