			{ StateName= Idle AnimName = civ12_thundergun_incan_idle.kf
				 }

			{ StateName= Walk AnimName = civ12_thundergun_incan_walk.kf
				TextKeys = [ 
					     { Name = START_SOUND_UNTIL_ANIM_CHANGE Data = fx_move_self_propelled KeyTime = 0} 
					   ] 
				}

			{ StateName= Attack1	AnimName = civ12_thundergun_incan_fire.kf
				TextKeys = [ 
					     { Name = PLAY_SOUND Data = Tank_firing1 KeyTime = 0.3 }
					   ] 
				}

			{ StateName= Death AnimName = civ12_thundergun_incan_death.kf
				}
		]
	ChildNames 	= [ FX_ExaustSmoke1 TankTracks Muzzle_HeavyArtillery ExplSelectorTank01 SelfPropelledShadow ]
	UIRenderingParams {
		xOffset = 0.01
		yOffset = 0.77
		zOffset = 1.27
		scale = 1.92
		angle = 56.84
		rotationSpeed = 0.00
		pitch = 20.00
	}
}