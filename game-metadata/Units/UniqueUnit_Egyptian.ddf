//------------------------------------------------
//	UNIQUE UNIT MODEL
//------------------------------------------------
UnitModel UniqueUnitEgyptian1
{
	Parent		= HeavyMounted1_06
        DefaultModel 	= CIV1_RoyalChariot_Egyptian.nif
	ChildNames 	= [ UnitShadow ]
	States 		= [
		{	StateName = Idle	AnimName = CIV1_RoyalChariot_Egyptian_idle01.KF
                              AnimVariants = [ CIV1_RoyalChariot_Egyptian_idle02.KF ]
                              AnimVariantsWeights = [ 0.3 ]
                 }  
                { 	StateName = Walk	AnimName = CIV1_RoyalChariot_Egyptian_walk01.KF  }
		{ 	StateName = Run	        AnimName = CIV1_RoyalChariot_Egyptian_run01.KF   }
		{ 	StateName = Attack1	AnimName = CIV1_RoyalChariot_Egyptian_attack01.KF 
			TextKeys = [ { Name = PLAY_SOUND Data = fx_bow_shoot_high KeyTime = 0.4 } ] 
                 }	
		{ 	StateName = Death	AnimName = CIV1_RoyalChariot_Egyptian_death01.KF  }
		{	StateName = Flinch	AnimName = CIV1_RoyalChariot_Egyptian_protect01.KF	}
		{	StateName = BeingThrown	AnimName = CIV1_RoyalChariot_Egyptian_flying01.KF
			AnimVariants = [ CIV1_RoyalChariot_Egyptian_flying02.KF ] AnimVariantsWeights = [ 0.5 ]	}
		{	StateName = ThrownDeath	AnimName = CIV1_RoyalChariot_Egyptian_ground_death01.KF	}
			]
          
}

