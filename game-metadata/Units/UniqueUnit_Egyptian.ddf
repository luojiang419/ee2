//	UNIQUE UNIT MODEL
//------------------------------------------------
UnitModel UniqueUnitEgyptian2
{
	Parent		= HeavyMounted1_08
        DefaultModel 	= CIV3_Bedouin_Egyptian.nif
	ChildNames 	= [ UnitShadow Muzzle_Musketeer ]
	States 		= [
		{	StateName = Idle	AnimName = CIV3_Bedouin_Egyptian_idle01.KF  }  
                { 	StateName = Walk	AnimName = CIV3_Bedouin_Egyptian_walk01.KF  }
		{ 	StateName = Run	        AnimName = CIV3_Bedouin_Egyptian_run01.KF   }
		{ 	StateName = Attack1	AnimName = CIV3_Bedouin_Egyptian_attack01.KF 
			TextKeys = [
					{ Name = PLAY_SOUND Data = fx_musket_fire KeyTime = 0.35 }
					] }	
		{ 	StateName = Pack	AnimName = CIV3_Bedouin_Egyptian_pack01.KF  }
		{ 	StateName = Unpack	AnimName = CIV3_Bedouin_Egyptian_unpack01.KF  }
		{ 	StateName = Death	AnimName = CIV3_Bedouin_Egyptian_death01.KF  }
		{	StateName = Flinch	AnimName = CIV3_Bedouin_Egyptian_protect01.KF	}
		{	StateName = BeingThrown	AnimName = CIV3_Bedouin_Egyptian_flying01.KF
			AnimVariants = [ CIV3_Bedouin_Egyptian_flying02.KF ] AnimVariantsWeights = [ 0.5 ]	}
		{	StateName = ThrownDeath	AnimName = CIV3_Bedouin_Egyptian_ground_death01.KF	}
			]
	UIRenderingParams {
		xOffset = -5.26
		yOffset = 1.73
		zOffset = -1.16
		scale = 0.89
		angle = 47.37
		pitch = 10.00
	}
}

