		SizeY = 0.2
		mass = 1
	}
	sounds = {
	}
	abilities = [
		Attack { range = 0.2; reloadTime = 1.5; applyDamageTime = 0.5; damage = 0 }
		ConvertAttack { convertTimeModifier = 3.0; range = 0.2; reloadTime = 4.0; applyDamageTime = 1.0; capture = 1 } // capture ability
		LOS { range = 0 }
		Move {speed = 1.3; angSpeed = 720}
	]
	attributes = [
		CanJoinHeroArmy
	]
}

