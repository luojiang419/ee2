//------------------------------------------------------------------------------------------------
//	FARM
//------------------------------------------------------------------------------------------------
UnitType Farm
{
	placementType = Farm
	OwnerType = PlayerOnly
	properties {
		FootprintType = kFootprintType_Rectangle
		SizeX = 1.5
		SizeY = 1.5
		mass = 0   // no pathblocking
		rps = Building
		hitpoints = 100
		displayName = tx_utn_farm_name
		VerboseTooltip = vtt_unit_Farm
		mmColor = [128,128,128,255]
	}
	sounds {
		sndSelection = ["Farm_select"]
    	}
	abilities [
		LOS { range = 0 }
		resourceFarm { type = Food; amount = 100; maxNumOfWorkers = 1 }	
			// farm will keep producing resource as long as someone works on it
	]
	fullMapOverlay { sprite = spr_fullmap_building }
	icon = icon_unit_farm
	citizenManagerCursorSprite = spr_citmanager_cursor_farm
}

UnitType FarmWheat
{
	properties {
		displayName = tx_utn_farmWheat_name
	}
	parent = Farm
}

UnitType FarmSugarCane
{
	properties {
		displayName = tx_utn_farmSugar_name
	}
	parent = Farm
}

UnitType FarmYam
{
	properties {
		displayName = tx_utn_farmYam_name
	}
	parent = Farm
}

//------------------------------------------------------------------------------------------------
//	FARM - UPGRADES
//------------------------------------------------------------------------------------------------
UpgradeSet FarmUpgradeEpoch2 {
	upgrades = [
		UpgradeDisplayName {UnitType = Farm; name = tx_utn_farm_u2_name}
		UpgradeUnitTypeFactor {UnitType = Farm; factor = HitPoints; method = Set; value = 100; upgradeChildren = 0;}
		UpgradeVisual {UnitType = FarmWheat; newVisual = FarmWheat;}
		UpgradeVisual {UnitType = FarmSugarCane; newVisual = FarmSugarCane;}
		//UpgradeVisual {UnitType = FarmYam; newVisual = FarmYam; }
	]
}

//------------------------------------------------------------------------------------------------
//	FARM - VISUAL INFO
//------------------------------------------------------------------------------------------------

// ---------------- generic farm, used during ghosting only -------------------------------------
CompositeModel Farm
{
	// copied from FarmWheat, because we want to see some visual while moving the mouse
	ScaleType 		= kScaleBuilding
	ChildNames 		= [FarmWheatCompositePlots TheHealthBar  SelectCircleBig UnderFarm ]
}

//------------------------------------------------
//	EPOCH 2
//------------------------------------------------

// ---------- wheat farm --------------------------

StateDatabase FarmWheatPlotState_1
{
	DefaultState = Harvest_3_1
	States = 
	[
		{	StateName = Seeding_1	AnimName = bld_farm_wheat_seeding.kf ModelName = bld_farm_wheat.nif
			TextKeys = [ 
					{ Name = SHOW_VISUAL Data = FarmWheatPlot_1 	KeyTime = 0 }
					] }
		{	StateName = Harvest_1_1	ModelName = bld_farm_wheat_harvest_1.nif }
		{	StateName = Harvest_2_1	ModelName = bld_farm_wheat_harvest_2.nif }
		{	StateName = Harvest_3_1	ModelName = bld_farm_wheat_harvest_3.nif }
		{	StateName = Death	ModelName = NULL.nif }
	]
}

FarmPlotModel FarmWheatPlot_1
{
	StateDatabaseName = FarmWheatPlotState_1
	XOffset = -25
	YOffset = -25
	ZOffset = 0
}

