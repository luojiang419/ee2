{
	unitType = UniqueUnitAztec1
	name = tx_utn_elite_modify_name
	upgradeRefs = [
		UniqueUnit_Improve_5
	]
}

//------------------------------------------------
//	UNIQUE UNIT MODEL
//------------------------------------------------
UnitModel UniqueUnitAztec1
{
	Parent		= LightInfantry_01
	ScaleType	= kScaleUnit
	DefaultModel 	= CIV3_AtlatlThrower_Aztec.nif
	ChildNames 	= [ UnitShadow ]
	States 		= [
		{	StateName = Idle	AnimName = CIV3_AtlatlThrower_Aztec_idle01.kf
                              AnimVariants = [ CIV3_AtlatlThrower_Aztec_idle02.kf ]
                              AnimVariantsWeights = [ 0.2 ]
                 }
		{ 	StateName = Walk	AnimName = CIV3_AtlatlThrower_Aztec_walk01.kf	}
                { 	StateName = CaptureAttack1	AnimName = CIV3_AtlatlThrower_Aztec_capture01.KF
                              AnimVariants = [ CIV3_AtlatlThrower_Aztec_capture02.KF ]
                              AnimVariantsWeights = [0.3]
                 }                            
		{ 	StateName = Run	        AnimName = CIV3_AtlatlThrower_Aztec_jog01.kf	}
		{ 	StateName = Attack1	AnimName = CIV3_AtlatlThrower_Aztec_attack01.kf
			TextKeys = [ { Name = PLAY_SOUND Data = fx_bow_shoot_high KeyTime = 1.15 } ] 
                 }
		{ 	StateName = Death	AnimName = CIV3_AtlatlThrower_Aztec_death01.kf	}
		{	StateName = Flinch	AnimName = CIV3_AtlatlThrower_Aztec_protect01.KF	}
		{	StateName = BeingThrown	AnimName = CIV3_AtlatlThrower_Aztec_flying01.KF
			AnimVariants = [ CIV3_AtlatlThrower_Aztec_flying02.KF ] AnimVariantsWeights = [ 0.5 ]	}
		{	StateName = ThrownDeath	AnimName = CIV3_AtlatlThrower_Aztec_ground_death01.KF	}
			]
	UIRenderingParams {
		xOffset = 0.01
		yOffset = -0.44
		zOffset = -6.42
		scale = 2.69
		angle = 23.68
	}
}

