//------------------------------------------------------------------------------------------------
//	UNIQUE UNIT AZTEC ATlATl THROWER (EPOCHS 1-5)
//------------------------------------------------------------------------------------------------
UnitType UniqueUnitAztec1
{
	parent = LightInfantry
	properties {
		DisplayName = tx_utn_UUAztec1_name
		DisplayNameScenEdit = tx_utn_UUAztec1_sname
		VerboseTooltip = vtt_unit_UUAztec1
		HitPoints = 0
		rps = LightInfantry
		SizeX = 0.225
		SizeY = 0.225
		mass = 1
	}
	sounds = {
	}
	abilities = [
		Attack { damage = 0; range = 0; reloadTime = 666; angularRange = 30; applyDamageTime = 1.15; missileName = "Spear"  }
		ConvertAttack { convertTimeModifier = 10; range = 5.0; reloadTime = 4.0; applyDamageTime = 1.0; capture = 1 } // capture ability
		LOS { range = 0 }
		Move { speed = 1.3; angSpeed = 720}
	]
}

