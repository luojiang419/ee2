//------------------------------------------------------------------------------------------------
//	UNIQUE UNIT JUNGLE HEALER (EPOCHS 11-15)
//------------------------------------------------------------------------------------------------
UnitType UniqueUnitAztec3
{
	parent = Medic
	properties {
		DisplayName = tx_utn_UUAztec3_name
		DisplayNameScenEdit = tx_utn_UUAztec3_sname
		VerboseTooltip = vtt_unit_UUAztec3
		HitPoints = 0
		SizeX = 0.225
		SizeY = 0.225
		mass = 1
		moveType = kUnitMoveType_Foot
		// medics default to aggressive.  they really like to heal
		stance = Aggressive
	}
	sounds = {
	}

	abilities = [
		Move {speed = 1.3; angSpeed = 720; angAccel = 720}
		LOS { range = 5 }
		Heal {range = 0.2; healRate = 7; healType = HealedByMedic; HealRadius = 2.0 }
	]
}

