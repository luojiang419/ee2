//------------------------------------------------------------------------------------------------
//	HOUSE - UNIT TYPE INFO
//------------------------------------------------------------------------------------------------
UnitType House
{
	ownerType = PlayerOnly
	parent = NoProduceBuilding
	properties {
		popCapacity = 10
		rps = BuildingCombat
		SizeX = 1.5
		SizeY = 1.5
		FootprintSizeX = 3
		FootprintSizeY = 3
		OffsetX = 0.75
		OffsetY = 0.75
		UndertextureSizeX = 1.5
		UndertextureSizeY = 1.5
		mass = 1
		displayName = tx_utn_house_name
		DisplayNameScenEdit = tx_utn_house_sname
		VerboseTooltip = vtt_unit_House
	}
	sounds {
    	}
	fullMapOverlay { sprite = spr_fullmap_house }
	abilities = [
		LOS { range = 0 }
		
		// houses have latent attack ability to support "LiberalFront" regional power
		// where suddenly your citizens get tough  and take up arms against enemies.
		// (all from the comfort of their homes)
		Attack { latent = true; range = 4; reloadTime = 1; applyDamageTime = 0.5; damage = 20; missileName = "Arrow"; angularRange = 360 }
		Convertable { 
			convertTimeModifier = 100.0;  //
			garrisonedUnitModifier = 0.0; // 10% increase in capture time
			garrisonedUnitDamage = 0.0;	  // hitpoints subtracted from capturer per round per garrisoned unit
			damageRate = 0.0;			  // hitpoints subtracted from capture target hitpoints per round
			capture = 1;
		} // may be captured
	]
}
UnitType AIResource
{
	ownerType = PlayerOnly
	parent = NoProduceBuilding
	properties {
		popCapacity = 10
		rps = BuildingCombat
		SizeX = 1.5
		SizeY = 1.5
		FootprintSizeX = 3
		FootprintSizeY = 3
		OffsetX = 0.75
		OffsetY = 0.75
		UndertextureSizeX = 1.5
		UndertextureSizeY = 1.5
		mass = 1
		displayName = tx_utn_house_name
		DisplayNameScenEdit = tx_utn_house_sname
		VerboseTooltip = vtt_unit_House
	}
	sounds {
    	}
	fullMapOverlay { sprite = spr_fullmap_house }
	abilities = [
		PowerReserve { timeToRecharge = 900 }
		LOS { range = 5 }	
		SpecialPower { 		
			effects = [ UnitsResourcePower ]
		}	
		// houses have latent attack ability to support "LiberalFront" regional power
		// where suddenly your citizens get tough  and take up arms against enemies.
		// (all from the comfort of their homes)
		Attack { latent = true; range = 4; reloadTime = 1; applyDamageTime = 0.5; damage = 20; missileName = "Arrow"; angularRange = 360 }
		Convertable { 
			convertTimeModifier = 100.0;  //
			garrisonedUnitModifier = 0.0; // 10% increase in capture time
			garrisonedUnitDamage = 0.0;	  // hitpoints subtracted from capturer per round per garrisoned unit
			damageRate = 0.0;			  // hitpoints subtracted from capture target hitpoints per round
			capture = 1;
		} // may be captured
	]
}
