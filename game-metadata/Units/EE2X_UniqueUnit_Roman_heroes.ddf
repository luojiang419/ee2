//------------------------------------------------------------------------------------------------
//	HERO UNIQUE UNIT ROMAN LEGIONNAIRE (EPOCHS 1-5)
//------------------------------------------------------------------------------------------------
UnitType UniqueUnitRoman1Hero
{
	parent = UniqueUnitRoman1
	placementType = Unplaceable
	properties {
		SizeX = 0.144
		SizeY = 0.144
	}
	abilities = [
		Hero { HeroClass = HeavyInfantry; HeroForUnit = UniqueUnitRoman1 }
		AreaEffect { effects = [ PrimaryHeroArmyBonus SupportingHeroArmyBonus ] }
	]
}

UnitModel UniqueUnitRoman1Hero
{
	Parent		= UniqueUnitRoman1
	ScaleType	= kScaleHero
	ChildNames 	= [ TheHeroArmyFlag ]
}
