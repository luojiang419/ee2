//------------------------------------------------------------------------------------------------
//	MILL - UNIT TYPE INFO
//------------------------------------------------------------------------------------------------
UnitType Mill
{
	parent = Building
	properties {
		SizeX = 2.5
		SizeY = 2.5
		OffsetX = 0.75
		OffsetY = 0.75
		FootprintSizeX = 3.5
		FootprintSizeY = 3.5
		UndertextureSizeX = 2.5
		UndertextureSizeY = 2.5
		UndertextureOffsetY = 0.25
		mass = 1
		displayName = tx_utn_mill_name
		DisplayNameScenEdit = tx_utn_mill_sname
		VerboseTooltip = vtt_unit_Mill
		requiredOpenSides = kBuildingOpenSides_NegY
		RallyPlacementFlags = ( Fortress | Tower | Terrain )
	}
	sounds {
    	}
	fullMapOverlay { sprite = spr_fullmap_mill}
	abilities = [
		LOS { range = 0 }
	]
}

