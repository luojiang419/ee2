//------------------------------------------------------------------------------------------------
//	AIRPORT - UNIT TYPE INFO
//------------------------------------------------------------------------------------------------
UnitType Airport2
{
	parent = Building
	properties {
		SizeX = 3
		SizeY = 3
		FootprintSizeX = 4.5
		FootprintSizeY = 4.5
		OffsetX = 0.75
		OffsetY = 0.75
		UndertextureSizeX = 3
		UndertextureSizeY = 3
		mass = 1
		DisplayNameScenEdit = tx_utn_airport2_11_sname
		displayName = tx_utn_airport2_11_name
		VerboseTooltip = vtt_unit_Airport2_11
		RallyPlacementFlags = ( Terrain | Water | Mountain | AnyBuilding | AnyMobile | Allied | Neutral | Hostile )
	}
	sounds {
    	}
	fullMapOverlay { sprite = spr_fullmap_airport }
	abilities = [
		Produce {}
		LOS { range = 0 }
		Garrison {
			numOfSlots = 2;
			garrisonType = Heliport;
			healPoints = 50;		// Each unit type garrison heals this many points per second
			rightClickToGarrison = true
			GarrisonFlagModelName = "GarrisonFlag"
		}
	]
}
