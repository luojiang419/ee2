	properties {
		SizeX = 0.144
		SizeY = 0.144
	}
	abilities = [
		Hero { HeroClass = LightInfantry; HeroForUnit = UniqueUnitInca1 }
		AreaEffect { effects = [ PrimaryHeroArmyBonus SupportingHeroArmyBonus ] }
	]
}

UnitModel UniqueUnitInca1Hero
{
