//------------------------------------------------------------------------------------------------
//	登陆艇
//------------------------------------------------------------------------------------------------
UnitType LandShip
{
	parent = NavalShallow
	properties {
		RPS = SeaNonCombat
		SizeX = 1.3
		SizeY = 0.5
		mass = 1
		hitpoints = 2000
		VerboseTooltip = vtt_unit_LandShip
		displayName = tx_utn_LandShip_name
		popCount = 5
	}
	sounds = {
	}
	abilities = [
		NavalMove {speed = 2.2; accel = 1.0; angSpeed = 130;}
		LOS { range = 0 }
		GarrisonParatrooper { 
			garrisonType = NavalTransport;	// well paratrooper plane is like air transport here
			numOfSlots = 20; // NOTE:  leave extra space so that effects that boost paratrooper count will work
			initialContents = [ { typeName="LightInfantry" count=10 } ];	// load up with these paratrooper 
			dontShowGarrisonButton = 1;	// don't show garrison button in ui unit info area
		}
	]
	icon = icon_unit_LandShip
}
//------------------------------------------------
//	EPOCH 11
//------------------------------------------------
// Attack Ability Upgrade
UpgradeAbilities LandShipEpoch11Attack
{
	upgradedAbilities = [
		NavalMove {speed = 2.2; accel = 1.0; angSpeed = 90}
	]
}
