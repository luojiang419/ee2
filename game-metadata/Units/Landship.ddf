	]
}
//------------------------------------------------
//	EPOCH 11
//------------------------------------------------
UnitModel LandShip_11
{
Parent		= BaseShip
	DefaultModel = Landship.nif
	ForceScale = 0.07
     States = [
				{ StateName= Attack1		
				TextKeys = [ 
					     { Name = PLAY_SOUND Data = Tank_firing1 KeyTime=0.5 }  
							] 
				}
			      { StateName = Walk				TextKeys = [ { Name = START_SOUND_UNTIL_ANIM_CHANGE Data = fx_move_destroyer1 KeyTime = 0}
					   ]
				}
                        { StateName= Death  TextKeys = [ { Name = PLAY_SOUND Data = fx_dea_ship_metal_3 KeyTime = 0 }   ] }
	]
	ChildNames 		= [  FX_Smoke_Chimney_Large2  TheMuzzleSmokeEffect Muzzle_GrenadePistol  ExplSelectorIronShip TheBoatWake4 MerchantMarine_FlyingParts ]
}

