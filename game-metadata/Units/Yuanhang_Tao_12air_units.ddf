UnitType b24kitai
{
	parent = Aircraft
	properties {
		rps = Bomber
		SizeX = 1
		SizeY = 1
		mass = 0
		HitPoints = 1500
		displayName = tx_utn_b24kitai_name
		verboseTooltip = vtt_unit_b24kitai
		popCount = 4
	}
	sounds = {
	}
	abilities = [
		AircraftMove {speed = 5.0; angSpeed = 40; CruisingHeight = 8.2; ElevChangeRate = 0.5; OnGroundScale = 0.8}
		Attack { damage = 20000; range = 1.5; reloadTime = 1; angularRange = 60; applyDamageTime = 0; missileName = "ChinaAtomBomb"; ignoreBlocking = 1; attackOnTheMove = 1; ordnance = 1;
				areaDamageRadius = 10; areaDamageFriendlyRatio = 0.5 }
		LOS { range = 13 }
	]
	fullMapOverlay { sprite = spr_fullmap_plane; scale = 1.5; }
attributes [
		GoesOnAirMissions
	]
icon = icon_unit_b24
}


UnitModel b24kitai
{
	Parent		= BaseAircraft
	DefaultModel 	= b24kitai.nif
	ChildNames 	= [ VaporTrail1 VaporTrail2 VaporTrail3 VaporTrail4 VaporTrail5 VaporTrail6 BuildingShadow TheAmmoBar QuadEngineBomber_FlyingParts expl_heli_Tandrill ]
	States 		= [
		{	StateName = Idle	AnimName = AB12_quadengine_idle.KF
				TextKeys = [{ Name = STOP_SOUND Data = fx_move_plane_03 KeyTime = 0}]}
		{ StateName= Walk AnimName = AB12_quadengine_walk.KF		
				TextKeys = [{ Name = START_SOUND Data = fx_move_plane_03 KeyTime = 0}]}
		{ 	StateName = Attack1	AnimName = AB12_quadengine_attack.KF
               			TextKeys = [{ Name = PLAY_SOUND Data = fx_bomb_drop KeyTime = 0.0 }]}
		{ 	StateName = TakeOff	AnimName = AB12_quadengine_takeoff.KF	
				TextKeys = [{ Name = PLAY_SOUND Data = fx_move_plane_takeoff_03 KeyTime = 0}]}
		{ 	StateName = Death	AnimName = AB12_quadengine_death.KF	}
		]
	UIRenderingParams {
		xOffset = 0.01
		yOffset = 0.75
		zOffset = 1.53
		scale = 1.79
		angle = 18.95
	}
}
