//------------------------------------------------------------------------------------------------
//	CITIZEN - basic type
//------------------------------------------------------------------------------------------------
UnitType Citizen 
{
	parent = Human
	icon = icon_unit_citizen_male_1
	properties {
		SizeX = 0.125
		SizeY = 0.125
		mass = 1
		displayName = tx_utn_citizen_name
		displayNamePlural = tx_utn_citizen_pname
		rps = Citizen
		stance = Cautious
		VerboseTooltip = vtt_unit_citizen
	}
	abilities [
		Move {speed = 1.4; angSpeed = 720; angAccel = 720}		
		LOS { range = 5 }
		Build { repairRate = 60 }
	]
}

UnitType FullCitizen
{
	parent = Citizen
	properties {
		moveType = FootCitizen
	}
	abilities [
		Attack { range = 0.0; reloadTime = 1; applyDamageTime = 0.0; damage = 0 }
		Move {speed = 1.3; angSpeed = 720; angAccel = 720}		
		LOS { range = 5 }
		Build { repairRate = 60 }
		GatherFarm { 
				treeCuttingRange = 0.9; 	// at this range, the axe of the citizen contact tree trunk
				otherRange = 0.8;
				dropoffRange = 0.7;
				carryLimit = 15; 
				farmCarryLimit = 15;

				// Food Resource gather rates.  This is the amount of the resource gathered per second.
				animalRate = 0.5;		// this is the gather rate from animals
				foodRate = 0.4;		// this is the gather rate from forage patch
				forageTreeRate = 0.4;	// this is the gather rate from forage trees
				farmRate = 0.8; 		// this is the gather rate from farms

				// Other basic resource gather rates.  This is the amount of the resource gathered per second.
				woodRate = 0.45;
				stoneRate = 0.45;
				goldRate = 0.45;
				tinRate = 0.45;
				ironRate = 0.45;
				saltpeterRate =0.5;
				oilRate = 0.6;
				uraniumRate = 0.6;
		}
		Garrisonable { garrisonTypes = [ UniWarehouseOilDerrickCityCenter Fortress Tower NavalTransport SeigeTower AirTransport ] }
	]
}

// Male Citizen
UnitType CitizenM
{
	parent = FullCitizen
	properties {
		DisplayNameScenEdit = tx_utn_citMale_sname
		hitpoints = 100
	}
	sounds {
		sndCmdMove = ["v_cit_m_ack_01" "v_cit_m_ack_02" "v_cit_m_ack_03" "v_cit_m_ack_04"]
		sndCmdAttack = ["v_cit_m_att_01" "v_cit_m_att_02"]
		sndSelection = ["v_cit_m_sel_01" "v_cit_m_sel_02" "v_cit_m_sel_03" "v_cit_m_sel_04"]
		sndDeath =  ["fx_death_male_01" "fx_death_male_02" "fx_death_male_03" "fx_death_male_04" "fx_death_male_05" "fx_death_male_06" "fx_death_male_07"]
    	}
	abilities [
		Attack { range = 0.3; reloadTime = 3; applyDamageTime = 1.3; damage = 5 }
	]
}

// Female Citizen
UnitType CitizenF
{
	parent = FullCitizen
	icon = icon_unit_citizen_female_1
	properties {
		DisplayNameScenEdit = tx_utn_citFemale_sname
		hitpoints = 100
	}
	sounds {
		sndCmdMove = ["v_cit_f_ack_01" "v_cit_f_ack_02" "v_cit_f_ack_03" "v_cit_f_ack_04"]
		sndCmdAttack = ["v_cit_f_att_01" "v_cit_f_att_02"]
		sndSelection = ["v_cit_f_sel_01" "v_cit_f_sel_02" "v_cit_f_sel_03" "v_cit_f_sel_04"]
		sndDeath =  ["fx_death_female_01" "fx_death_female_02" "fx_death_female_03" "fx_death_female_04"]
    }
	abilities [
		Attack { range = 0.3; reloadTime = 3; applyDamageTime = 1.3; damage = 5 }
	]
}


//------------------------------------------------------------------------------------------------
//	ENGINEER
//------------------------------------------------------------------------------------------------
UnitType Engineer
{
	parent = Citizen
	properties {
		displayName = tx_utn_engineer_name
		displayNamePlural = tx_utn_engineer_pname
		DisplayNameScenEdit = tx_utn_engineer_name
		VerboseTooltip = vtt_unit_engineer
		hitpoints = 100
	}
	sounds {
		sndCmdMove = ["v_cit_m_ack_01" "v_cit_m_ack_02" "v_cit_m_ack_03" "v_cit_m_ack_04"]
		sndSelection = ["v_cit_m_sel_01" "v_cit_m_sel_02" "v_cit_m_sel_03" "v_cit_m_sel_04"]
		sndDeath =  ["fx_death_male_01" "fx_death_male_02" "fx_death_male_03" "fx_death_male_04" "fx_death_male_05" "fx_death_male_06" "fx_death_male_07"]
    	}
	icon = icon_unit_engineer

}

