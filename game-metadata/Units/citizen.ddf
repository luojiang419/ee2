//------------------------------------------------------------------------------------------------
//	CITIZEN - UPGRADES
//------------------------------------------------------------------------------------------------
UpgradeSet IntCitizenUpgradeEpoch1 {
	upgrades = [
		// do icon upgrade for generic citizen too
		UpgradeIcon {UnitType = Citizen; icon = icon_unit_citizen_male_1;}

		// generic citizen upgrades
		UpgradeUnitTypeFactor {UnitType = Citizen; factor = HitPoints; method = Set; value = 30; upgradeChildren = 1;}
		UpgradeUnitTypeFactor {UnitType = FullCitizen; factor = Damage; method = Set; value = 5; upgradeChildren = 1;}

		// MALE CITIZEN UPGRADES
		UpgradeVisual {UnitType = CitizenM; newVisual = CitizenM;}
		UpgradeIcon {UnitType = CitizenM; icon = icon_unit_citizen_male_1;}

		// FEMALE CITIZEN UPGRADES
		UpgradeVisual {UnitType = CitizenF; newVisual = CitizenF;}
		UpgradeIcon {UnitType = CitizenF; icon = icon_unit_citizen_female_1;}
	]
}

UpgradeSet IntCitizenUpgradeEpoch4 {
	upgrades = [
		// do icon upgrade for generic citizen too
