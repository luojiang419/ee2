//------------------------------------------------------------------------------------------------
//	ARTILLERY
//------------------------------------------------------------------------------------------------
UnitType Artillery
{
	properties {
		moveType = kUnitMoveType_Wheeled
		rps = HeavyArtillery
		FootprintType = Ellipse
		SizeX = 0.125
		SizeY = 0.125
		mass = 1
		hitpoints = 50
		popCount = 3
		
		// Default to hold position
		stance = Defensive
	}
	abilities [
		Move {speed = 1.15; angSpeed = 720; angAccel = 720}
		LOS { range = 5 }
		Convertable { convertTimeModifier = 3.0; }
		Garrisonable { garrisonTypes = [ NavalTransport Fortress ] }
	]
	attributes = [ 
		HealedByMedic
		CanJoinHeroArmy
	]
	fullMapOverlay { sprite = spr_fullmap_smallunit ignoreOrientation = 1 }
	icon = icon_unit_default_human
}
UnitModel BaseArtillery
{
	ScaleType 		= kScaleUnit
	OutlineType		= kOutlineMake
	DefaultState 		= Idle
	ChildNames 		= [ TheHealthBar  SelectCircleMedium ArtilleryShadow MediumGlow SinkArtillery
						HemisphereLighting_Unit DynamicLighting_Unit
					  ]
	UIRenderingParams {
		xOffset = 0.01
		yOffset = -1.34
		zOffset = -6.48
		scale = 2.43
		angle = 23.68
		rotationSpeed = 0.00
		pitch = 20.00
		lightAngle = 30.00
		lightPitch = 90.00
		lightDiffuse = [50 50 45 255]
		lightSpecular = [0 0 0 255]
		lightAmbient = [40 40 40 255]
	}
}
