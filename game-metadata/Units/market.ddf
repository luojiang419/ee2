UnitModel Market
{
	Parent		= BaseBuilding
	DefaultModel 	= bld_MARKET2.NIF
	ChildNames 		= [ LargeGlow UnderMarket ExplSelectorBuild_Small CityNameText ExplPartsWood ]
	States 			= [
		{	StateName = Idle	}
			]
	UIRenderingParams {
		xOffset = 0.01
		yOffset = -0.24
		zOffset = 1.51
		scale = 1.28
		angle = 45.00
		rotationSpeed = 0.00
		pitch = 30.00
		lightAngle = 30.00
		lightPitch = 90.00
		lightDiffuse = [50 50 45 255]
		lightSpecular = [0 0 0 255]
		lightAmbient = [40 40 40 255]
	}
}

