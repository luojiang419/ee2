//------------------------------------------------------------------------------------------------
//	MARKET - UNIT TYPE INFO
//------------------------------------------------------------------------------------------------
UnitType Market
{
	parent = Building
	properties {
		SizeX = 2
		SizeY = 2
		FootprintSizeX = 3.5
		FootprintSizeY = 3.5
		OffsetX = 0.75
		OffsetY = 0.75
		UndertextureSizeX = 2
		UndertextureSizeY = 2
		mass = 1
		displayName = tx_utn_market_name
		DisplayNameScenEdit = tx_utn_market_sname
		VerboseTooltip = vtt_unit_Market
		requiredOpenSides = kBuildingOpenSides_NegY
		RallyPlacementFlags = ( Market | Terrain | Allied | Neutral )
	}
	sounds {
    	}
	fullMapOverlay { sprite = spr_fullmap_market }
	abilities = [
		Produce {}
		LOS { range = 0 }
		Convertable {
			convertTimeModifier = 100.0;  //
			garrisonedUnitModifier = 0.1; // 10% increase in capture time
			garrisonedUnitDamage = 1.0;	  // hitpoints subtracted from capturer per round per garrisoned unit
			damageRate = 10.0;			  // hitpoints subtracted from capture target hitpoints per round
			capture = 1;
			resourcesTransferred = [
				{
					resource = Gold
					percentTransferred = 0.1
					NativeTribesAmountTransferredMin = 200.0
					NativeTribesAmountTransferredMax = 300.0
				}
			]
		}
		GarrisonTrade
		{
			dontShowGarrisonButton = 1
			GarrisonFlagModelName = "GarrisonFlag"
		}
	]
}

