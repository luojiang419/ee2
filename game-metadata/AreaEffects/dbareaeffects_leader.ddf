//The leader emits an area effect of 5 tiles and all special power recharge rates are done 50% faster.
DbAreaEffectInfo Resourcefulness
{
	name = text_larea_rsrcflnss_name
	desc = text_larea_rsrcflnss_desc
	effects = [
		EffectSpecialPowerRechargeTime {
			// decrease all my neighbors' recharge time, but leave mine alone.
			range = RadiusFromUnitExcludingSelf
			radius = 5
			mask = UnitsWithPower
			player = Self

			scale = 0.5
		}
		EffectVisualGlow {
			range = RadiusFromUnitExcludingSelf
			radius = 5
			mask = UnitsWithPower
			player = Self
			GlowType = Good
			OwnerOnly = true
			Icon = icon_leaderpwr_resourceful_s
			Tooltip = tt_power_Resourcefullness
			VTooltip = vtt_power_unitinfo_Resourcefull
		}
	]
}

// adds grey glow to dudes that are going to be blessed
DbAreaEffectInfo PropagandaPreviewGlow
{
	name = text_larea_propchg_name
	desc = text_larea_propchg_desc
	
	effects = [
		EffectVisualGlow {
			range = RadiusFromLocation
			radius = 3 // should match radius in Propaganda.EffectMassConvert below
			mask = SubjectToConversion
			player = NonSelf
			GlowType = Neutral
			OwnerOnly = false
			
			// this effect wants to be updated at a higher
			// frequency, to make the glows responsive to mouse movement
			period = 0.2
		}
	]
}

DbAreaEffectInfo Propaganda
{
	disableDuringCeasefire = true
	
	name = text_larea_propag_name
	desc = text_larea_propag_desc
	button = "unit_power_propaganda"
	selectionType = Location
	mouseCursor = Propaganda
	mouseCursorInvalid = Propaganda_Invalid

	MouseRadius = 3
	HighlightAreaEffect = PropagandaPreviewGlow
	
	effects = [
		EffectMassConvert {
			range = RadiusFromLocation
			radius = 3
			mask = SubjectToConversion
			player = NonSelf
			
			// yes instant, the time you see below is the delay before
			// this effect is even instantiated, once created,
			// the effect does it's thing instantly.
			instant = 1

			chance = 0.2	// base (same-epoch) chance for success 
			
			// how long does it take to adequately
			// indoctrinate the targeted units?
			time = 0.1
			
			// this visual state is assumed by the unit casting this effect
			stateName = "Indoctrinate"
		}
	]
}

DbAreaEffectInfo Resistance
{
	name = text_larea_resist_name
	desc = text_larea_resist_desc
	effects = [
		EffectDamageCapturers {
			range = Unit
			mask = Buildings
			player = Self

			scale = 0.5		// scale of damage
		}
	]
}

