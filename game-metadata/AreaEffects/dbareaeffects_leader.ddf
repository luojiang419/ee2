// ECONOMIC LEADER POWER
// CUSTOMS
//Any market within the leader's area of effect - 5 tiles - receives twice the normal gold resources from a successful trade route.
DbAreaEffectInfo Customs
{
	name = text_larea_customs_name
	desc = text_larea_customs_desc
	effects = [
		EffectResourceTrade {
			range = RadiusFromUnit
			radius = 5
			mask = AffectedByCustoms
			player = Self

			affected = [Gold]

			scale = 2
		}
		EffectVisualGlow {
			range = RadiusFromUnit
			radius = 5
			mask = AffectedByCustoms
			player = Self
			GlowType = Good
			OwnerOnly = true
			Icon = icon_leaderpwr_customs_s
			Tooltip = tt_power_Customs
			VTooltip = vtt_power_unitinfo_Customs
		}
		EffectVisualGlow {
			range = Unit
			player = Self
			OwnerOnly = true
			SuppressGlow = true
			Icon = icon_leaderpwr_customs_s
			Tooltip = tt_power_Customs
			VTooltip = vtt_power_pl_Customs
		}
	]
}

