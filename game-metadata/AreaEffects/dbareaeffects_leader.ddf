//////////////////////////////Leader Area Effects//////////////////////////////

///////////////////////////// 
// ACTIVE POWERS
///////////////////////////// 

// ECONOMIC LEADER POWER
// MOBILIZATION
DbAreaEffectInfo Mobilization
{
	name = text_larea_mobilize_name
	desc = text_larea_mobilize_desc
	
	button = unit_power_mobilize
	selectionType = Unit
	mouseCursor = Mobilization
	mouseCursorInvalid = Mobilization_Invalid

	maskSelection = BuildingsThatProduce
	playerSelection = Self
	
	bSkipKingOfTheHillUnit = true

	duration = 45
	
	effects = [
		EffectProductionTime {
			range = Unit
			mask = BuildingsThatProduce
			player = Self

			affected = Anything
			scale = 0.80
		}
		
		EffectVisualGlow {
			range = Unit
			mask = BuildingsThatProduce
			player = Self
			
			GlowType = Good
			OwnerOnly = true
			Icon = icon_leaderpwr_mobilize_s
			Tooltip = text_larea_mobilize_name
			VTooltip = vtt_power_unitinfo_mobilize
		}
	]
}

// ECONOMIC LEADER POWER
// FOREIGN INVESTMENT
DbAreaEffectInfo ForeignInvestment
{
	disableDuringCeasefire = true
	
	name = text_larea_forinvest_name
	desc = text_larea_forinvest_desc
	
	button = unit_power_forInvest
	selectionType = Unit
	mouseCursor = ForeignInvestment
	mouseCursorInvalid = ForeignInvestment_Invalid
	
	maskSelection = SubjectToForeignInvestment
	playerSelection = NonAlliedPlayers
	
	effects = [
		EffectPurchaseUnit {
			range = Unit
			mask = Buildings
			player = NonSelf
			
			instant = true

			affectedResourceTypes = [ Food Wood Stone Gold Tin Iron Saltpeter Oil Uranium]
			scale = 2.0
		}
	]
}

// ECONOMIC LEADER POWER
// CAPITALISM
