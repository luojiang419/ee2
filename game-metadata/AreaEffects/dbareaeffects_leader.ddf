// IMPERIAL LEADER POWER
// IMPERIALISM
DbAreaEffectInfo Imperialism
{
	name = text_larea_imperial_name
	desc = text_larea_imperial_desc
	
	bSkipKingOfTheHillUnit = true
	
	button = unit_power_imperialism
	selectionType = Unit
	mouseCursor = Imperialism
	mouseCursorInvalid = Imperialism_Invalid

	maskSelection = Buildings
	playerSelection = Self

	duration = 45
	
	effects = [
		// affected units may not be converted/captured,
		EffectNoConversion {
			range = Unit
		}
		
		// and may not take damage,
		EffectDamage {
			range = Unit
			scale = 0.0
		}
	
		// not even area damage,
		EffectAreaDamage {
			range = Unit
			scale = 0.0
		}
	
		// but they will glow...
		EffectVisualGlow {
			range = Unit
					
			GlowType = Good
			OwnerOnly = true
			Icon = icon_leaderpwr_imperialism_s
			Tooltip = text_larea_imperial_name
			VTooltip = vtt_power_unitinfo_imperial
		}
	]
}

// MILITARY LEADER POWER
// RALLY
DbAreaEffectInfo Rally
{
	name = text_larea_rally_name
	desc = text_larea_rally_desc
	button = "unit_power_Rally"
	selectionType = None
	effects = [
		// Heal nearby units.
		EffectMassHeal {
			range = RadiusFromUnit
			radius = 3
			mask = LandRPS
			player = Self
			instant = 1

			hitpointsHealed = 0.5
			usePercentage = 1
			effectName = "FX_BeingHealed"
		}
	]

}

// MILITARY LEADERPOWER
// FIRE AND MANUEVER
DbAreaEffectInfo FireAndManeuver
{
	disableDuringCeasefire = true
	
	name = text_larea_fireman_name
	desc = text_larea_fireman_desc
	button = "unit_power_fireandmaneuver"
	selectionType = None
	duration = 45

	effects = [
		// Make friendlies move faster.
		EffectSpeed {
			range = RadiusFromUnit
			radius = 5
			mask = LandRPS
			player = Self
			scale = 1.5
		}
		// Make em glow
		EffectVisualGlow {
			range = RadiusFromUnit
			radius = 5
			mask = LandRPS
			player = Self
			GlowType = Good
			OwnerOnly = true
			Icon = icon_leaderpwr_firemanuever_s
			Tooltip = tt_power_FireAndManeuver
			VTooltip = vtt_power_unitinfo_FaM_fast
		}
		// Make enemies stop
		EffectImmobilize {
			range = RadiusFromUnit
			radius = 5
			mask = LandRPS
			player = Enemies
		}
		// Make em glow
		EffectVisualGlow {
			range = RadiusFromUnit
			radius = 5
			mask = LandRPS
			player = Enemies
			GlowType = Bad
			Icon = icon_leaderpwr_firemanuever_s
			Tooltip = tt_power_FireAndManeuver
			VTooltip = vtt_power_unitinfo_FaM_slow
		}
	]

}

// MILITARY LEADER POWER
// DIVERSION
DbAreaEffectInfo Diversion
{
	disableDuringCeasefire = true
	
	name = text_larea_diversion_name
	desc = text_larea_diversion_desc
	
	button = unit_power_diversion
	
	selectionType = Location
	mouseCursor = Diversion
	mouseCursorInvalid = Diversion_Invalid
	
	effects = [
		EffectDiversion {
			instant = true
			range = Unit
			
			// diversion lasts this long
			duration = 45
			
			// diversion is in a phalanx formation
			formation = Phalanx
			
			// diversion is composed of the 
			// following unit type counts
			// (keep in mind that epoch ranges are inclusive)
			units = [
			    { 
			      name = DiversionUnit_Epoch11
			      count = 9
			      startEpoch = 11
			      endEpoch = 11
			    }
			    { 
			      name = DiversionUnit_Epoch12
			      count = 12
			      startEpoch = 12
			      endEpoch = 12
			    }
			    { 
			      name = DiversionUnit_Epoch13
			      count = 13
			      startEpoch = 13
			      endEpoch = 13
			    }  
			    { 
			      name = DiversionUnit_Epoch14
			      count = 13
			      startEpoch = 14
			      endEpoch = 15
			    }  

			]
		}
	]
}

