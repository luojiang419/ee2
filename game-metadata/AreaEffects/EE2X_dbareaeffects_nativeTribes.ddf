	]
}

// migration
// Penalties for building in foreign/unclaimed territory is reduced 100%
DbAreaEffectInfo Migration
{
	name = text_NTarea_migration_name
	desc = text_NTarea_migration_desc
	effects = [
			
		// the way the math for these works is 1.0 plus, for each
		// modifier, (the modifier - 1.0)
		// by default, building in unclaimed territory has a modifier of 2.0
		// (giving a total modifier of 1.0 + (2.0 - 1.0) = 2.0)
		// and building in other-owned territory has a modifier of 3.0
		// (giving a total modifier of 1.0 + (3.0 - 1.0) = 3.0)
			
		// unclaimed territory modifier
		EffectTerritoryConstructionTime {
			range = UnclaimedTerritory
			mask = BuildSlowInNonOwnedTerritories // city centers are excluded (in code) for this effect type
			player = SelfAndLiege
			
			// base + default mod + power mod   = total mod
			// 1.0  + (2.0 - 1.0) + (0.0 - 1.0) = 1.0
			scale = 0.0
		}

		// claimed territory modifier
		EffectTerritoryConstructionTime {
			range = OtherClaimedTerritoryIncludeDisputed
			mask = BuildSlowInNonOwnedTerritories // city centers are excluded (in code) for this effect type
			player = SelfAndLiege
			
			// base + default mod + pwer mod    = total mod
			// 1.0  + (2.0 - 1.0) + (0.0 - 1.0) = 1.0
			scale = 0.0
		}
		
		// "glow" (suppressed) so we get sexy icon
		EffectVisualGlow {
			range = Global
			mask = Empty	// @HACK don't want the icon on any units
			player = SelfAndLiege
			SuppressGlow = 1
			GlowType = Good
			OwnerOnly = true
			Icon = icon_tribepower_migration
			Tooltip = text_NTarea_migration_name
			VTooltip = text_NTarea_migration_desc
		}
	]
}

