// adobe construction
// Walls can be built for free and Tower upgrade times are reduced 50%
DbAreaEffectInfo Adobe
{
	name = text_NTarea_adobe_name
	desc = text_NTarea_adobe_desc
	effects = [
		// wall build cost
		EffectConstructionCost {
			range = SpaceTime
			player = SelfAndLiege
  			affected = WallConstructionTargets
			scale = 0.0
		}
		
		// tower upgrade time
		EffectTowerUpgradeTime {
			range = Global
			mask = WallConnector
			player = SelfAndLiege
			scale = 0.5
		}
		
		// "glow" (suppressed) so we get sexy icon
		EffectVisualGlow {
			range = Global
			mask = WallFoundations
			player = SelfAndLiege
			SuppressGlow = 1
			GlowType = Good
			OwnerOnly = true
			Icon = icon_tribepower_adobe
			Tooltip = text_NTarea_adobe_name
			VTooltip = text_NTarea_adobe_desc
		}
		EffectVisualGlow {
			range = Global
			mask = WallsNoFoundations
			player = SelfAndLiege
			SuppressGlow = 1
			GlowType = Good
			OwnerOnly = true
			Icon = icon_tribepower_adobe
			Tooltip = text_NTarea_adobe_name
			VTooltip = text_NTarea_adobe_desc
		}
	]
}

