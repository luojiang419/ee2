// fertility
// +25% Pop cap at all player owned city centers
DbAreaEffectInfo Fertility
{
	name = text_NTarea_fertility_name
	desc = text_NTarea_fertility_desc
	
	bSkipKingOfTheHillUnit = true
	
	effects = [
		EffectPopulation {
			range = PopCap
			player = SelfAndLiege
			UnitType = CityCenter
			scale = 1.25
		}
		
		// "glow" (suppressed) so we get sexy icon
		EffectVisualGlow {
			range = Global
			mask = CityCenters
			player = SelfAndLiege
			SuppressGlow = 1
			GlowType = Good
			OwnerOnly = true
			Icon = icon_tribepower_fertility
			Tooltip = text_NTarea_fertility_name
			VTooltip = text_NTarea_fertility_desc
		}
	]
}

