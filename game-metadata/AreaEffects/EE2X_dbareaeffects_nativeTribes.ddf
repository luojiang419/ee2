			scale = 1.5
		}
		
		// "glow" (suppressed) so we get sexy icon
		EffectVisualGlow {
			range = Global
			mask = Empty	// @HACK don't want the icon on any units
			player = SelfAndLiege
			SuppressGlow = 1
			GlowType = Good
