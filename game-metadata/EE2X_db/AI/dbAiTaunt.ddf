// this is used when someone keeps sending alliance request over and over in a short period
DbAITauntDef RepeatedAllianceRequest
{
	records = [
		{
			tauntText = text_ai_repeatalliance
			// other params you could use:
			
			// default to being HOSTILE only text, use the following line
			//	to have it be used for allies
			//isNonHostile = true
			
			// Not yet hooked up entirely
			//personalityType = "angryAI"
			
			// weight is how much it will use one response over another
			//	currently defaults to 1.0 if not assigned
			//	if you make it higher, that response will show up more frequently
			// weight = 3.2
		}

		{
			// Standard AI Personality
			tauntText = text_ai_repeatalliance
		}

		{
			// Aggressive AI Personality
			tauntText = text_ai_repeatalliance2
		}

		{
			// Defensive AI Personality
			tauntText = text_ai_repeatalliance3
		}
		
		// if we're friendly, use these -
		//		this is actually for repeated WAR PLAN requests
		//		since we're already friends
		{
			tauntText = text_ai_repeatalliance3
			isNonHostile = true;
		}
	]
}

