


// NOTE:  if you don't understand the reasoning behind the notes below,
// or just need someone to consult, then see Andrew before modifying the information below.

DbTerritoryInfo TheTerritoryInfo
{
	// what to scale cost of buildings constructed in unclaimed territory by
	unclaimedCostModifier = 1.0
	
	// what to scale cost of buildings constructed in territory claimed by others
	otherClaimedCostModifier = 1.5
	
	upgradeableFactors =
	{
		moraleBonusPerHouse = 0.02				// 2% per house
		fervorBonusPerHouse = 0.02  			// 2% per house
		maxMoraleFervorBonus = 0.14		// 14% max per territory
		foodBonus = 0.02    			// 1% harvest bonus per house
		goldBonus = 0.02				// 1% per house
		stoneBonus = 0.02				// 1% per house
		woodBonus = 0.02				// 1% per house
		generalResourceBonus = 0.02		// 1% per house
		maxResourceBonus = 0.20			// 10% max harvest bonus per territory
	}

	// what unit types and associated minimum counts are needed to capture 
	// an unclaimed or disputed territory adjacent to one you control?
	adjacentReq =
	{
		typeCounts =
		[
			{ type = CityCenter 	count = 1 }
		]
	}
	
	// what unit types and associated minimum counts are needed to capture 
	// an unclaimed or disputed territory that is not adjacent to one you control?
	// NOTE:  the "non adjacent requirements" should be a superset
	// of the "adjacent requirements"
	nonAdjacentReq =
	{
		typeCounts =
		[
			{ type = CityCenter	count = 1 }
			{ type = Fortress	count = 1 }
		]
	}
	
	// what unit types and associated minimum counts are needed to capture
	// and unclaimed or disputed territory if the player has the parthenon wonder?
	parthenonReq =
	{
		typeCounts =
		[
			{ type = Barracks	count = 1 }
			{ type = Mill		count = 1 }
		]
	}
	
	// what unit types and associated miniumum counts are needed to capture
	// an unclaimed or disputed territory if the game is "king of the hill"
	kingOfTheHillReq = 
	{
		typeCounts =
		[
			{ type = KingOfTheHill count = 1 }
		]
	}
	
	// what unit types and associated minimum counts are needed to keep
	// your ownership of a territory from being labeled "disputed"?
	// NOTE: the "undisputed requirements" should be a subset
	// of the "adjacent requirements"
	undisputedReq =
	{
		typeCounts =
		[
			{ type = CityCenter	count = 1 }
		]
	}
	
	// what constraints are placed on unit types and their associated
	// maximum counts on a per-territory basis?
	// NOTE: the "maximum requirements (constraints)" should
	// be designed such that it is actually possible to satisfy
	// the adjacent, non adjacent, and undisputed requirements
	// @NOTE from daniel:
	// the order of these determines the order they will show up
	// in the info panel.  specify showInUI = 1 to make it show up.
	// the name used is the plural display name for the indicated type, unless 
	// you specify a text-db override using nameInUI = ...
	maximumReq =
	{
		typeCounts =
		[
			{ type = CityCenter	count = 1 }
			{ type = AirDefense	count = 7 	showInUI = 1 nameInUI = tx_utn_airdefense_tReqName }
			{ type = CoastalDefense	count = 12 	showInUI = 1 nameInUI = tx_utn_coastdefense_tReqName }
			{ type = Fortress	count = 2 	showInUI = 1 }
			{ type = Wall_Tower	count = 8 	showInUI = 1 nameInUI = tx_utn_walltower_tReqName }
			{ type = House		count = 8 	showInUI = 1 }			// @NOTE houses requirement is needed for various power upgrades.  please consult Andrew before removing it
			{ type = Warehouse	count = 12 	showInUI = 0}
			{ type = Market		count = 2 	showInUI = 0}	
			{ type = Outpost	count = 12 	showInUI = 1 }
			{ type = Temple		count = 4 	showInUI = 0 }			// @NOTE temple requirement is needed for "Favor of the Gods" region power to work correctly.  please consult Andrew before removing it
			{ type = University	count = 4 	showInUI = 0 }
			{ type = Airport	count = 1 	showInUI = 1 }
			{ type = Airport2	count = 4 	showInUI = 0 }
			{ type = Stable	count = 4 	showInUI = 0 }
			{ type = Mill	count = 4 	showInUI = 0 }
			{ type = Barracks	count = 6 	showInUI = 0 }
			{ type = Missile_Silo	count = 4 	showInUI = 1 }
			{ type = AMissileDefense	count = 6 	showInUI = 1 }
			{ type = dapao	count = 4 	showInUI = 1 }
			{ type = AIAirDefense	count = 4 	showInUI = 1 }
			{ type = AICoastalDefense	count = 6 	showInUI = 1 }
			{ type = Radar	count = 1 	showInUI = 0 }
			{ type = Machinegunnest	count = 4 	showInUI = 0 }
			{ type = Fire		count = 4	showInUI = 1 }
			{ type = poj_popBuild	count = 1 	showInUI = 0 }
			{ type = Tavern       	count = 4	showInUI = 0 }
			{ type = Alchemy       	count = 4	showInUI = 0 }
			{ type = Quarry     	count = 4	showInUI = 0 }
			{ type = Minegold     	count = 1	showInUI = 0 }
			{ type = SaltPeterFactory     	count = 4	showInUI = 0 }
			{ type = Ironref     	count = 4	showInUI = 0 }
			{ type = Vineyard    	count = 1	showInUI = 0 }
			{ type = Oilref    	count = 1	showInUI = 0 }
			{ type = Chemistry    	count = 1	showInUI = 0 }
			{ type = Autofactory    	count = 1	showInUI = 0 }
			{ type = bank    	count = 1	showInUI = 0 }
			{ type = Winery    	count = 1	showInUI = 0 }
			{ type = AIResource1    	count = 1	showInUI = 0 }
			{ type = AIResource    	count = 1	showInUI = 0 }
			{ type = AIBuilding    	count = 1	showInUI = 0 }
			{ type = AInavyBuilding    	count = 1	showInUI = 0 }
			{ type = AIMissile_Silo	count = 1 	showInUI = 0 }
			{ type = NuclearMissile	count = 1 	showInUI = 0 }
			{ type = NuclearMissile_ch	count = 1	showInUI = 0 }
			{ type = NuclearMissile_Rus	count = 1	showInUI = 0 }
			{ type = NuclearMissile_Eng	count = 1 	showInUI = 0 }
			{ type = NuclearMissile_fre	count = 1 	showInUI = 0 }
			{ type = MachineGunNest12	count = 5 	showInUI = 0 }
			{ type = ArmyAcademy	count = 1	showInUI = 0 }
			{ type = AirAcademy	count = 1 	showInUI = 0 }
			{ type = NavalAcademy	count = 1 	showInUI = 0 }
		]
	}
}

