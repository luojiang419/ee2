//
// Wild animals
//
Animal Deer
{
	DeadUnitType = DeadAnimalDeer
	
	AnimalType = Wild
	
	WanderRadius = 4
	TimeBetweenWandering = 6
	
	// If it's a Wild animal, all the 'herd' stuff should be nonzero.
	
	// At creation time, a max herd size is also calculated and stored
	// with the herd, and they'll never exceed this.
	MaxHerdSize =  { min = 5 max = 10 }
	
	// If there are 2X animals in the herd, a new one will be created
	// every ReproPeriod/X seconds, up to MaxHerdSize.
	ReproPeriod = 360
}

Animal Camel
{
	DeadUnitType = DeadAnimalCamel
	AnimalType = Wild
	WanderRadius = 4
	TimeBetweenWandering = 6

	// At creation time, a max herd size is also calculated and stored
	// with the herd, and they'll never exceed this.
	MaxHerdSize =  { min = 5 max = 10 }
	
	// If there are 2X animals in the herd, a new one will be created
	// every ReproPeriod/X seconds, up to MaxHerdSize.
	ReproPeriod = 360
}

Animal Elephant
{
	DeadUnitType = DeadAnimalElephant
	AnimalType = Wild
	WanderRadius = 4
	TimeBetweenWandering = 6
	MaxHerdSize =  { min = 5 max = 10 }
	ReproPeriod = 360
}

Animal Boar
