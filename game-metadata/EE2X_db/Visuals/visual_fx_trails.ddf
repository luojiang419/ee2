//---------------------------------------------------------------------------
// Unit tracks of various types, including decal'd tracks and smoke trails
// and boat wakes.
//---------------------------------------------------------------------------

SmokeTrailDC		AircarftFlames1
{
	//Shader
	ShaderName = SmokeTrail_1Texture_Additive
	//Where to attach the effetc
	TagName = tag_exhaust1_1
	//Texture
	TextureSet1 = fx_firetrail_128.tga
	TexturesNbrOfSubPart = 1
	ExpandTexture = false
	//Effect manager
	LiveFrombornToDeath = true
	//Particle parameter
	MinLife = 0.18
	MaxLife = 0.18
	//Geometry
	MaximumParticle = 500
	ColorStart = [0, 0, 255, 255]
	ColorMiddle = [0, 100, 255, 125]
	ColorEnd = [255, 255, 255, 0]
	MiddleColorFor = 0.1
	OriginalSizeMin = 0.2
	OriginalSizeMax = 0.2
	SizeGrowMin = -0.2
	SizeGrowMax = -0.2
	PositionRadiusRandom = 0.02
	ParticleDensity = 0.016
	//Physics
	WindOn = false
	VelocityRandom = 0.02
}

