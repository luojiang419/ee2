//------------------------------------------------------------------------------------
// EXPLOSION
//------------------------------------------------------------------------------------
// Explosion with an EMP burst
Explosion			Expl_emp01
{
	BoundingSphereRadius = 1
	ExplosionSequences =	[ sq_emp_blast01 sq_emp_blast02 sq_emp_blast03 sq_emp_screenflash01 
								sq_emp_screenflash02 sq_emp_spark01 
								sq_emp_ground01 ]
	VelocityOn = 0
	VelocityAngle = 0
	SpeedMin = 0
	SpeedMax = 0
	GravityOn = 0
}

//------------------------------------------------------------------------------------
// EXPLOSION SELECTOR
//------------------------------------------------------------------------------------
// An emp explosion
ExplosionSelector	ExplSelectorEmp01
{
	ExplosionDescriptors =	[
								// Use this on all hits.
								{
									BoundingSphereRadius = 1
									Weapon = (Any)
									Trigger = DynamicMessage
									MessageName = DamagedToDeath
									ExplosionName = Expl_emp01
									HitPoint = -1
									Hide = false
								}
							]
}

