AnimatedTerrainTexture AmmoExplosionTerrainFlash
{	
	Texture = fx_explode_terrain1.tga
	StartColor = [ 255, 255, 255, 255 ]
	MidColor = [ 255, 255, 255, 255 ]
	EndColor = [ 255, 255, 255, 0 ]

	TimeColorUp = .01
	TimeColorPeak = .1
	TimeColorDown = 1.5

	ColorUpType = QuadFastStart
	ColorDownType = QuadSlowStart

	StartScale = 0
	MidScale = 6
	EndScale = 6

	TimeScaleUp = .04
	TimeScalePeak = .1
	TimeScaleDown = 5.5

	ScaleUpType = QuadFastStart
	ScaleDownType = QuadSlowStart
}

AnimatedTerrainTexture BomberExplosionTerrainFlash
{	
