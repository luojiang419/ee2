//------------------------------------------------------------------------------------
// EXPLOSION MAPPER
//------------------------------------------------------------------------------------
// For bombs.  Includes fire and appropriate scorch marks.
ExplosionSelector	ExplSelectorBomb01
{
	ExplosionDescriptors =	[
								// Use this on terrain hits.
								{
									BoundingSphereRadius = 1
									Weapon = (Terrain)
									Trigger = DynamicMessage
									MessageName = DamagedToDeath
									ExplosionName = Expl_Ammo_10
									HitPoint = -1
									Hide = false
								}
								// Use this on unit hits.
								{
									BoundingSphereRadius = 1
									Weapon = (MobileUnit)
									Trigger = DynamicMessage
									MessageName = DamagedToDeath
									ExplosionName = Expl_Ammo_10
									HitPoint = -1
									Hide = false
								}
								// Use this on building hits.
								{
									BoundingSphereRadius = 1
									Weapon = (Building)
									Trigger = DynamicMessage
									MessageName = DamagedToDeath
									ExplosionName = Expl_Ammo_10
									HitPoint = -1
									Hide = false
								}
							]
}

// For Guided Missiles.  Includes fire and appropriate scorch marks.
ExplosionSelector	ExplSelectorMissile01
{
	ExplosionDescriptors =	[
								// Use this on terrain hits.
								{
									BoundingSphereRadius = 1
									Weapon = (Any)
									Trigger = DynamicMessage
									MessageName = DamagedToDeath
									ExplosionName = Expl_Ammo_10
									HitPoint = -1
									Hide = false
								}								
							]
}

