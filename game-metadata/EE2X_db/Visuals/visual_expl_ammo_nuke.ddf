// Explosions for nuclear weapons.

//------------------------------
//Animated bitmap nuke explosion
//------------------------------
ExplosionSequence	sq_nuke_worldflash01
{
	TimeA = 0.15
	TimeB = 0.15
	FiringProbability = 1
	SequenceNames = [ nuke_LightFlash ]
	SequenceType = FlashWorldLight
}

WorldLightFlash nuke_LightFlash
{
	FlashPeakColor = [172 172 172 0]
	TimeIn = 0.3
	TimeDur = 1.2
	TimeOut = 1.8

	FadeInType = QuadFastStart
	FadeOutType = QuadSlowStart
}


AnimatedExplosionDC AnimatedNukeExplosionFlash1
{
	ShaderName = AnimExpl_Add_Add_Depth
	ShaderDepth = eAnimExploDepth_Medium
	TextureName = flash.tga
	StaticBitmap = true
	//TextureRandomUv = false
	WidthNbrBitmapInTexture = 1
	HeightNbrBitmapInTexture = 1
