//------------------------------------------------------------------------------------
// EXPLOSION SELECTOR
//------------------------------------------------------------------------------------

// An nuclear explosion
ExplosionSelector	ExplSelectorNuke01
{
	ExplosionDescriptors =	[
								// Use this when shot out of the sky by
								// some star-wars missile-shield style interception
								{
										BoundingSphereRadius = 1
										Weapon = (None Melee LightProjectile MediumProjectile Missile Beam)
										Trigger = DynamicMessage
										MessageName = DamagedToDeath
										ExplosionName = Expl_Nuke_ShotDown
										HitPoint = -1
										Hide = false
								}
								// Use this on all other hits.
								{
									BoundingSphereRadius = 1
									Weapon = (Any)
									Trigger = DynamicMessage
									MessageName = DamagedToDeath
									ExplosionName = Expl_Nuke01
									HitPoint = -1
									Hide = false
								}
							]
}

