AnimatedTerrainTexture HercExplosionTerrainFlash
{	
	Texture = fx_explode_terrain1.tga
	StartColor = [ 255, 255, 255, 255 ]
	MidColor = [ 255, 255, 255, 255 ]
	EndColor = [ 255, 255, 255, 0 ]

	TimeColorUp = .01
	TimeColorPeak = .1
	TimeColorDown = 1.5

	ColorUpType = QuadFastStart
	ColorDownType = QuadSlowStart

	StartScale = 0
	MidScale = 6
	EndScale = 6

	TimeScaleUp = .04
	TimeScalePeak = .1
	TimeScaleDown = 5.5

	ScaleUpType = QuadFastStart
	ScaleDownType = QuadSlowStart
}

//------------------------------------------------------------------------------------
// EXPLOSION SMOKE TRAILS
//------------------------------------------------------------------------------------
ExplosionSmokeTrailDC		expl_herc_Tandrill
{
	//File containing object to draw
	NifName = fx_explosion_trails01.nif

	MessageToStartEffect = Heli_fx_exp_smokeTrail_1

	//Drawing options
	ShaderName = SmokeTrail_1Texture_Additive
	//ShaderName = SmokeTrail_1Texture
	Texture1 = TrailA_1.tga
	Texture2 = TrailB_1.tga
	AdditiveBlending = false
	DrawUnderWater = false
	DrawingLayer = 3

	//Node options
	NodePhysicsOn = false
	NodeProbabilityToPlay = 0.4
	NodeRandomizerotation = true
	NodeMinSpeed = 3
	NodeMaxSpeed = 6
	NodeVelocityRotation = 80
	NodeMinLife = 3
	NodeMaxLife = 10

	//Particle options
	PhysicsOn = true
	GravityOn = false
	WindOn = false
	MaximumParticle = 150
	MinLife = 2.0
	MaxLife = 2.0
	MinSpeed = 0.0
	MaxSpeed = 0.0
	StopSpeed = false
	ColorStart [0.4, 0.8, 0.972, 1.0]
	ColorMiddle = [0.180, 0.494, 0.925, 0.8]
	ColorEnd = [1.0, 1.0, 1.0, 0.0]
	MiddleColorFor = 0.7
	BounceOnTerrain = true
	OriginalSizeMin = 0.13
	OriginalSizeMax = 0.13
	SizeGrowMin = -0.07
	SizeGrowMax = -0.07
	GrowFor = 0.4
	PositionRadiusRandom = 0.05
	ParticleDensity = 0.06
}

