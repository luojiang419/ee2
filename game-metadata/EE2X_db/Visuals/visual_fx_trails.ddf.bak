//--------------------------------------------------------------------------
//	SMOKE TRAILS
//--------------------------------------------------------------------------
// Smoke trail Guided Missile
SmokeTrailDC		SmokeTrailGuidedMissile
{
	//Shader
	ShaderName = SmokeTrail_2Textures
	//Where to attach the effetc
	TagName = tag_trail_1_c
	//Texture
	TextureSet1 = TrailA_1.tga
	TextureSet2 = TrailB_1.tga
	TexturesNbrOfSubPart = 1
	ExpandTexture = false
	//Effect manager
	LiveFrombornToDeath = true
	//Particle parameter
	MinLife = 1.0
	MaxLife = 1.5
	//Geometry
	MaximumParticle = 100
	ColorStart = [255, 255, 255, 0]
	ColorMiddle = [255, 255, 255, 255]
	ColorEnd = [255, 255, 255, 0]
	MiddleColorFor = 0
	OriginalSizeMin = 0.1   
	OriginalSizeMax = 0.1
	SizeGrowMin = 0.1
	SizeGrowMax = 0.1
	PositionRadiusRandom = 0.05
	ParticleDensity = 0.1
	//Physics
	WindOn = false
	VelocityRandom = 0.0
}

// Missile Fire
SmokeTrailDC		SmokeTrailMFGuidedMissile
{
	//Shader
	ShaderName = SmokeTrail_1Texture_Additive
