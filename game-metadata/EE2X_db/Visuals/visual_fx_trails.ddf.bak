//---------------------------------------------------------------------------
// Unit tracks of various types, including decal'd tracks and smoke trails
// and boat wakes.
//---------------------------------------------------------------------------

//--------------------------------------------------------------------------
//	TRACKS
//--------------------------------------------------------------------------
UnitTracks	TankTracks
{
	TrackDecalNames =	   [Track_Tank_1 ]
	TrackDecalNamesLod2 =  [Track_Tank_1_L2 ]
	TrackDecalNamesLod3 =  [Track_Tank_1_L3 ]

	TrackSpacing = 0.25
	NumFeet = 1

	ShowTurns = true
	TrackDecalTurnL = Track_Tank_Turn_L1
	TrackDecalTurnR = Track_Tank_Turn_R1
	// PI / 16
	TrackTurnSpacing = 0.19625
}

UnitTracks	ArtilleryTracks
{
	TrackDecalNames =	   [Track_Artillery_1 ]
	TrackDecalNamesLod2 =  [Track_Artillery_1_L2 ]
	TrackDecalNamesLod3 =  [Track_Artillery_1_L3 ]

	TrackSpacing = 0.25
	NumFeet = 1

	ShowTurns = true
	TrackDecalTurnL = Track_Artillery_Turn_L1
	TrackDecalTurnR = Track_Artillery_Turn_R1
	// PI / 16
	TrackTurnSpacing = 0.19625
}

UnitTracks	Footprints
{
	TrackDecalNames =	   [Track_Human_1 Track_Human_2 Track_Human_3 Track_Human_4
							Track_Human_5 Track_Human_6 Track_Human_7 Track_Human_8 ]
	
	TrackDecalNamesLod2 =   [Track_Human_1_L2 Track_Human_2_L2 Track_Human_3_L2 Track_Human_4_L2
							Track_Human_5_L2 Track_Human_6_L2 Track_Human_7_L2 Track_Human_8_L2 ]
	
	TrackDecalNamesLod3 =   [Track_Human_1_L3 Track_Human_2_L3 Track_Human_3_L3 Track_Human_4_L3
							Track_Human_5_L3 Track_Human_6_L3 Track_Human_7_L3 Track_Human_8_L3 ]
	
	NumFeet = 2
	//TrackSpacing = 0.2
	TrackSpacing = 0.25
	JitterPositional = 0.01
	JitterRotational = 0.0008
}

UnitTracks	Hercprints
{
	TrackDecalNames =	   [Track_Herc_1 Track_Herc_2 Track_Herc_3 Track_Herc_4
							Track_Herc_5 Track_Herc_6 Track_Herc_7 Track_Herc_8 ]
	
	TrackDecalNamesLod2 =   [Track_Herc_1_L2 Track_Herc_2_L2 Track_Herc_3_L2 Track_Herc_4_L2
							Track_Herc_5_L2 Track_Herc_6_L2 Track_Herc_7_L2 Track_Herc_8_L2 ]
	
	TrackDecalNamesLod3 =  [Track_Herc_1_L3 Track_Herc_2_L3 Track_Herc_3_L3 Track_Herc_4_L3
							Track_Herc_5_L3 Track_Herc_6_L3 Track_Herc_7_L3 Track_Herc_8_L3 ]

	NumFeet = 2
	TrackSpacing = 0.4
}

