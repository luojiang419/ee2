//---------------------------------------------------------------------------
// BEAM DEFINITIONS
//---------------------------------------------------------------------------
BeamEffect 	TestBeam
{
//	StartLaserName = laser_linear_Start.nif
	MiddleLaserName = laser_linear_Middle.nif
//	EndLaserName = laser_linear_End.nif
//	StartEffect = laser_linear_PowerUp.nif
//	SplashEffect = laser_linear_Splash.nif
	Life  = 0.2
	DelayBeforeStartLaser = 0.25
	TravelSpeed = 200
	DeathLife = 0.2
	TypeOfDeath = eLaserTypeOfDeath_Message_BegginingToEnd2
	RepeatEffect = 0
}

