// repair HERCs send a beam of energy to the HERC they are healing
BeamEffect 	Beam_HercRepair
{
	MiddleLaserName = fx_beam_herc2.nif
	StartEffect = fx_laser_muzzle_1.nif
	
	// @TODO get a different splash effect for healing
	SplashEffect = fx_laser_impact_1.nif
	SplashEffectLife = 1.5
	
	//StartEffectLife = 1.5
	Life  = 0.6
	DelayBeforeStartLaser = 0.0
	TravelSpeed = 20
	DeathLife = 0.4
	TypeOfDeath = eLaserTypeOfDeath_Message_Catchup
	RepeatEffect = 0
}


// Bullet tracer effect for machineguns and the like.
BeamEffect 	MachineGunTracer
{
	MiddleLaserName = fx_weapon_tracer.nif
	Life  = 0.005
	TravelSpeed = 30
	DeathLife = 0.5
	TypeOfDeath = eLaserTypeOfDeath_Message_Catchup
	RepeatEffect = 0
	FireAndForget = true
}

// Bullet tracer effect for machineguns and the like.
BeamEffect 	Beam_Tracer01
{
	MiddleLaserName = fx_weapon_tracer.nif
	Life  = 0.045
	TravelSpeed = 20
	DeathLife = 10
	TypeOfDeath = eLaserTypeOfDeath_Message_Catchup
	RepeatEffect = 0
	FireAndForget = true
}

// This one is for buildings.
BeamEffect 	Beam_Tracer02
{
	MiddleLaserName = fx_building_tracer.nif
	Life  = 0.025
	TravelSpeed = 20
	DeathLife = 10
	TypeOfDeath = eLaserTypeOfDeath_Message_Catchup
	RepeatEffect = 0
	FireAndForget = true
}

