Decal UnderWonderAfrican_01
{
	DefaultState = Idle
	States	= [
	          { StateName = Idle  
			RuralSpriteNames = [ under_manyatta under_manyatta under_manyatta ] 
			UrbanSpriteNames = [ under_manyatta under_manyatta under_manyatta ]

		  }
		  { StateName = Death  
			RuralSpriteNames = [ under_manyatta_d under_manyatta_d under_manyatta_d ]
			UrbanSpriteNames = [ under_manyatta_d under_manyatta_d under_manyatta_d ]
			FadeOutTime = 10 
   			StartFadeDelay = 10

	          }
	]
}

