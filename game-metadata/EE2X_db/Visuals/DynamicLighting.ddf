// @TEST light
DynamicLightEmitter DL_Test
{
	Type = eDynamicLightingType_OneColor_PlayOnce
	TypeOfAttenuation = eDynamicLighting_Linear
	Life = 1.0
	DirectionalColor = [0.4,  0.4,  0.4]
	LifeFadeOut = 0.5
	Radius = 8
}

DynamicLightEmitter DL_Missile
{
	Type = eDynamicLightingType_TwoColors_PlayOnce
	TypeOfAttenuation = eDynamicLighting_Linear
	Life = 0.1
	DirectionalColor = [0.15,  0.15,  0.15]
	DirectionalColor2 = [0.25,  0.1,  0.025]
	LifeFadeOut = 0.3
	LifeFadeOut2 = 0.7
	Radius = 8
}

