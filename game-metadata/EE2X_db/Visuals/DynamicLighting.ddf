//---------------------------------------------
// Dynamic light receivers
//

// attach dynamic lighting to buildings
DynamicLightingReceiver DynamicLighting_Building
{
	Radius = 2
	MaxLightCount = [ 0 2 4 ]	// indexed by lighting LOD
}

// attach dynamic lighting to walls
DynamicLightingReceiver DynamicLighting_Wall
{
	Radius = 2
	MaxLightCount = [ 0 0 2 ]	// indexed by lighting LOD
}

// attach dynamic lighting to (non-tree, non-animal) resources
DynamicLightingReceiver DynamicLighting_Resource
{
	Radius = 2
	MaxLightCount = [ 0 2 4 ]	// indexed by lighting LOD
}

// attach dynamic lighting to trees
DynamicLightingReceiver DynamicLighting_Tree
{
	Radius = 2
	MaxLightCount = [ 0 0 2 ]	// indexed by lighting LOD
}

// attach dynamic lighting to mobile units
DynamicLightingReceiver DynamicLighting_Unit
{
	Radius = 2
	MaxLightCount = [ 0 0 2 ]	// indexed by lighting LOD
}

