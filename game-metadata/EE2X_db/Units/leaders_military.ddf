UnitType LeaderMilitary
{
	parent = Leader
	properties {
		DisplayName = tx_utn_LeadMili_name
		DisplayNamePlural = tx_utn_LeadMili_pname
		DisplayNameScenEdit = tx_utn_LeadMili_sname
		VerboseTooltip = vtt_unit_LeaderMilitary
//		SizeX = 0.4
//		SizeY = 0.4
		mass = 2
		moveType = Mounted
		HitPoints = 50
	}
	sounds {
	}
	abilities = [
		PowerReserve { timeToRecharge = 60 }
		Attack { range = 0.2; reloadTime = 1.5; applyDamageTime = 0.5; damage = 8 }
		Move {speed = 1.3; angSpeed = 180}
		LOS { range = 5 }
		AreaEffect {
			effects = [ 
			]
		}
		SpecialPower {
			effects = [
			]	
		}
	]
}

