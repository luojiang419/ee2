//------------------------------------------------------------------------------------------------
//	WONDERS
//------------------------------------------------------------------------------------------------
UnitType Wonder
{
	ownerType = PlayerOnly
	parent = NoProduceBuilding
	properties {
		SizeX = 3
		SizeY = 3
		mass = 1
		hitpoints = 6000
		displayNameTTTooltip = tx_utn_Wonder_tt_name
	}

	abilities = [
		LOS { range = 2 }
		Convertable { 
			convertTimeModifier = 300.0;  //
			garrisonedUnitModifier = 0.0; // 10% increase in capture time
			garrisonedUnitDamage = 0.0;	  // hitpoints subtracted from capturer per round per garrisoned unit
			damageRate = 0.0;			  // hitpoints subtracted from capture target hitpoints per round
			capture = 1;
		} // may be captured
	]
	attributes = [IsWonder]
}

//------------------------------------------------------------------------------------------------
//	WONDERS WESTERN - UNIT TYPE AND VISUAL INFO
//------------------------------------------------------------------------------------------------
//------------------------------------------------
//	EPOCH 1 - PARTHENON
//------------------------------------------------
UnitType WonderWestern_01
{
	parent = Wonder
	properties {
		SizeX = 5
		SizeY = 3
		FootprintSizeX = 6.5
		FootprintSizeY = 4.5
		UndertextureSizeX = 6.5
		UndertextureSizeY = 4.5
		OffsetX = 0.75
		OffsetY = 0.75
		displayName = tx_utn_WonderW1_name
		VerboseTooltip = vtt_unit_WonderW1
	}

abilities = [
		LOS { range = 5 }
	]
	icon = icon_unit_wonderwestern_01
}

UnitModel WonderWestern_01
{
	Parent			= BaseBuilding
	DefaultModel 		= bld_wonder1_we.nif
	ChildNames		= [ UnderWonderWestern_01 ]
	UIRenderingParams {
		xOffset = 0.53
		yOffset = 0.89
		zOffset = 1.17
		scale = 1.28
		angle = 42.63
		rotationSpeed = 0.00
		pitch = 40.26
	}
}

