//------------------------------------------------
//	EPOCH 11 - ROBOTICS FACTORY
//------------------------------------------------
UnitType WonderFarEast_11
{
	parent = Wonder
	properties {
		SizeX = 6
		SizeY = 4
		FootprintSizeX = 7.5
		FootprintSizeY = 5.5
		UndertextureSizeX = 7.5
		UndertextureSizeY = 5.5
		OffsetX = 0.75
		OffsetY = 0.75
		displayName = tx_utn_WonderFarE11_name
		VerboseTooltip = vtt_unit_WonderFarE11
		requiredOpenSides = kBuildingOpenSides_PosX
		RallyPlacementFlags = ( Fortress | Tower | Terrain )
		hitpoints = 10000
	}
	abilities = [
		LOS { range = 5 }
		AreaEffect {
			effects = [ AutomationEpoch11 ]
		}
		// For the automation effect, we need to produce
		Produce {
		}
	]
	icon = icon_unit_WonderFarEast_11
}

UnitModel WonderFarEast_11
{
	Parent			= BaseBuilding
	DefaultModel 		= bld_robotics_factory.NIF
	ChildNames		= [ UnderWonderFarEast_11 ]
}

UpgradeEffects WonderFarEastEpoch15AreaEffect
{
	unitType = WonderFarEast_11
	effectsToAdd = [ AutomationEpoch15 ]
	effectsToRemove = [ AutomationEpoch11 ]
}

