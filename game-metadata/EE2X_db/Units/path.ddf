//---------------------------------------------------------------------------
//	PATH UNIT TYPES
//	paths are kind of like roads only not buildable and smaller and
//	maybe don't give you a pathing bonus, also they are probably
//	indestructible and should ultimately be only owned by the world
//	but right now they will be player owned...
//
//	... I am mostly just making this up as I go @DANIEL
//---------------------------------------------------------------------------

//
// base type for Path and Path_Elbow
//
UnitType Path_Base
{
	placementType = Unplaceable
	properties 
	{
		displayName = tx_utn_path_name
		mass = 0	// so it does not block pathing
		FootprintType = kFootprintType_Rectangle
		SizeX = 0.75
		SizeY = 0.75
		rps = Building
		hitpoints = 10000	// so it won't get killed...
	}
	attributes = [NotSelectable]
}

//
// basic rectangular path piece (straight, T, 4way)
//
UnitType Path
{
	Parent = Path_Base
	placementType = Road   // this one is actually placeable!!!
	abilities [
		Connect { type = kComposite_RoadPiece; }
	]
	fullMapOverlay { sprite = spr_fullmap_road_piece }
}

//
// elbow path piece
//
UnitType Path_Elbow
{
	Parent = Path_Base
	abilities [
		Connect { type = kComposite_RoadElbow; }
	]
	fullMapOverlay { sprite = spr_fullmap_road_elbow }
}



//-------------------------------------------------
//	PATH DECAL VISUALS
//-------------------------------------------------

//
// rectangular piece
//
RoadDecal PathDecal
{
	DefaultState = Straight
	States	= [ 
		// straight piece
		{ 
			StateName = Straight
			RuralSpriteNames = [ Path_Piece ]
			UrbanSpriteNames = [ Path_Piece ]
		}
		
		// straight piece with start capped
		{ 
			StateName = CapStart
			RuralSpriteNames = [ Path_CapStart ]
			UrbanSpriteNames = [ Path_CapStart ]
		}
		
		// straight piece with both ends capped
		{ 
			StateName = CapBoth
			RuralSpriteNames = [ Path_CapBoth ]
			UrbanSpriteNames = [ Path_CapBoth ]
		}
		
		// 3-way T piece
		{ 
			StateName = T
			RuralSpriteNames = [ Path_T ]
			UrbanSpriteNames = [ Path_T ]
		}
		
		// 4-way piece
		{ 
			StateName = "4way"
			RuralSpriteNames = [ Path_4way ]
			UrbanSpriteNames = [ Path_4way ]
		}
	]
}

// parent model for above decal
UnitModel Path
{
	ScaleType 	= kScaleBuilding
	DefaultModel 	= null.NIF
	DefaultState 	= Idle
	States 		= [ { StateName = Idle } ]
	ChildNames 	= [ PathDecal ]
}


//
// elbow piece
//
RoadElbowDecal PathDecal_Elbow
{
	DefaultState = Elbow
	States	= [ 
		// elbow piece
		{ 
			StateName = Elbow
			RuralSpriteNames = [ Path_Elbow ]
			UrbanSpriteNames = [ Path_Elbow ]
		}
	]
}

// parent model for above decal
UnitModel Path_Elbow
{
	ScaleType 	= kScaleBuilding
	DefaultModel 	= null.NIF
	DefaultState 	= Idle
	States 		= [ { StateName = Idle } ]
	ChildNames 	= [ PathDecal_Elbow ]
}

