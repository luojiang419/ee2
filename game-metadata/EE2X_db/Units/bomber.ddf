// Attack Ability Upgrade
UpgradeAbilities BomberEpoch11Attack
{
	upgradedAbilities = [
		AircraftMove {speed = 3.5; angSpeed = 40; CruisingHeight = 9.0; ElevChangeRate = 0.5; OnGroundScale = 0.8}
		Attack { damage = 0; range = 0; reloadTime = 666; angularRange = 60; applyDamageTime = 0; missileName = "bomb"; ignoreBlocking = 1; attackOnTheMove = 1; ordnance = 6;
				areaDamageRadius = 2; areaDamageFriendlyRatio = 0.5; throwUnits = true }
	]
}

