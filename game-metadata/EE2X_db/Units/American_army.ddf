//////////////////////////////////////////
///////X47
///////////////////////////////////////////
UnitType X47
{
	parent = Aircraft
	properties {
		rps = Animal
		SizeX = 1
		SizeY = 1
		mass = 0
		popCount = 1
		displayName = tx_utn_X47_name
		verboseTooltip = vtt_unit_X47
		HitPoints = 1900
	}
	sounds = {
	}
	abilities = [
		AircraftMove {speed = 8.0; angSpeed = 35; CruisingHeight = 9.0; ElevChangeRate = 1.0} 
		Attack { damage = 900; range = 24; reloadTime = 1.0; angularRange = 120; applyDamageTime = 0.3; missileName = "pl12"; ignoreBlocking = 1; attackOnTheMove = 1; ordnance = 8;areaDamageRadius = 1.0; }
		LOS { range = 30 }
		AreaEffect {
			effects = [ 
				SuperVision
			]
		}
		SpecialPower { 		
			effects = [ Air_anti_missle]
		}
	]
	fullMapOverlay { sprite = spr_fullmap_plane; scale = 1.5; }
	attributes [
		GoesOnAirMissions
	]
	icon = icon_unit_X47
}


UnitModel X47
{
	Parent		= BaseAircraft
	DefaultModel 	= X47.nif
	ForceScale      = 0.15
	DefaultState 	= Idle
		States 		= [
		{	StateName = Idle	AnimName = ab15_orbital_idle.kf
				TextKeys = [{ Name = STOP_SOUND Data = fx_move_jet_01 KeyTime = 0}]}
		{ 	StateName = Walk	AnimName = ab15_orbital_walk.kf
				TextKeys = [{ Name = START_SOUND Data = fx_move_jet_01 KeyTime = 0}]}
		{ 	StateName = Attack1	AnimName = ab15_orbital_attack.kf
				TextKeys = [{ Name = START_SOUND Data = fx_move_jet_01 KeyTime = 0}
               				    { Name = PLAY_SOUND Data = fx_bomb_drop KeyTime = 0}]}
		{ 	StateName = TakeOff	AnimName = ab15_orbital_takeoff.kf
				TextKeys = [{ Name = PLAY_SOUND Data = fx_move_jet_takeoff_01 KeyTime = 0}]}
		{ 	StateName = Death	AnimName = ab15_orbital_death.kf }
			]
	ChildNames 	= [VaporTrail5 VaporTrail6 EngineTrail1 EngineTrail2 TheAmmoBar BomberShadow5 Orbital_FlyingParts expl_heli_Tandrill ]
	UIRenderingParams {
		xOffset = 0.01
		yOffset = 1.45
		zOffset = 2.31
		scale = 1.79
		angle = 18.95
	}
DamageDecalsSetName = BuildingDamageDecals
}

