//------------------------------------------------------------------------------------------------
//	TRADE CART - UNIT TYPE INFO
//------------------------------------------------------------------------------------------------
UnitType TradeCart
{
	properties {
		rps = LandNonCombat
		SizeX = 0.4
		SizeY = 0.4
		mass = 1
		displayName = tx_utn_TradeCart_name
		moveType = WheeledTrade
		hitpoints = 0
		VerboseTooltip = vtt_unit_TradeCart
		FootprintType = Ellipse
		popCount = 2
	}
	sounds {
		sndDeath =  ["fx_death_male_01" "fx_death_male_02" "fx_death_male_03" "fx_death_male_04" "fx_death_male_05" "fx_death_male_06" "fx_death_male_07"]
    	}
	abilities = [
		Convertable { }
		VehicleMove {speed = 1.5; angSpeed = 180; followTerrainSlope = 0}
		LOS { range = 0 }
		Trade { MarketType = Markets; 
				GoldPerTile = 0.90; 
				TechPerTile = 0.0; 
				TechBonusEpochDiff = 0.0;
				TechBonusLikelyhood = [ .10 .15 .20 .25 .30 ] 
				ForeignTradeAllowed = false
				timeToLoad = 5}
		Garrisonable { garrisonTypes = [ NavalTransport ] }
	]
	attributes = [ 
		HealedByMedic 
	]
	fullMapOverlay { sprite = spr_fullmap_smallunit ignoreOrientation = 1 }
}

//------------------------------------------------
//	EPOCH 2
//------------------------------------------------
// TradeCartUpgradeEpoch2 is in upgrade_unittypes.csv

//------------------------------------------------
//	EPOCH 3 TECH TREE UPGRADE
//------------------------------------------------
// Upgrade purchased through the tech tree that allows the player to trade with other players
UpgradeAbilities TradeCartTechTreeUpgrade
{
	UnitType = TradeCart
	upgradedAbilities = [
		Trade { MarketType = Markets; 
				GoldPerTile = 0.90; 
				TechPerTile = 0.0; 
				TechBonusEpochDiff = 0.0;
				TechBonusLikelyhood = [ .10 .15 .20 .25 .30 ] 
				ForeignTradeAllowed = true
				timeToLoad = 5}
	]
}

