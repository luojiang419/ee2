//------------------------------------------------------------------------------------------------
//	TRADE CART - VISUAL INFO
//------------------------------------------------------------------------------------------------
//------------------------------------------------
//	EPOCH 2
//------------------------------------------------
UnitModel TradeCart
{
	ScaleType 	= kScaleUnit
	OutlineType	= kOutlineMake
	DefaultModel 	= LSF2_tradecart.NIF
	DefaultState 	= Idle
	ChildNames 		= [ UnitShadow TheHealthBar SelectCircleMedium SmallGlow ExplSelectorHuman01 Footprints TheTradePath SinkCorpse ]
	States 		= [
		{	StateName = Idle	AnimName = LSF2_tradecart_idle01.KF
                              AnimVariants = [ LSF2_tradecart_idle02.KF ]
                              AnimVariantsWeights = [ 0.3 ]
                 }

			{ StateName = Walk 	AnimName = LSF2_tradecart_walk01.kf }
			{ StateName = Death 	AnimName = LSF2_tradecart_death01.kf }
			]
	UIRenderingParams {
		xOffset = 0.01
		yOffset = 0.72
		zOffset = -5.04
		scale = 2.56
		angle = 23.68
		rotationSpeed = 0.00
		pitch = 9.47
		lightAngle = 30.00
		lightPitch = 90.00
		lightDiffuse = [50 50 45 255]
		lightSpecular = [0 0 0 255]
		lightAmbient = [40 40 40 255]
	}
}

