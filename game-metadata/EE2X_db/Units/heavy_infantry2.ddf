UnitModel HeavyInfantry2_02
{
	Parent		= BaseHuman
	DefaultModel 	= LHI2_spearman.nif
	ChildNames 	= [ UnitShadow ]
	States 		= [
		{	StateName = Idle	AnimName = sh_spear_idle01.kf	
                              AnimVariants = [ sh_spear_idle02.kf sh_spear_idle03.kf ]
                              AnimVariantsWeights = [ 0.1 0.1 ]
                 }
		{ 	StateName = Walk	AnimName = sh_spear_walk01.kf	}
		{ 	StateName = CaptureAttack1	AnimName = sh_spear_capture01.kf
                              AnimVariants = [ sh_spear_capture02.kf ]
                              AnimVariantsWeights = [0.3]
                 }
                { 	StateName = Run	AnimName = sh_spear_jog01.kf	}
		{ 	StateName = Attack1	AnimName = sh_spear_attack01.kf
			TextKeys = [
					{ Name = PLAY_SOUND Data = fx_spear_thrust KeyTime = 0.40 }
							] }
		{ 	StateName = Death	AnimName = sh_spear_death01.kf	}
		{	StateName = Flinch	AnimName = sh_spear_protect01.kf }
		{	StateName = BeingThrown	AnimName = sh_spear_flying01.kf
			AnimVariants = [ sh_spear_flying02.kf ] AnimVariantsWeights = [ 0.5 ]	}
		{	StateName = ThrownDeath	AnimName = sh_spear_ground_death01.kf }
			]
	UIRenderingParams {
		xOffset = 0.01
		yOffset = -0.06
		zOffset = -3.33
		scale = 3.33
	}
}

// veteran version
