//------------------------------------------------------------------------------------------------
//	NON COMBAT AIR 2 (PARATROOPER PLANE\STEALTH HALO) - UNIT TYPE INFO
//------------------------------------------------------------------------------------------------
UnitType NonCombatAir2
{
	parent = Aircraft
	properties {
		SizeX = 1
		SizeY = 1
		mass = 0
		DisplayNameScenEdit = tx_utn_NonCmbtAir2_e12_sname
		HitPoints = 0
	}
	sounds = {
	}
	abilities = [
		AircraftMove {speed = 6; angSpeed = 60; CruisingHeight = 6.0; ElevChangeRate = 0.5}
		LOS { range = 1 }
		GarrisonParatrooper { 
			garrisonType = AirTransport;	// well paratrooper plane is like air transport here
			numOfSlots = 10; // NOTE:  leave extra space so that effects that boost paratrooper count will work
			initialContents = [ { typeName="LightInfantry" count=10 } ];	// load up with these paratrooper 
			dontShowGarrisonButton = 1;	// don't show garrison button in ui unit info area
		}
	]
	attributes [
		GoesOnAirMissions
	]
	fullMapOverlay { sprite = spr_fullmap_plane; scale = 1.5; }
}

