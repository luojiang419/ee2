// Add to mobile units for a blobby ellipsoid shadow
ShadowData        paratooperShadow_01
{
	Flags = (IsMobile | ImmutableBounds)
	FlatBillboard
	{
		TextureFilename = anc12_ParatrooperPlane_shadow.tga
		WidthScale = 0.9
		LengthScale = 0.9
		HeightScale = 0.1
	}
}


ShadowData        paratooperShadow_02
{
	Flags = (IsMobile | ImmutableBounds)
	FlatBillboard
	{
		TextureFilename = anc14_halo_shadow.tga
		WidthScale = 0.9
		LengthScale = 0.9
		HeightScale = 0.1
	}
}


UnitType Parachute
{
	ownertype = PlayerOnly
	properties {
		moveType = Air
		rps = AirNonCombat
		SizeX = 0.5
		SizeY = 0.5
		mass = 0
		hitpoints = 1
		popCount = 0
		FootprintType = Ellipse
	}
	abilities = [
		MoveFreeFall {speed = 0.6; accel = 0.4}
	]
	attributes = [NotSelectable]
	fullMapOverlay { sprite = spr_fullmap_smallunit ignoreOrientation = 1 }
}

UnitModel Parachute
{
	ScaleType 	= kScaleUnit
	OutlineType	= kOutlineMake
	DefaultModel 	= lla11_parachute.nif
	DefaultState 	= Idle
	ChildNames = [ SinkParachute UnitShadow ]
	States 		= [
		{	StateName = Idle		}
		{ 	StateName = Death		}
			]
}

