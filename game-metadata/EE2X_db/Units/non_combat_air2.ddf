}


//------------------------------------------------------------------------------------------------
//	NON COMBAT AIR 2 (PARATROOPER PLANE\STEALTH HALO) - VISUAL INFO
//------------------------------------------------------------------------------------------------
//------------------------------------------------
//	EPOCH 12
//------------------------------------------------
UnitModel NonCombatAir2_12
{
	Parent		= BaseAircraft
	DefaultModel 	= anc12_ParatrooperPlane.nif
	ChildNames 	= [ VaporTrail1 VaporTrail2 VaporTrail3 VaporTrail4 VaporTrail5 VaporTrail6 paratooperShadow_01 ParatrooperPlane_FlyingParts expl_heli_Tandrill ]
	States 		= [
		{	StateName = Idle	AnimName = anc12_ParatrooperPlane_idle.kf	}
		{ 	StateName = Walk	AnimName = anc12_ParatrooperPlane_walk.kf	
               			TextKeys = [{ Name = START_SOUND_UNTIL_ANIM_CHANGE Data = fx_move_plane_03 KeyTime = 0.5 }]}
		{ 	StateName = Death	AnimName = anc12_ParatrooperPlane_death.kf	}
		{ 	StateName = Takeoff	AnimName = anc12_ParatrooperPlane_takeoff.kf
               			TextKeys =    [{ Name = PLAY_SOUND Data = fx_move_plane_takeoff_03 KeyTime = 0}]}

			]
	UIRenderingParams {
		xOffset = 0.01
		yOffset = 0.63
		zOffset = 0.86
		scale = 1.79
		angle = 18.95
	}
}


