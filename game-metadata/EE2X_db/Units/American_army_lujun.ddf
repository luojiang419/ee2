UnitType Stryker
{
	parent = Tank
	properties {
		rps = LightMounted
		SizeX = 0.9
		SizeY = 0.7
		mass = 1
		popCount = 2
		
		displayName = tx_utn_Stryker_name
		verboseTooltip = vtt_unit_Stryker
		HitPoints = 2000
	}
	sounds = {
		sndSelection = ["v_heavyartillery_12_spe01" 
"v_HeavyMounted1_11_spe01"
"v_HeavyMounted1_13_spe01"
"v_lightartillery1_13_sel01"
"v_LightMounted1_11_spe01"]
sndCmdMove = ["v_heavyartillery_12_com01" 
"v_HeavyMounted1_11_com01"
"v_HeavyMounted1_11_com02"
"v_HeavyMounted1_12_spe01"
"v_HeavyMounted1_12_com01"
"v_LightMounted1_11_com01"]
//		sndCmdAttack = [""]
//		sndDeath =  [""]
	}
	abilities = [
		Attack { damage = 30; range = 15; reloadTime = 0.2; angularRange = 360; applyDamageTime = 0.1; missileName = "fkjqAmmo"; turretControllerName = TankTurret; }
        VehicleMove {speed = 2.0; angSpeed = 180; followTerrainSlope = 1; mustMoveToTurn = 0}
		LOS { range = 11 }
		Garrison { 
			garrisonType = Tower; 
			numOfSlots = 5;
			attackBonus = 0.05;	
			healPoints = 10;		
			rightClickToGarrison = 1;
			GarrisonFlagModelName = "GarrisonFlag"
		}
		Garrisonable { garrisonTypes = [ Fortress  NavalTransport  AirTransport ] }
	]
	attributes = [
		HealedByHERC 
		CanJoinHeroArmy
	]
	icon = icon_unit_Stryker
}
