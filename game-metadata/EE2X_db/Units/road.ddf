///////////////////////////////////////////////////
// fake road visuals for the UI rendering

UnitModel UIRoad_Base
{
	ScaleType 	= kScaleBuilding
	DefaultState	= Idle
	States 		= [ { StateName = Idle } ]
	
	UIRenderingParams {
		xOffset = 0.00
		yOffset = -0.03
		zOffset = 2.41
		scale = 2.55
		angle = 301.50
		rotationSpeed = 0.00
		pitch = 30.00
		lightAngle = 30.00
		lightPitch = 30.00
		lightDiffuse = [50 50 45 255]
		lightSpecular = [0 0 0 255]
		lightAmbient = [15 15 12 255]
	}
}

UnitModel UIRoad_1
{
	Parent 		= UIRoad_Base
	DefaultModel	= road1.nif
}

UnitModel UIRoad_2
{
	Parent 		= UIRoad_Base
	DefaultModel	= road2.nif
}

UnitModel UIRoad_3
{
	Parent 		= UIRoad_Base
	DefaultModel	= road3.nif
}
