UnitType ChinaPlane
{
	parent = Aircraft
	visualName = Fighter_11
	properties {
		rps = Animal 
		SizeX = 1
		SizeY = 1
		mass = 0
		HitPoints = 666
		VerboseTooltip = vtt_unit_Fighter
		popCount = 1
	}
	sounds = {
		sndSelection = ["v_plane_select_chn" 
				"v_plane_select_chn01" 
				"v_plane_select_chn02"
				"v_plane_select_chn03"
				"v_plane_select_chn04"
		]
		sndCmdMove = ["v_plane_move_chn01" 
	      		      "v_plane_move_chn02"
			      "v_plane_move_chn03"
			      "v_plane_move_chn04"
			      "v_plane_move_chn05"
			      "v_plane_move_chn06"
		]
		sndCmdAttack = ["v_plane_attack_chn01"
				"v_plane_attack_chn02"
				"v_plane_attack_chn03"
		]
		sndDeath =  ["v_plane_death_chn01"
			     "v_plane_death_chn02"
			     "v_plane_death_chn03"
		]
	}
	abilities = [
		AircraftMove {speed = 7.5; angSpeed = 75; CruisingHeight = 8.5; ElevChangeRate = 0.5}
		Attack { range = 13; reloadTime = 1; applyDamageTime = 0; damage = 700; missileName = "pl12"; ordnance = 20;attackOnTheMove = 1;areaDamageRadius = 1.5;  }
		LOS { range = 13 }
		SpecialPower { 		
			effects = [ Air_anti_missle ]
		}
	]
	fullMapOverlay { sprite = spr_fullmap_plane; scale = 1.5; }
	attributes [
		GoesOnAirMissions
	]

}

// Attack Ability Upgrade
UpgradeAbilities ChinaPlaneEpoch14Attack
{
	upgradedAbilities = [
		AircraftMove {speed = 8; angSpeed = 68; CruisingHeight = 9.0; ElevChangeRate = 1.0}
		Attack { damage = 0; range = 0; reloadTime = 666; angularRange = 120; applyDamageTime = 0; missileName = "pl12"; ignoreBlocking = 1; attackOnTheMove = 1; ordnance = 28 }
	]
}

