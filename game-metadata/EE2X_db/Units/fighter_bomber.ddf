//------------------------------------------------------------------------------------------------
//	FIGHTER BOMBER - UNIT TYPE INFO
//------------------------------------------------------------------------------------------------
UnitType FighterBomber
{
	parent = Aircraft
	properties {
		rps = CloseAirSupport
		SizeX = 1
		SizeY = 1
		mass = 0
		VerboseTooltip = vtt_unit_FighterBomber
		popCount = 2
	}
	abilities = [
		AircraftMove {speed = 6.5; angSpeed = 40; CruisingHeight = 10.0; ElevChangeRate = 0.5}
		Attack { range = 0; reloadTime = 1; applyDamageTime = 0; damage = 0; missileName = "bomb02 "; attackOnTheMove = 1;
				areaDamageRadius = 1; areaDamageFriendlyRatio = 0.5 }
		LOS { range = 0 }
		SpecialPower { 		
			effects = [ Air_anti_missle ]
		}
	]
	fullMapOverlay { sprite = spr_fullmap_plane; scale = 1.5; }
	attributes [
		GoesOnAirMissions
	]
}

// Add to mobile units for a blobby ellipsoid shadow
ShadowData        fighterBomberShadow_01
{
	Flags = (IsMobile | ImmutableBounds)
	FlatBillboard
	{
		TextureFilename = afb11_triplane_shadow.tga
		WidthScale = 0.9
		LengthScale = 0.9
		HeightScale = 0.1
	}
}

