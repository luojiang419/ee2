//------------------------------------------------
//	EPOCH 11
//------------------------------------------------
UnitModel FighterBomber_11
{
	Parent		= BaseAircraft
	DefaultModel 	= AFB11_triplane.nif
	ChildNames 	= [ VaporTrail1 VaporTrail2 TheAmmoBar fighterBomberShadow_01 Triplane_FlyingParts expl_heli_Tandrill ]
	States 		= [
			{StateName = Idle 	AnimName = afb11_triplane_idle.kf	
				TextKeys = [{ Name = STOP_SOUND Data = fx_move_plane_04 KeyTime = 0}]}
			{ StateName = Walk	AnimName = afb11_triplane_walk.kf		
				TextKeys = [{ Name = START_SOUND Data = fx_move_plane_04 KeyTime = 0}]}
			{ StateName = Attack1	AnimName = afb11_triplane_attack.kf	
				TextKeys = [{ Name = START_SOUND Data = fx_move_plane_04 KeyTime = 0}
               				    { Name = PLAY_SOUND Data = fx_bomb_drop KeyTime = 0}]}
		{ 	StateName = Takeoff	
               			TextKeys =    [{ Name = PLAY_SOUND Data = fx_move_plane_takeoff_04 KeyTime = 0}]}

			{ StateName = Death	AnimName = afb11_triplane_death.kf		
				TextKeys = [
				{ Name = STOP_SOUND Data = fx_move_plane_04 KeyTime = 0}
				]
			}]
	UIRenderingParams {
		xOffset = 0.01
		yOffset = 0.33
		zOffset = -1.57
		scale = 1.92
		angle = 18.95
	}
}

