//------------------------------------------------
//	UNIQUE UNIT MODEL
//------------------------------------------------
UnitModel UniqueUnitRussian1
{
	Parent 		= BaseHuman
	DefaultModel 	= civ1_varangianwarrior_russian.nif
	ChildNames 	= [ UnitShadow ]
	States 		= [
		{	StateName = Idle	AnimName = civ1_varangianwarrior_russian_idle01.kf
                              AnimVariants = [ civ1_varangianwarrior_russian_idle02.kf ]
                              AnimVariantsWeights = [0.4]
                 }
		{ 	StateName = Walk	AnimName = civ1_varangianwarrior_russian_walk.kf
		}
		{ 	StateName = CaptureAttack1	AnimName = civ1_varangianwarrior_russian_capture01.kf
                              AnimVariants = [ civ1_varangianwarrior_russian_capture02.kf ]
                              AnimVariantsWeights = [0.3]
                 }
                { 	StateName = Run	AnimName = civ1_varangianwarrior_russian_jog.kf
		}

		{ 	StateName = Attack1	AnimName = civ1_varangianwarrior_russian_attack01.kf	       
			TextKeys =  [
						{ Name = PLAY_SOUND Data = fx_sword_swing KeyTime = 1.0 }
						]
		 }
		{ 	StateName = Death	AnimName = civ1_varangianwarrior_russian_death.kf	}
		{	StateName = Flinch	AnimName = civ1_varangianwarrior_russian_protect01.KF	}
		{	StateName = BeingThrown	AnimName = civ1_varangianwarrior_russian_flying01.KF
			AnimVariants = [ civ1_varangianwarrior_russian_flying02.KF ] AnimVariantsWeights = [ 0.5 ]	}
		{	StateName = ThrownDeath	AnimName = civ1_varangianwarrior_russian_ground_death01.KF	}

			]
	UIRenderingParams {
		xOffset = 0.01
		yOffset = 0.02
		zOffset = -6.43
		scale = 2.69
	}
}

