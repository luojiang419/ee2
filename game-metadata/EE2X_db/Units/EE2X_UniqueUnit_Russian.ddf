		DisplayNameScenEdit = tx_utn_UURussian1_sname
		VerboseTooltip = vtt_unit_UURussian1
		HitPoints = 0
	}
	sounds {
	}
	abilities = [
		Attack { damage = 0; range = 0; reloadTime = 666; applyDamageTime = 0.5; WeaponType = Melee }
		ConvertAttack { convertTimeModifier = 1.0; range = 2.0; reloadTime = 8.0; applyDamageTime = 1.0; capture = 1 }
		LOS { range = 0 }
		Move {speed = 1.3; angSpeed = 720}
	]
}

