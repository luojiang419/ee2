//------------------------------------------------------------------------------------------------
//	AMBIENTS CAMPAIGN
//------------------------------------------------------------------------------------------------
UnitType AmbientCampaignBuilding
{
	ownerType = PlayerOnly
	Parent = NoProduceBuilding
	properties {
		FootprintType = kFootprintType_Rectangle
		SizeX = 2.5
		SizeY = 2.5
		mass = 1
		hitpoints = 666
		rps = Building
	}
	abilities = [
		LOS { range = 2 }
		]
	fullMapOverlay { sprite = spr_fullmap_building }
}

//------------------------------------------------------------------------------------------------
//	AMBIENTS CAMPAIGN - UNIT INFO
//------------------------------------------------------------------------------------------------
//------------------------------------------------
//	COMMAND TENT - WEST / FAR EAST
//------------------------------------------------
UnitType CommandTent
{
	parent = AmbientCampaignBuilding
	properties {
		SizeX = 1.5
		SizeY = 1.5
		displayName = tx_utn_CommandTent_name
		DisplayNameScenEdit = tx_utn_CommandTent_sname
		VerboseTooltip = vtt_unit_CommandTentWEFE
	}
	abilities = [
	]
	icon = icon_unit_commandTent_we
}

UnitModel CommandTent
{
	Parent		= BaseBuilding_NoFoundation
	DefaultModel 	= bld_commandtent12.NIF
	ChildNames 	= [ LargeGlow ExplSelectorBuild_Small ]
	DamageDecalsSetName = BuildingDamageDecals
}

