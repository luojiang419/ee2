//------------------------------------------------
//	MACHINEGUN NEST
//------------------------------------------------
UnitType MachineGunNest12
{
	parent = AmbientCampaignBuilding
	properties {
		hitpoints = 2000
		rps = BuildingCombat
		SizeX = 1.0
		SizeY = 1.0
		displayName = tx_utn_machinegunnest12_name
		DisplayNameScenEdit = tx_utn_machinegunnest12_sname
		VerboseTooltip = vtt_unit_machinegunnest12
	}
	abilities = [
		Attack { range = 15; reloadTime = 0.3; applyDamageTime = 0.5; damage = 30; turretControllerName = BuildingTurret; }
		LOS { range = 15 }
	]
	icon = icon_unit_machinegunnest
}

UnitModel MachineGunNest12
{
	Parent		= BaseBuilding_NoFoundation
	DefaultModel 	= bld_machinegunnest12.NIF
	ChildNames 	= [ MediumGlow Beam_Tracer01 ExplSelectorBuild_Tiny Muzzle_Pillbox ]
	States 		= [
					{	StateName = Idle }
					{ 	StateName = Attack1
						TextKeys = [
					{ Name = PLAY_SOUND Data = fx_machine_gun_fire KeyTime = 0.16 }
					] 
	}
					]
	DamageDecalsSetName = BuildingDamageDecals

}

