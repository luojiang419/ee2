//------------------------------------------------
//	BUOY
//------------------------------------------------
UnitType Buoy
{
	placementType = DeepWater
	properties {
		FootprintType = kFootprintType_Rectangle
		moveType = kUnitMoveType_NavalDeep
		SizeX = 0.25
		SizeY = 0.25
		displayName = tx_utn_Buoy_name
		DisplayNameScenEdit = tx_utn_Buoy_sname
		VerboseTooltip = vtt_unit_buoy		
		mass = 0
		hitpoints = 666
		rps = SeaNonCombat
	}
	abilities [
		NavalMove {speed = 0; accel = 0; angSpeed = 0}		
		LOS { range = 14 }
	]
	fullMapOverlay { sprite = spr_fullmap_building }
	icon = icon_unit_buoy
}

UnitModel Buoy
{
	DefaultModel 	= amb_buoy.NIF
	OutlineType	= kOutlineReceive
	ScaleType 	= kScaleBuilding
	DefaultState 	= Idle
	States 		= [
			{	StateName = Idle	}
			]
	ChildNames 	= [ MediumGlow TheHealthBar TheResistanceBar ]
}
