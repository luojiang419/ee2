UnitType ZSL92
{
	parent = Mounted
	properties {
		rps = LightMounted
		SizeX = 0.8
		SizeY = 0.5
		mass = 1
		popCount = 2
		displayName = tx_utn_ZSL92_name
        verboseTooltip = vtt_unit_ZSL92
		HitPoints = 2000
	}
	sounds = {
		sndSelection = ["v_lightarmor_select_chn" 
				"v_lightarmor_select_chn01"
		]
		sndCmdMove = ["v_lightarmor_move_chn01" 
	      		      "v_lightarmor_move_chn02"
			      "v_lightarmor_move_chn03"
			      "v_lightarmor_move_chn04"
			      "v_lightarmor_move_chn05"
			      "v_lightarmor_move_chn06"
		]
		sndCmdAttack = ["v_lightarmor_attack_chn01"
		]
		sndDeath =  ["v_cmon_unit_death_chn"]
	}
	abilities = [
		Attack { damage = 30; range = 15; reloadTime = 0.2; applyDamageTime = 0.01; missileName = "fkjqAmmo"; turretControllerName = TankTurret;  }
		VehicleMove {speed = 1.6; angSpeed = 70;followTerrainSlope = 1;mustMoveToTurn = 0} 
		LOS { range = 17 }
	Garrison { 
			garrisonType = Tower; 
			numOfSlots = 5;
			attackBonus = 0.05;	
			healPoints = 10;		
			rightClickToGarrison = 1;
			GarrisonFlagModelName = "GarrisonFlag"
		}
	Garrisonable { garrisonTypes = [ Fortress  NavalTransport  AirTransport ] }
	]
icon = icon_unit_ZSL92
}
