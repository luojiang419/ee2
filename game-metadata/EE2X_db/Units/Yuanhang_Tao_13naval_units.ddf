///////////////////////////////////
// 054A 护卫舰
//////////////////////////////////
UnitType Ch054A
{
	parent = NavalDeep
	//VisualName=Ch054destoryModel
	properties {
		rps = AntiAircraft
		SizeX = 2.5
		SizeY = 1.0
		mass = 1
		popCount = 2
		displayName = tx_utn_Ch054A_name
		VerboseTooltip = vtt_unit_Ch054A
		HitPoints = 6000
	}
	attributes = [
		HealedByHERC 
			]
     sounds = {
		sndSelection = ["v_aircraftcarrier_select_chn01"
				"v_aircraftcarrier_select_chn04" 
		]
		sndCmdMove = ["v_aircraftcarrier_move_chn01" 
	      		      "v_aircraftcarrier_move_chn02"
		]
		sndCmdAttack = [
				"v_aircraftcarrier_attack_chn02"
				"v_aircraftcarrier_attack_chn03"
		]
		sndDeath =  ["v_cmon_unit_death_chn"]
	}
	abilities = [
            Attack { damage = 800; range = 25; angularRange = 360; reloadTime = 2.5; applyDamageTime = 0.01; missileName = "A054Rocket"; ignoreBlocking = 1; areaDamageRadius = 2; } //turretControllerName = sensordestroyerTurret;
            NavalMove {speed = 2.0; accel = 1; angSpeed = 40}
		LOS { range = 24 }
		AreaEffect {
		effects = [ 
				SuperVision
			]
		}
		Produce {}
			Garrison { 
			garrisonType = Heliport; 
			numOfSlots = 2;
			healPoints = 1200;		// Each unit type garrison heals this many points per second
			rightClickToGarrison = true
			GarrisonFlagModelName = "GarrisonFlag"
		}
			]
	icon = icon_unit_054A
}
