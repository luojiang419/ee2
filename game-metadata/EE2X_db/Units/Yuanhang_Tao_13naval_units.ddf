{
	parent = NavalDeep
	properties {
		rps = SubmarineNuclear
		SizeX = 3.5
		SizeY = 0.75
		mass = 1
		popCount = 3
		displayName = tx_utn_Redoutable_name
		VerboseTooltip = vtt_unit_Redoutable
		HitPoints = 7000
	}
	sounds = {
	}
	abilities = [
		Attack { damage = 35000; range = 80; reloadTime = 25; angularRange = 1; applyDamageTime =0.5; missileName = "SubNUke"; ignoreBlocking = 1; areaDamageRadius = 11; areaDamageFriendlyRatio = 1.0 ; minRangeMobile = 20; minRangeImmobile = 20; weaponType = Nuke }
		LOS { range = 18 }
		NavalMove {speed = 1.5; angSpeed = 40; cruisingDepth = -1 }
		SpecialPower { 
			effects = [ SubmarineDiveing ]
			}
			]
	icon = icon_unit_Redoutable
}

UnitModel Redoutable
{
	parent		= BaseSubmarine
      DefaultModel 	= Redoutable.nif
	  DefaultState 	= Idle
      ForceScale = 0.13
      States 		= [
		{	StateName = Idle	AnimName = LLM13_rpgstriker_walk.KF 
		        TextKeys = [ { Name = START_SOUND Data = fx_move_sub_ping_low KeyTime = 0.5}  ] }                           
        	{ StateName = Walk	AnimName = LLM13_rpgstriker_walk.KF
				TextKeys = [ { Name = START_SOUND_UNTIL_ANIM_CHANGE Data = fx_move_sub_ping_low KeyTime = 0.5}  ]
				}
		{ StateName= Attack1		
			TextKeys = [ 
				{ Name = PLAY_SOUND Data = fx_rocket_launchICBM KeyTime = 0.2 }  
				] 
		}		
		{ 	StateName = Death	
				TextKeys = [{ Name = PLAY_SOUND Data = fx_tmp_boat_sink_01 KeyTime = 0}]}
]
	ChildNames	= [ ExplSelectorSubmarine Muzzle_SubNuke NuclearSubmarine_FlyingParts Muzzle_Silo LargeGlow ]
UIRenderingParams {
		xOffset = 0.01
		yOffset = 2.91
		zOffset = 0.62
		scale = 1.66
		angle = 47.37
	}
}
UnitType Triomphant
{
	parent = NavalDeep
	properties {
		rps = SubmarineNuclear
		SizeX = 3.5
		SizeY = 0.4
		mass = 1
		HitPoints = 8000
		popCount = 4
        displayName = tx_utn_Triomphant_name
        verboseTooltip = vtt_unit_Triomphant
		// The missile defaults to not firing on its own.
		stance = HoldFire
	}
	sounds = {
			sndSelection = ["v_Submarine_13_sel01"]
		    sndCmdMove = ["v_Submarine_13_com01" "v_Submarine_13_com02"]
	}
	abilities = [
	 AreaEffect {
			effects = [ 
				RocketLaunchingTBMFix1
			]
		}
		Attack { damage = 40000; range = 100; reloadTime = 25; angularRange = 1; applyDamageTime =0.5; missileName = "SubNUke"; ignoreBlocking = 1; areaDamageRadius = 12; areaDamageFriendlyRatio = 1.0 ; minRangeMobile = 20; minRangeImmobile = 20; weaponType = Nuke }
		
LOS { range = 20 }
SpecialPower { 
			effects = [ SubmarineDiveing ]
			}
		NavalMove {speed = 1.6; angSpeed = 40; cruisingDepth = -1 }
	]
icon = icon_unit_Triomphant
}

UnitModel Triomphant
{
	parent		= BaseSubmarine
	DefaultModel 	= Triomphant.nif
	 ForceScale = 0.1
	States 		= [
		{	StateName = Idle	AnimName = ns13_nuclearsubmarine_walk.KF   	}                            
        	{ 	StateName = Walk	AnimName = ns13_nuclearsubmarine_walk.KF	
                     		TextKeys = [{ Name = PLAY_SOUND Data = fx_move_sub_ping_low KeyTime = 0.5 }]}
		{ 	StateName = Attack1	AnimName = ns13_nuclearsubmarine_walk.KF 	
		                TextKeys = [{ Name = PLAY_SOUND Data = fx_battle_torp_launch KeyTime = 0.5 }]}		
		{ 	StateName = Death	AnimName = ns13_nuclearsubmarine_walk.KF  	}
]
	ChildNames	= [ ExplSelectorSubmarine Muzzle_SubNuke NuclearSubmarine_FlyingParts ]
	UIRenderingParams {
		xOffset = 0.01
		yOffset = 3.40
		zOffset = 1.15
		scale = 1.66
		angle = 47.37
	}
}
