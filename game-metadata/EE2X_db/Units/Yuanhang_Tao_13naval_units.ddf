//////////////////////////////////////
// 075型两栖攻击舰
////////////////////////////////////
UnitType Type075
{
	parent = NavalDeep  
      properties {
		rps = Carrier
		SizeX = 5
		SizeY = 1.0
		mass = 1		
		popCount = 4     
		displayName = tx_utn_Type075_name		
		VerboseTooltip = vtt_unit_Type075
		HitPoints = 20000  
        stance = Aggressive
	}
	sounds = {
		sndSelection = ["v_aircraftcarrier_select_chn01"
				"v_aircraftcarrier_select_chn04" 
		]
		sndCmdMove = ["v_aircraftcarrier_move_chn01" 
	      		      "v_aircraftcarrier_move_chn02"
		]
		sndCmdAttack = [
				"v_aircraftcarrier_attack_chn02"
				"v_aircraftcarrier_attack_chn03"
		]
		sndDeath =  ["v_cmon_unit_death_chn"]
	}
	attributes = [
		HealedByHERC 
			]
      abilities = [
		NavalMove {speed = 1.7; accel = 1; angSpeed = 40}
		LOS { range = 25 }	
		Attack { damage = 600; range = 24; angularRange = 360; reloadTime = 2; applyDamageTime = 0.5; missileName = "A054Rocket";  areaDamageRadius = 2; }
        Produce { 	
		}
        Garrison {
			numOfSlots = 10;
			garrisonType = Heliport;
			healPoints = 100;		// Each unit type garrison heals this many points per second
			rightClickToGarrison = true
			GarrisonFlagModelName = "GarrisonShip"
		}
		LOS { range = 26 }            
	]
	icon = icon_unit_Type075
}

UnitModel Type075
{
	parent		= BaseShip
	DefaultModel 	= Type075_china.NIF // ND14_mistral.NIF
	ForceScale = 0.15
	States = [
		{ StateName = Idle	}
		{ 	StateName = Walk	
				TextKeys = [{ Name = START_SOUND_UNTIL_ANIM_CHANGE Data = fx_move_aircraftcarrier KeyTime = 0}]}
		{ 	StateName = Death	
				TextKeys = [{ Name = PLAY_SOUND Data = fx_dea_ship_metal_3  KeyTime = 0}]}
		{ StateName= Attack1		
			TextKeys = [ { Name = PLAY_SOUND Data = fx_battle_Laser_01 KeyTime=0.5 } ]
		}
	]

	ChildNames 	= [ ExplSelectorDestroy TheBoatWake6 AircraftCarrier_FlyingParts   ]
	
      UIRenderingParams {
		xOffset = 0.01
		yOffset = 3.43
		zOffset = -0.08
		scale = 1.66
		angle = 47.37
	}
}
