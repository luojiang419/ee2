UnitType UniqueUnitTurkish1
{
	parent = HeavyMounted1
	properties {
		DisplayName = tx_utn_UUTurkish1_name
		DisplayNameScenEdit = tx_utn_UUTurkish1_sname
		VerboseTooltip = vtt_unit_UUTurkish1
		HitPoints = 0
		SizeX = 0.4
		SizeY = 0.2
		mass = 2
		moveType = Mounted
	}
	sounds = {
	}
	abilities = [
		Attack { damage = 0; range = 0; reloadTime = 666; applyDamageTime = 0.5 }
		LOS { range = 5 }
		Move {speed = 1.5; angSpeed = 180}
	]
}

