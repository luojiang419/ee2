//------------------------------------------------
//	UNIQUE UNIT MODEL
//------------------------------------------------
UnitModel UniqueUnitTurkish1
{
	Parent		= HeavyMounted1_04
        DefaultModel 	= CIV1_Spahi_Turkish.NIF
	States 		= [
		{	StateName = Idle	AnimName = sh_elitecavalry_idle01.kf	
                              AnimVariants = [ sh_elitecavalry_idle02.kf 
sh_elitecavalry_idle03.kf 
sh_elitecavalry_win.kf 
sh_elitecavalry_season01.kf ]
                              AnimVariantsWeights = [ 0.05 0.3 0.1 0.2 ]
                 }
		{ 	StateName = Walk	AnimName = sh_elitecavalry_walk01.KF AnimSpeedScale = 2.25 }
		{	StateName = Run		AnimName = sh_elitecavalry_run01.KF	}
		{ 	StateName = Attack1	AnimName = sh_elitecavalry_attack01.KF
		                              TextKeys = [
					{ Name = PLAY_SOUND Data = fx_spear_thrust KeyTime = 0.40 }]
                              AnimVariants = [ sh_elitecavalry_attack02.KF sh_elitecavalry_attack03.KF sh_elitecavalry_attack04.KF sh_elitecavalry_attack05.KF ]
                              AnimVariantsWeights = [ 0.02 0.03 0.03 0.02 ]
                 }
       		{ 	StateName = Death	AnimName = sh_elitecavalry_death01.KF	}
		{	StateName = Flinch	AnimName = sh_elitecavalry_protect01.KF	}
		{	StateName = BeingThrown	AnimName = sh_elitecavalry_flying01.KF
			AnimVariants = [ sh_elitecavalry_flying02.KF ] AnimVariantsWeights = [ 0.5 ]	}
		{	StateName = ThrownDeath	AnimName = sh_elitecavalry_ground_death01.KF	}
			]
}

