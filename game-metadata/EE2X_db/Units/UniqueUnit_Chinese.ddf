//------------------------------------------------
//	UNIQUE UNIT MODEL
//------------------------------------------------
UnitModel UniqueUnitChinese1
{
	Parent		= LightInfantry_01
        ScaleType	= kScaleUnit
	DefaultModel 	= CIV3_DragonArcher_Chinese.nif
	ChildNames 	= [ UnitShadow ]
	States 		= [
		{	StateName = Idle	AnimName = sh_compositebowman_idle01.KF	
                        AnimVariants = [ CIV3_DragonArcher_Chinese_idle02.KF sh_compositebowman_win.kf sh_compositebowman_season01.KF]
                        AnimVariantsWeights = [ 0.1 0.1 0.1 ]
				TextKeys = [
								{ Name = HIDE_NODE Data = arrow KeyTime = 0 }
				]}
		{ 	StateName = Walk	AnimName = sh_compositebowman_walk01.KF 
				TextKeys = [
								{ Name = HIDE_NODE Data = arrow KeyTime = 0 }
				]}
                { 	StateName = CaptureAttack1	AnimName = CIV3_DragonArcher_Chinese_capture01.KF
                              AnimVariants = [ CIV3_DragonArcher_Chinese_capture02.KF ]
                              AnimVariantsWeights = [0.3]
				TextKeys = [
								{ Name = SHOW_NODE Data = arrow KeyTime = 0 }
				]}     
		{ 	StateName = Run	        AnimName = sh_compositebowman_jog01.KF
				TextKeys = [
								{ Name = HIDE_NODE Data = arrow KeyTime = 0 }
				]}
		{ 	StateName = Attack1	AnimName = sh_compositebowman_attack01.KF
                        TextKeys = [ { Name = PLAY_SOUND Data = fx_bow_shoot KeyTime = 1.56 } 
				     { Name = HIDE_NODE Data = arrow KeyTime = 0 }
				     { Name = SHOW_NODE Data = arrow KeyTime = 0.3 }
				     { Name = HIDE_NODE Data = arrow KeyTime = 1.56  }] 
                }
		{ 	StateName = Death	AnimName = sh_compositebowman_death01.KF
				TextKeys = [
								{ Name = HIDE_NODE Data = arrow KeyTime = 0 }
				]}
		{	StateName = Flinch	AnimName = CIV3_DragonArcher_Chinese_protect01.kf }
		{	StateName = BeingThrown	AnimName = CIV3_DragonArcher_Chinese_flying01.kf
			AnimVariants = [ CIV3_DragonArcher_Chinese_flying02.kf ] AnimVariantsWeights = [ 0.5 ]	}
		{	StateName = ThrownDeath	AnimName = CIV3_DragonArcher_Chinese_ground_death01.kf }
			]
	UIRenderingParams {
		xOffset = 0.01
		yOffset = -1.32
		zOffset = -5.75
		scale = 2.69
	}
}

