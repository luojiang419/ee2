//------------sa2-------------
UnitType AMissileDefense
{
	ownerType = PlayerOnly
	parent = NoProduceBuilding
	properties {
		rps = AntiAircraft
		SizeX = 1
		SizeY = 1
		FootprintSizeX = 2.5
		FootprintSizeY = 2.5
		OffsetX = 0.75
		OffsetY = 0.75
		mass = 1
		hitpoints = 6000
		displayName = tx_utn_sa2_name
		DisplayNameScenEdit = tx_utn_sa2_pname
		VerboseTooltip = vtt_airdefense2_dsc
	}
	sounds {
		sndSelection = [""]
   	}	
	abilities = [
	AreaEffect {
			effects = [
				AntiMissileMember
			]
		}
		// @AA - removed: 'missileName = "Flak01"' from attack ability, this one wants to have instant hits
		Attack { damage = 250; range = 30; reloadTime = 6; angularRange = 360; missileName = "SA2Missile"; ignoreBlocking = 1; turretControllerName = TankTurret; areaDamageRadius = 1.5; throwUnits = true }
		LOS { range = 40 }
	]
	icon = icon_unit_sa2
}
