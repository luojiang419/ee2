//------------------------------------------------------------------------------------------------
//	FORTRESS - UNIT TYPE INFO
//------------------------------------------------------------------------------------------------
UnitType Fortress
{
	// You'd -think- that the fortress would be player only, but in fact,
	// the unit type needs to exist for the world player, because it uses
	// it for testing when setting up a hot spots game.  So please leave
	// the ownerType field blank.  @BEN
	//ownerType = PlayerOnly
	parent = NoProduceBuilding
	properties {
		rps = BuildingCombat
		SizeX = 3
		SizeY = 3
		FootprintSizeX = 4.5
		FootprintSizeY = 4.5
		OffsetX = 0.75
		OffsetY = 0.75
		UndertextureSizeX = 3
		UndertextureSizeY = 3
		mass = 1
		displayName = tx_utn_fortress_name
		DisplayNameScenEdit = tx_utn_fortress_sname
		VerboseTooltip = vtt_unit_Fortress
		hitpoints = 0
		UnitHeight = 3.0
	}
	sounds {
    	}
	fullMapOverlay { sprite = spr_fullmap_fortress }
	abilities = [
		Garrison { 
			garrisonType = Fortress; 
			numOfSlots = 30;
			attackBonus = 0.03;	// 3 percent more attack for each garrisoned UnitType
			healPoints = 2;		// 2 hit points heal every second for each UnitType
			rightClickToGarrison = 1;
			GarrisonFlagModelName = "GarrisonFlag"
		}
		Attack { range = 0; reloadTime = 666; applyDamageTime = 0.5; damage = 0; missileName = "FireArrow"; angularRange = 360 }
		LOS { range = 0 }
		AreaEffect {
			effects = [ 
				FortressCentral
			]
		}
	]
}

