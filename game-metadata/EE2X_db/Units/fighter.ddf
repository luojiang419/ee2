// Attack Ability Upgrade
UpgradeAbilities FighterEpoch11Attack
{
	upgradedAbilities = [
		AircraftMove {speed = 5.0; angSpeed = 40; CruisingHeight = 8.0; ElevChangeRate = 1.0}
		Attack { damage = 0; range = 0; reloadTime = 666; angularRange = 120; applyDamageTime = 0; missileName = "OutpostBullet";ignoreBlocking = 1; attackOnTheMove = 1; ordnance = 50 }
	]
}

// Veteran Upgrade
UpgradeUnitTypeImprove FighterEpoch11Veteran
{
	unitType = Fighter
	name = tx_utn_veteran_modify_name
	upgradeRefs = [
		Fighter_Improve_Default
	]
}

