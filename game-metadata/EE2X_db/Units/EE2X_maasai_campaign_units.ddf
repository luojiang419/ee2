//------------------------------------------------
//	COW
//------------------------------------------------
UnitType MaasaiCow
{
	parent = LandAnimal
	properties {		
		displayName = tx_utn_cow_name
		VerboseTooltip = vtt_unit_cow
		hitpoints = 100
		SizeX = 0.3
		SizeY = 0.3
	}
	sounds {
		sndSelection = ["fx_animal_cow_sel_01" "fx_animal_cow_sel_02"]
	}
	abilities = [
							 //having these move slower than the sheperds is skill testing and a little fun (if frustrating, so not TOO slow)
// 		Move { mustMoveToTurn = 0; speed = 0.92; angSpeed = 180 }
		Move { mustMoveToTurn = 0; speed = 0.80; angSpeed = 180 }
		LOS { range = 3 }
	]
}

UnitModel MaasaiCow
{
	Parent 		= BaseLandAnimal
	DefaultModel 	= faucow.nif
	ChildNames 		= [ UnitShadow ]
	States 		= [
		{	StateName = Idle	AnimName = sh_faucow_idle01.kf
			AnimVariants = [ sh_faucow_idle02.kf sh_faucow_idle03.kf ] AnimVariantsWeights = [ 0.3 0.1 ]
		}
		{ 	StateName = Walk	AnimName = sh_faucow_walk01.kf }
		{ 	StateName = Death	AnimName = sh_faucow_death01.kf 
				TextKeys = [{ Name = PLAY_SOUND Data = fx_animal_cow_die_01 KeyTime = 0}]}
			]
	UIRenderingParams {
		xOffset = -2.89
		yOffset = 1.34
		zOffset = 0.04
		scale = 1.02
		angle = 47.37
		rotationSpeed = 0.00
		pitch = 0.01
		lightAngle = 30.00
		lightPitch = 90.00
		lightDiffuse = [50 50 45 255]
		lightSpecular = [0 0 0 255]
		lightAmbient = [40 40 40 255]
	}
}

