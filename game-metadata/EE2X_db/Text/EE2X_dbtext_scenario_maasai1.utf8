// Territories

// Names of units
text_maasai_hero_name,"""巴利迪·海特利·尼亚马""" // Beer Danger Meat in Swahili
text_maasai_hero_desc,"""巴利迪·海特利·尼亚马有重新集结部队的能力，而且这一个部队是依照他的旨意的凶猛斗士。巴利迪必须在这个任务中存活才能获胜！""" 
text_maasai_hero_hurt,"""巴利迪受伤了，快保护他的安全！"""
text_maasai_chief_name,"""达克塔利·邦德·尼亚马""" // Doctor Valley Meat in Swahili
text_maasai_chief_desc,"""达克塔利·邦德·尼亚马是一位能激励人心的领袖，同时拥有神奇的魔力可以将敌方的军队转换成自己的阵营。达克塔利必须存活才能让这场任务成功！"""
text_maasai_chief_hurt,"""达克塔利受伤了，确保他的安全！"""
text_maasai_warlord_name,"""科梭米为兹""" // Tomorrow Thief in Swahili
text_maasai_lion_name,"""狮子"""

// Scenario Info
text_scen_m1_name,"""成年礼"""
text_scen_m1_hints,"""小心的看顾巴利迪·海特利·尼亚马跟达克塔利‧邦德‧尼亚马，如果他们死去，你将会在这个任务中失败。\n\n经常存档。\n\n > 越多次要目标完成，你在下一个任务中就会有越多的增援可以选择。"""
//tx_fe_prog_EE2X_Maasai1,"""A pack of lions has been slaughtering the village's herd of cattle. Baridi Hatari Nyama, son of the Chief, must lead a small group of young men in a rite of passage. They must eliminate the threat of the lions and discover why they are suddenly causing so much trouble."""
tx_fe_prog_EE2X_Maasai1,"""一群狮子一直在屠杀这个村庄的牛群。巴利迪‧海特利‧尼亚马，酋长之子，必须领导一小群年轻人来完成成年礼。他们必须消灭狮群的威胁以及发现牠们为什么突然引起了这么多的麻烦。"""
text_scen_m1_date,"""2037年，夏季"""

// Objectives
//text_scen_m1_pobj1,"""Investigate the Lions (Placeholder Tigers used)"""
text_scen_m1_pobj1,"""研究调查狮子"""
//text_scen_m1_pobj1_description,"""Take your units and discover why the lions are very aggressive."""
text_scen_m1_pobj1_description,"""狮群正在攻击我们的牛只跟人，研究并发现为什么狮子如此的具侵犯性。"""
text_scen_m1_pobj2,"""防御马加迪！"""
text_scen_m1_pobj2_description,"""伯科尼吉的军队正在对城镇攻击！保卫它！\n\n所有的马赛军队跟建筑现在全部归你管辖。"""
text_scen_m1_pobj3,"""查出为什么伯科尼吉正在攻击"""
text_scen_m1_pobj3_description,"""我们不知道为什么伯科尼吉要攻击我们，但是我们必须查明出来。研究伯科尼吉的基地，使用武力！"""

text_scen_m1_sobj1,"""防御卡瓦非的城市"""
text_scen_m1_sobj1_description,"""伯科尼吉正在攻击我们的邻居及长期盟友卡瓦非！帮助防御他们的基地！"""

text_scen_m1_pobj4,"""消灭葛洛伯公司的防卫军"""
text_scen_m1_pobj4_description,"""葛洛伯公司的防卫军在一旁与伯科尼吉一起作战！他们看起来像是再帮伯科尼吉训练和补给来对我们作战。但是为什么呢？消灭所有葛洛伯公司在这个区域的军事单位，这将会帮助占领伯科尼吉的区域变得容易一些。"""

text_scen_m1_CapFort_short,"""占领葛洛伯公司的堡垒"""
text_scen_m1_CapFort_desc,"""葛洛伯公司弄一个堡垒在这里作甚么？为什么他们要攻击呢？\n\n摧毁葛洛伯公司的堡垒。（占领它将会获得公司的机密。）"""

text_scen_m1_KillFort_short,"""摧毁葛洛伯公司的堡垒"""
text_scen_m1_KillFort_desc,"""葛洛伯公司弄一个堡垒在这里作甚么？为什么他们要攻击呢？\n\n摧毁葛洛伯公司的堡垒。（占领它将会获得公司的机密。）"""

text_scen_m1_dobj1,"""保护巴利迪·海特利·尼亚马"""
text_scen_m1_dobj1_description,"""如果巴利迪·海特利·尼亚马死亡，你将会失败。"""
text_scen_m1_dobj2,"""保护酋长达克塔利·邦德·尼亚马"""
text_scen_m1_dobj2_description,"""如果达克塔利·邦德·尼亚马死亡，你将会失败。"""
text_scen_m1_dobj3,"""保卫你的市中心"""
text_scen_m1_dobj3_description,"""如果你的市中心被摧毁，你将会失败。"""

// Mission text
text_m1_destroy_burkeneji_base,"""这看起来像是伯科尼吉在煽动狮群来攻击我们的人民！消灭他们！"""
text_m1_reinforcments,"""增援部队已经到达堡垒。"""
text_m1_helicopter,"""葛洛伯公司的领导人正利用直升机逃亡！"""
//text_m1_build_infantry,"""With the help of Kwafi, you may now build infantry."""
text_m1_artillery,"""卡瓦非提供火炮来援助你来对抗葛洛伯公司。"""

tx_m1_captured_fort,"""你占领了堡垒！"""
tx_m1_lose_Baridi,"""巴利迪死亡！"""
tx_m1_lose_Baridi_desc,"""因为巴利迪‧海特利‧尼亚马的死亡，马赛将很快的被征服。"""
tx_m1_lose_Daktari,"""达克塔利死亡！"""
tx_m1_lose_Daktari_desc,"""没有了酋长睿智的领导，马赛人将被驱逐开他们的土地。"""


// Narration
// Intro cinematic will use above tx_fe_prog_EE2X_Maasai1
// Text for lose cinematic for hero death for all scenarios
text_maasai_cin_lose_hero,"""因为巴利迪·海特利·尼亚马的死亡，马赛将很快的被征服。""" 
// Text for lose cinematic for chief death for first 3 scenarios
text_maasai_cin_lose_chief,"""没有了酋长睿智的领导，马赛人将被驱逐开他们的土地。"""
// Text for lose cinematic (city destroyed) for this scenario
text_m1_cin_city,"""马赛村庄已经被摧毁，马赛人被驱离开他们的土地。"""
// Text for win cinematic
text_m1_cin_win,"""近来受到伯科尼吉无故的侵略，而葛洛伯公司暂时停止，但是他们一定会持续进行的…"""



