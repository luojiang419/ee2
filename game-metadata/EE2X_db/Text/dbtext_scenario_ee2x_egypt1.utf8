tx_eg_monument_khnum_name,"""献给赫努姆的纪念碑"""
tx_eg_monument_khnum_verbose,"""献给赫努姆的纪念碑\n\n赫努姆是掌管尼罗河之神，将生命带给埃及。同时他也是造物者，赫努姆由河中的泥土塑造小孩的样子，并且创造所有其它的神。"""

tx_eg_monument_horus_name,"""献给何洛斯的纪念碑"""
tx_eg_monument_horus_verbose,"""献给何洛斯的纪念碑\n\n何洛斯是天神，祂一个眼睛是太阳，另一个眼睛是月亮。"""
//,
// text_scenario_e1_verbose4,"""Collect 3000 Gold to pay for the construction of the Great Monument to Horus and Khnum."""
// text_scenario_e1_verbose5,"""Collect 2000 Stone to construct the Great Monuments to Horus and Khnum."""
// text_scenario_e1_verbose8,"""Collect an additional 1250 Gold and 750 Stone and use these resources to construct a Statue to Isis.(== @PH@ PLACEHOLDER ART FOR MONUMENT TO GOD ISIS ==to fulfill this objective, build an Outpost in the Al Minya territory where the two monuments are to be built)"""
text_scenario_e1_verbose11,"""科姆萨必须存活至亲眼看到纪念碑完成。"""
// text_scenario_e1_verbose12,"""Gather 3000 Gold and 2000 Stone - Failure to gather the necessary resources to build the monuments in time will result in a loss."""
text_scenario_e1_verbose13,"""无法于时限内完成纪念碑将会导致失败。"""
//,
tx_e1_heros_are_cool,"""你的单位可以获得经验。如果某个单位在战斗中杀了足够的敌人数量，他就有可能变成英雄！"""


//CAMP
text_scen_e1_name,"""尼夫里尔卡尔及旧王国"""
text_scen_e1_brief,""""""
text_scen_e1_victory,"""你赢了！"""
text_scen_e1_loss,"""你输了。"""
text_scen_e1_hints,""" > 利用科姆萨回复的力量－它可以改变战斗的局势！\n\n利用斥候去显露领土范围。\n\n > 赢得经济桂冠之后，选择采石功能将可以协助收集需要建造纪念碑所用的石头。\n\n > 你完成越多的次要任务，在进行下一个任务时所能选择的后援就越多。"""
text_scen_e1_history,"""这是尼夫里尔卡尔统治期间最低潮的时候。在法老王90年统治期间有了很大的进步，但是在政府里面却不稳定。区域总督把人民当做奴隶，而法老却在华丽的宫殿里面计划着他伟大的事迹。"""
text_scen_e1_desc,"""背景说明：\n\n埃及，公元前2183年。\n\n在最盛世的时候，法老尼夫里尔卡尔为了表达他对于神明的尊崇，他将要兴建纪念碑给神明。他任命了他最忠实的仆人、他的宫廷侍卫及他们的将军，科姆萨－要求他保全必要的材料来完成这个目标。\n\n解救巴哈利亚绿洲旁的当亚特矿场。击败任何挡路的敌人。"""
text_scen_e1_date,"""公元前2183年"""
text_scen_e1_pobj1,"""解放当亚特矿场"""
text_scenario_e1_verbose1,"""从盗贼威胁中将当亚特矿场解究出来\n\n将部队移动至当亚特溪谷，并且解救困在矿场内的人民。消灭所有位于当亚特的盗贼，并且重新控制矿场。"""
text_scen_e1_pobj2,"""保护矿场"""
text_scenario_e1_verbose2,"""保护矿场：将盗贼驱离金矿场及采石场，直到采集到足够开始法老王纪念碑工程所需要的数量。"""
text_scen_e1_pobj3,"""让矿场持续作业"""
text_scenario_e1_verbose3,"""法老尼夫里尔卡尔要求当亚特矿场中心要持续运作。\n\n > 保护当亚特矿场中心（堡垒）"""
// text_scen_e1_pobj4,"""Gather 3000 Gold"""
// text_scen_e1_pobj5,"""Gather 2000 Stone"""
text_scen_e1_pobj6,"""建造献给何洛斯的伟大纪念碑"""
text_scenario_e1_verbose6,"""法老尼夫里尔卡尔要在辞世之前，荣耀神明。\n\n建造献给何洛斯的伟大纪念碑。"""
text_scen_e1_pobj7,"""建造献给赫努姆的伟大纪念碑"""
text_scenario_e1_verbose7,"""法老尼夫里尔卡尔要在辞世之前，荣耀神明。\n\n建造献给赫努姆的伟大纪念碑。"""
// text_scen_e1_sobj1,"""Build the Statue of Isis"""
text_scen_e1_sobj2,"""用黄金交换市场科技"""
text_scenario_e1_verbose9,"""努比亚商人希望能够与我们分享他交易的知识。但是为了要学习他的秘密，他要求我们提供黄金做为回报。\n\n > 贡献700黄金给努比亚人以解开市场科技。"""
text_scen_e1_sobj3,"""消灭黑色太阳"""
text_scenario_e1_verbose10,"""消灭附近黑色太阳盗贼之后，我们可以确保这个纪念碑和平的进行兴建。法老尼夫里尔卡尔已经宣布，当这个认务完成的时候，他将会给我们一大笔奖赏以感谢我们的辛劳。\n\n > 摧毁盗贼营地。\n（消灭在马图上的黑色太阳建筑及部队）"""
text_scen_e1_lobj1,"""科姆萨必须存活。"""
// text_scen_e1_lobj2,"""Stone & Gold"""
text_scen_e1_lobj3,"""纪念碑必须在时限内完成。"""

tx_e1_combined_objective_title,"""建造献给神明的纪念碑"""
tx_e1_combined_objective,"""矿场再次于埃及的英明领导下可以让法老尼夫里尔卡尔觉得高兴。现在要在尼夫里尔卡尔辞世之前，建立一个献给神明的纪念碑。\n\n建立献给何洛斯的伟大纪念碑。\n > 建立献给赫努姆的伟大纪念碑"""
tx_e1_miner_blurb,"""矿工：%COUNT%"""


