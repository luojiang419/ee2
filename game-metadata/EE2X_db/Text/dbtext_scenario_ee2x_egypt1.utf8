tx_utn_cmpgnKemsa_sname,"""科姆萨领袖战役"""
tx_e1_kemsa_display,"""科姆萨"""
tx_e1_kemsa_display_p,"""科姆萨"""
tx_e1_kemsa_vtt,"""科姆萨是法老尼夫里尔卡尔选为继承人的人选。他战斗英勇，而且也能激励部队像他一样的英勇。"""
