//CAMP
text_scen_e2_name,"""在戴尔塔上的黑色太阳"""
text_scen_e2_brief,""""""
text_scen_e2_victory,"""你赢了！"""
text_scen_e2_loss,"""你输了。"""
text_scen_e2_hints,""" > 利用科姆萨回复的力量－它可以改变战斗的局势！\n\n > 试着获得旗帜或是最高领袖来协助加速资源及单位的生产。\n\n > 你完成越多的次要任务，在进行下一个任务时所能选择的后援就越多。"""
text_scen_e2_history,"""根据传说，尼夫里尔卡尔是埃及第六朝代最后的统治者，事实上他也是古埃及学者称为第一中间时期前古王国最后一个伟大的统治者。尼夫里尔卡尔的统治期间长达94年（有些埃及学者认为是64年），这是也是在古埃及历史上最长的统治期间。他6岁的时候就已经接受加冕，而且一直活到100岁。"""
text_scen_e2_desc,"""背景说明：\n\n埃及，公元前2182年－现在他的纪念碑已经完成，尼夫里尔卡尔宣誓要清理黑色太阳的土地。黑色太阳一族是由邪恶暴君阿卡特所领导的盗贼王国。\n阿卡特在伟大的赫拉克莱奥波利坦城市后山上建立了防御良好的阵地。你必须歼灭他们并杀掉阿卡特，以回复和平及繁荣给戴尔塔。\n\n > 消灭盗贼领袖阿卡特。"""
text_scen_e2_date,"""公元前2182年"""
text_scen_e2_pobj1,"""消灭阿卡特"""
text_scen_e2_pobj2,"""摧毁所有黑色太阳城市"""
text_scen_e2_pobj3,"""摧毁黑色太阳军事建筑"""
text_scen_e2_sobj1,"""将谷仓填满"""
text_scen_e2_sobj2,"""与巴拉卡建立同盟"""
text_scen_e2_sobj3,"""防御何洛斯神殿"""
text_scen_e2_lobj1,"""科姆萨必须存活"""
text_scen_e2_lobj2,"""赫拉克莱奥波利坦必须存在"""
