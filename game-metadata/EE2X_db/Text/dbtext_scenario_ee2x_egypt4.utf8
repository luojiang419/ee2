tx_eg_monument_pyramid_name,"""大金字塔"""
tx_eg_monument_pyramid_verbose,"""大金字塔\n\n尼夫里尔卡尔的大型陵寝。它是由金字塔文字及保护死人的咒语所覆盖。尼夫里尔卡尔的大金字塔有数百个咒语，比任何一个地方都要来得多。"""

tx_eg_crocodile_name,"""鳄鱼"""
tx_eg_crocodile_verbose,"""鳄鱼\n\n一个巨大的攻城机，由黑色太阳的建筑师所设计。"""
tx_eg_crocodile_name_scen,"""埃及鳄鱼战役"""

tx_eg_EgyptFortress_name,"""坚固的堡垒"""
// tx_eg_EgyptFortress_sname,"""Hardened Fortress"""
tx_eg_EgyptFortress_verbose,"""坚固的堡垒\n\n一个大型的堡垒，坚固的足以抵抗正常的攻击。只有鳄鱼可以对这个超级堡垒造成损害！"""
tx_eg_EgyptFortress_scen,"""埃及坚固堡垒战议"""
