// EXAMPLE: text_scenario_russian5_killed,"""Your leader has been killed!"""

tx_r5_blank,""""""

text_scen_r5_name,"""解放"""
text_scen_r5_victory,"""你赢了！"""
text_scen_r5_loss,"""你输了。"""
text_scen_r5_hints,"""> 越快取得联合的帮助将会越大。\n\n> 派遣间谍来监视拿破仑重整势力的速度。\n\n> 在这个剧情中亚历山大可以成为最高领导人，请确认好好的利用这个情况优势。\n\n> 你现在可以前进到工业时期，请好好的利用新的单位跟建筑。"""
text_scen_r5_history,"""拿破仑用了四十万大军攻打俄国，结果在离开时只剩下了一万人。当他退败回巴黎重整他的军队时，欧洲就爆开了一股反法国势力的革命。当亚历山大带领俄军攻进欧洲时，普鲁士跟奥地利便同时对法宣战，结束了拿破仑帝国的美梦。"""
text_scen_r5_desc,"""解放。\n\n欧洲。1813年3月 - \n\n当法国军队被击退回法国并请开始重建重组时，亚历山大派遣他的军队继续追击。当俄国人向法国挺进时，其它像是普鲁士或是奥地利随即开始起义反抗法国的统治，并且与沙皇结盟。法国皇帝很快的招募并且训练了一支新的大军，让新联盟了解到他们必须重新并且快速的再次击败法国来解决一切。俄国必须赶快击败法军以免拿破仑的势力再次变得过度庞大起来。\n\n>加速你在欧洲的脚步并且迅速占领区域，以免拿破仑恢复了他的力量。"""
text_scen_r5_date,"""1813"""



//cinematic
tx_r5_intro1,"""战败的法国军队撤退到法国进行重新集结及重整之后，亚历山大将他的军队开往欧洲进行追击。"""
tx_r5_intro2,"""当俄国军队到达法国时，其它的国家，像是普鲁士及奥地利，也同时起义反抗法国的统治，并与沙皇联合同盟。"""
tx_r5_intro3,"""法国皇帝很快的重新征召及训练了一批强大的军队，不过同盟国知道他们必须要快速且果断一次就彻底打败拿破仑。"""
tx_r5_intro4,"""俄国必须在拿破仑再次变强之前尽快打败法国。"""
tx_r5_win1,"""欧洲从拿破仑的暴政中解放出来。如果没有俄国人民的牺牲及沙皇亚历山大的英明领导，是不可能有这样的成功。对于欧洲的国家来说，似乎未来终于见到了光明。而对于前法国皇帝来说，他已经要前往厄尔巴岛…这只是时间的问题。"""
tx_r5_lose1,"""我们的沙皇战死在战场，现在已经没有人可以领导俄国来抵御拿破仑的攻击！"""
tx_r5_lose2,"""保卫华沙的任务失败，你将失去祖国的支持，亚历山大的势力很快将瓦解。"""
tx_r5_lose3,"""俄在欧洲占领领土的举动受到普鲁士和澳大利亚的警告，俄国将无法持续战争。"""

//==OBJECTIVE TEXT== ; used in ddf
tx_r5_paris,"""占领巴黎"""
tx_r5_paris_desc,"""你必须击败拿破仑来迫使法国投降，你同时必须占领或是摧毁巴黎来让法国签订投降协议。"""
tx_r5_napoleon,"""击败拿破仑"""
tx_r5_napoleon_desc,"""你必须击败拿破仑来迫使法国投降，你同时必须占领或是摧毁巴黎来让法国签订投降协议。"""


//SECONDARY
tx_r5_prussia_ally,"""解放普鲁士人"""
tx_r5_prussia_ally_desc,"""占领布兰登堡并将它贡献给普鲁士人，他们将会帮助你对抗拿破仑。"""
tx_r5_austria_ally,"""解放奥地利人"""
tx_r5_austria_ally_desc,"""占领维也纳并将它贡献给奥地利人，他们将会帮助你对抗拿破仑。"""


//LOSE
tx_r5_defend_alexander,"""亚历山大被杀害"""
tx_r5_defend_alexander_desc,"""如果沙皇在战争中被杀害，便代表了俄罗斯的混乱。"""
tx_r5_defend_warsaw,"""保卫华沙"""
tx_r5_defend_warsaw_desc,"""如果华沙市中心被占领或是摧毁，你将会从俄国被切断并且被摧毁。"""
tx_r5_tread_lightly,"""太多的区域。"""
tx_r5_tread_lightly_desc,"""在任何时候如果俄国占领了超过三个区域，使得欧洲势力开始猜忌俄国的意图。如果不马上归还这些区域，将会阻碍亚历山大的传奇来击败拿破仑。"""


// end obj txt
