text_scen_tut2_pobj13A,"""完成前哨站附近的城墙"""
text_scen_tut2_buildFortress,"""在城门附近建造堡垒"""
text_scen_tut2_buildFortress1,"""建造1座堡垒"""
text_scen_tut2_selectWonder,"""选择你的世界奇观"""
text_scen_tut2_selectWonder1,"""选择特诺克蒂特兰大金字塔。"""
