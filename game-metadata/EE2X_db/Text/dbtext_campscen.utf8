text_scen_tut2_pobj15A,"""靠你的步兵攻下一个敌方的城市中心"""
text_scen_tut2_createPatrol,"""建立一条巡逻路线"""
text_scen_tut2_createPatrol1,"""用你的枪兵建立一条巡逻路线"""
text_scen_tut2_convertUnit,"""煽动一个敌人单位变节"""
text_scen_tut2_convertUnit1,"""用你的祭司煽动一个敌人单位变节"""
text_scen_tut2_sobj1,"""建造一座桥梁"""
text_scen_tut2_sobj2,"""将城墙升级为城塔"""
