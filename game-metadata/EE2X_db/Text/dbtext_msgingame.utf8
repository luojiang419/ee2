// These work like so:  there are AMT and RES pairs, where AMT gets substituted with an amount and RES gets substituted
// with the name of a resource.  so %AMT1% %RES1% will come out to something like "500 Gold".
msg_ig_dip_tribute_sent1,"""你已经成功的把%AMT1%%RES1%的贡品送给%PLAYER%。"""
msg_ig_dip_tribute_rcvd1,"""你已经从%PLAYER%手中收到%AMT1%%RES1%的贡品。"""
msg_ig_dip_tribute_sent2,"""你已经成功的把%AMT1%%RES1%和%AMT2%%RES2%的贡品送给%PLAYER%。"""
msg_ig_dip_tribute_rcvd2,"""你已经从%PLAYER%手中收到%AMT1%%RES1%和%AMT2%%RES2%的贡品。"""
msg_ig_dip_tribute_sent3,"""你已经成功的把%AMT1%%RES1%，%AMT2%%RES2%和%AMT3%%RES3%的贡品送给%PLAYER%。"""
msg_ig_dip_tribute_rcvd3,"""你已经从%PLAYER%手中收到%AMT1%%RES1%，%AMT2%%RES2%和%AMT3%%RES3%的贡品。"""
msg_ig_dip_tribute_sent4,"""你已经成功的把%AMT1%%RES1%，%AMT2%%RES2%，%AMT3%%RES3%和%AMT4%%RES4%的贡品送给%PLAYER%。"""
msg_ig_dip_tribute_rcvd4,"""你已经从%PLAYER%手中收到%AMT1%%RES1%，%AMT2%%RES2%，%AMT3%%RES3%和%AMT4%%RES4%的贡品。"""
msg_ig_dip_tribute_sent5,"""你已经成功的把%AMT1%%RES1%，%AMT2%%RES2%，%AMT3%%RES3%，%AMT4%%RES4%和%AMT5%%RES5%的贡品送给／%PLAYER%。"""
msg_ig_dip_tribute_rcvd5,"""你已经从%PLAYER%手中收到%AMT1%%RES1%，%AMT2%%RES2%，%AMT3%%RES3%，%AMT4%%RES4%和%AMT5%%RES5%的贡品。"""
msg_ig_dip_tribute_sent6,"""你已经成功的把%AMT1%%RES1%，%AMT2%%RES2%，%AMT3%%RES3%，%AMT4%%RES4%，%AMT5%%RES5%和%AMT6%%RES6%的贡品送给%PLAYER%。"""
