// NAME,TEXT
msg_ingame_donotuse,"""零式入口－不要使用"""

// Building Capture chat messages,
// 'You have captured a <building type> from <player name>.',
msg_ingame_capture_self,"""你已经从%PLAYER%手中攻下%BUILDING%。"""
// <player name> has captured a <building type> from you.',
msg_ingame_capture_other,"""%PLAYER%已经从你手中抢下%BUILDING%。"""

// 'You have captured the hill from <player name>.',
msg_ingame_capture_KOTH_self,"""您已经占领了%PLAYER%的山丘。"""
// player captured hill from the world (first capture)
msg_ingame_capture_KOTH_w_self,"""您已经占领了山丘。"""
// <player name> has captured the hill from you.',
msg_ingame_capture_KOTH_other,"""%PLAYER%已经占领了您的山丘。"""
// '<player name> has captured the hill.' -- broadcast to all 3rd parties
msg_ingame_capture_KOTH_others,"""%PLAYER%已经占领了山丘。"""


//
// special capture messages for [allied] capitols victory condition
// these message names follow this format msg_ingame_<capturer>_capitol_<msg-reader>
// where capturer and msg-reader are [self | ally | enemy]
// notice that only as subset of combinations are necessary to keep players "adequately" up to date.
//
// ---- player captures own capitol from enemy ----
msg_ingame_self_capitol_self,"""你已经从%ENEMY%手中夺回你的首都！"""
msg_ingame_self_capitol_enemy,"""%PLAYER%从你手中夺回了他的首都！"""
// ---- player captures ally's capitol from enemy ----
msg_ingame_ally_capitol_self,"""你从%ENEMY%手中占领了一座首都，并且将它还给你的盟友%ALLY%！"""
msg_ingame_ally_capitol_ally,"""%PLAYER%从%ENEMY%手中占领了一座首都，并且将它还给你！"""
msg_ingame_ally_capitol_enemy,"""%PLAYER%从你手中占领了一座首都，并且将它还给了他的盟友%ALLY%！"""
// ---- player captures enemy's capitol ----
msg_ingame_enemy_capitol_self,"""你已经占领了%ENEMY%的首都！"""
msg_ingame_enemy_capitol_enemy,"""%PLAYER%已经占领了你的首都！你有%MINUTES%分钟的时间可以将之夺回，否则便算失败！"""


// 'We have seized valuable resources from <player name>.';
msg_ingame_capture_loot_robber, """我们已经从%PLAYER%手中夺取了宝贵的资源。"""
// 'One of our buildings has been captured and looted by <player name>.'
msg_ingame_capture_loot_victim, """我们的一栋建筑物已经被%PLAYER%攻占，并掠夺一空。"""
msg_ingame_capture_tech_robber,"""我们从%PLAYER%那里抢到了科技。"""
// 'The enemy is capturing one of our buildings, loyalty there has faded to X%'
msg_ingame_capture_progress, """敌人正在攻占我们的一栋%BUILDING%，忠诚度降为%LOYALTY%\\\\%"""
msg_ingame_capture_KOTH_prog, """敌人从你手中夺走了山丘，忠诚度已经降为%LOYALTY%\\\\%"""

// you are under attack messages,
msg_ingame_under_attack,"""你正受到攻击！"""

// you have been defeated message
msg_ingame_you_defeated,"""你已经被消灭了！"""

// player has been defeated message
msg_ingame_player_defeated,"""%PLAYER%已经被消灭了！"""

