// sole-survivor messages

// message for when there are only two un-allied players left in the game
msg_ingame_sole_survivor_na,"""你和%PLAYER%是这场游戏的残存者。彻底摧毁%PLAYER%就可以取得胜利！"""

// for maximal localization factor, we enumerate every number of allies that can be left in the game... ugh.
// message for when there's 1 other allied player left in the game
msg_ingame_sole_survivor1,"""你和%P1%是这场游戏最后的幸存者。你们之间的同盟将会在%N%秒后中止。彻底摧毁%P1%就可以获得胜利！"""
// message for when there's 2 other allied player left in the game
msg_ingame_sole_survivor2,"""你、%P1%和%P2%是这场游戏最后的幸存者。你们之间的同盟将会在%N%秒后中止。彻底摧毁%P1%and%P2%就可以取得胜利！"""
msg_ingame_sole_survivor3,"""你、%P1%、%P2%和%P3%是这场游戏最后的幸存者。你们之间的同盟将会在%N%秒后中止。彻底摧毁%P1%、%P2%和%P3%就可以取得胜利！"""
msg_ingame_sole_survivor4,"""你、%P1%、%P2%、%P3%和%P4%是这场游戏最后的幸存者。你们之间的同盟将会在%N%秒后中止。彻底摧毁%P1%、%P2%、%P3%和%P4%就可以取得胜利！"""
msg_ingame_sole_survivor5,"""你、%P1%、%P2%、%P3%、%P4%和%P5%是这场游戏最后的幸存者。你们之间的同盟将会在%N%秒后中止。彻底摧毁%P1%、%P2%、%P3%、%P4%和%P5%就可以取得胜利！"""
msg_ingame_sole_survivor6,"""你、%P1%、%P2%、%P3%、%P4%、%P5%和%P6%是这场游戏最后的幸存者。你们之间的同盟将会在%N%秒后中止。彻底摧毁%P1%、%P2%、%P3%、%P4%、%P5%和%P6%就可以取得胜利！"""
msg_ingame_sole_survivor7,"""你、%P1%、%P2%、%P3%、%P4%、%P5%、%P6%和%P7%是这场游戏最后的幸存者。你们之间的同盟将会在%N%秒后中止。彻底摧毁%P1%、%P2%、%P3%、%P4%、%P5%、%P6%和%P7%就可以取得胜利！"""
msg_ingame_sole_survivor8,"""你、%P1%、%P2%、%P3%、%P4%、%P5%、%P6%、%P7%和%P8%是这场游戏最后的幸存者。你们之间的同盟将会在%N%秒后中止。彻底摧毁%P1%、%P2%、%P3%、%P4%、%P5%、%P6%、%P7%和%P8%就可以取得胜利！"""
msg_ingame_sole_survivor9,"""你、%P1%、%P2%、%P3%、%P4%、%P5%、%P6%、%P7%、%P8%和%P9%是这场游戏最后的幸存者。你们之间的同盟将会在%N%秒后中止。彻底摧毁%P1%、%P2%、%P3%、%P4%、%P5%、%P6%、%P7%、%P8%和%P9%就可以取得胜利！"""
msg_ingame_sole_survivor10,"""你、%P1%、%P2%、%P3%、%P4%、%P5%、%P6%、%P7%、%P8%、%P9%和%P10%是这场游戏最后的幸存者。你们之间的同盟将会在%N%秒后中止。彻底摧毁%P1%、%P2%、%P3%、%P4%、%P5%、%P6%、%P7%、%P8%、%P9%和%P10%就可以获得胜利！"""
msg_ingame_sole_survivor11,"""你、%P1%、%P2%、%P3%、%P4%、%P5%、%P6%、%P7%、%P8%、%P9%、%P10%和%P11%是这场游戏最后的幸存者。你们之间的同盟将会在%N%秒后中止。彻底摧毁%P1%、%P2%、%P3%、%P4%、%P5%、%P6%、%P7%、%P8%、%P9%、%P10%和%P11%就可以取得胜利！"""
msg_ingame_sole_survivor12,"""你、%P1%、%P2%、%P3%、%P4%、%P5%、%P6%、%P7%、%P8%、%P9%、%P10%、%P11%和%P12%是这场游戏最后的幸存者。你们之间的同盟将会在%N%秒后中止。彻底摧毁%P1%、%P2%、%P3%、%P4%、%P5%、%P6%、%P7%、%P8%、%P9%、%P10%、%P11%和%P12%就可以取得胜利！"""
msg_ingame_sole_survivor13,"""你、%P1%、%P2%、%P3%、%P4%、%P5%、%P6%、%P7%、%P8%、%P9%、%P10%、%P11%、%P12%和%P13%是这场游戏最后的幸存者。你们之间的同盟将会在%N%秒后中止。彻底摧毁%P1%、%P2%、%P3%、%P4%、%P5%、%P6%、%P7%、%P8%、%P9%、%P10%、%P11%、%P12%和%P13%就可以取得胜利！"""
msg_ingame_sole_survivor14,"""你、%P1%、%P2%、%P3%、%P4%、%P5%、%P6%、%P7%、%P8%、%P9%、%P10%、%P11%、%P12%、%P13%和%P14%是这场游戏最后的幸存者。你们之间的同盟将会在%N%秒后中止。彻底摧毁%P1%、%P2%、%P3%、%P4%、%P5%、%P6%、%P7%、%P8%、%P9%、%P10%、%P11%、%P12%、%P13%和%P14%就可以取得胜利！"""
msg_ingame_sole_survivor15,"""你、%P1%、%P2%、%P3%、%P4%、%P5%、%P6%、%P7%、%P8%、%P9%、%P10%、%P11%、%P12%、%P13%、%P14%和%P15%是这场游戏最后的幸存者。你们之间的同盟将会在%N%秒后中止。彻底摧毁%P1%、%P2%、%P3%、%P4%、%P5%、%P6%、%P7%、%P8%、%P9%、%P10%、%P11%、%P12%、%P13%、%P14%和%P15%就可以取得胜利！"""

