msg_ig_dip_tribute_sent7,"""你已经成功的把%AMT1%%RES1%，%AMT2%%RES2%，%AMT3%%RES3%，%AMT4%%RES4%，%AMT5%%RES5%，%AMT6%%RES6%和%AMT7%%RES7%的贡品送给%PLAYER%。"""
