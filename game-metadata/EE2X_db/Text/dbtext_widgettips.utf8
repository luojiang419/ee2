vtt_unitact_nestedAttackAndMove,"""打开攻击与移动指令的子选单"""
vtt_unitact_buildCivilian,"""开启建造平民建筑物的子选单。"""
vtt_unitact_buildMilitary,"""开启建造军事建筑物的子选单。"""
vtt_unitact_buildMore,"""开启建造新版本建筑物的子选单。"""
vtt_unitact_research,"""打开此建筑物中有关研发的子选单。"""
vtt_unitact_buildAircraft,"""开启建造飞机的子选单。"""
vtt_unitact_produceMore,"""开启生产更多的子选单。"""
vtt_unitact_back,"""回到此单位的主选单。"""

vtt_unitact_market_buy,"""购买此项资源。"""
vtt_unitact_market_sell,"""卖掉这项资源。"""

vtt_unitact_move,"""移到指定地点，和按下滑鼠右键的效果一样。"""
vtt_unitact_attack,"""攻击任何敌对目标。按下Alt+鼠标左键可以强制攻击任何可攻击的目标。"""
vtt_unitact_attackMove,"""移到指定地点，然后沿路上攻击所有敌人单位，和同时按下Ctrl+鼠标右键的效果一样。"""
vtt_unitact_attackGroup,"""攻击一群目标单位，和同时按下Alt+Ctrl+鼠标右键的效果一样。"""
vtt_unitact_attackType,"""攻击目标单位，设定你的单位优先攻击你所点选的那一种单位。"""
vtt_unitact_buildRepair,"""修护一个受损的建筑物，或是协助建造一座施工中的建筑物。"""
vtt_unitact_gather,"""采集资源\n\n移到指定地点并采集资源。"""
vtt_unitact_unpack,"""强迫单位保持组装状态。"""
vtt_unitact_pack,"""取消部队的组装动作，这样一来，单位只会在需要时才会进行组装动作。"""
vtt_unitact_emergency,"""命令在此区的所有人民在堡垒中驻扎。如果堡垒中没有多余栏位可驻扎的话，人民将会驻扎到城市中心里。"""
vtt_unitact_allClear,"""命令所有回应警报的人民从驻扎地点离开，并回到原先的工作岗位上。"""
vtt_unitact_guard,"""命令单位守卫另一个单位。"""
vtt_unitact_explore,"""命令单位探勘地图。"""
vtt_unitact_stop,"""命令该单位停止所有动作。"""
vtt_unitact_captureBuilding,"""命令该单位占领敌人的建筑物。"""
vtt_unitact_capturingBuilding,"""该建筑物已被敌人部队占领。"""
vtt_unitact_convertUnit,"""命令单位使敌方单位变节。"""
vtt_unitact_searchDestroy,"""命令此单位搜寻最靠近的敌人单位或是建筑物，然后展开攻击。"""
vtt_unitact_towerUpgrade,"""将一坐标准的城塔升级成能向射程内的敌人目标开火的城塔。"""
vtt_unitact_makeGate,"""将一段城墙升级成城门。"""
vtt_unitact_lockGate,"""锁定城门后，任何单位就无法通过了。"""
vtt_unitact_unlockGate,"""解除锁定城门可让友军单位自由通过这道门。"""
vtt_unitact_Patrol,"""命令该单位沿着特定的路线巡逻，巡逻中的单位会与射程内的任何敌人单位交战，但不会离开他们的巡逻路线太远。"""
vtt_unitact_attackGround,"""命令单位对着指定的地面位置发射武器。"""
vtt_unitact_launchICBM,"""向某特定地点发射洲际导弹。"""
vtt_unitact_ungarrison,"""将所有驻扎单位从建筑物内移除。"""
vtt_unitact_garrison,"""命令单位驻扎在建筑物内。"""
vtt_unitact_unload,"""将所有单位由运输船内移除，并且把他们放置到指定的地点。"""
vtt_unitact_setRally,"""所有在此建筑物里生产的单位会自动移动到此集结点。"""
vtt_unitact_renameCity,"""按下此钮可重新命名你的城市中心。"""
vtt_unitact_cycleBuildQueue,"""切换生产顺序\n\n在所需的资源足够的情况下，循环目前的生产顺序。"""
vtt_unitact_trade,"""建立商路\n\n此举可让你指定贸易单位的起点和终点。"""
vtt_renameTerritory,"""按下此钮可重新命名你的地区。"""
vtt_stance_button,"""按下此钮可以设定某单位的行为模式。"""
vtt_stance_Aggressive,"""设定为攻击模式的单位会攻击任何进入视野范围内的敌人，除非自己或是敌人被摧毁，否则不会罢手。"""
vtt_stance_Defensive,"""当你的单位处于防守模式时，他们会对着进入视野范围的敌人开火，但是不会追出一开始接触的区域。用来防守重要建筑物时很好用。"""
vtt_stance_HoldPosition,"""当你的单位处于固守模式时，他们只会对着进入射程的敌人开火，他们不会往敌人的位置移动或是追击。"""
vtt_stance_HoldFire,"""当你的单位处于停火模式时，不会攻击也不会移动。"""
vtt_stance_Cautious,"""当你的单位处于谨慎模式时，他们不会进攻，而且遇到敌军时一定会撤退。"""
vtt_formation_button,"""按下此按钮可以设定此单位的队形。"""
vtt_formation_column,"""纵队是小组沿着马路或穿越狭窄地区移动时的最理想队形，但并不是有效的战斗队形。"""
vtt_formation_Phalanx,"""方阵队形是经典的防御队形，可提供有效的防护。"""
vtt_formation_StaggeredLine,"""交错阵队形很适合用在尝试闪避掉广域武器攻击的单位。"""
vtt_formation_DoubleLine,"""双行队形将近战单位放置在前方，远距离单位放置在后方。这种队形可以有效的阻挡企图通过山路的单位。"""
vtt_formation_Wedge,"""楔形队形主要是用来突破敌军的队形，队形中装甲最厚重的单位是位于楔形的尖端。"""
vtt_formation_Horn,"""犄角队形对于要接近重兵防守地区或是要攻击具有强大广域杀伤力的敌人的单位非常有用，犄角队形尝试将敌人包围起来，并且将伤害减到最低，火力增到最大。"""
vtt_formation_Circle,"""圆形队形主要是要来保护目标的，在此队形中的部队会以被保护的目标为中心，组成一个朝外的圆形。"""
vtt_formation_Bowed,"""弓形队形是个很好的保守型攻击队形，它将重单位集中在前方和中间，轻型和快速单位则放在侧翼，支援和火砲单位则是放在后方的中央，以取得相对的保护。"""
vtt_formation_FlyingV,"""飞行V队形可增加群组内的有效视野范围，并且增加他们摧毁任何目标的机率。最适合用在执行空中巡逻作战的战斗机上。"""
vtt_formation_Spear,"""长矛队形是用来让群组中所有飞机的所有炸弹／火砲集中在一个单一目标上。"""
vtt_formation_Pyramid,"""金字塔队形是有效率的轰炸机队形，可让炸弹分布在投掷区上，对目标进行有效的地毯式轰炸。"""
vtt_formation_Line,"""横列队形对所有由舷侧开火的船舰是很有效率的，这个队形会立刻尝试同时转向以舷侧面对敌舰。"""
vtt_formation_Crescent,"""新月队形最适合用在早期的船舰上，他们会尝试同时让愈多愈好的船舰投入作战，以砲火包围敌人舰队。"""
vtt_formation_Convoy,"""如果你需要保护其他船只，护航是相当好的队形。被保护的船只会被负责护航的船舰包围在中间。"""
vtt_formation_Blockade,"""封锁队形会尝试在敌人的港口外排列成双行，其中一行会将砲口对准港口，另一行会将砲口对准海上，以防被偷袭。"""

// specialty airport/aircraft carrier unit actions,
tt_airmission_mission,"""设定任务旗帜"""
tt_airmission_cancel,"""取消任务"""
tt_airmission_launch,"""新增飞机至任务"""
tt_airmission_returnToBase,"""回到基地"""
tt_airmission_scramble,"""紧急起飞"""
tt_airplane_returnToBase,"""回到基地"""
vtt_airmission_mission,"""设定任务旗帜\n\n要放置任务旗帜，请点选这个图示，在世界里每按一下鼠标左键就可放置任务旗帜路线的一个导航点，按一下鼠标右键即可完成路线。任何受命执行任务的飞机都会飞往这个任务旗帜。"""
vtt_airmission_cancel,"""取消任务\n\n替飞机重设任务旗帜即可取消任务，按下图示。"""
vtt_airmission_launch,"""新增飞机至任务\n\n一旦你将旗帜放到这个世界，即可选择你想指派任务的飞机，并在该按钮上按下滑鼠左键。此按钮所拥有的自动启动功能将会被预设为开启，而且会自动指定任务给在机场内的任何飞机。这可以利用在此按钮上点击鼠标右键来切换为开启/关闭。"""
vtt_airmission_returnToBase,"""回到基地\n\n选择飞机，再于该图示上面按下滑鼠左键，即可命令这架飞机飞回基地。"""
vtt_airmission_scramble,"""紧急起飞\n\n这可以命令你目前在机场上的所有飞机紧急起飞。"""
vtt_airplane_returnToBase,"""回到基地\n\n选择飞机，再于该图示上面按下滑鼠左键，即可命令这架飞机飞回基地。"""

// Epoch inicator
tt_epoch_normal,"""%EPOCHNAME%(%EPOCH%/%FINALEPOCH%)"""
tt_epoch_last,"""%EPOCHNAME%(%EPOCH%/%FINALEPOCH%)"""
tt_epoch_cantafford,"""晋升至%NEXTEPOCHNAME%(第%NEXTEPOCH%纪元)\n成本：<color red>%TECH%科技点数</color>"""
tt_epoch_advance,"""晋升至%NEXTEPOCHNAME%(第%NEXTEPOCH%纪元)\n成本：%TECH%科技点数"""
tt_epoch_advancing,"""正在晋升至%NEXTEPOCHNAME%(第%NEXTEPOCH%纪元)..."""
vtt_epoch_normal,"""%EPOCHNAME%(%EPOCH%/%FINALEPOCH%)\n当你已研发出%NUMTECHS%项科技，合乎晋升到下一个纪元的条件时，这就会变成一个按钮，让你晋升到下一个纪元。"""
vtt_epoch_last,"""%EPOCHNAME%(%EPOCH%/%FINALEPOCH%)\n你已经达到此游戏最终的纪元。"""
vtt_epoch_cantafford,"""晋升至%NEXTEPOCHNAME%(第%NEXTEPOCH%纪元)\n成本：<color red>%TECH%科技点数</color>"""
vtt_epoch_advance,"""晋升至%NEXTEPOCHNAME%(第%NEXTEPOCH%纪元)\n成本：%TECH%科技点数"""
vtt_epoch_advancing,"""正在晋升至%NEXTEPOCHNAME%(第%NEXTEPOCH%纪元)..."""

// Button bar,
tt_optionsbutton,"""游戏选项"""
tt_chatbutton,"""交谈"""
tt_encyclopediabutton,"""百科全书"""
tt_objectivesbutton,"""剧本目标"""
tt_pausebutton,"""PAUSE"""
vtt_optionsbutton,"""按下此钮可以叫出游戏选项面板，这些选项有储存游戏、记录游戏、重新开始游戏（仅用于单人游戏）、放弃、载入游戏、游戏设定、离开游戏以及回到桌面。"""
vtt_chatbutton,"""按下此钮可以叫出交谈选单，传送讯息给其他的玩家。"""
vtt_encyclopediabutton,"""按下此钮可叫出世纪争霸百科全书，在世纪争霸百科全书中你会找到所有的相关知识。"""
vtt_objectivesbutton,"""按下此钮可以显示剧本目标画面。剧本简报、背景故事与所有的目标都会详细列在此处。"""
vtt_pausebutton,"""点选这个按钮来暂停/继续游戏。"""

// dash buttons
tt_bottombutton_flare,"""信号弹"""
tt_bottombutton_idlecit,"""闲置人民"""
tt_bottombutton_megamap,"""全荧幕地图"""
tt_bottombutton_territories,"""地区"""
tt_bottombutton_mm_warplans,"""切换目前作战计划"""
tt_bottombutton_mm_listenUp,"""切换协同作战"""
tt_bottombutton_techtree,"""科技树"""
tt_bottombutton_diplomacy,"""外交"""
tt_bottombutton_warplans,"""作战计划"""
