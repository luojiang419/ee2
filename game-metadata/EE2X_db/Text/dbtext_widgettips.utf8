tt_techtree_icon_fwd,"""观看下一个纪元"""

tt_techtree_military,"""军事科技"""
tt_techtree_economic,"""经济科技"""
tt_techtree_cultural,"""文化科技"""
tt_techtree_imperial,"""帝国科技"""
tt_techtree_progress,"""纪元进度(%PERCENT%\\\\%)"""

