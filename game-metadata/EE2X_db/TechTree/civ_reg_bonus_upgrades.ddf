//This holds the upgrades used to give Civilization and Regional Traits and Bonuses as well as some custom
//trait upgrades.
//Each Civ and Regions has its own entry which is a set of upgrades to call.  The upgrade
//set is called as an upgrade from a tech tree node with the node define as region or civ 
//specific

////////////////////////////////////////////////////
//  Below are some special custom civ and regional bonus upgrades
//
//

//If the player captures a city center, temple, or university from antoher player
//they get 20% of that player's tech points
UpgradeCivRegBonus RegionalTraitUpgrade_WE_04 {
	//NON-Modifiable parameters
	onAction = Capture;	

	//Modifiable parameters
	unitTypes = ["Temple" "University"];
	resourceType = Tech;
	amount = 10.0;	//percent of other player's
}

//Whenever the player builds a wonder, they get enough techpoints to be able to advance to
//the next epoch.  
UpgradeCivRegBonus RegionalTraitUpgrade_ME_04 {
	//NON-Modifiable parameters
	onAction = BuiltWonder;

	//Modifiable Parameters
	amount = 100.0;  	//Percentage scale factor of how much of the tech points to actually give
				//the player when the wonder is built
}

UpgradeCivRegBonus RegionalTraitUpgrade_AM_04 {
	//NON-Modifiable parameters
	onAction = Convert;

	//Modifiable Parameters
	resourceType = Tech;	//which resource to add
	amount = 3.0;		//Base amount for conversion.  A percentage of this amount will
				//be used based on the epoch difference between the players involved
	amount2 = 25.0;		//Percent per epoch difference, only when converting a unit of later epoch
}

UpgradeCivRegBonus RegionalTraitUpgrade_FE_01 {
	//NON-Modifiable parameters
	onAction = EpochAdvance;
}

UpgradeCivRegBonus RegionalTraitUpgrade_AF_03 {
	//Non-Modifiable parameters
	onAction = ExtraBuildings;

	//Modifiable Parameters
	unitTypes = [ "Fortress" "Temple" ];	// You get extra buildings when you build/capture one of these
	stringData = House;						// You get this when you build a special building
	amount = 2.0;							// You get this many extra buildings of the specified type
	amount2 = 10.0;							// The extra buildings take this long to automatically build.
}

UpgradeCivRegBonus CivUpgr_SpecRes_Cost {
	//Non-Modifiable parameters
	onAction = CostModification;

	//Modifiable Parameters
	amount = 0.0;		//basic resource cost modification
	amount2 = -10.0;	//special resource cost modification
}


/////////////////////////////////////////////////////////////////////////
//
//   List of Upgrades to perform by region 
//
//   Called as result of tech tree node
////////////////////////////////////////////////////////////////////////

//
// ******************* Western ******************
//
UpgradeRefSet Traits_Regional_WE {
	upgrades = [
			RegionalTraitUpgrade_WE_01
			RegionalTraitUpgrade_WE_02
			RegionalTraitUpgrade_WE_03
			RegionalTraitUpgrade_WE_04
	]
}

//
// ****************** Middle East ***********************
//
UpgradeRefSet Traits_Regional_ME {
	upgrades = [
		RegionalTraitUpgrade_ME_01
		RegionalTraitUpgrade_ME_02
		RegionalTraitUpgrade_ME_03
		RegionalTraitUpgrade_ME_04
	]
}

//
// ****************** Far East *********************
//
UpgradeRefSet Traits_Regional_FE {
	upgrades = [
		RegionalTraitUpgrade_FE_04
		RegionalTraitUpgrade_FE_02
		RegionalTraitUpgrade_FE_03
		RegionalTraitUpgrade_FE_01
	]
}

//
// ********************** Meso-American *********************
//
UpgradeRefSet Traits_Regional_AM {
	upgrades = [
		RegionalTraitUpgrade_AM_01
		RegionalTraitUpgrade_AM_02
		RegionalTraitUpgrade_AM_03
		RegionalTraitUpgrade_AM_04
	]
}

//
// ********************** African *********************
//

// We want to add some special "glows" to city centers and warehouses
// These effects are essentially UI-only.  They have no effect on gameplay.
// Other upgrades handle the gameplay aspect.
UpgradeEffects CityCenterAddFoodBonusGlow
{
	unitType = CityCenter
	effectsToAdd = [ AfricanFoodDropoffGlow ]
}
UpgradeEffects WarehouseAddFoodBonusGlow
{
	unitType = Warehouse
	effectsToAdd = [ AfricanFoodDropoffGlow ]
}


UpgradeRefSet Traits_Regional_AF {
	upgrades = [
		RegionalTraitUpgrade_AF_01
		RegionalTraitUpgrade_AF_02
		RegionalTraitUpgrade_AF_03	
		RegionalTraitUpgrade_AF_04
		CityCenterAddFoodBonusGlow
		WarehouseAddFoodBonusGlow
	]
}

