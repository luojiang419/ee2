Scenario EE2X_Kursk_Russia {
	name = txt_kursk_name_russia
	mapfilename = "EE2X_Kursk.scn"
	overrideScriptLib = "ScriptLibs_EE2X\\\\EE2X_Kursk_Russia.dll"
