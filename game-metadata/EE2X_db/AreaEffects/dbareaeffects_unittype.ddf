			range = Unit
			GlowType = Bad
			OwnerOnly = false
			Icon = spr_game_unitinfo_icon_contam
			Tooltip = tt_power_ToxicSick
			VTooltip = vtt_power_unitinfo_ToxicSick
		}
	]
}


