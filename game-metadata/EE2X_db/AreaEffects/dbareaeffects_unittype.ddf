// Repair Herc can cast a shield
DbAreaEffectInfo HERC_Shield
{
	button = "unit_power_shield" // see dbunitactions.csv
	selectionType = Unit
	// if requireSelection,
	// then maskSelection and playerSelection should also be specified
	// they are used to determine who valid targets of this super effect are
	maskSelection = AllHercs
	playerSelection = Self
	
	mouseCursor = HercShield
	mouseCursorInvalid = HercShield_Invalid
	
	// the shield lasts this long
	effects = [
		EffectShield {
			instant = true
			player = Self
			range = Unit	
			mask = LandRPS
			radius = 2
			
			// absorb 1000 points of damage before we go away
			hitPoints = 200
			
			// HERC shield lasts one minute max
			duration = 10
			visualName = "HERC_Shield"
		}
	]
}

// EMP blast area effect
DbAreaEffectInfo HERC_EMP_blast
{
	disableDuringCeasefire = true
	
	name = tt_power_emp
	button = unit_action_EMP
	
	mouseCursor = HercEMP
	mouseCursorInvalid = HercEMP_Invalid
	
	selectionType = Location
	//selectionType = Unit
	//maskSelection = EMP_targets_ground_air
	playerSelection = NotTheWorld

	// units are disabled for this long
	// NOTE:  this duration should match that of the other HERC_EMP_blast effects
	duration = 120
	
	effects = [
		
		EffectExplode
		{
			range = Unit
			
			instant = true // just a one-shot thinger
			
			explosionName = Expl_emp01
			
			// this will make the effect send a (unit) hit list
			// to the explosion visuals containing units described by
			// the parameters below
			hitRadius = 5
			hitMask = EMP_targets_ground
			hitPlayerMode = NonSelf
			
		}
		
		// NOTE:  air units are not frozen in place (ground units are)
		EffectImmobilize
		{ 
			range = RadiusFromLocation 
			radius = 5
			mask = LandRPS
			player = NonSelf	
			updateOnce = 1		// so that only units in the area initially gets affected
		}

		EffectPreventAttack
		{ 
			range = RadiusFromLocation 
			radius = 5
			mask = LandRPS
			player = NonSelf	
			updateOnce = 1		// so that only units in the area initially gets affected
		}	
				
		EffectVisualGlow {
			range = RadiusFromLocation 
			radius = 5
			mask = LandRPS
			player = NonSelf	
			updateOnce = 1	// so that only units in the area initially gets affected
			GlowType = Bad
			OwnerOnly = false
			Icon = icon_power_emp
			Tooltip = tt_power_EMP
			VTooltip = vtt_power_unitinfo_EMP
		}		
	]
}

