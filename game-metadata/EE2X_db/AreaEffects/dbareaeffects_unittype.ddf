DbAreaEffectInfo TankNoConversion
{
	selectionType = None
	effects = [
		EffectNoConversion {
			range = RadiusFromUnit 
			radius = 3
			mask = SubjectToConversion
			player = Self
		}
		EffectVisualGlow {
			range = RadiusFromUnit 
			radius = 3
			mask = SubjectToConversion
			player = Self
			GlowType = Good
			OwnerOnly = true
			Icon = icon_crown_fanaticism_s
			Tooltip = tt_power_Fanaticism
			VTooltip = vtt_power_unitinfo_Fanaticism
		}
		
	]
}
