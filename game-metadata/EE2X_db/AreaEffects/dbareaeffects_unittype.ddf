	effects = [
		// this sub-effect must be present (and first)
		// to identify this area effect as "gather intelligence"
		EffectGatherIntel {
			range = Unit
			time = 5 // how long to gather intelligence?
			stateName = "GatherIntel"
			playerEffectName = "GatherIntelligencePlayer"
			instant = true
			
			// if the spy gathers intel from a city center
			// then crown status of the player owning that center
			// will be visible to the spies player for this long
			intelSourceDuration = 300
		}
	]
}


// Units that SpyCanContaminate get this attached to them when ToxicSpill activated,
// infects nearby units that ContaminationCanSicken with ToxicSickness
DbAreaEffectInfo ToxicSpill
{
	disableDuringCeasefire = true
	
	name = tx_uarea_ToxContam_name
	desc = tx_uarea_ToxContam_desc
	button = "unit_power_contaminate" // see dbunitactions.csv
	selectionType = Unit
	// if requireSelection,
	// then maskSelection and playerSelection should also be specified
	// they are used to determine who valid targets of this super effect are
	maskSelection = SpyCanContaminate
	playerSelection = Enemies
	
	mouseCursor = Contaminate
	mouseCursorInvalid = Contaminate_Invalid
	
	// infected units are contagious for this long
	duration = 40
	
	effects = [
		// this sub-effect must be present (and first)
		// to identify this area effect as toxic contamination
		EffectContaminate {
			range = Unit
			time = 5		// how long to contaminate?
			
			stateName = "Contaminate"
		}

		EffectInfect {
			// what kind of units
			range = RadiusFromUnit
			player = Self
			Mask = ContaminationCanSicken
			radius = 4
			// what to infect exposed units with
			EffectName = "ToxicSickness"
		}

		EffectVisualGlow {
			//SuppressGlow = true // don't show the glow
			range = Unit
			GlowType = Bad
			OwnerOnly = false
			Icon = spr_game_unitinfo_icon_contam
			Tooltip = tt_power_ToxicSpill
			VTooltip = vtt_power_unitinfo_ToxicSpill
		}		
	]
}

// Units that SpyCanContaminate get this attached to them when ToxicSpill activated,
// infects nearby units that ContaminationCanSicken with ToxicSickness
