// adds grey glow to dudes that are going to be blessed
DbAreaEffectInfo BlessPreviewGlow
{
	effects = [
		EffectVisualGlow {
			range = RadiusFromLocation
			radius = 2 // should match radius in Bless.EffectAttack below
			mask = LandRPS
			player = Self
			GlowType = Neutral
			OwnerOnly = true
			
			// this effect wants to be updated at a higher
			// frequency, to make the glows responsive to mouse movement
			period = 0.2
		}
	]
}

// this is the effect that does the actual bless simulation effects
DbAreaEffectInfo Bless
{	
	name = text_uarea_bless_name
	desc = text_uarea_bless_desc
	button = "unit_power_bless"

	selectionType = Unit
	mouseCursor = Bless
	mouseCursorInvalid = Bless_Invalid
	MouseRadius = 2 // should match radius in EffectAttack below

	maskSelection = LandRPS
	playerSelection = Self
	
	HighlightAreaEffect = BlessPreviewGlow
	
	// the blessing wears off after this many seconds
	duration = 10
	
	effects = [
		// this sub-effect must be present (and first)
		// to identify this area effect as bless
		EffectBless {
			range = Unit
			time = 4 	// how long does it take to bless?
			stateName = "bless"
		}
		
		EffectRepeat {
			range = RadiusFromUnit
			radius = 2 // actual radius of the bless effect
			player = Self
			mask = LandRPS
			effectName = "BlessUnits"
		}		
	]
}

