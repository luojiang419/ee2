//////////////////////////////Flag Area Effects///////////////////////////////

// Naval Flag Power
DbAreaEffectInfo NavalPower
{
	name = text_farea_navalpower_name
	desc = text_farea_navalpower_desc

	mouseCursor = FlagNaval
	mouseCursorInvalid = FlagNavalInvalid

	effects = [
	
		// decrease built time for military vessels by 15%
		EffectProductionTime {
			range = Unit
			player = Self
			affected = MilitaryNavalUnits
			scale = 0.85
		}

		// decrease cost of military vessels by 15%
		EffectProductionCost {
			range = Unit
			player = Self
			affected = MilitaryNavalUnits
			scale = 0.85
		}
		
		// "glow" (suppressed) so we get sexy icon
		EffectVisualGlow {
			range = Unit
			player = Self
			SuppressGlow = 1
			GlowType = Good
			Icon = icon_flag_naval
			Tooltip = text_farea_navalpower_name
			VTooltip = text_farea_navalpower_desc
		}
	]
}


