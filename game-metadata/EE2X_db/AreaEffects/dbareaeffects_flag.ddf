{
	name = text_farea_finpower_name
	desc = text_farea_finpower_desc

	mouseCursor = FlagFinancial
	mouseCursorInvalid = FlagFinancialInvalid

	effects = [

//@TODO: trade time is halved

		// triple trade route drop-off amount
		EffectResourceTrade {
			range = Unit
			player = Self
			affected = [Gold]
			scale = 3
		}

		// decrease built time for trade units by 75%
