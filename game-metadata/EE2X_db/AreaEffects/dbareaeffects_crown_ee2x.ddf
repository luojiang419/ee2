//////////////////////////////Crown Area Effects for EE2X///////////////////////////////

// Player effect to propogate when military leader is garrisoned
DbAreaEffectInfo SuperemeLeader_Mil_GarrEffect
{
	effects = [
		// Glow on units that have improved attack
		EffectVisualGlow {
			range = Global
			mask = LandRPS
			player = Self

			GlowType = Good
			Icon = icon_crown_superspies_s
			Tooltip = text_carea_sl_mil_fervor_name
			VTooltip = vtt_carea_sl_mil_fervor
		}
		// Nearby units attack better
		EffectAttack {
			range = Global
			mask = LandRPS
			player = Self

			scale = 1.05
		}
	]
}

// Host effect to propogate when military leader is garrisoned
DbAreaEffectInfo SuperemeLeader_Mil_GarrEffectH
{
	effects = [
		EffectVisual {
			range = Unit
			player = Self

			visualEffect = SupremeLeaderGarrison_Military
			AttachWhenCulled = true
			OnlyForOwner = true
		}
	]
}

// Military Supreme leader crown effect
DbAreaEffectInfo CrownSupremeLeader_Mil
{
	name = text_carea_sl_mil_name
	desc = text_carea_sl_mil_desc
	
	selectionType = LeaderOrHero

	effects = [
		// Glow on the supreme leader
		EffectVisualGlow {
			range = Unit
			player = Self
			GlowType = SupremeLeader
			Icon = icon_crown_sleader_mil_s
			Tooltip = text_carea_sl_mil_name
			VTooltip = text_carea_sl_mil_desc
		}
		// Visual above the supreme leader
		EffectVisual {
			range = Unit
			player = Self

			visualEffect = SupremeLeaderUnit_Military
			AttachWhenCulled = true
		}
		// Nearby units attack better
		EffectAttack {
			range = RadiusFromUnit
			mask = LandRPS
			player = Self
			radius = 5

			scale = 1.10
		}
		// Glow on units that have improved attack
		EffectVisualGlow {
			range = RadiusFromUnit
			mask = LandRPS
			player = Self
			radius = 5
			GlowType = Good
			Icon = icon_crown_superspies_s
			Tooltip = text_carea_sl_mil_fervor_name
			VTooltip = vtt_carea_sl_mil_fervor
		}
		// When the supreme leader is garrisoned, propagate the effect globally
		EffectPropagateWhenGarrisoned{
			range = Unit
			HostMask = Fortress
			EffectsToPropagate = [ SuperemeLeader_Mil_GarrEffect ]
		}
		// Put a visual on the garrison host
		EffectPropagateWhenGarrisoned{
			range = Unit
			HostMask = Fortress
			EffectsToPropagate = [ SuperemeLeader_Mil_GarrEffectH ]
			AttachToGarrisonHost = true
		}
	]
}

DbAreaEffectInfo SuperemeLeader_Eco_GarrEffect
{
	effects = [
		// Global units gather faster
		EffectResourceGatherRate {
			range = Global
			mask = ResourceGatherers
			player = Self

			affectedResourceTypes = [AllNaturalResource]
			affectedResourceSources = Anything	//gather from anything

			scale = 1.05
		}
		// Glow on units gathering faster
		EffectVisualGlow {
			range = Global
			mask = ResourceGatherers
			player = Self
			GlowType = Good
			Icon = icon_crown_superspies_s
			Tooltip = text_carea_sl_eco_gather_name
			VTooltip = vtt_carea_sl_eco_gather
		}
	]
}

