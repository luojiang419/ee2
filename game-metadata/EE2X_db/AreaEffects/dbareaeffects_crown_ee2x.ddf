DbAreaEffectInfo SuperemeLeader_Imp_GarrEffect
{
	effects = [
		// Global priests and spies recharge faster
		EffectSpecialPowerRechargeTime {
			range = Global
			mask = TT_PriestSpy
			player = Self

			scale = 0.95
		}
		// Glow on priests and spies
		EffectVisualGlow {
			range = Global
			mask = TT_PriestSpy
			player = Self
			Icon = icon_crown_superspies_s
			Tooltip = text_carea_sl_imp_recharge_name
			VTooltip = vtt_carea_sl_imp_recharge
		}
		// Priests get +1 LOS 
		EffectAddLOS {
			range = Global
			mask = Priests
			player = Self

			additionalLOS = 1.0
		}
		// Priests get increased conversion range
		EffectConversionRange {
			range = Global
			mask = Priests
			player = Self

			scale = 1.10
		}
		// Glow on priets
		EffectVisualGlow {
			range = Global
			mask = Priests
			player = Self
			Icon = icon_crown_superspies_s
			Tooltip = text_carea_sl_imp_LOSRange_name
			VTooltip = text_carea_sl_imp_LOSRange
		}
	]
}

