// Imperial Supreme leader crown effect
DbAreaEffectInfo CrownSupremeLeader_Imp
{
	name = text_carea_sl_imp_name
	desc = text_carea_sl_imp_desc
	
	selectionType = LeaderOrHero

	effects = [
		// Supreme leader glow
		EffectVisualGlow {
			range = Unit
			player = Self
			GlowType = SupremeLeader
			Icon = icon_crown_sleader_imp_s
			Tooltip = text_carea_sl_imp_name
			VTooltip = text_carea_sl_imp_desc
		}
		// Visual above the supreme leader
		EffectVisual {
			range = Unit
			player = Self

			visualEffect = SupremeLeaderUnit_Imperial
			AttachWhenCulled = true
		}
		// Nearby priests and spies recharge faster
		EffectSpecialPowerRechargeTime {
			range = RadiusFromUnit
			radius = 7
			mask = TT_PriestSpy
			player = Self

			scale = 0.8
		}
		// Glow on priests and spies
		EffectVisualGlow {
			range = RadiusFromUnit
			radius = 7
			mask = TT_PriestSpy
			player = Self
			Icon = icon_crown_superspies_s
			Tooltip = text_carea_sl_imp_recharge_name
			VTooltip = vtt_carea_sl_imp_recharge
		}
		// Nearby units may not be converted
		EffectNoConversion {
			range = RadiusFromUnit
			radius = 7
			mask = SubjectToConversion
			player = Self
		}
		// Glow on convertable units
		EffectVisualGlow {
			range = RadiusFromUnit
			radius = 7
			mask = SubjectToConversion
			player = Self
			Icon = icon_crown_superspies_s
			Tooltip = text_carea_sl_imp_loyalty_name
			VTooltip = vtt_carea_sl_imp_loyalty
		}
		// When the supreme leader is garrisoned, propagate the effect globally
		EffectPropagateWhenGarrisoned{
			range = Unit
			HostMask = Fortress
			EffectsToPropagate = [ SuperemeLeader_Imp_GarrEffect ]
		}
		// Put a visual on the garrison host
		EffectPropagateWhenGarrisoned{
			range = Unit
			HostMask = Fortress
			EffectsToPropagate = [ SuperemeLeader_Imp_GarrEffectH ]
			AttachToGarrisonHost = true
		}
	]
}
