	pageLayout = eee_layout_tinfo
	pageTOC = eee_contents_unittype_sidebar
	elems = [
		// top non tiling widgets
		{widgetName = eee_tinfo_header; text = tx_eee_camp_main_title;}
		{widgetName = eee_tinfo_intro; text = tx_eee_camp_intro;}
		// tiled widgets
		{widgetName = eee_tinfo_titletop; text = tx_eee_camp_title1; }
		{widgetName = eee_tinfo_bodytop; text = tx_eee_camp_body1; }
		{widgetName = eee_tinfo_title; anchorToPrev = PrevCreated; text = tx_eee_camp_title2; }
		{widgetName = eee_tinfo_body; text = tx_eee_camp_body2; }
		{widgetName = eee_tinfo_title; indexCopy = 1; anchorToPrev = PrevCreated; text = tx_eee_camp_title3; }
		{widgetName = eee_tinfo_body; indexCopy = 1; text = tx_eee_camp_body3; }
		{widgetName = eee_tinfo_title; indexCopy = 2; anchorToPrev = PrevCreated; text = tx_eee_camp_title4; }
		{widgetName = eee_tinfo_body; indexCopy = 2; text = tx_eee_camp_body4; }
		{widgetName = eee_tinfo_title; indexCopy = 3; anchorToPrev = PrevCreated; text = tx_eee_camp_title5; }
		{widgetName = eee_tinfo_body; indexCopy = 3; text = tx_eee_camp_body5; }
		{widgetName = eee_tinfo_title; indexCopy = 4; anchorToPrev = PrevCreated; text = tx_eee_camp_title6; }
		{widgetName = eee_tinfo_body; indexCopy = 4; text = tx_eee_camp_body6; }
	]
}

