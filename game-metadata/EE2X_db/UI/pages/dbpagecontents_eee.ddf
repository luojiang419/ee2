	pageLayout = eee_layout_utmain
	pageTOC = eee_contents_unittype_sidebar 
	elems = [
	]
}

// Test page
PageContents eee_contents_test {
	pageLayout = eee_layout_test
	pageTOC = eee_contents_unittype_sidebar 
	elems = [
		{widgetName = eee_test_texttop; text = text_rarea_citadel_desc;}
		{widgetName = eee_test_text; text = text_rarea_cloning_desc;}
		{widgetName = eee_test_text; indexCopy = 1; anchorToPrev = PrevName; text = text_rarea_tribcust_desc;}
		{widgetName = eee_test_icon; indexCopy = 1; sprite = spr_eee_butt_fwd;}
		{widgetName = eee_test_text; indexCopy = 2; anchorToPrev = PrevName; text = text_rarea_favorofgods_desc;}
		{widgetName = eee_test_icon; indexCopy = 2; sprite = spr_eee_butt_back;}
	]
}

