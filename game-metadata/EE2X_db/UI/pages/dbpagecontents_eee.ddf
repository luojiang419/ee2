// Page contents for the Empire Earth Encyclopedia

// Test sidebar
PageContents eee_contents_unittype_sidebar {
	pageLayout = eee_layout_sidebartext
	retainOnArgChange = 1
	elems = [
		{widgetName = eee_sidebar_list; tooltip = tx_eee_sidebar_units;}
	]
}

// Home page
PageContents eee_contents_home {
	pageLayout = eee_layout_home
	pageTOC = eee_contents_unittype_sidebar
}

// Unit Type
PageContents eee_contents_unittype {
	pageLayout = eee_layout_unittype
	pageTOC = eee_contents_unittype_sidebar 
	elems = [
	]
}

