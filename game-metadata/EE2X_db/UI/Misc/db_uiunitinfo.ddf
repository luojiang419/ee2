/////////////////////////////////////////////////////
//
// meters
//

UnitInfoMeter HealthMeter
{
	tooltip 	= tt_unitinfo_health
	verboseTooltip 	= vtt_unitinfo_health
	colors		= [ red, yellow, green ]
	format		= CurrentMax
	tooltipFormat	= CurrentMaxMod
}

UnitInfoMeter PowerMeter
{
	icon		= spr_game_unitinfo_icon_power
	tooltip 	= tt_unitinfo_power
	verboseTooltip 	= vtt_unitinfo_power
	colors		= [ medBlue, blue ]
	tooltipFormat	= Percent
}

