tx_utn_rus_univer_sname,"""俄罗斯的大学"""
tx_utn_rus_univer_name,"""大学"""
vtt_unit_RussianUniversity,"""一栋专门研究进阶知识的建筑。让人民驻扎在大学里面可以生产科技点数。生产间谍。"""

tx_utn_Napoleon_name,"""拿破仑·波拿巴"""
tx_utn_Napoleon_pname,"""拿破仑家族"""
tx_utn_Napoleon_sname,"""拿破仑·波拿巴"""
vtt_unit_Napoleon,"""拿破仑·波拿巴。一位伟大的军事家。"""

tx_utn_Alexander_name,"""亚历山大·罗曼诺夫"""
tx_utn_Alexander_pname,"""亚历山大家族"""
tx_utn_Alexander_sname,"""亚历山大·罗曼诺夫"""
vtt_unit_Alexander,"""亚历山大·罗曼诺夫。一位伟大的苏联沙皇。"""

tx_utn_RuscityCenter_name,"""俄罗斯市中心"""
tx_utn_RuscityCenter_sname,"""俄罗斯市中心"""
vtt_unit_RusCityCenter,"""这是俄罗斯城市的焦点同时也是资源的集散地。围绕在市中心的四周有下列的好处：修补任何被损坏的单位、并提高被占领单位的反抗能力。人民、斥侯及领袖单位由市中心生产， 同时可以驻防来提升资源生产的能力。"""

tx_utn_Cossack_name,"""哥萨克骑士"""
tx_utn_Cossack_pname,"""哥萨克骑士"""
tx_utn_Cossack_sname,"""哥萨克骑士"""
vtt_unit_Cossack,"""俄罗斯的哥萨克骑士是勇猛的骑兵。行动快速又强健，这些轻骑乘单位在对抗轻火砲单位及重骑乘单位时有攻击优势。"""

tx_utn_ImperialGuard_name,"""帝国警卫军"""
tx_utn_ImperialGuard_pname,"""帝国警卫军"""
tx_utn_ImperialGuard_sname,"""帝国警卫军"""
vtt_unit_ImperialGuard,"""帝国的警卫由拿破仑的菁英部队中挑选组成。这些重步兵在对抗轻骑乘单位及轻砲兵单位时拥有攻击优势。"""

tx_utn_Conscript_name,"""征召兵员"""
tx_utn_Conscript_pname,"""征召兵员"""
tx_utn_Conscript_sname,"""征召兵员"""
vtt_unit_Conscript,"""俄国的征召兵员从祖国的人力中征调过来，虽然训练并非良好，但是这些重步兵还是在对抗轻骑乘及轻火砲单位上有攻击的优势。"""






