VaporizerDef TheVaporizerDef
{
	SpecularTargetColor = [255, 255, 0, 0]
	ShininessTarget = 0.001
	SpecularFadeTime = 0.1
	SpecularFadeType = QuadFastStart

	PeakTime = 0.1

	AlphaFadeTime = 0.2
	AlphaFadeType = QuadSlowStart
	FadeTargetAlpha = 0.0
	FadeTargetColor = [13, 13, 13, 0]
}

CameraShakeDef NukeShakeDef
{
	ExpandTime = 5
	ExpandDistance = 40
	ExpandType = Linear

	FarMultiplier = 0.1
	MultiplierType = QuadFastStart

	Duration = 2
	StartAmplitudeX = 0.5
	StartAmplitudeY = 0.5
	StartAmplitudeZ = 0.7

	XFadeType = QuadSlowStart
	YFadeType = QuadSlowStart
	ZFadeType = QuadFastStart
}

