

// SUPREME LEADERS
// Effects to attach to a fortress when the supreme leader is garrisoned.
BaseModel	SupremeLeaderGarrison_Imperial
{
	ModelFileName 	= fx_supreme_imperial.nif
	DeletionMode	= eNEVER	
	UseTopOfParent = true
	Offset = [ 0.0 0.0 1.0] // X Y Z
	RotateOffsetWithParent = true
}

