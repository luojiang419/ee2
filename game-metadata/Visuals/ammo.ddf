// =======================================================
//  Base Ammunition Type
// =======================================================

UnitType Ammo
{
	PlacementType = Unplaceable
	
	properties {
		// uses projectile move type
		moveType = kUnitMoveType_Projectile
		FootprintType = Ellipse
		}

	abilities [
		ProjectileMissileMove { type = RegularProjectile; speed = 6 }
		PayloadAttack { }
	]
}

// =======================================================
//  Base Ammunition Type2
// =======================================================

UnitType Ao_Cluster
{
	PlacementType = Unplaceable
	
	properties {
		// uses projectile move type
		moveType = kUnitMoveType_Projectile
		FootprintType = Ellipse
		}

	abilities [
		ProjectileMissileMove { type = ICBM; speed = 10;accel = 6; angSpeed = 180 }
		Attack { }
	]
}

//=========================================================
// Arrow
//=========================================================
StateDatabase ArrowStates
{
	DefaultModel 	= fx_arrow.nif
	DefaultState 	= Idle
	States = [
		{	
			StateName="Idle" 
			TextKeys = []
		}
		{ 
			StateName = Death 	
			TextKeys = [ { Name = HIDE_VISUAL	Data = MainModel } ] 
		}
		]
}

CompositeModel Arrow
{
	ScaleType 			= kScaleAmmo
	StateDatabaseName 	= ArrowStates
	ChildNames 		= [ ArrowStreak ]
}

UnitType Arrow
{
	Parent = Ammo
	properties {
		SizeX = 0.35
		SizeY = 0.35
		mass = 0
		hitpoints = 1
	}
	abilities [
		ProjectileMissileMove { type = RegularProjectile; speed = 8 }
		PayloadAttack { weaponType = LightProjectile }
	]
}

StateDatabase ArrowStates_BreathOfDragon
{
	DefaultModel 	= fx_arrow.nif
	DefaultState 	= Idle
	States = [
		{	
			StateName="Idle" 
			TextKeys = []
		}
		{ 
			StateName = Death 	
			TextKeys = [ { Name = HIDE_VISUAL	Data = MainModel } ] 
		}
		]
}

