//Do not add this effect in any ddf file.  This effect is added in the code
WavesArray		TheWavesArray {}



// Add to non-mobile units that want to have a nice shadow
ShadowData        BuildingShadow
{
	Flags = (UseStencil | AutoGenerated)
}

// for buildings with turrets
ShadowData        BuildingWithTurretsShadow
{
	Flags = (UseStencil | AutoGenerated | HasTurret)
}

// Add to mobile units for a blobby ellipsoid shadow
ShadowData        UnitShadow
{
	Flags = (UseStencil | IsMobile)

	FlatBillboard
	{
		TextureFilename = TreeShadow.tga
		WidthScale = 0.9
		LengthScale = 0.9
		HeightScale = 0.1
	}
}

// Dynamic stencil shadow only (no projected shadow)
// for use on mobile units, like tanks, that don't look good with 
// a blobby ellipsoid shadow
ShadowData        MobileStencilShadow
{
	Flags = (UseStencil | IsMobile)
}


// Wall shadow; enabled only when stencil shadows are used
ShadowData        WallShadow
{
	Flags = (UseStencil | SkipAlpha)
}

