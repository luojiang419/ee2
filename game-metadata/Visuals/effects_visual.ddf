//display a domage effect on a building
BldDamageEffect		TheBldDamageEffect
{ 
	TagDefs = [
			{
				TagName = "front"
				Models = [ { ModelName = fx_damage_fire_1.NIF ModelScale = 0.05 }
						   { ModelName = fx_damage_fire_2.NIF ModelScale = 0.05 }
						 ]
			}
			{
				TagName = "corner"
				Models = [ { ModelName = fx_damage_fire_1.NIF ModelScale = 0.05 }
						   { ModelName = fx_damage_fire_2.NIF ModelScale = 0.05 }
						 ]
			}
			{
				TagName = "top"
				Models = [ { ModelName = fx_damage_fire_1.NIF ModelScale = 0.05 }
						   { ModelName = fx_damage_fire_2.NIF ModelScale = 0.05 }
						 ]
			}
		]
	FireDataClassName = Building_fire
	SmokeDataClassName = Building_smoke
	UseHitPointThreshold = 0
	HitPointThreshold = 0
	
	// dynamic lights
	FireLights = [ DL_Fire1 DL_Fire2 DL_Fire3 DL_Fire4 DL_Fire5 DL_Fire6 ]
}

