//
// @NOTE:
// Shimmer visual names are code critical;
// if you change the name here without changing MsgIDs.h, things will break.
//

// Shimmer effect used by spy
VisualShimmerDC		SpyShimmer
{
	// how opaque does unit appear when shimmer is disabled
	disabledOpacity = 1.0
	// how opaque does unit appear to friendly eyes (when in disguise)
	friendlyOpacity = 0.3
	// how opaque does unit appear to enemy eyes (when in disguise)
	enemyOpacity = 0.0
	// what is the  opacity pulse amplitude?
	opacityPulseAmplitude = 0.2
	// what is the  opacity pulse wavelength?
	opacityPulseWavelength = 4.0

	// how fast does  opacity blend?
	opacityBlendRate = 0.1
	// how fast does  pulse amplitude blend?
	amplitudeBlendRate = 0.1
	//  emissive color is driven by opacity for friendly eyes
	friendlyEmissiveFactor = 1.0
}
// Shimmer effect used by Plane
VisualShimmerDC		PlaneShimmer
{
	// how opaque does unit appear when shimmer is disabled
	disabledOpacity = 1.0
	// how opaque does unit appear to friendly eyes (when in disguise)
	friendlyOpacity = 0.3
	// how opaque does unit appear to enemy eyes (when in disguise)
	enemyOpacity = 0.0
	// what is the  opacity pulse amplitude?
	opacityPulseAmplitude = 0.2
	// what is the  opacity pulse wavelength?
	opacityPulseWavelength = 4.0

	// how fast does  opacity blend?
	opacityBlendRate = 0.1
	// how fast does  pulse amplitude blend?
	amplitudeBlendRate = 0.1
	//  emissive color is driven by opacity for friendly eyes
	friendlyEmissiveFactor = 1.0
}
// Shimmer effect used by phantom formation in Diversion leader power
VisualShimmerDC		DiversionShimmer
{
	// how opaque does unit appear when shimmer is disabled
	disabledOpacity = 0.0
	// how opaque does unit appear to friendly eyes
	friendlyOpacity = 0.5
	// how opaque does unit appear to enemy eyes
	enemyOpacity = 1.0
	// what is the  opacity pulse amplitude?
	opacityPulseAmplitude = 0.2
	// what is the  opacity pulse wavelength?
	opacityPulseWavelength = 2.0

	// how fast does  opacity blend?
	opacityBlendRate = 0.1
	// how fast does  pulse amplitude blend?
	amplitudeBlendRate = 0.1
	//  emissive color is driven by opacity for friendly eyes
	friendlyEmissiveFactor = 0.4
}

// Shimmer effect used by "The Lost City" Wonder power
VisualShimmerDC		LostCityShimmer
{
	lostCityMode = true
	
	// how opaque does unit appear when shimmer is disabled
	disabledOpacity = 0.5
	// how opaque does unit appear to friendly eyes
	friendlyOpacity = 0.5
	// how opaque does unit appear to enemy eyes
	enemyOpacity = 0.0
	// what is the  opacity pulse amplitude?
	opacityPulseAmplitude = 0.2
	// what is the  opacity pulse wavelength?
	opacityPulseWavelength = 4.0

	// how fast does  opacity blend?
	opacityBlendRate = 0.1
	// how fast does  pulse amplitude blend?
	amplitudeBlendRate = 0.1
	//  emissive color is driven by opacity for friendly eyes
	friendlyEmissiveFactor = 0.4
}



