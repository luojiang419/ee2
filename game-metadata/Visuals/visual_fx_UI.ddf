//---------------------------------------------------------------------------
// Definitions for "UI" visual effects.  This includes things like health
// bars and selection circles.
//---------------------------------------------------------------------------

//---------------------------------------------------------------------------
// HEALTH BARS
//---------------------------------------------------------------------------
HealthBar 		TheHealthBar 
{
	verticalOffset = 0.25;

	StartingLevel = 1.0;

	colorLow = [255,0,0,255]
	colorMed = [255,255,0,255]
	colorHigh = [0,255,0,255]

	// MSG_HITPOINT
	UpdateMsg = "HitPointChange";
	FlashMsg = "HealthBar_HealFlash";

	FlashWhenHealing = true;
	FlashTexture = health_heal_flash.tga;
	FlashDuration = 1;
	FlashAlphaMax = 1;
	FlashAlphaMid = 0.5;
	FlashAlphaRate = 1.5;
}

HealthBar 		ThePowerBar 
{
	verticalOffset = 0.19;

	StartingLevel = 0.001;

	colorLow = [0,0,255,255]
	colorMed = [0,0,255,255]
	colorHigh = [0,0,255,255]

	// MSG_POWERRESERVE
	UpdateMsg = "PowerReserveChange";
}

HealthBar 		TheAmmoBar 
{
	verticalOffset = 0.19;

	StartingLevel = 1.0;

	colorLow = [0,0,255,255]
	colorMed = [0,0,255,255]
	colorHigh = [0,0,255,255]

	// MSG_POWERRESERVE
	UpdateMsg = "AmmoReserveChange";
}


HealthBar 		TheResistanceBar 
{
	verticalOffset = 0.13;
	StartingLevel = 1.0;
	
	colorLow = [150,16,16,255]
	colorMed = [200,32,32,255]
	colorHigh = [255,32,32,255]

	// MSG_RESISTANCE
	UpdateMsg = "ResistanceChange";
}

