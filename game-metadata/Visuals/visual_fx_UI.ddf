// Visual for showing the destinations of units when they are ordered to move.
DestinationIndicator TheDestinationIndicator
{
	ClickIndicator = fx_destination_indicator_click.tga
	ClickColor = [255 255 100 255]
	ClickIndicatorScale = 0.15
	UnitIndicator = fx_destination_indicator.tga
	UnitColor = [0 255 0 255]
	TimeDur = 0.2
	TimeFade = 0.2
	OrientIndicator = fx_destination_indicator_orient.tga
	OrientIndicatorScale = 1
}

