////////////////////////////
// @EE2X flag for hero army
RallyFlag 	TheHeroArmyFlag
{
	FlagModel		= fx_hero_flagpole.nif
	BaseFlagTexture		= fx_hero_flag01.tga
	//DarkFlagTexture 	= fx_RallFlag_01.tga
	//TagPoint		= tag_flag_hero
	FlagTag1		= "tag_hero_flag_1"
	FlagTag2		= "tag_hero_flag_02"
	physicalHeight		= 3.2
	VerticalFlag		= 1
	GravityMult		= 0.6
	WindMult		= 0.3
	SpringTensionMult	= 2.5
	SpringDampingMult	= 3.0
	DragCoefficientMult	= 2.5
	Scale			= 1.5
	StartHidden		= 1
	FaceCameraRotateZ	= 1
	UseTopOfParent		= 1
	Offset			= [ 0.0, 0.0, 0.5 ]
	RotateOffsetWithParent	= 0
}


