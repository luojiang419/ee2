// normal rally point visual
RallyPoint	TheRallyFlag
{ 
	FlagVisualScaleType 	= kScaleBuilding  
	FlagVisual 		= TheRallyPointFlag
}

// air-mission rally point visuals (@HACK should all start with "TheAirmissionFlag"...)
RallyPoint	TheAirmissionFlag
{ 
	FlagVisualScaleType 	= kScaleBuilding  
	FlagVisual 		= TheRallyPointFlag
}
RallyPoint	TheAirmissionFlag_Mobile
{
	FlagVisualScaleType 	= kScaleBuilding  
	FlagVisual 		= TheRallyPointFlag
	MobileParent		= 1
}

// Visual for the patrol path.
PatrolPath		ThePatrolPath 
{
	WaypointVisualScaleType = kScaleBuilding
	WaypointVisual 		= ThePatrolPointMarker
}

// visuals for queued order paths
