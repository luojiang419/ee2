//--------------------------------------------------------------------------
//	Glows (for units/buildings affected by special powers)
//--------------------------------------------------------------------------
GlowEffect SmallGlow
{
	GoodGlowName = glow_good.tga
	GoodGlowScale = 0.5

	BadGlowName = glow_bad.tga
	BadGlowScale = 0.5

	MixedGlowName = glow_both.tga
	MixedGlowScale = 0.5
	
	NeutralGlowName = glow_neutral.tga
	NeutralGlowScale = 0.5
	
	KingGlowName = glow_king.tga
	KingGlowScale = 0.4

	HeroArmyGlowName = glow_HeroArmy.tga
	HeroArmyGlowScale = 0.25

	HeroArmyLeaderGlowName = glow_HeroArmyLeader.tga
	HeroArmyLeaderGlowScale = 0.25

	SupremeLeaderGlowName = glow_supremeleader.tga
	SupremeLeaderGlowScale = 0.25

	PulseMaxMult = 1.15
	PulseMinMult = 0.95

	PulseMaxAlpha = 150
	PulseMinAlpha = 75
}

