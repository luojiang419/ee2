//---------------------------------------------------------------------------
// Decals to be placed under buildings and other units that need them.
//---------------------------------------------------------------------------

//	char*							StateName;
//	// these arrays are the same size, they contain the epoch number and the corresponding sprite to use
//	LSizedArray<int>				EpochNumberForSprites;
//	LSizedArray<DBINDEX(DbSprite)>	RuralSpriteNames;		
//	LSizedArray<DBINDEX(DbSprite)>	UrbanSpriteNames;		
//	float							FadeOutTime;	// time to fade out
//	float							WorldSize;

Decal UnderAirport
{
	DefaultState = Idle
	States	= [
	          {
			StateName = Idle  
			RuralSpriteNames = [ under_airport_3_r under_airport_3_r under_airport_3_r] 
			UrbanSpriteNames = [ under_airport_3_u under_airport_3_u under_airport_3_u]

		  }
		  {
			StateName = Death  
//			RuralSpriteNames = [ under_airport_3_r_d under_airport_3_r_d under_airport_3_r_d] 
//			UrbanSpriteNames = [ under_airport_3_u_d under_airport_3_u_d under_airport_3_u_d]
			RuralSpriteNames = [ under_airport_3_r under_airport_3_r under_airport_3_r] 
			UrbanSpriteNames = [ under_airport_3_u under_airport_3_u under_airport_3_u]
			FadeOutTime = 10 
   			StartFadeDelay = 10

		}
		  ]
}

Decal	UnderFarm
{
	DefaultState = Idle
	States	= [ 
		{ 
			StateName = Idle  		
			RuralSpriteNames = [ under_farm under_farm under_farm ]
			UrbanSpriteNames = [ under_farm under_farm under_farm ]
		}
		{ 
			StateName = Death 
			RuralSpriteNames = [ under_farm under_farm under_farm ]
			UrbanSpriteNames = [ under_farm under_farm under_farm ]
			FadeOutTime		= 6 
			StartFadeDelay	= 1
		}
		  ]
}

