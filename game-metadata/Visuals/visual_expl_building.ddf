ExplosionSequence	sq_collapse_Big_1
{
	BoundingSphereRadius = 1
	TimeA = 0.1
	TimeB = 0.6
	DelayBeforeDie = 5
	StartingPositionMinX = -3
	StartingPositionMaxX = 3
	StartingPositionMinY = -3
	StartingPositionMaxY = 3
	StartingPositionMinZ = 0
	StartingPositionMaxZ = 0
	StartFromMainModel = 1
	FiringProbability = 1
	Replay = 7
	SequenceType = Nif
	SequenceNames = [ fx_Smoke_BuildingCollapse.nif]
	SequenceWorldScales = [0.03]
}

//------------------------------------------------------------------------------------
// EXPLOSION
//------------------------------------------------------------------------------------

Explosion			Expl_Building_01
{
	BoundingSphereRadius = 1
	ExplosionSequences =	[ s_building_debris ]
	VelocityOn = 0
	VelocityAngle = 0
	SpeedMin = 0
	SpeedMax = 0
	GravityOn = 0
}

Explosion			Expl_Building_Collapse_Tiny
{
	BoundingSphereRadius = 1
	ExplosionSequences =	[  sq_collapse_Tiny_1 ]
	VelocityOn = 0
	VelocityAngle = 0
	SpeedMin = 0
	SpeedMax = 0
	GravityOn = 0
}

