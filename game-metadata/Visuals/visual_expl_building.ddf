}

//------------------------------------------------------------------------------------
// EXPLOSION MAPPER
//------------------------------------------------------------------------------------
ExplosionSelector	ExplSelectorBuild_Tiny
{
	ExplosionDescriptors =	[
								{
									BoundingSphereRadius = 1
									Weapon = (MediumProjectile | Missile | Beam)
									Trigger = DynamicMessage
									MessageName = HitPosition
									ExplosionName = Expl_Building_01
									HitPoint = -1
									Hide = false
								}

								{
									BoundingSphereRadius = 1
									Weapon = (Melee | LightProjectile | MediumProjectile | Missile | Beam | Nuke)
									Trigger = DynamicMessage
									MessageName = DamagedToDeath
									ExplosionName = Expl_Building_Collapse_Tiny
									HitPoint = -1
									Hide = false
								}
							]
}

