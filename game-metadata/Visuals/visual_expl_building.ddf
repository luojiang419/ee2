//------------------------------------------------------------------------------------
// SEQUENCE
//------------------------------------------------------------------------------------

// Start debris flying from a building.
ExplosionSequence	s_building_debris
{
	SequenceType = Message
	FiringProbability = 1
	SequenceNames = [ startFlyingPartExplosion ]
}

ExplosionSequence	s_bridge_debris_splash01
{
	BoundingSphereRadius = 1
	FiringProbability = 0.5
	SequenceType = Nif
	SequenceNames = [ fx_watersplash_1.nif ]
	SequenceWorldScales = [0.2]
}

ExplosionSequence	sq_collapse_Tiny_1
{
	BoundingSphereRadius = 1
	TimeA = 0.2
	TimeB = 1.0
	DelayBeforeDie = 5
	StartingPositionMinX = -0.5
	StartingPositionMaxX = 0.5
	StartingPositionMinY = -0.5
	StartingPositionMaxY = 0.5
	StartingPositionMinZ = 0
	StartingPositionMaxZ = 0
	StartFromMainModel = 1
	FiringProbability = 1
	Replay = 2
	SequenceType = Nif
	SequenceNames = [ fx_Smoke_BuildingCollapse.nif ]
	SequenceWorldScales = [0.03]
}


ExplosionSequence	sq_collapse_Small_1
{
	BoundingSphereRadius = 1
	TimeA = 0.2
	TimeB = 0.6
	DelayBeforeDie = 5
	StartingPositionMinX = -1.5
	StartingPositionMaxX = 1.5
	StartingPositionMinY = -1.5
	StartingPositionMaxY = 1.5
	StartingPositionMinZ = 0
	StartingPositionMaxZ = 0
	StartFromMainModel = 1
	FiringProbability = 1
	Replay = 3
	SequenceType = Nif
	SequenceNames = [ fx_Smoke_BuildingCollapse.nif ]
	SequenceWorldScales = [0.03]
}

ExplosionSequence	sq_collapse_Medium_1
{
	BoundingSphereRadius = 1
	TimeA = 0.1
	TimeB = 0.6
	DelayBeforeDie = 5
	StartingPositionMinX = -2
	StartingPositionMaxX = 2
	StartingPositionMinY = -2
	StartingPositionMaxY = 2
	StartingPositionMinZ = 0
	StartingPositionMaxZ = 0
	StartFromMainModel = 1
