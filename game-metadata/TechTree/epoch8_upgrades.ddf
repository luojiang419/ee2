UpgradeSet AdvanceEpoch8 {
	upgrades = [
		UpgradeEpoch {epoch = 8;}
	]
}
UpgradeObsoleteTech ObsoleteFirearcher {
	tech = Firearcher
}
UpgradeObsoleteTech ObsoleteEngarcher {
	tech = Engarcher
}

