UpgradeSet AdvanceEpoch7 {
	upgrades = [
		UpgradeEpoch {epoch = 7;}
	]
}
UpgradeObsoleteTech ObsoleteRam {
	tech = Ram
}
UpgradeObsoleteTech ObsoleteSeigeTower {
	tech = SiegeTower
}
UpgradeObsoleteTech ObsoleteAlchemy {
	tech = Alchemy
}

UpgradeObsoleteTech ObsoleteVikingship {
	tech = Vikingship
}
UpgradeObsoleteTech ObsoleteLodia {
	tech = Lodia
}
UpgradeObsoleteTech ObsoleteKobukson {
	tech = Kobukson
}

UpgradeUndo UndoMilitary1_3 {
	techNode = Military1_3
}

UpgradeUndo UndoImperial1_3 {
	techNode = Imperial1_3
}

