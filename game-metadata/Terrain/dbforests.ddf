//Forest generation paramteres for random map generation.
//
// "coverage" is roughly what fraction of terrain will be forested.
// "density" is the number of trees per square tile in a forested region.
// "scale" is the correlation length.  In general, the odds of a tile being forested is influenced by whether other nearby
// 	tiles are forested; Tiles more the "scale" distance away will have no affect.
// "roughness" is a measure of the variation within a block of size "scale".  If roughness is zero, all tiles within the 
// 	block will either be forested or unforested; If roughness is 1, tiles are more or less randomly forested.
// "brush" is the name of the ForestBrush used to randomly select trees to place in the forested region.
//
// These variables are paramterized by climate (Arid, temperate, or tropical) and forestation level (light, medium, or heavy)
//

// No forests; climate irrelevant
ForestGen ForestGenNone {
	coverage = 0
}	

// Temperate light
ForestGen ForestGenTemperateLight {
	density = 1.6
	scale = 10.0
	coverage = 0.25
	roughness = 0.4
	brush = Temperate1
}

// Temperate medium
ForestGen ForestGenTemperateMedium {
	density = 1.6
	scale = 10.0
	coverage = 0.3
	roughness = 0.4
	brush = Temperate1
}

// Temperate heavy
ForestGen ForestGenTemperateHeavy {
	density = 1.6
	scale = 10.0
	//coverage = 0.35
	coverage = 0.32
	roughness = 0.4
	brush = Temperate2
}

// Tropical medium
ForestGen ForestGenTropicalLight {
	density = 1.6
	scale = 10.0
	coverage = 0.25
	roughness = 0.4
	brush = Tropic1
}

// Tropical light
ForestGen ForestGenTropicalMedium {
	density = 1.6
	scale = 10.0
	coverage = 0.3
	roughness = 0.4
	brush = Tropic1
}

// Tropical heavy
ForestGen ForestGenTropicalHeavy {
	density = 1.6
	scale = 10.0
	coverage = 0.32
	roughness = 0.4
	brush = Tropic2
}

// Arid light
ForestGen ForestGenAridLight {
	density = 1.6
	scale = 10.0
	coverage = 0.25
	roughness = 0.4
	brush = Arid1
}

// Arid medium
ForestGen ForestGenAridMedium {
	density = 1.6
	scale = 10.0
	coverage = 0.3
	roughness = 0.4
	brush = Arid1
}

// Arid Heavy
ForestGen ForestGenAridHeavy {
	density = 1.6
	scale = 10.0
	coverage = 0.32
	roughness = 0.4
	brush = Arid2
}

// Tundra light
ForestGen ForestGenTundraLight {
	density = 1.6
	scale = 10.01
	coverage = 0.25
	roughness = 0.4
	brush = Tundra1
}

// Tundra medium
ForestGen ForestGenTundraMedium {
	density = 1.6
	scale = 10.0
	coverage = 0.3
	roughness = 0.4
	brush = Tundra1
}

// Tundra heavy
ForestGen ForestGenTundraHeavy {
	density = 1.6
	scale = 10.0
	coverage = 0.32
	roughness = 0.4
	brush = Tundra1
}

//
// ClimateForestGen objects are the list of ForestGen objects for a specific climate, ordered by forestation level
//
ClimateForestGen Temperate {
	forestGen = [ForestGenTemperateLight ForestGenTemperateMedium ForestGenTemperateHeavy]
}

ClimateForestGen Tropical {
	forestGen = [ForestGenTropicalLight ForestGenTropicalMedium ForestGenTropicalHeavy]
}

ClimateForestGen Arid {
	forestGen = [ForestGenAridLight ForestGenAridMedium ForestGenAridHeavy]
}

ClimateForestGen Tundra {
	forestGen = [ForestGenTundraLight ForestGenTundraMedium ForestGenTundraHeavy]
}
