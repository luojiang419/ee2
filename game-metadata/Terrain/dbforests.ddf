//Here are the sets of brushes that are available for each climate.
//Note!  The FIRST BRUSH IN THE LIST is considered the 'default brush'
//for that climate, and is used when auto-placing resources, so try to
//be reasonable, yo.
ClimateForest Tropical {
	brushes = [Tropic1 Tropic2 Tropic3 Tropic4 Loew_Temperate4_15 Loew_Temperate5_15 Loew_Temperate6_15 Loew_Temperate7_15 Loew_Temperate_Random_15 Loew_Tropic6_15 Loew_Tropic7_15 Loew_Tropic8_15 Loew_Tropic9_15 Loew_Tropic10_15 Loew_Tropic11_15 Loew_Tropic_Random_15 Loew_Arid3_15 Loew_Arid4_15 Loew_Arid5_15 Loew_Arid6_15 Loew_Arid7_15 Loew_Arid_Random_15 Loew_Arctic1_15 Loew_Arctic2_15 Loew_Arctic3_15 Loew_Arctic_Random_15 Loew_Carbon1_15 Loew_Carbon2_15 Loew_Carbon3_15 Loew_Carbon4_15 Loew_Carbon_Random_15 TotallyRandom]
}

ClimateForest Temperate {
	brushes = [Temperate1 Temperate2 Temperate3 Loew_Temperate4_15 Loew_Temperate5_15 Loew_Temperate6_15 Loew_Temperate7_15 Loew_Temperate_Random_15 Loew_Tropic6_15 Loew_Tropic7_15 Loew_Tropic8_15 Loew_Tropic9_15 Loew_Tropic10_15 Loew_Tropic11_15 Loew_Tropic_Random_15 Loew_Arid3_15 Loew_Arid4_15 Loew_Arid5_15 Loew_Arid6_15 Loew_Arid7_15 Loew_Arid_Random_15 Loew_Arctic1_15 Loew_Arctic2_15 Loew_Arctic3_15 Loew_Arctic_Random_15 Loew_Carbon1_15 Loew_Carbon2_15 Loew_Carbon3_15 Loew_Carbon4_15 Loew_Carbon_Random_15 TotallyRandom]
