//////////////////////////////////////////////////////////////////////
// CLIMATE DATA
DbClimateInfo Temperate
{
	pTerrainDbName = DbTerrain_Temperate
	pSeasonalTexturesDbName = DbSeasonalTextureSets_Temperate
	pTerrainTextureDbName = DbTerrainTexture_Temperate
	bSnow = 1

	// Weather
	WeatherInfo = ClimateWeatherTemperate
	ToDSettingsMorning = ClimateToD_Temperate_Morn
	ToDSettingsAfternoon = ClimateToD_Temperate_Aft
	ToDSettingsEvening = ClimateToD_Temperate_Eve
	ToDSettingsNight = ClimateToD_Temperate_Nght

	// Animals
	domesticatedAnimals [ 
		{minGroupSize = 6; maxGroupSize = 6; unitType = Cow }
		{minGroupSize = 6; maxGroupSize = 6; unitType = Goat }
	]
	wildAnimals [ 
		{minGroupSize = 6; maxGroupSize = 10; unitType = Deer }
		{minGroupSize = 6; maxGroupSize = 10; unitType = Boar }
	]
	predators [ 
		{minGroupSize = 4; maxGroupSize = 8; unitType = Deer }
		{minGroupSize = 4; maxGroupSize = 8; unitType = Boar }
	]
	birds
	[
		Hawk Vulture
	]
	
	// Food type info
	farms
	[
		FarmWheat FarmYam
	]
	forageTrees
	[
		TRE_APPLE TRE_ORANGE
	]

	# DbTerrain_ = Temperate
	terrainBrushes {
		grassBrush {
			terrainTypes [
				{terrainType = Grass; weight = 30;}
				{terrainType = GrassPatchy; weight = 25;}
				{terrainType = GrassDark; weight = 5;}
				{terrainType = SparseGrass01; weight = 15;}
				{terrainType = SparseGrass02; weight = 5;}
				{terrainType = SparseGrass03; weight = 5;}
				{terrainType = HillMeadow; weight = 5;}
				{terrainType = FloodMeadow; weight = 5;}
			]
		}
		oceanBrush {
			brushes
			[
				{terrainTypes [
					{terrainType = OceanFloor; weight = 100;}
// @NOTE: we probably want to create an 'OceanFloor2' which uses the ShallowWater texture, but has the 
// oceanfloor movement type
//					{terrainType = ShallowWater; weight = 50;}
				]}
				{terrainTypes [{terrainType = Beach; weight = 100;}]}
				{terrainTypes [
					{terrainType = CoastalGrass01; weight = 50;}
					{terrainType = CoastalGrass02; weight = 50;}
				]} 
				{terrainTypes [{terrainType = Saltgrass; weight = 100}]}
				{terrainTypes [{terrainType = SparseGrass03; weight = 100}]}
			]
		}
		forestBrush {
			brushes [
				{terrainTypes [{terrainType = ForestRoots; weight = 100;}]}
				{terrainTypes [
					{terrainType = UnderstoryThicket; weight = 50;}
					{terrainType = GrassDark; weight = 50;}
				]}
				{terrainTypes [
					{terrainType = GrassDark; weight = 50;}
					{terrainType = HillMeadow; weight = 50;}
				]}
			]
		}
		riverBrush {
			brushes [
				{terrainTypes [{terrainType = ShallowWater; weight = 100}]}
				{terrainTypes [{terrainType = RiverBank; weight = 100}]}
				{terrainTypes [
					{terrainType = RiverBankGrassy; weight = 50}
					{terrainType = RiverBankPatchy; weight = 50}
				]}
			]
		}
		// @NOTE: The first three entries should all have the 'Mountain' movement type
		mountainBrush {
			brushes [
				{terrainTypes [{terrainType = MountainTop; weight = 100;}]}
				{terrainTypes [{terrainType = Mountain01; weight = 100;}]}
				{terrainTypes [{terrainType = Mountain01; weight = 100;}]}
				{terrainTypes [{terrainType = MountainGrass; weight = 100;}]}
			]
		}
	}

	// Ambient audio
	ambientAudio = ambient_master_set_temperate

	// Season suffixes for asset load
	winterSuffix = _wi
	springSuffix = _sp
	summerSuffix = _su
	fallSuffix   = _fa
}
    	
DbClimateInfo Arid
{  
	pTerrainDbName = DbTerrain_Arid
	pSeasonalTexturesDbName = DbSeasonalTextureSets_Arid
	pTerrainTextureDbName = DbTerrainTexture_Arid
	bSnow = 0

	// Weather
	WeatherInfo = ClimateWeatherArid
	ToDSettingsMorning = ClimateToD_Arid_Morn
	ToDSettingsAfternoon = ClimateToD_Arid_Aft
	ToDSettingsEvening = ClimateToD_Arid_Eve
	ToDSettingsNight = ClimateToD_Arid_Nght

	// Animals
	domesticatedAnimals [ 
		{minGroupSize = 6; maxGroupSize = 6; unitType = LLama} 
		{minGroupSize = 6; maxGroupSize = 6; unitType = Cow} 
	]
	wildAnimals [ 
		{minGroupSize = 6; maxGroupSize = 10; unitType = Elephant} 
		{minGroupSize = 6; maxGroupSize = 10; unitType = Camel} 
	]
	predators [ 
		{minGroupSize = 4; maxGroupSize = 8; unitType = Camel} 
	]
	birds
	[
		Hawk Vulture
	]
	
	// Food type info
	farms
	[
		FarmWheat FarmYam
	]
	forageTrees
	[
		TRE_POMEGRANATE TRE_DATE
	]
	

	# DbTerrain_ = Arid
	terrainBrushes {
		grassBrush {
			terrainTypes [
                {terrainType = AridGrass; weight = 30;}
				{terrainType = GrassPrairieArid; weight = 15;}
				{terrainType = AridDenseGrass; weight = 15;}
				{terrainType = AridSmallScrub; weight = 10;}
				{terrainType = AridDesertScrub; weight = 10;}
				{terrainType = AridSparseGrass; weight = 20;}
			]
		}
		oceanBrush {
			brushes
			[
				{terrainTypes [
					{terrainType = OceanFloor; weight = 100;}
// @NOTE: we probably want to create an 'OceanFloor2' which uses the ShallowWater texture, but has the 
// oceanfloor movement type
//					{terrainType = ShallowWater; weight = 50;}
				]}
				{terrainTypes [{terrainType = Beach; weight = 100;}]}
				{terrainTypes [
					{terrainType = CoastalGrass01; weight = 50;}
					{terrainType = CoastalGrass02; weight = 50;}]}
			]
		}
		forestBrush {
			brushes [
				{terrainTypes [{terrainType = UnderTreeArid; weight = 100;}]}
				{terrainTypes [
					{terrainType = UnderTreeArid; weight = 50;}
					{terrainType = AridGrass; weight = 50;}
				]}
				{terrainTypes [
					{terrainType = AridSparseGrass; weight = 50;}
					{terrainType = AridDesertScrub; weight = 50;}
				]}
			]
		}
		riverBrush {
			brushes [
				{terrainTypes [{terrainType = ShallowWater; weight = 100}]}
				{terrainTypes [{terrainType = RiverBank; weight = 100}]}
				{terrainTypes [
					{terrainType = GrassPrairieArid; weight = 50}
					{terrainType = AridDenseGrass; weight = 50}
				]}
			]
		}
		// @NOTE: The first three entries should all have the 'Mountain' movement type
		mountainBrush {
			brushes [
				{terrainTypes [{terrainType = MountainArid; weight = 100;}]}
				{terrainTypes [{terrainType = MountainArid; weight = 100;}]}
				{terrainTypes [{terrainType = MountainGrassArid; weight = 100;}]}
				{terrainTypes [
					{terrainType = AridLongDryGrass; weight = 50;}
					{terrainType = AridSmallScrub; weight = 50;}
					{terrainType = AridDesertScrub; weight = 50;}
				]}
			]
		}
	}

	// Ambient audio
	ambientAudio = ambient_master_set_arid

	// Season suffixes for asset load (just pretend it's always summer)
	winterSuffix = _su
	springSuffix = _su
	summerSuffix = _su
	fallSuffix   = _su
}

