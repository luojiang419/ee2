//////////////////////////////////////////////////////////////////////
// WEATHER SETTINGS
// UP1.5 Modification 31.07.2014, Dr.MonaLisa: -0.88 -0.47 -0.09 = ~62 degrees / ~5
// Changed sky effects, depending on the time of the day.

// Temperate
DbClimateWeatherInfo ClimateWeatherTemperate
{
	RainySeasonStart = 3
	RainySeasonStop = 6
	
	SnowySeasonStart = 11
	SnowySeasonStop = 3
	SnowRequiredLeadTime = 5
	SnowRequiredMonths = 3

	DustySeasonStart = -1

	LeafySeasonStart = 9
	LeafySeasonStop = 11
}

// Arid
DbClimateWeatherInfo ClimateWeatherArid
{
	RainySeasonStart = 11
	RainySeasonStop = 0

	SnowySeasonStart = -1

	DustySeasonStart = 4
	DustySeasonStop = 9

	LeafySeasonStart = -1
}

// Tropical
DbClimateWeatherInfo ClimateWeatherTropical
{
	RainySeasonStart = 10
	RainySeasonStop = 5
	
	SnowySeasonStart = -1

	DustySeasonStart = -1

	LeafySeasonStart = -1
}

// Tundra
DbClimateWeatherInfo ClimateWeatherTundra
{
	RainySeasonStart = 5
	RainySeasonStop = 7
	
	SnowySeasonStart = 10
	SnowySeasonStop = 5
	SnowRequiredLeadTime = 5
	SnowRequiredMonths = 4

	DustySeasonStart = -1

	LeafySeasonStart = -1
}

