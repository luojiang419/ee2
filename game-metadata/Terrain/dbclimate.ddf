	]
	wildAnimals [ 
		{minGroupSize = 6; maxGroupSize = 10; unitType = Elephant} 
		{minGroupSize = 6; maxGroupSize = 10; unitType = Boar} 
	]
	predators 
	[ 
		{minGroupSize = 4; maxGroupSize = 8; unitType = Boar} 
	]
	birds
	[
		Hawk Vulture
	]
	
	// Food type info
	farms
	[
		FarmSugarCane FarmYam
	]
	forageTrees
	[
		TRE_BANANA TRE_MANGO
	]
	

	# DbTerrain_ = Tropical
	terrainBrushes {
		grassBrush {
			terrainTypes [
				{terrainType = MossyCover; weight = 30;}
				{terrainType = UnderstoryCover; weight = 25;}
				{terrainType = Grass; weight = 5;}
				{terrainType = ClayShrubs; weight = 15;}
				{terrainType = Kudzu; weight = 5;}
				{terrainType = TropicalCoverRocky; weight = 5;}
				{terrainType = GrassPatchy; weight = 5;}
				{terrainType = TropicalCover; weight = 5;}
			]
		}
		oceanBrush {
			brushes
			[
				{terrainTypes [
					{terrainType = OceanFloor; weight = 100;}
// @NOTE: we probably want to create an 'OceanFloor2' which uses the ShallowWater texture, but has the 
// oceanfloor movement type
//					{terrainType = ShallowWater; weight = 50;}
				]}
				{terrainTypes [{terrainType = Beach; weight = 100;}]}
				{terrainTypes [
					{terrainType = CoastalGrass01; weight = 50;}
					{terrainType = CoastalGrass02; weight = 50;}]}
			]
		}
	forestBrush {
			brushes [
				{terrainTypes [{terrainType = ForestRoots; weight = 100;}]}
				{terrainTypes [
					{terrainType = ClayShrubs; weight = 50;}
					{terrainType = ForestRoots; weight = 50;}
				]}
				{terrainTypes [
					{terrainType = MossyCover; weight = 50;}
					{terrainType = Kudzu; weight = 50;}
				]}
			]
		}
		riverBrush {
			brushes [
				{terrainTypes [{terrainType = ShallowWater; weight = 100}]}
				{terrainTypes [{terrainType = RiverBank; weight = 100}]}
				{terrainTypes [
					{terrainType = RiverBankGrassy; weight = 50}
					{terrainType = RiverBankPatchy; weight = 50}
				]}
			]
		}
		mountainBrush {
			brushes [
			// @NOTE: 'Mountain' is the only terrain type in the tropical terrain 
			// database that has the Mountain movement type, which is required
			// for the first three entries here
				{terrainTypes [{terrainType = Mountain; weight = 100;}]}
				{terrainTypes [{terrainType = Mountain; weight = 100;}]}
				{terrainTypes [{terrainType = Mountain; weight = 100;}]}
				{terrainTypes [{terrainType = MountainGrass; weight = 100;}]}
			]
		}
	}

	// Ambient audio
	ambientAudio = ambient_master_set_tropical

	// Season suffixes for asset load (just pretend it's always summer)
	winterSuffix = _su
	springSuffix = _su
	summerSuffix = _su
	fallSuffix   = _su
}

DbClimateInfo Tundra
{
	pTerrainDbName = DbTerrain_Tundra
	pSeasonalTexturesDbName = DbSeasonalTextureSets_Tundra
	pTerrainTextureDbName = DbTerrainTexture_Tundra
	bSnow = 1

	// Weather
	WeatherInfo = ClimateWeatherTundra
	ToDSettingsMorning = ClimateToD_Tundra_Morn
	ToDSettingsAfternoon = ClimateToD_Tundra_Aft
	ToDSettingsEvening = ClimateToD_Tundra_Eve
	ToDSettingsNight = ClimateToD_Tundra_Nght

	// Animals
	domesticatedAnimals [ 
	//	{minGroupSize = 6; maxGroupSize = 8; unitType = TundraRabbit }
		{minGroupSize = 6; maxGroupSize = 6; unitType = Cow }
		{minGroupSize = 6; maxGroupSize = 6; unitType = Goat }
	]
	wildAnimals [ 
		{minGroupSize = 6; maxGroupSize = 10; unitType = Deer }
		{minGroupSize = 6; maxGroupSize = 10; unitType = Boar }
	]
	predators [ 
		{minGroupSize = 4; maxGroupSize = 8; unitType = Deer }
		{minGroupSize = 4; maxGroupSize = 8; unitType = Boar }
	]
	
	birds
	[
		Hawk Vulture
	]
	
	// Food type info
	farms
	[
		FarmWheat FarmYam
	]
	forageTrees
	[
		TRE_BANANA TRE_MANGO 
	]

	# DbTerrain_ = Tundra
	terrainBrushes {
		grassBrush {
			terrainTypes [
				{terrainType = GrassTundra; weight = 55;}
				{terrainType = GrassTundra2; weight = 35;}
				{terrainType = GrassTundra4; weight = 10;}
			]
		}
		oceanBrush {
			brushes
			[
				{terrainTypes [
					{terrainType = OceanFloor; weight = 100;}
// @NOTE: we probably want to create an 'OceanFloor2' which uses the ShallowWater texture, but has the 
// oceanfloor movement type
//					{terrainType = ShallowWater; weight = 50;}
				]}
				{terrainTypes [{terrainType = Beach; weight = 100;}]}
				{terrainTypes [
					{terrainType = CoastalArctic01; weight = 50;}
					{terrainType = CoastalArctic02; weight = 50;}]}
			]
		}
		forestBrush {
			brushes [
				{terrainTypes [{terrainType = ForestRoots; weight = 100;}]}
				{terrainTypes [
					{terrainType = GrassTundra3; weight = 100;}
                    //{terrainType = GrassTundra4; weight = 50;}
				]}
			]
		}
		riverBrush {
			brushes [
				{terrainTypes [{terrainType = ShallowWater; weight = 100}]}
				{terrainTypes [{terrainType = RiverBank; weight = 100}]}
				{terrainTypes [
					{terrainType = RiverBankGrassy; weight = 50}
					{terrainType = RiverBankPatchy; weight = 50}
				]}
			]
		}
		// @NOTE: The first three entries should all have the 'Mountain' movement type
		mountainBrush {
			brushes [
				{terrainTypes [{terrainType = MountainArctic_Snow2; weight = 100;}]}
				{terrainTypes [{terrainType = MountainArctic; weight = 100;}]}
				{terrainTypes [{terrainType = MountainArctic; weight = 100;}]}
				{terrainTypes [{terrainType = GrassTundra4; weight = 100;}]}
			]
		}
	}

	// Ambient audio
	ambientAudio = ambient_master_set_tundra

	// Season suffixes for asset load
	winterSuffix = _wi
	springSuffix = _sp
	summerSuffix = _su
	fallSuffix   = _fa
}
