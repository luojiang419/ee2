{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "EE2X魔改版启动器",
  "version": "1.0.1",
  "identifier": "com.ee2x.modlauncher",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build:frontend",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "EE2X魔改版启动器",
        "width": 1600,
        "height": 960,
        "minWidth": 1366,
        "minHeight": 840,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$APPDATA/backgrounds/**",
          "$APPLOCALDATA/backgrounds/**",
          "$APPCONFIG/backgrounds/**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "nsis",
    "icon": [
      "icons/EE2X.ico"
    ],
    "resources": [
      "resources/vnt/vnt-cli.exe",
      "resources/vnt/wintun.dll"
    ],
    "windows": {
      "nsis": {
        "installMode": "both"
      }
    }
  }
}
