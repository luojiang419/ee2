UnitType T3476
{
	parent = HeavyMounted
	properties {
		rps = HeavyMounted
		moveType = Mechanized
		SizeX = 0.8
		SizeY = 0.7
		mass = 1
		popCount = 2
		displayName = tx_utn_T3476_name
		VerboseTooltip = vtt_unit_T3476
		HitPoints = 3000
	}
	sounds = {
		sndSelection = ["v_heavyartillery_12_spe01" 
"v_HeavyMounted1_11_spe01"
"v_HeavyMounted1_13_spe01"
"v_lightartillery1_13_sel01"
"v_LightMounted1_11_spe01"]
sndCmdMove = ["v_heavyartillery_12_com01" 
"v_HeavyMounted1_11_com01"
"v_HeavyMounted1_11_com02"
"v_HeavyMounted1_12_spe01"
"v_HeavyMounted1_12_com01"
"v_LightMounted1_11_com01"]
//		sndCmdAttack = [""]
//		sndDeath =  [""]
	}
	abilities = [
	Garrisonable { garrisonTypes = [   NavalTransport AirTransport ] }
	Attack { range = 13; reloadTime = 3.0;angularRange = 360; applyDamageTime = 0.5; damage = 230; missileName = TankShell; turretControllerName = TankTurret;throwUnits = true }
		VehicleMove {speed = 1.7; angSpeed = 90; followTerrainSlope = 1; mustMoveToTurn = 0}
		LOS { range = 13 }
		AreaEffect {			effects = [ Taran_Tanks ]		}
	]
	icon = T3485
}

