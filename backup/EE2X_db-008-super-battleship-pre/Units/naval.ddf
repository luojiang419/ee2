//------------------------------------------------------------------------------------------------
//	NAVAL Base visual, derive from this visual 
//------------------------------------------------------------------------------------------------
UnitModel BaseShip
{
	ScaleType 	= kScaleVehicle
	DefaultState 	= Idle
	States 		= [
		{	StateName = Idle	}
			]
	ChildNames 	= [ SelectCircleWaterUnit TheHealthBar TheBoatDamageEffect
					TheVisualFlagBoat LargeGlow MobileStencilShadow]
	UIRenderingParams {
		xOffset = 0.01
		yOffset = 1.17
		zOffset = 0.43
		scale = 1.66
		angle = 47.37
		rotationSpeed = 0.00
		pitch = 9.47
		lightAngle = 30.00
		lightPitch = 90.00
		lightDiffuse = [50 50 45 255]
		lightSpecular = [0 0 0 255]
		lightAmbient = [40 40 40 255]
	}
}

UnitModel BaseSubmarine
{
	ScaleType 	= kScaleVehicle
	DefaultState 	= Idle
	States 		= [
		{	StateName = Idle	}
			]
	ChildNames 	= [ SelectCircleSubmarine TheHealthBar TheBoatDamageEffect TheSubmarineWake 
					TheVisualFlagBoat LargeGlow ]
	UIRenderingParams {
		xOffset = 0.01
		yOffset = 1.17
		zOffset = 0.43
		scale = 1.66
		angle = 47.37
		rotationSpeed = 0.00
		pitch = 9.47
		lightAngle = 30.00
		lightPitch = 90.00
		lightDiffuse = [50 50 45 255]
		lightSpecular = [0 0 0 255]
		lightAmbient = [40 40 40 255]
	}
}
