//------------------------------------------------------------------------------------------------
//	NAVAL DEEP
//------------------------------------------------------------------------------------------------
UnitType NavalDeep
{
	properties {
		moveType = kUnitMoveType_NavalDeep
		rps = SeaNonCombat
		popCount = 3
		stance = Defensive
		FootprintType	= Ellipse
	}
	sounds {
		sndDeath =  ["fx_tmp_boat_sink_01" "fx_tmp_boat_sink_02"]
    	}
	abilities [
		// the following provide a sample NavalMove parameter setting, remember, since 
		// we are moving in water, acceleration and turning should be lower.
		NavalMove {speed = 2.3; accel = 1; angSpeed = 60}		
		Garrisonable { garrisonTypes = [ Dock ] }
	]
	fullMapOverlay { sprite = spr_fullmap_boat }
	icon = icon_unit_default_human
}

