UnitType J12
{
	parent = Aircraft
	properties {
		rps = AirSuperiority
		SizeX = 1
		SizeY = 1
		mass = 0
		HitPoints = 1700
		displayName = tx_utn_J12_name
		verboseTooltip = vtt_unit_J12
		popCount = 2
	}
	sounds = {
		sndSelection = ["v_plane_select_chn" 
				"v_plane_select_chn01" 
				"v_plane_select_chn02"
				"v_plane_select_chn03"
				"v_plane_select_chn04"
		]
		sndCmdMove = ["v_plane_move_chn01" 
	      		      "v_plane_move_chn02"
			      "v_plane_move_chn03"
			      "v_plane_move_chn04"
			      "v_plane_move_chn05"
			      "v_plane_move_chn06"
		]
		sndCmdAttack = ["v_plane_attack_chn01"
				"v_plane_attack_chn02"
				"v_plane_attack_chn03"
		]
		sndDeath =  ["v_plane_death_chn01"
			     "v_plane_death_chn02"
			     "v_plane_death_chn03"
		]
	}
	abilities = [
		AircraftMove {speed = 7; angSpeed = 68; CruisingHeight = 9.5; ElevChangeRate = 0.5}
		Attack { damage = 750; range = 10; reloadTime = 1; angularRange = 120; applyDamageTime = 0.3; missileName = "GuidedMissile"; ignoreBlocking = 1; attackOnTheMove = 1; ordnance = 8;areaDamageRadius = 1.0;}
	LOS { range = 11}
	SpecialPower { 		
			effects = [ Air_anti_missle ]
		}
	]
attributes [
		GoesOnAirMissions
	]
icon = icon_unit_J12
}
