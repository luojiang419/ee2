///////////////////////////////////China Start////////////////////////////////////////////////////
//----------------KJ2000 AWACS----------
UnitType KJ2000
{
	parent = Aircraft 	
      properties {
        SizeX = 2
		SizeY = 2
		mass = 0
		popCount = 2            
		VerboseTooltip = vtt_unit_E3
		HitPoints = 1000
	}
	sounds = {
		sndSelection = ["v_plane_select_chn" 
				"v_plane_select_chn01" 
				"v_plane_select_chn02"
				"v_plane_select_chn03"
				"v_plane_select_chn04"
		]
		sndCmdMove = ["v_plane_move_chn01" 
	      		      "v_plane_move_chn02"
			      "v_plane_move_chn03"
			      "v_plane_move_chn04"
			      "v_plane_move_chn05"
			      "v_plane_move_chn06"
		]
		sndCmdAttack = ["v_plane_attack_chn01"
				"v_plane_attack_chn02"
				"v_plane_attack_chn03"
		]
		sndDeath =  ["v_plane_death_chn01"
			     "v_plane_death_chn02"
			     "v_plane_death_chn03"
		]
	}
	abilities = [
		AircraftMove {speed = 6.0; angSpeed = 58; CruisingHeight = 12.2 }
            Attack { range = 0; reloadTime = 0; applyDamageTime = 0; damage = 0; missileName = "Arrow" }
            AreaEffect {
			effects = [ 
				Awacs,SuperVision
			]
		}
        LOS { range = 30 }
       // SpecialPower { 
		//	range = 100; 
		//	effects = [ Awace_PowerControler ]
		//}  		
	]
	attributes [
		GoesOnAirMissions
	]
	fullMapOverlay { sprite = spr_fullmap_plane; scale = 1.5; }
}

// Add to mobile units for a blobby ellipsoid shadow
ShadowData        KJ2000Shadow_01
{
	Flags = (IsMobile | ImmutableBounds)
	FlatBillboard
	{
		TextureFilename = BomberShadow3.tga
		WidthScale = 0.9
		LengthScale = 0.9
		HeightScale = 0.1
	}
      
}

UnitModel KJ2000_13
{
	Parent	= BaseAircraft
	DefaultModel 	= KJ2000.nif
      ScaleType 	= kScaleVehicle
      ForceScale=0.150      
	ChildNames 	= [  VaporTrail5 VaporTrail6 TheAmmoBar BomberShadow3 JetEngineBomber_FlyingParts  ]
	DefaultState	= Idle	
	States 		= [
		{	StateName = Idle	AnimName = afb15_smartplane_idle.kf			
				TextKeys = [ 
					{ Name = HIDE_NODE Data = swipe 	KeyTime = 0 }
					{ Name = START_SOUND Data = fx_move_jet_03 }
					]}
		{ 	StateName = Walk	AnimName = mona_slow_helicopter.kf		
				TextKeys = [ 
					{ Name = HIDE_NODE Data = swipe 	KeyTime = 0 }
					{ Name = START_SOUND Data = fx_move_jet_03 }
					]}
		{ 	StateName = Attack1	AnimName = llm13_missilehelicopter_attack.kf	
				TextKeys = [ 
					{ Name = HIDE_NODE Data = swipe 	KeyTime = 0 }
					{ Name = PLAY_SOUND Data = fx_battle_rocket_launch }
					]}

		{ 	StateName = Takeoff	AnimName = afb15_smartplane_takeoff.kf
               			TextKeys =    [{ Name = PLAY_SOUND Data = fx_move_jet_takeoff_03 KeyTime = 0}]}
		{ 	StateName = Death	AnimName = afb15_smartplane_death.kf
			TextKeys = [ { Name = PLAY_SOUND Data = v_Bomber_13_death KeyTime = 0} { Name = STOP_SOUND Data = fx_move_jet_03 KeyTime = 0}
			]
			}
]
	UIRenderingParams {
		xOffset = 0.01
		yOffset = -0.57
		zOffset = -0.43
		scale = 1.79
		angle = 18.95
	}

}

