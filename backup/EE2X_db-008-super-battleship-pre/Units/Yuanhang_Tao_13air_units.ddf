// E2D            ////
////////////////////////////////////////
UnitType E2D
{
	parent = Aircraft
      properties {
		rps = Bomber
        SizeX = 1
		SizeY = 1
		mass = 0
		popCount = 2
       displayName = tx_utn_E2D_name
		VerboseTooltip = vtt_unit_E2D
		HitPoints = 2000
	}
	sounds = {
	}
	abilities = [
		AircraftMove {speed = 4.5; angSpeed = 18; CruisingHeight = 10.2; }
            AreaEffect {
			effects = [ 
				Awacs,SuperVision
			]
		}
        LOS { range = 13 }
	]
	attributes [
		GoesOnAirMissions
	]
	fullMapOverlay { sprite = spr_fullmap_plane; scale = 1.5; }
	icon = icon_unit_E2D
}

// Visuals Model
UnitModel E2D
{
	Parent	= BaseAircraft
	DefaultModel 	= E2D.nif
      ScaleType 	= kScaleVehicle
      ForceScale=0.3    
	ChildNames 	= [ VaporTrail1 VaporTrail5 VaporTrail6 TheAmmoBar BomberShadow3 JetEngineBomber_FlyingParts expl_heli_Tandrill ]
	DefaultState	= Idle	
	States 		= [
		{	StateName = Idle	AnimName = afb15_smartplane_idle.kf			
				TextKeys = [ 
					{ Name = HIDE_NODE Data = swipe 	KeyTime = 0 }
					{ Name = START_SOUND Data = fx_move_plane_03 }
					]}
		{ 	StateName = Walk	AnimName = mona_slow_helicopter.kf		
				TextKeys = [ 
					{ Name = HIDE_NODE Data = swipe 	KeyTime = 0 }
					{ Name = START_SOUND Data = fx_move_plane_03 }
					]}
		{ 	StateName = Attack1	}

		{ 	StateName = Takeoff	AnimName = afb15_smartplane_takeoff.kf
               			TextKeys =    [{ Name = PLAY_SOUND Data = fx_move_jet_takeoff_03 KeyTime = 0}]}
		{ 	StateName = Death	AnimName = afb15_smartplane_death.kf
			TextKeys = [ { Name = PLAY_SOUND Data = v_Bomber_13_death KeyTime = 0} { Name = STOP_SOUND Data = fx_move_plane_03 KeyTime = 0}
			]
			}
]
	UIRenderingParams {
		xOffset = 0.01
		yOffset = -0.57
		zOffset = -0.43
		scale = 1.79
		angle = 18.95
	}
}
