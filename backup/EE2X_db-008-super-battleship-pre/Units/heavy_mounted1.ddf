UnitModel HeavyMounted1_02
{
	Parent		= BaseHeavyMountedHorse
	DefaultModel 	= LHM2_mountedinfantry.NIF
	ChildNames 	= [ UnitShadow SinkCorpse ]
	States 		= [
		{	StateName = Idle	AnimName = sh_mountedinfantry_idle01.kf	
                              AnimVariants = [ sh_mountedinfantry_idle02.kf sh_mountedinfantry_season01.kf ]
                              AnimVariantsWeights = [ 0.2 0.3 ]
                 }
		{ 	StateName = Walk	AnimName = sh_mountedinfantry_walk01.kf AnimSpeedScale = 2.25 }
		{	StateName = Run		AnimName = sh_mountedinfantry_run01.kf 	
			
			}
		{ 	StateName = Attack1	AnimName = sh_mountedinfantry_attack01.kf
                              TextKeys = [
					{ Name = PLAY_SOUND Data = fx_spear_thrust KeyTime = 1.0 }]
				AnimVariants = [ sh_mountedinfantry_attack02.kf sh_mountedinfantry_attack03.kf sh_mountedinfantry_attack04.kf ]
                              AnimVariantsWeights = [ 0.05 0.05 0.02  ]
                 }
       		{ 	StateName = Death	AnimName = sh_mountedinfantry_death01.kf	}
		{	StateName = Flinch	AnimName = sh_mountedinfantry_protect01.KF	}
		{	StateName = BeingThrown	AnimName = sh_mountedinfantry_flying01.KF
			AnimVariants = [ sh_mountedinfantry_flying02.KF ] AnimVariantsWeights = [ 0.5 ]	}
		{	StateName = ThrownDeath	AnimName = sh_mountedinfantry_ground_death01.KF	}
			]
	UIRenderingParams {
		xOffset = -5.26
		yOffset = 1.38
		zOffset = -0.45
		scale = 1.15
		angle = 47.37
	}
}

