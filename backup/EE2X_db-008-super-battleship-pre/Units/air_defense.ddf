//------------------------------------------------------------------------------------------------
//	AIR DEFENSE - UNIT TYPE INFO
//------------------------------------------------------------------------------------------------
UnitType AirDefense
{
	ownerType = PlayerOnly
	parent = NoProduceBuilding
	properties {
		rps = AntiAircraft
		SizeX = 1
		SizeY = 1
		FootprintSizeX = 2.5
		FootprintSizeY = 2.5
		OffsetX = 0.75
		OffsetY = 0.75
		mass = 1
		hitpoints = 400
		displayName = tx_utn_airdefense_name
		DisplayNameScenEdit = tx_utn_airdefense_sname
		VerboseTooltip = vtt_unit_AirDefense
	}
	sounds {
		sndSelection = ["AirDefense_select"]
   	}	
	abilities = [
		// @AA - removed: 'missileName = "Flak01"' from attack ability, this one wants to have instant hits
		Attack { range = 6; angularRange = 360; reloadTime = 2; applyDamageTime = 0.5; damage = 40; ignoreBlocking = 1; turretControllerName = BuildingTurret; }
		LOS { range = 0 }		
	]
	icon = icon_unit_airdefense_13
}

