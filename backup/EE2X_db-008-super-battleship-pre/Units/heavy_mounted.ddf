//------------------------------------------------------------------------------------------------
//	HEAVY MOUNTED
//------------------------------------------------------------------------------------------------
UnitType HeavyMounted
{
	properties {
		rps = HeavyMounted
		popCount = 1
		FootprintType = Ellipse
		// default stance to defensive
		stance = Defensive
	}
	sounds {
		sndDeath =  ["fx_death_male_01" "fx_death_male_02" "fx_death_male_03" "fx_death_male_04" "fx_death_male_05" "fx_death_male_06" "fx_death_male_07"]
    	}
	abilities [
		Convertable { convertTimeModifier = 3.0; }
		Garrisonable { garrisonTypes = [ Fortress Tower NavalTransport ] }
	]
	attributes = [ 
		HealedByMedic, 
		CanJoinHeroArmy
	]
	fullMapOverlay { sprite = spr_fullmap_smallunit ignoreOrientation = 1 }
	icon = icon_unit_default_human
}


//------------------------------------------------------------------------------------------------
//	HEAVY MOUNTED - Visual info common to all heavy mounted
//------------------------------------------------------------------------------------------------
UnitModel BaseHeavyMountedHorse
{
	ChildNames 		= [ TheHealthBar SelectCircleMounted DustHeavyMonted 
						MediumGlow ExplSelectorMounted01 VisualThrownUnit
						HemisphereLighting_Unit DynamicLighting_Unit
					  ]
	OutlineType		= kOutlineMake
	DefaultState 		= Idle
	ScaleType 		= kScaleMountedUnit
	UIRenderingParams {
		xOffset = -5.26
		yOffset = 0.54
		zOffset = 1.95
		scale = 1.00
		angle = 47.37
		rotationSpeed = 0.00
		pitch = 10.00
		lightAngle = 30.00
		lightPitch = 90.00
		lightDiffuse = [50 50 45 255]
		lightSpecular = [0 0 0 255]
		lightAmbient = [40 40 40 255]
	}
}


UnitModel BaseHeavyMountedArmored
{
	ChildNames 		= [ TheHealthBar SelectCircleTank MediumGlow 
						expl_tank_Tandrill
						HemisphereLighting_Unit DynamicLighting_Unit
					  ]
