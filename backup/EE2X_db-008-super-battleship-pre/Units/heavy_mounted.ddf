	UIRenderingParams {
		xOffset = 0.00
		yOffset = 1.32
		zOffset = 1.10
		scale = 1.66
		angle = 37.89
		rotationSpeed = 0.00
		pitch = 20.00
		lightAngle = 30.00
		lightPitch = 90.00
		lightDiffuse = [50 50 45 255]
		lightSpecular = [0 0 0 255]
		lightAmbient = [40 40 40 255]
	}
}