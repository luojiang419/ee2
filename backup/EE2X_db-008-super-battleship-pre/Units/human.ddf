//------------------------------------------------------------------------------------------------
//	HUMAN
//------------------------------------------------------------------------------------------------
UnitType LandMammal
{
	ownertype = PlayerOrWorld
	properties {
		moveType = kUnitMoveType_Foot
		rps = LandNonCombat
		FootprintType = Ellipse
		SizeX = 0.125
		SizeY = 0.125
		mass = 1
		hitpoints = 50
		popCount = 1
	}
	abilities [
		LOS { range = 5 }
	]
	fullMapOverlay { sprite = spr_fullmap_smallunit ignoreOrientation = 1 }
}

UnitType HumanNoConvert
{
	parent = LandMammal
	sounds {
		sndDeath =  ["fx_death_male_01" "fx_death_male_02" "fx_death_male_03" "fx_death_male_04" "fx_death_male_05" "fx_death_male_06" "fx_death_male_07"]
    	}
	ownertype = PlayerOnly
	attributes = [ 
		HealedByMedic
	]
	abilities [
		Move {speed = 1.15; angSpeed = 720; angAccel = 720}
		Garrisonable { garrisonTypes = [ Fortress Tower NavalTransport SeigeTower AirTransport ] }
	]
	icon = icon_unit_default_human
	properties {
		stance = Defensive
	}
}

UnitType Human
{
	parent = HumanNoConvert
	abilities [
		Convertable { convertTimeModifier = 3.0; }
	]	
	// Units default to defensive, not aggressive
	properties {
		stance = Defensive
	}
}


//------------------------------------------------------------------------------------------------
// BASE visual info for Human units
//------------------------------------------------------------------------------------------------


UnitModel	BaseHuman
{
	OutlineType		= kOutlineMake
	ScaleType 		= kScaleUnit
	ChildNames 		= [ TheHealthBar SelectCircleSmall SmallGlow ExplSelectorHuman01 Footprints SinkCorpse VisualThrownUnit
						HemisphereLighting_Unit DynamicLighting_Unit
					  ]
	DefaultState 		= Idle	
	UIRenderingParams {
		xOffset = 0.01
		yOffset = -1.34
		zOffset = -6.48
		scale = 2.43
		angle = 23.68
		rotationSpeed = 0.00
		pitch = 9.47
		lightAngle = 30.00
		lightPitch = 90.00
		lightDiffuse = [50 50 45 255]
		lightSpecular = [0 0 0 255]
		lightAmbient = [40 40 40 255]
	}
}
