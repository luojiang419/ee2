	}
	sounds = {
		sndCmdMove = ["v_Bomber_14_com01" "v_Bomber_14_com02"]
		sndCmdAttack = ["v_Bomber_14_com01" "v_Bomber_14_com02" "v_Bomber_14_spe01"]
		sndSelection = ["v_Bomber_14_sel01"]
	}
	abilities = [
		AircraftMove {speed = 8.05; angSpeed = 60; CruisingHeight = 4.0; ElevChangeRate = 0.5; OnGroundScale = 0.8}
