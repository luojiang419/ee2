//------------------------------------------------
//	AMERICAN 8 - PRESIDENTIAL HUMMVEE
//------------------------------------------------
UnitType PresidentialHumvee
{
	parent = Mounted
	properties {
		rps = LightMounted
		SizeX = 0.4
		SizeY = 0.4
		mass = 1
		popCount = 2
		displayName = tx_utn_UniqPresHumvee_name
		DisplayNameScenEdit = tx_utn_UniqPresHumvee_sname
		VerboseTooltip = vtt_unit_UniqPresHumvee
		HitPoints = 700
	}
	sounds = {
		sndSelection = ["v_LightArtillery2_13_sel01"]
		sndCmdMove = ["v_LightArtillery2_13_com01" "v_LightArtillery2_13_com02"]
//		sndCmdAttack = [""]
//		sndDeath =  [""]
	}
	abilities = [
		Move {speed = 2.875; angSpeed = 180}
		LOS { range = 6 }
		Garrisonable { garrisonTypes = [ AirTransport Fortress Tower ] }
	]
	icon = icon_unit_presHumvee
}

UnitModel PresidentialHumvee
{
	ScaleType 	= kScaleVehicle
	DefaultModel 	= lla13_preshumvee.nif
	DefaultState 	= Idle
	States = [
			{ StateName= Idle AnimName = lla13_preshumvee_idle.KF	
				TextKeys = [ { Name = STOP_CONTROLLER	Data = NiUVController KeyTime = 0 } 
					   ]
				 }

			{ StateName= Walk AnimName = lla13_preshumvee_walk.KF		
				TextKeys = [ { Name = START_CONTROLLER	Data = NiUVController KeyTime = 0 }
					     { Name = START_SOUND_UNTIL_ANIM_CHANGE Data = fx_move_halftrack KeyTime = 0} 
					   ] 
				}
			{ StateName= Death }

		]
	ChildNames 	= [ TheHealthBar SelectCircleMedium FX_ExaustSmoke1 TankTracks ExplSelectorTank01 PresHumvee_FlyingParts ]
}

