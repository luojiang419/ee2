//------------------------------------------------------------------------------------------------
//	AMERICAN 6 - OH-56 MOHAWK OBSERVATION HELICOPTER
//------------------------------------------------------------------------------------------------
UnitType UniqueUnitOH58
{
	parent = Helicopter
	properties {
		displayName = tx_utn_OH58_name
		DisplayNameScenEdit = tx_utn_OH58_sname
		VerboseTooltip = vtt_unit_OH58
		hitpoints = 350

	}
	sounds {
		sndCmdMove = ["v_LightMounted2_13_com01" "v_LightMounted2_13_com02"]
		sndSelection = ["v_LightMounted2_13_sel01"]
    	}
	abilities [
		AircraftMove {speed = 3.45; angSpeed = 90; CruisingHeight = 3.0; ElevChangeRate = 0.5; canHover = 1}
		LOS { range = 7 }
	]
	icon = icon_unit_MissileHelicopter
}
// Add to mobile units for a blobby ellipsoid shadow
ShadowData        OH56Shadow
{
	Flags = (IsMobile)
	FlatBillboard
	{
		TextureFilename = LLM13_MissileHelicopter_shadow.tga
		WidthScale = 0.9
		LengthScale = 0.9
		HeightScale = 0.1
	}
}

UnitModel UniqueUnitOH58
{
	Parent		= BaseHelicopter
	ScaleType 	= kScaleVehicle
	DefaultModel 	= LLM13_Mohawk.nif
      ChildNames 	= [ TheHealthBar SelectCircleHelicopter Muzzle_MissHelicopter 
						expl_heli_Tandrill MissileHelicopter_FlyingParts OH56Shadow ]
	States 		= 
[
		{	StateName = Idle	AnimName = llm13_missilehelicopter_idle.kf		
				TextKeys = [ 
					{ Name = HIDE_NODE Data = swipe 	KeyTime = 0 }
					{ Name = START_SOUND Data = fx_move_helicopter_01 }
					]}
		{ 	StateName = Walk	AnimName = llm13_missilehelicopter_walk.kf		
				TextKeys = [ 
					{ Name = HIDE_NODE Data = swipe 	KeyTime = 0 }
					{ Name = START_SOUND Data = fx_move_helicopter_01 }
					]}
		{ 	StateName = Attack1	AnimName = llm13_missilehelicopter_attack.kf	
				TextKeys = [ 
					{ Name = HIDE_NODE Data = swipe 	KeyTime = 0 }
					{ Name = PLAY_SOUND Data = fx_battle_rocket_launch }
					]}
		{ 	StateName = Death	AnimName = llm13_missilehelicopter_death.kf		
				TextKeys = [ 
					{ Name = HIDE_NODE Data = swipe 	KeyTime = 0 }
					]}
]
}

