//------------------------------------------------------------------------------------------------
//	CARGO SHIP
//------------------------------------------------------------------------------------------------
UnitType CargoShip
{
	parent = NavalShallow
	properties {
		RPS = SeaNonCombat
		SizeX = 1.5
		SizeY = 0.5
		mass = 1
		hitpoints = 200
		VerboseTooltip = vtt_unit_CargoShip
		displayName = tx_utn_cargoShip_name
		popCount = 1
	}
	sounds = {
	}
	abilities = [
		NavalMove {speed = 1.6; accel = 1.0; angSpeed = 90}
		LOS { range = 5 }
		Produce {  } // needs produce ability for EffectSpawn
		Garrison { 
			garrisonType = NavalTransport; 
			numOfSlots = 40;
			healPoints = 25;		// Each unit type garrison heals this many points per second
			GarrisonFlagModelName = "GarrisonShip"
		}
	]
}

