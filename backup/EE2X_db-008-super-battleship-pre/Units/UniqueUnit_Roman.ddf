//------------------------------------------------------------------------------------------------
//	UNIQUE UNIT ROMAN LEGIONNAIRE (EPOCHS 1-5)
//------------------------------------------------------------------------------------------------
UnitType UniqueUnitRoman1
{
	parent = HeavyInfantry1
	properties {
		DisplayName = tx_utn_UURoman1_name
		DisplayNameScenEdit = tx_utn_UURoman1_sname
		VerboseTooltip = vtt_unit_UURoman1
		HitPoints = 0
	}
	sounds {
	}
	abilities = [
		Attack { damage = 0; range = 0; reloadTime = 666; applyDamageTime = 0.5; WeaponType = Melee }
		ConvertAttack { convertTimeModifier = 10.0; range = 5.0; reloadTime = 4.0; applyDamageTime = 1.0; capture = 1 }
		LOS { range = 0 }
		Move {speed = 1.3; angSpeed = 720}
	]
}

//------------------------------------------------
//	UNIQUE UNIT IMPROVEMENTS
//------------------------------------------------

// Veteran Upgrade
UpgradeUnitTypeImprove UniqueUnitRoman1Veteran
{
	unitType = UniqueUnitRoman1
	name = tx_utn_veteran_modify_name
	upgradeRefs = [
		UniqueUnit_Improve_2_5
	]
}

// Elite Upgrade
UpgradeUnitTypeImprove UniqueUnitRoman1Elite
{
	unitType = UniqueUnitRoman1
	name = tx_utn_elite_modify_name
	upgradeRefs = [
		UniqueUnit_Improve_2_5
	]
}

//------------------------------------------------
//	UNIQUE UNIT MODEL
//------------------------------------------------
UnitModel UniqueUnitRoman1
{
	Parent 		= BaseHuman
	DefaultModel 	= civ1_legionnaire_roman.nif
	ChildNames 	= [ UnitShadow ]
	States 		= [
		{	StateName = Idle	AnimName = civ1_legionnaire_roman_idle.kf
                              AnimVariants = [ civ1_legionnaire_roman_idle2.kf]
                              AnimVariantsWeights = [0.4]
                 }
		{ 	StateName = Walk	AnimName = civ1_legionnaire_roman_walk.kf
		}
		{ 	StateName = CaptureAttack1	AnimName = civ1_legionnaire_roman_capture01.kf
                              AnimVariants = [ civ1_legionnaire_roman_capture02.kf ]
                              AnimVariantsWeights = [0.3]
                 }
                { 	StateName = Run	AnimName = civ1_legionnaire_roman_jog.kf
		}

		{ 	StateName = Attack1	AnimName = civ1_legionnaire_roman_attack1.kf	
                              AnimVariants = [ civ1_legionnaire_roman_attack2.kf ]
                              AnimVariantsWeights = [0.4]         
			TextKeys =  [
						{ Name = PLAY_SOUND Data = fx_sword_swing KeyTime = 1.0 }
						]
		 }
		{ 	StateName = Death	AnimName = civ1_legionnaire_roman_death.kf	}
		{	StateName = Flinch	AnimName = civ1_legionnaire_roman_protect01.KF	}
		{	StateName = BeingThrown	AnimName = civ1_legionnaire_roman_flying01.KF
			AnimVariants = [ civ1_legionnaire_roman_flying02.KF ] AnimVariantsWeights = [ 0.5 ]	}
		{	StateName = ThrownDeath	AnimName = civ1_legionnaire_roman_ground_death01.KF	}
			]
	UIRenderingParams {
		xOffset = 0.01
		yOffset = 0.02
		zOffset = -6.43
		scale = 2.69
	}
}
