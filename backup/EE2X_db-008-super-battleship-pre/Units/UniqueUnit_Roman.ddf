{
	Parent		= HeavyInfantry2_05
	DefaultModel 	= CIV7_mercenary_roman.nif
	States 		= [
		{	StateName = Idle	AnimName = CIV7_mercenary_roman_idle01.kf
                              AnimVariants = [ CIV7_mercenary_roman_idle02.kf CIV7_mercenary_roman_idle03.kf CIV7_mercenary_roman_season01.kf ]
                              AnimVariantsWeights = [ 0.2 0.1 0.1 ]
                 }
		{ 	StateName = Walk	AnimName = CIV7_mercenary_roman_walk01.kf	}
                { 	StateName = CaptureAttack1	AnimName = CIV7_mercenary_roman_capture01.kf
                              AnimVariants = [ CIV7_mercenary_roman_capture02.kf ]
                              AnimVariantsWeights = [0.3]
                 }
		{ 	StateName = Run	AnimName = CIV7_mercenary_roman_jog01.kf	}
		{ 	StateName = Attack1	AnimName = CIV7_mercenary_roman_attack01.kf
                              AnimVariants = [ CIV7_mercenary_roman_attack02.kf ]
                              AnimVariantsWeights = [ 0.2 ]
			TextKeys = [
					{ Name = PLAY_SOUND Data = fx_pike_thrust KeyTime = 0.40 }
							] }
		{ 	StateName = Death	AnimName = CIV7_mercenary_roman_death01.kf	}
