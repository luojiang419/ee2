//------------------------------------------------------------------------------------------------
//	HEAVY MOUNTED HERO - UNIT TYPE INFO
//------------------------------------------------------------------------------------------------
UnitType HeavyMountedHero
{
	parent = HeavyMounted1
	placementType = Unplaceable	// @TODO maybe make heroes placeable, but that causes problems with the HeroManager...
	properties {
		SizeX = 0.46
		SizeY = 0.23
	}
	abilities = [
		Hero { HeroClass = HeavyMounted; HeroForUnit = HeavyMounted1 }
		AreaEffect { effects = [ PrimaryHeroArmyBonus SupportingHeroArmyBonus ] }
	]
}

