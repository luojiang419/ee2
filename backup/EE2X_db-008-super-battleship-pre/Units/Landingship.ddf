UnitModel LandingShip_11
{
	Parent			= BaseShip
	DefaultModel = LandingShip.NIF
	ForceScale = 0.13
	States = [
		{ StateName = Idle	}
		{ 	StateName = Walk	
				TextKeys = [{ Name = START_SOUND_UNTIL_ANIM_CHANGE Data = fx_move_aircraftcarrier KeyTime = 0}]}
		{ 	StateName = Death	
				TextKeys = [{ Name = PLAY_SOUND Data = fx_dea_ship_metal_3  KeyTime = 0}]}
		{ StateName= Attack1		
			TextKeys = [ { Name = PLAY_SOUND Data = fx_battle_Laser_01 KeyTime=0.5 } ]
		}
	]

	ChildNames 	= [ ExplSelectorDestroy TheBoatWake6 AircraftCarrier_FlyingParts FX_Smoke_Chimney_Large3 FX_Smoke_Chimney_Large2 ]
	
      UIRenderingParams {
		xOffset = 0.01
		yOffset = 3.43
		zOffset = -0.08
		scale = 1.66
		angle = 47.37
	}
}

