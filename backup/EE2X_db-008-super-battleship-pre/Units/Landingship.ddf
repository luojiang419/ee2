UnitType LandingShip
{
	parent = NavalDeep
	properties {
		rps = Carrier
		SizeX = 3.5
		SizeY = 0.75
		mass = 5
		displayName = tx_utn_LandingShip_name
		verboseTooltip = vtt_unit_LandingShip
		popCount = 2
		hitpoints = 4000
	}
	attributes = [
		HealedByHERC 
			]
	sounds = {
	}
	abilities = [
		NavalMove {speed = 1.8; accel = 1; angSpeed = 60}
		Attack { range = 0; reloadTime = 1; applyDamageTime = 0.66; damage = 0; missileName = "fkjqAmmo" }
		LOS { range = 13 }
		 Produce { 
		}
		Garrison { 
			garrisonType = NavalTransport; 
			numOfSlots = 30;
			healPoints = 50;		// Each unit type garrison heals this many points per second
			GarrisonFlagModelName = "GarrisonShip"
		}
	]
	icon = icon_unit_LandingShip
}
