{
  "name": "ee2x-launcher",
  "version": "0.1.0",
  "private": true,
  "main": "main.js",
  "dependencies": {
    "axios": "^1.7.7",
    "fs-extra": "^11.2.0",
    "ssh2": "^1.17.0"
  },
  "devDependencies": {
    "electron": "^39.2.6",
    "electron-builder": "^26.0.12"
  },
  "scripts": {
    "build": "electron-builder"
  },
  "build": {
    "appId": "com.ee2x.launcher",
    "productName": "地球帝国二代远航版启动器",
    "directories": {
      "output": "../../../output"
    },
    "win": {
      "target": "nsis",
      "requestedExecutionLevel": "requireAdministrator"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "地球帝国二代远航版启动器"
    },
    "files": [
      "**/*"
    ],
    "extraFiles": [
      {
        "from": "../../../Config",
        "to": "Config",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "../../../List",
        "to": "List",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "../../../Data",
        "to": "Data",
        "filter": [
          "**/*"
        ]
      }
    ]
  }
}
