// this UTA is used by the "Overtime" power
// that eminates from the Robotics Factory
//  * Barracks
//  * Mill
//  * Stable
//  * Airport
//  * Dock
//

UnitTypeAttribute Empty
{
	MaskMode = All
	RPSMask = [
		Null
	]
}

UnitTypeAttribute NonHeroes
{
	MaskMode = NotAny
	AbilityMask = [
		Hero
	]
}

