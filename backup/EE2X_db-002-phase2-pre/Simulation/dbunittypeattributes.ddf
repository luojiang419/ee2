	MaskMode = All
	AbilityMask = [Produce]

	UnitTypeFamilies = ["BareBoneBuilding"]
}

UnitTypeAttribute BuildingsAndConstructionSites { UnitTypeFamilies = ["BareBoneBuilding" "ConstructionSite"] }


