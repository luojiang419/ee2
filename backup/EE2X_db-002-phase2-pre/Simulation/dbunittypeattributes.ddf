//Attribute DemoAttribute
//{
//	//MaskMode is either Any or All, and in fact defaults to All, so you don't
//	//always need to specify it.
//	MaskMode = All
//
//	AbilityMask = [
//		Movement		// move (or rotate)
//		Attack			// Attack enemy
//		LOS			// Line-Of-Sight
//		Build			// citizen can build something
//		Construction		// construction: from foundation to the eventual building the passive
//					// receiving end of eUABT_Build
//		Produce			// buildings produce units
//		Connect			// composite units (roads + walls) need info about inter-unit connections
//		GatherFarm		// gather resources and work on farm to gather resource
//		Resource		// contain resource
//		ResourceDropoff		// is a resource drop-off unit
//		TerrainOverlay		// for roads and other units that generate overlays
//		Research		// ability to research
//		Heal			// healing ability of medic unit etc.
//		Garrison		// certain units (usually buildings) can be garrisoned.
//		Convertable		// some units can be converted to/from enemy side by priests
//	]
//	
//	MovementMask = [
//		Foot			// normal land foot unit (default)
//		FootCitizen		// citizen basically
//		Mounted			// mounted unit
//		Wheeled			// wheeled unit
//		Mechanized		// mechanized unit
//		NavalShallow		// naval unit, shallow water
//		NavalDeep		// naval unit, deep water
//		Air			// air unit (no terrain pathing)
//		Projectile		// ammo unit, like an arrow
//	]
//	
//	RPSMask = [
//		Null			// invalid entry
//		LightInfantry		// land units
//		HeavyInfantry
//		LightArtillery
//		AntiAircraft
//		HeavyArtillery
//		LightMounted
//		HeavyMounted
//		Citizen
//		Building
//		LandNonCombat
//		Animal
