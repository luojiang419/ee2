// important units are those whose:
// 1) death the AI/PlayerStats object cares about
// 2) ???
UnitTypeAttribute ImportantUnits
{
	MaskMode = NotAny
	// projectiles are not important (trust me)
	MovementMask = [
		Projectile
	]
}

//Specifically need MaskMode = All for this, because of a cornercase in the
//UTA Contains() method.  Even though it's the default, we should be explicit
//since it depends on this..
UnitTypeAttribute Anything { MaskMode = All }

// Buildings are convertible, but not subject to conversion.  So include the moveable
// ability, which will cull out buildings.
UnitTypeAttribute SubjectToConversion 
{ 
	AbilityMask = [Movement Convertable] 
}

// Buildings that may be captured
UnitTypeAttribute SubjectToCapture
{
  MaskMode = All
  AbilityMask = [ Convertable ]
  UnitTypeFamilies = [ "BareBoneBuilding" ]
}

// UTA used by economic leader's foreign investment power
// Any hostile or neutral
// barracks, stable, mill,
// warehouse, airport, dock,
// market, university, house, or farm.
UnitTypeAttribute SubjectToForeignInvestment
{
	MaskMode = All
  	AbilityMask = [ Convertable ]
	UnitTypeInstances = ["Barracks" "Stable" "Mill" "Warehouse" "Airport"
						 "Dock" "Market" "University" "House" "Farm" "MyOutpost" ]
}

UnitTypeAttribute Buildings { UnitTypeFamilies = ["BareBoneBuilding"] }

