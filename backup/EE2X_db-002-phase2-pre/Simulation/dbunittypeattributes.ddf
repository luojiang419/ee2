// This is for the CityCenter heal effect, for allied units.  We can heal everyone,
// except spies. So that means we pull out the SpecialForces RPS, and add a few
// UnitTypeFamilies for non-spy SpecialForces units.
UnitTypeAttribute LandRPSNoSpy {
	MaskMode = Any
	RPSMask = [
		LightInfantry		// land units
		HeavyInfantry
		LightArtillery
		HeavyArtillery
		LightMounted
		HeavyMounted
		Citizen
		LandNonCombat
		Priest
		Animal
		Ram
		HERC
	]
	UnitTypeFamilies = [
		// For Mobile AA
		"LightArtillery2"
		// For SpecialForces that are not spies
		"HercElecWarfare"
		"Leader"
		"Scout"
	]
}

