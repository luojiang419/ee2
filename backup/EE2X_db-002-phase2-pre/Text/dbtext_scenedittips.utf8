tt_se_cinematics_insshot,"""在所选镜头之前添加镜头"""
tt_se_cinematics_remshot,"""移除所选镜头"""
tt_se_seasons_cancel,"""重置季节设置"""
tt_se_seasons_ok,"""应用季节设置"""
tt_se_cinematic_only,"""次要玩家不会出现在外交以及战后统计等场景中"""
tt_se_player_name_local,"""选中代表该玩家为本地玩家"""
tt_se_player_civCustName,"""自定义文明名称"""

// verbose tooltips
vtt_se_player_name_local,"""本地玩家名称\n\n如果你选中了这个选项框, 您输入的名称应当存在是文本数据库中一个条目的名称。当您载入剧情时, 本地玩家名称会被载入使用。"""
vtt_se_player_civCustName,"""自定义文明名称\n\n此处输入的名称应当是一个有效的文本数据库条目, 在游戏中，它会替代原有文明名称。"""

tt_se_atmosphere_sundiralt,"""高度角 (指向太阳)\n(0度为水平, 90度为垂直向上)"""
tt_se_atmosphere_sundirazi,"""方位角 (指向太阳)\n(0度为北, 90度为东, 180度为南, 以此类推)"""
tt_se_atmosphere_dirfromsun,"""XYZ direction FROM the sun:\n(%X%, %Y%, %Z%)"""
