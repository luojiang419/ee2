tt_se_terr_selection2,"""鼠标右键选择"""
tt_se_terr_sample,"""对地图上某点的地形进行取样"""
tt_se_group_create,"""创建一个群组"""
tt_se_group_delete,"""删除所选群组"""
tt_se_group_assign,"""指派所有所选单位到所选群组"""
tt_se_group_remove,"""从所选群组中移除所有所选单位"""
tt_se_group_select,"""选择 被选中群组 中的所有单位"""
tt_se_shot_controlPts_tanRigid,"""未手动设置具体参数时，将自动填入测算出的最佳参数"""
