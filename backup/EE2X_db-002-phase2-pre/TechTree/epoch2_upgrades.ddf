//------------------------------------------------
//	MAIN BRANCH
//------------------------------------------------
UpgradeSet AdvanceEpoch2 {
	upgrades = [
		UpgradeEpoch {epoch = 2;}
	]
}

// Main2
UpgradeRefSet MainEpoch2 {
	upgrades = [
		AdvanceEpoch2
		FarmUpgradeEpoch2
		dapaoUpgradeEpoch2
		WallFragmentUpgradeEpoch2	// @TODO we should have a TT node for wall fragment, and just specify this there
		WallTowerAbilitiesEpoch2
		
		// LEADERS
		LeaderEconomicUpgradeEpoch2
		LeaderMilitaryUpgradeEpoch2
		LeaderImperialUpgradeEpoch2
		KingRegicideUpgradeEpoch2
		
		// EE2X HERO UPGRADES
		HeavyInfantry2HeroUpgradeEp2
		LightMountedHeroUpgradeEp2
		HeavyMountedHeroUpgradeEp2
		HeavyArtilleryHeroUpgradeEp2
	]
}

