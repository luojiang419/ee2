UnitType ImperialGuard
{
	parent = Human
	properties {
		DisplayName = tx_utn_ImperialGuard_name
		DisplayNamePlural = tx_utn_ImperialGuard_pname
		DisplayNameScenEdit = tx_utn_ImperialGuard_sname
		VerboseTooltip = vtt_unit_ImperialGuard
		rps = HeavyInfantry
		SizeX = 0.125
		SizeY = 0.125
		HitPoints = 150
		mass = 1
	}
	sounds = {
			sndCmdMove = ["v_HeavyInfantry1_09_spe01" "v_HeavyInfantry1_09_com01" "v_HeavyInfantry1_09_com02"]
			sndCmdAttack = ["v_HeavyInfantry1_09_spe01" "v_HeavyInfantry1_09_spe01" "v_HeavyInfantry1_09_com01" "v_HeavyInfantry1_09_com02"]
			sndSelection = ["v_HeavyInfantry1_09_sel01"]
	}
	abilities = [
		Attack { range = 9; reloadTime = 1.25; applyDamageTime = 0.5; damage = 16 }
		ConvertAttack { convertTimeModifier = 3.0; range = 0.2; reloadTime = 4.0; applyDamageTime = 1.0; capture = 1 } // capture ability
		LOS { range = 9 }
		Move {speed = 1.7250; angSpeed = 720}
	]
	attributes = [
		CanJoinHeroArmy
	]
	icon = icon_unit_camp_frenchImperial
}

