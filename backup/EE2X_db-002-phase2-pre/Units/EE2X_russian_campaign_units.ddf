////////////////////////////////////////
// Special units for Russian Campaign.
////////////////////////////////////////

///////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
// Russian University
///////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
UnitType RussianUniversity
{
	parent = Building
	properties {
		SizeX = 3
		SizeY = 3
		FootprintSizeX = 4.5
		FootprintSizeY = 4.5
		OffsetX = 0.75
		OffsetY = 0.75
		UndertextureSizeX = 3
		UndertextureSizeY = 3
		mass = 1
		DisplayNameScenEdit = tx_utn_rus_univer_sname
		displayName = tx_utn_rus_univer_name
		VerboseTooltip = vtt_unit_RussianUniversity
		requiredOpenSides = kBuildingOpenSides_NegY
		RallyPlacementFlags = ( Fortress | Tower | Terrain )
	}
	sounds {
		sndSelection = ["University_select"]
    	}
	fullMapOverlay { sprite = spr_fullmap_university}
	abilities = [
		LOS { range = 0 }
		Garrison { 
			garrisonType = UniWarehouseOilDerrickCityCenter; 
			numOfSlots = 2;
			gatherRate = 0.08;	// number of tech points gathered per second for each garrisoned UnitType
			gatherType = Tech;
			rightClickToGarrison = 1;
			GarrisonFlagModelName = "GarrisonFlag"
		}
		Convertable {
			convertTimeModifier = 100.0;  //
			garrisonedUnitModifier = 0.1; // 10% increase in capture time
			garrisonedUnitDamage = 1.0;	  // hitpoints subtracted from capturer per round per garrisoned unit
			damageRate = 10.0;			  // hitpoints subtracted from capture target hitpoints per round
			capture = 1;
			resourcesTransferred = [
				{
					resource = Tech
					percentTransferred = 0.1
					NativeTribesAmountTransferredMin = 10.0
					NativeTribesAmountTransferredMax = 20.0
				}
			]
		}
	]
	icon = icon_unit_university_10
}

UpgradeAbilities RussianUniversityGarrison
{
	upgradedAbilities = [
		Garrison { 
			garrisonType = UniWarehouseOilDerrickCityCenter; 
			numOfSlots = 3;
			gatherRate = 0.03;	// number of tech points generated per second.
			gatherType = Tech;
			rightClickToGarrison = 1;
			GarrisonFlagModelName = "GarrisonFlag"
		}
	]
}

UnitModel RussianUniversity
{
	Parent		= BaseBuilding
	DefaultModel 	= bld_university10_ru.nif
	ChildNames	= [HugeGlow UnderUniversity ExplSelectorBuild_Medium ExplPartsUniversity7]
	UIRenderingParams {
		xOffset = 0.01
		yOffset = 0.16
		zOffset = -1.09
		scale = 1.15
		angle = 45.00
		rotationSpeed = 0.00
		pitch = 40.26
		lightAngle = 30.00
		lightPitch = 90.00
		lightDiffuse = [50 50 45 255]
		lightSpecular = [0 0 0 255]
		lightAmbient = [40 40 40 255]
	}
}


///////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
///NAPOLEON
///////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
UnitType Napoleon
{
	parent = LeaderMilitary
	properties {
		DisplayName = tx_utn_Napoleon_name
		DisplayNamePlural = tx_utn_Napoleon_pname
		DisplayNameScenEdit = tx_utn_Napoleon_sname
		VerboseTooltip = vtt_unit_Napoleon
//		SizeX = 0.4
//		SizeY = 0.4
		mass = 2
		moveType = Mounted
		HitPoints = 5000
	}
	sounds 	{
			sndCmdMove = ["v_leader_mil_02_com01" "v_leader_mil_02_com02"]
			sndCmdAttack = ["v_leader_mil_02_com01" "v_leader_mil_02_com02" "v_leader_mil_02_spe01"]
			sndSelection = ["v_leader_mil_02_sel01"]
	}
	abilities = [
		PowerReserve { timeToRecharge = 60 }
		Attack { range = 0.2; reloadTime = 666; applyDamageTime = 1.2; damage = 24 }
		Move {speed = 3.45; angSpeed = 180}
		LOS { range = 5 }
		AreaEffect {
			effects = [ HighMorale
			]
		}
		SpecialPower {
			effects = [ FireAndManeuver
			]	
		}
	]
}


// 'Fire and Manuever' active power
UpgradePowers NapoleonPowerUpgradeEpoch6
{
	unitType = Napoleon
	effectsToAdd = [ FireAndManeuver ]
	effectsToRemove = [ Rally ]
}

// 'High Morale' passive power
UpgradeEffects NapoleonEffectUpgradeEpoch6
{
	unitType = Napoleon
	effectsToAdd = [ HighMorale ]
	effectsToRemove = [ HighFervor ]
}

// Move ability upgrade
UpgradeAbilities NapoleonMoveUpgradeEpoch6
{
	upgradedAbilities = [
		Move {speed = 3.45; angSpeed = 180}
	]
}

// Attack Ability Upgrade
UpgradeAbilities NapoleonAttackUpgradeEpoch6
{
	upgradedAbilities = [
		Attack { damage = 0; range = 0; reloadTime = 666; applyDamageTime = 1.2 }
	]
}


UnitModel Napoleon
{
	parent	 	= BaseHuman
	DefaultModel 	= LM10_Napoleon_fr.nif
	ForceScale = 0.300
	ChildNames	= [ ThePowerBar UnitShadow ]
	States 		= [
		{	StateName = Idle	AnimName = sh_leader_idle01.kf	
                              AnimVariants = [ sh_leader_idle02.kf sh_leader_idle03.kf sh_leader_battlecry01.kf sh_leader_battlecry02.kf ]
                              AnimVariantsWeights = [ 0.05 0.05 0.05 0.05 ]
                 }
		{ 	StateName = Walk	AnimName = sh_leader_walk01.KF}
		{ 	StateName = Run	AnimName = sh_king_run01.KF } 
		{ 	StateName = Attack1	AnimName = sh_leader_attack01.kf
			TextKeys = [
							{ Name = PLAY_SOUND Data = fx_mace_swing KeyTime = 1.2 }
							] }
		{ 	StateName = Death	AnimName = sh_leader_death01.kf	}
		{	StateName = Flinch	AnimName = sh_elitecavalry_protect01.KF	}
		{	StateName = BeingThrown	AnimName = sh_elitecavalry_flying01.KF
			AnimVariants = [ sh_elitecavalry_flying02.KF ] AnimVariantsWeights = [ 0.5 ]	}
		{	StateName = ThrownDeath	AnimName = sh_elitecavalry_ground_death01.KF	}
			]
	UIRenderingParams {
		xOffset = -1.84
		yOffset = 2.03
		zOffset = -2.21
		scale = 1.53
		angle = 47.37
	}
}


