//------------------------------------------------------------------------------------------------
//	UNIQUE UNIT ENGLISH DRUID (EPOCHS 1-5)
//------------------------------------------------------------------------------------------------
UnitType UniqueUnitEnglish1
{
	parent = Priest
	properties {
		DisplayName = tx_utn_UUEnglish1_name
		DisplayNameScenEdit = tx_utn_UUEnglish1_sname
		VerboseTooltip = vtt_unit_UUEnglish1
		HitPoints = 0
		SizeX = 0.225
		SizeY = 0.225
		mass = 1
		rps = Priest
	}
	sounds = {
	}
	abilities = [
		// inherit move from human Move {speed = 1.3; angSpeed = 180}
		PowerReserve { timeToRecharge = 60 }
		ConvertAttack { convertTimeModifier = 4.0; range = 8; reloadTime = 2; applyDamageTime = 0.5; }
		SpecialPower { range = 2; effects = [ Bless ]	}
	]
}

//------------------------------------------------
//	UNIQUE UNIT IMPROVEMENTS
//------------------------------------------------

// Veteran Upgrade
UpgradeUnitTypeImprove UniqueUnitEnglish1Veteran
{
	unitType = UniqueUnitEnglish1
	name = tx_utn_veteran_modify_name
	upgradeRefs = [
		UniqueUnitHP_Improve_Default
	]
}

// Elite Upgrade
