	upgradeRefs = [
		UniqueUnitHP_Improve_Default
	]
}

//------------------------------------------------
//	UNIQUE UNIT MODEL
//------------------------------------------------
UnitModel UniqueUnitEnglish1
{
	Parent		= Priest
	DefaultModel 	= CIV1_Druid_british.nif
        ChildNames 		= [ UnitShadow ThePowerBar ]
	States 		= [
		{	StateName = Idle	AnimName = CIV1_Druid_british_idle01.kf  }
		{ 	StateName = Walk	AnimName = CIV1_Druid_british_walk01.kf   }
		{ 	StateName = Run	AnimName = CIV1_Druid_british_jog01.kf   }
		{ 	StateName = Attack1	AnimName = CIV1_Druid_british_attack01.kf	
			TextKeys = [ { Name = ATTACH_VISUAL	Data = FX_Conversion }
		   		     { Name = PLAY_SOUND 	Data = fx_priest_convert KeyTime = 0.0 }
						]
		}
		{	StateName = AttackTolerance AnimName = CIV1_Druid_british_attack01.kf
			TextKeys = [ { Name = ATTACH_VISUAL	Data = FX_Tolerance_Priest }
						]
		}
		{
			StateName = Bless AnimName = CIV1_Druid_british_attack01.kf
			TextKeys = [ { Name = ATTACH_VISUAL	Data = FX_Bless } ]
		}
			
		{ 	StateName = Death	AnimName = CIV1_Druid_british_death01.kf   }
		{	StateName = Flinch	AnimName = CIV1_Druid_british_protect01.KF	}
		{	StateName = BeingThrown	AnimName = CIV1_Druid_british_flying01.KF
			AnimVariants = [ CIV1_Druid_british_flying02.KF ] AnimVariantsWeights = [ 0.5 ]	}
		{	StateName = ThrownDeath	AnimName = CIV1_Druid_british_ground_death01.KF	}
			]
	UIRenderingParams {
		xOffset = 0.01
		yOffset = -0.62
		zOffset = -9.18
		scale = 2.94
		angle = 23.68
	}
}

