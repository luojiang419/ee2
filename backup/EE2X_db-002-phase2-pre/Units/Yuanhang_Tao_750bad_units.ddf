UnitType NM_mortarre
{
	parent = Artillery
	properties {
		SizeX = 1
		SizeY = 1
		mass = 2
popCount = 10
		hitpoints = 150
rps = BuildingCombat
displayName = tx_utn_NM_mortarre_name
verboseTooltip = vtt_unit_NM_mortarre
	}
	sounds {
		sndDeath =  ["fx_death_male_01" "fx_death_male_02" "fx_death_male_03" "fx_death_male_04" "fx_death_male_05" "fx_death_male_06" "fx_death_male_07"]
    	}
	abilities = [
		Attack { range = 12; reloadTime = 4; applyDamageTime = 0.3; damage = 200; missileName = "CannonBall02"; ignoreBlocking = 1; areaDamageRadius = 0; areaDamageFriendlyRatio = 0; minRangeMobile = 8.0; minRangeImmobile = 8.0; throwUnits = true }
	LOS { range = 15 }
		Move {speed = 1.5; angSpeed = 180}
Garrisonable { garrisonTypes = [ Fortress NavalTransport ] }
Convertable { 
			convertTimeModifier = 10.0;  //
			garrisonedUnitModifier = 0.0; // 10% increase in capture time
			garrisonedUnitDamage = 0.0;	  // hitpoints subtracted from capturer per round per garrisoned unit
			damageRate = 0.0;			  // hitpoints subtracted from capture target hitpoints per round
			capture = 1;
		} // may be captured
	]
attributes = [ CanJoinHeroArmy ]
icon = icon_unit_NM_mortarre
}

UnitModel NM_mortarre
{
	Parent		= BaseArtillery
	DefaultModel 	= NM_mortarre.nif
	States 		= [
		{	StateName = Idle	AnimName = LLA9_fieldgun_idle.kf   }
		{ 	StateName = Walk	AnimName = LLA9_fieldgun_walk.KF   
				TextKeys = [	{ Name = START_SOUND_UNTIL_ANIM_CHANGE Data = fx_move_wheeled_04 KeyTime = 0 }]}
		{ 	StateName = Attack1	 AnimName = LLA9_fieldgun_attack.kf
				TextKeys = [
								{ Name = PLAY_SOUND Data = Cannon_firing1 KeyTime = 0.29 }
						]}

		{ 	StateName = Death	AnimName = LLA9_fieldgun_death.kf  }
			]
	ChildNames 		= [ Muzzle_FieldGun ArtilleryTracks TheSiegeUnitDamageEffect ]
	DamageDecalsSetName = BuildingDamageDecals
	UIRenderingParams {
		xOffset = 1.05
		yOffset = 0.13
		zOffset = -0.92
		scale = 1.66
		angle = 28.42
	}
}
