UnitType French320mm
{
	parent = HeavyArtillery
	properties {
		SizeX = 1.0
		SizeY = 1.0
		mass = 1
		popCount = 3
		HitPoints = 600
		displayName = tx_utn_French320mm_name
verboseTooltip = vtt_unit_French320mm
	}
	sounds = {
	}
	abilities = [
		Attack { range = 15; reloadTime = 10; applyDamageTime = 1.5; damage =400; missileName = "TankShell03"; ignoreBlocking = 1; areaDamageRadius = 3; areaDamageFriendlyRatio = 0.5; packTime = 3.5; unpackTime = 3.5; minRangeMobile = 3.0; minRangeImmobile = 3.0 }
		Move {speed = 0.5; angSpeed = 20}
		LOS { range = 15 }
	]
	icon = icon_unit_French320mm
}

UnitModel French320mm
{
	Parent		= BaseArtillery
        DefaultModel 	= French320mm.nif
	ChildNames 	= [ Muzzle_FiringShell ArtilleryTracks TheSiegeUnitDamageEffect ]
//	Muzzle_Tank Muzzle_FiringShell
	States 		= [
		{	StateName = Idle	AnimName = LLA11_FieldArtillery_idle01.kf 
                                                                 TextKeys = [
								{ Name = HIDE_NODE Data = boom KeyTime = 0 }
				]}
		{   	StateName = UnpackedIdle  AnimName = LLA11_FieldArtillery_unpackidle01.kf 
                                                                 TextKeys = [
								{ Name = SHOW_NODE Data = boom KeyTime = 0 }
				]}
                                { 	StateName = Walk	AnimName = LLA11_FieldArtillery_walk01.kf 
                                                                 TextKeys = [
								{ Name = HIDE_NODE Data = boom KeyTime = 0 }
				]}
		{	StateName = UnpackedWalk  AnimName = LLA11_FieldArtillery_unpackwalk01.kf 
                                                                 TextKeys = [
								{ Name = SHOW_NODE Data = boom KeyTime = 0 }
				]}
                { 	StateName = Attack1	AnimName = LLA11_FieldArtillery_attack01.kf
				TextKeys = [ { Name = PLAY_SOUND Data = Cannon_firing1 KeyTime = 1.5 }
                                                                                     { Name = SHOW_NODE Data = boom KeyTime = 0 }
                                                                                     { Name = HIDE_NODE Data = boom KeyTime = 0.5 } 
                                                                                     { Name = SHOW_NODE Data = boom KeyTime = 1.6}
                                                                                   ] }
		{	StateName = Pack	AnimName = LLA11_FieldArtillery_pack01.kf 
                                                                 TextKeys = [
								{ Name = HIDE_NODE Data = boom KeyTime = 0 }
				]}
		{	StateName = Unpack	AnimName = LLA11_FieldArtillery_unpack01.kf 
                                                                 TextKeys = [
								{ Name = HIDE_NODE Data = boom KeyTime = 0 }
                                                                                                                                { Name = SHOW_NODE Data = boom KeyTime = 0.3 }
				]}
		{ 	StateName = Death	AnimName = LLA11_FieldArtillery_unpackdeath01.kf 
                                                                 TextKeys = [
								{ Name = HIDE_NODE Data = boom KeyTime = 0 }
				]}
                	{   	StateName = PackedDeath AnimName = LLA11_FieldArtillery_death01.kf 
                                                                 TextKeys = [
								{ Name = HIDE_NODE Data = boom KeyTime = 0 }
				]}  

			]
	DamageDecalsSetName = BuildingDamageDecals
	UIRenderingParams {
		xOffset = 1.05
		yOffset = 0.34
		zOffset = 0.13
		scale = 1.79
		angle = 28.42
	}
}
UnitType Eagle
{
	parent = Aircraft
      VisualName=EagleUnitModel
	icon = icon_unit_Eagle
      properties {
		rps = SpecialForces
            SizeX = 0.2
		SizeY = 0.2
		mass = 0
		popCount = 1
            displayName = tx_utn_Eagle_name
		DisplayNameScenEdit = tx_utn_Eagle_sname
		VerboseTooltip = vtt_unit_Eagle
		HitPoints = 300
	}
	sounds = {
	}
	abilities = [
		AircraftMove {speed = 3.45; angSpeed = 90; CruisingHeight = 4.0; ElevChangeRate = 0.5}
            LOS { range = 13 }
            AreaEffect {
			effects = [ 
				CanbeStealth,
                        SuperVision
			]
		}
            SpecialPower { 
			range = 0.1; 
			canDisguise = true;
			
			spottedTextDBI = tx_eagle_spotted_owner
			spotterTextDBI = tx_eagle_spotted_spotter
			
			doesNotRequirePowerReserve = true; // disable "power bar" and "power reserve ability"
		}
           		
	]
	attributes [
		GoesOnAirMissions
	]
	fullMapOverlay { sprite = spr_fullmap_smallunit; scale = 1.5; }
}

// Add to mobile units for a blobby ellipsoid shadow
ShadowData        EagleShadow_01
{
	Flags = (IsMobile | ImmutableBounds)
	FlatBillboard
	{
		TextureFilename = anc12_ParatrooperPlane_shadow.tga
		WidthScale = 0.9
		LengthScale = 0.9
		HeightScale = 0.1
	}
      
}

UnitModel EagleUnitModel
{
	Parent		= HawkBase
	DefaultModel 	= fauhawk.nif
	ScaleType 	= kScaleVehicle
      ForceScale=0.260
      DefaultState 	= Idle
      ChildNames 	= [ UnitShadow ]
	States = [
		{ StateName = Idle }
		{ StateName = Walk AnimName = sh_fauhawk_idle01.kf
		  AnimVariants = [sh_fauhawk_idle02.kf ] AnimVariantsWeights = [ 0.3 ] 
		}
		{ 	StateName = Death	AnimName = sh_fauhawk_death01.kf }
	]

	UIRenderingParams {
		xOffset = 1.84
		yOffset = 0.77
		zOffset = -1.14
		scale = 2.02
		angle = 32.73
		rotationSpeed = 0.00
		pitch = 32.73
		lightAngle = 30.00
		lightPitch = 90.00
		lightDiffuse = [50 50 45 255]
		lightSpecular = [0 0 0 255]
		lightAmbient = [40 40 40 255]
	}


}
