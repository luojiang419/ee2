//------------------------------------------------------------------------------------------------
//	DOCK
//------------------------------------------------------------------------------------------------
UnitType Dock
{
	parent = Building
	placementType = Dock
	properties {
		SizeX = 4.0
		SizeY = 5.0
		mass = 1
		displayName = tx_utn_dock_name
		DisplayNameScenEdit = tx_utn_dock_sname
		VerboseTooltip = vtt_unit_Dock
		RallyPlacementFlags = ( Dock | Water | Fish | Allied | Neutral )
	}
	sounds {
    	}
	fullMapOverlay { sprite = spr_fullmap_dock }
	abilities = [
		LOS { range = 0 }
		AreaEffect {
			effects = [ 
				DockHealing
			]
		}
		ResourceDropoff { type = kResourceType_Food; }
		GarrisonTrade { 
			garrisonType = Dock; 
			numOfSlots = 4;
			healPoints = 100;		// 2 hit points heal every second for each UnitType
			rightClickToGarrison = 1;
			GarrisonFlagModelName = "GarrisonFlag"
		}
		Convertable {
			convertTimeModifier = 200.0;  //
			garrisonedUnitModifier = 0.1; // 10% increase in capture time
			garrisonedUnitDamage = 1.0;	  // hitpoints subtracted from capturer per round per garrisoned unit
			damageRate = 10.0;			  // hitpoints subtracted from capture target hitpoints per round
			capture = 1;
			resourcesTransferred = [
				{
					resource = Gold
					percentTransferred = 0.1
					NativeTribesAmountTransferredMin = 200.0
					NativeTribesAmountTransferredMax = 300.0
				}
			]
		}
	]
}

