//------------------------------------------------------------------------------------------------
//	MERCHANT SHIP
//------------------------------------------------------------------------------------------------
UnitType MerchantShip
{
	parent = NavalShallow
	properties {
		SizeX = 1.5
		SizeY = 0.5
		//SizeX = 1.7
		//SizeY = 1.02
		mass = 1
		hitpoints = 50
		VerboseTooltip = vtt_unit_MerchantShip
		displayName = tx_utn_MerchShip_name
		popCount = 2
	}
	abilities = [
		NavalMove {speed = 1.2; angSpeed = 80}
		LOS { range = 5 }
		Trade { MarketType = Docks; 
				GoldPerTile = 0.13; 
				TechPerTile = 0.00; 
				TechBonusEpochDiff = 0.00; 
				TechBonusLikelyhood = [ .01 .02 .04 .08 .1 ]
				ForeignTradeAllowed = false
				timeToLoad = 5}
	]
}

//------------------------------------------------
//	EPOCH 1
//------------------------------------------------

//------------------------------------------------
//	EPOCH 3 TECH TREE UPGRADE
//------------------------------------------------
// Upgrade purchased through the tech tree that allows the player to trade with other players
UpgradeAbilities MerchantShipTechTreeUpgrade
{
	UnitType = MerchantShip
	upgradedAbilities = [
		Trade { MarketType = Docks; 
				GoldPerTile = 0.13; 
				TechPerTile = 0.0; 
				TechBonusEpochDiff = 0.0;
				TechBonusLikelyhood = [ .10 .15 .20 .25 .30 ] 
				ForeignTradeAllowed = true
				timeToLoad = 5}
	]
}

