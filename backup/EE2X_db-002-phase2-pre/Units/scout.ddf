//------------------------------------------------------------------------------------------------
//	SCOUT - UNIT TYPE INFO
//------------------------------------------------------------------------------------------------
UnitType Scout
{
	parent = Human
	properties {
		SizeX = 0.4
		SizeY = 0.4
		mass = 1
		displayName = tx_utn_Scout_name
		displayNamePlural = tx_utn_Scout_pname
		stance = Cautious
		VerboseTooltip = vtt_unit_scout
		rps = SpecialForces
	}
	abilities [
		Attack { range = 0.2; reloadTime = 2; applyDamageTime = 0.5; damage = 0 }
		Move {speed = 1.6; angSpeed = 720; angAccel = 720}		
		LOS { range = 0 }
	]
	attributes = [ 
	]
}

