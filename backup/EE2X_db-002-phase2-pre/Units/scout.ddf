//------------------------------------------------------------------------------------------------
//	SCOUT - VISUAL INFO
//------------------------------------------------------------------------------------------------

ShadowData        ScoutShadow
{
	Flags = (UseStencil | IsMobile | ImmutableBounds)
	FlatBillboard
	{
		TextureFilename = Scout_Shadow.tga
		WidthScale = 1.0
		LengthScale = 1.0
		HeightScale = 0.1
	}
}

//------------------------------------------------
//	EPOCH 1
//------------------------------------------------

UnitModel Scout
{
	OutlineType		= kOutlineMake
	ScaleType 		= kScaleUnit
	ChildNames 		= [ TheHealthBar SelectCircleScout SmallGlow ExplSelectorHuman01 
						Footprints SinkCorpse ScoutShadow VisualThrownUnit 
						HemisphereLighting_Unit DynamicLighting_Unit
					  ]
	DefaultState 		= Idle	
	DefaultModel 		= LSF1_scout.nif
	States 		= [
		{	StateName = Idle	AnimName = sh_Scout1_1_idle01.kf
                              AnimVariants = [ sh_Scout1_1_idle02.kf]
                              AnimVariantsWeights = [0.4]
                 }

      	{	StateName = Jog		AnimName = sh_Scout1_1_jog01.KF   }
		{ 	StateName = Walk	AnimName = sh_Scout1_1_jog01.KF   }
		{ 	StateName = Death	AnimName = sh_Scout1_1_death01.KF  }
		{ 	StateName = Attack1	AnimName = sh_Scout1_1_attack01.KF
			TextKeys = [ { Name = PLAY_SOUND Data = fx_battle_swing      KeyTime = 0.5 } ]
		}
		{	StateName = Flinch	AnimName = sh_Scout1_1_protect01.KF	}
		{	StateName = BeingThrown	AnimName = sh_Scout1_1_flying01.KF
			AnimVariants = [ sh_Scout1_1_flying02.KF ] AnimVariantsWeights = [ 0.5 ]	}
		{	StateName = ThrownDeath	AnimName = sh_Scout1_1_ground_death01.KF	}
			]
	UIRenderingParams {
		xOffset = 0.00
		yOffset = 7.83
		zOffset = -10.00
		scale = 4.87
		angle = 45.00
		rotationSpeed = 0.00
		pitch = 20.00
		lightAngle = 30.00
		lightPitch = 90.00
		lightDiffuse = [50 50 45 255]
		lightSpecular = [0 0 0 255]
		lightAmbient = [40 40 40 255]
	}
}

