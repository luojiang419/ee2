//------------------------------------------------------------------------------------------------
//	ANIMAL
//
//	@NOTE for @HACKY code reasons, all Dead Animal unit types should be named with the prefix
//	DeadAnimal
//
//------------------------------------------------------------------------------------------------

UnitType LandAnimal
{
	ownertype = WorldOnly	// do we ever need to allow human to own/command animals??? - Xinbo
	parent = LandMammal
	properties {
		rps = Citizen
		SizeX = 0.225
		SizeY = 0.225
		mass = 1
	}
	sounds {
	}
	abilities = [
		LOS { range = 3 }
	]
}
UnitType NavalAnimal
{
	ownertype = WorldOnly	// do we ever need to allow human to own/command animals??? - Xinbo
	parent = NavalShallow
	placementType = DeepWater
      properties {
		rps = Citizen
		SizeX = 1.0
		SizeY = 1.0
		mass = 1
	}
	sounds {
	}
	abilities = [
		LOS { range = 6 }
	]
}

// dead animal type (has no abilities)
UnitType DeadAnimal
{
	placementType = Unplaceable
	OwnerType = WorldOnly
	properties {
		SizeX = 0.225
		SizeY = 0.225
		mass = 0
		hitpoints = 1000
		rps = Citizen
		FootprintType = kFootprintType_Rectangle
		mmColor = [224,224,224,255]
	}
	fullMapOverlay { sprite = spr_fullmap_resource }
	abilities [ 
//		Resource { type = kResourceType_Food; alwaysExhaustible = 1; amount = 500; maxNumOfWorkers = 2 }
	]
}
UnitType DeadAnimal_NoFood
{
	placementType = Unplaceable
	OwnerType = WorldOnly
	properties {
		SizeX = 0.225
		SizeY = 0.225
		mass = 0
		hitpoints = 5
		rps = Citizen
		FootprintType = kFootprintType_Rectangle
		mmColor = [224,224,224,255]
	}
	fullMapOverlay { sprite = spr_fullmap_resource }
	abilities [ 
		Resource { type = kResourceType_Food; alwaysExhaustible = 1; amount = 0; maxNumOfWorkers = 6 }
	]
}

