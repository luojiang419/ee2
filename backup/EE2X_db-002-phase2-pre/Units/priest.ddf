//------------------------------------------------------------------------------------------------
//	PRIEST
//------------------------------------------------------------------------------------------------
UnitType Priest
{
	parent = Human
	properties {
		SizeX = 0.125
		SizeY = 0.125
		mass = 1
		//rps = Priest
		rps = LightInfantry
	}
	sounds = {
	}
	abilities = [
		// inherit move from human Move {speed = 2.0; angSpeed = 180}
		ConvertAttack { convertTimeModifier = 10.0; range = 5; reloadTime = 4; applyDamageTime = 0.5; }
		SpecialPower { range = 1; effects = [ Bless ]	}
		Garrisonable { garrisonTypes = [ Temple Fortress Tower NavalTransport SeigeTower AirTransport ] }
	]
}

