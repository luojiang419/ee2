//------------------------------------------------------------------------------------------------
//	PRIEST - VISUAL INFO
//------------------------------------------------------------------------------------------------
//------------------------------------------------
//	EPOCH 1
//------------------------------------------------
UnitModel	Priest
{
	Parent 			= BaseHuman
	DefaultModel 		= lsf1_priest.nif
	ChildNames 		= [ UnitShadow ThePowerBar ]
	States 			= [
		{	StateName = Idle	AnimName = sh_Priest_1_idle01.KF   }
		{ 	StateName = Walk	AnimName = sh_Priest_1_walk01.KF   }
		{ 	StateName = Run	AnimName = sh_Priest_1_jog01.KF   }
		{ 	StateName = Attack1	AnimName = sh_Priest_1_attack01.KF	
			TextKeys = [ 
			{ Name = ATTACH_VISUAL	Data = FX_Conversion }
			{ Name = PLAY_SOUND Data = fx_priest_convert KeyTime = 0.0 }
						]
		}
		{	StateName = AttackTolerance AnimName = sh_Priest_1_attack01.KF
			TextKeys = [ 
					{ Name = ATTACH_VISUAL	Data = FX_Tolerance_Priest }
					{ Name = PLAY_SOUND Data = fx_priest_convert KeyTime = 0.0 }
						]
		}
		{
			StateName = Bless AnimName = sh_Priest_1_attack01.KF
			TextKeys = [ 
			{ Name = ATTACH_VISUAL	Data = FX_Bless }
			//{ Name = PLAY_SOUND Data = fx_priest_convert KeyTime = 0.0 }
					 ]
		}
			
		{ 	StateName = Death	AnimName = sh_Priest_1_death01.KF   }
		{	StateName = Flinch	AnimName = sh_Priest_1_protect01.KF	}
		{	StateName = BeingThrown	AnimName = sh_Priest_1_flying01.KF
			AnimVariants = [ sh_Priest_1_flying02.KF ] AnimVariantsWeights = [ 0.5 ]	}
		{	StateName = ThrownDeath	AnimName = sh_Priest_1_ground_death01.KF	}
				]
	UIRenderingParams {
		xOffset = 0.01
		yOffset = 0.50
		zOffset = -5.24
		scale = 2.69
		angle = 23.68
	}
}


