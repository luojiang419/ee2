UnitType UniqueUnitTurkish1Hero
{
	parent = UniqueUnitTurkish1
	placementType = Unplaceable
	properties {
		SizeX = 0.46
		SizeY = 0.23
	}
	abilities = [
		Hero { HeroClass = HeavyMounted; HeroForUnit = UniqueUnitTurkish1 }
		AreaEffect { effects = [ PrimaryHeroArmyBonus SupportingHeroArmyBonus ] }
	]
}

UnitModel UniqueUnitTurkish1Hero
{
	Parent		= UniqueUnitTurkish1
	ScaleType	= kScaleHeroMountedUnit
	ChildNames 	= [ TheHeroArmyFlag ]
}

