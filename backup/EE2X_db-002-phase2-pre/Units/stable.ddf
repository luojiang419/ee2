//------------------------------------------------------------------------------------------------
//	STABLE
//------------------------------------------------------------------------------------------------
UnitType Stable
{
	parent = Building
	properties {
		SizeX = 2
		SizeY = 2
		FootprintSizeX = 3.5
		FootprintSizeY = 3.5
		OffsetX = 0.75
		OffsetY = 0.75		
		UndertextureSizeX = 3
		UndertextureSizeY = 2
		UndertextureOffsetX = -0.5
		mass = 1
		DisplayNameScenEdit = tx_utn_Stable_sname
		displayName = tx_utn_Stable_name
		VerboseTooltip = vtt_unit_Stable
		RallyPlacementFlags = ( Fortress | Tower | Terrain )
		requiredOpenSides = kBuildingOpenSides_PosX
	}
	sounds {
    	}
	fullMapOverlay { sprite = spr_fullmap_stable }
	abilities = [
		LOS { range = 0 }
	]
}

