//------------------------------------------------------------------------------------------------
//	PALISADE
//------------------------------------------------------------------------------------------------

// 
// base unit type for all the palisade unit types
//
UnitType PalisadeBase
{
	ownerType = PlayerOnly
	placementType = Unplaceable	// most palisade unit types are not placeable
	parent = BareBoneBuilding
	properties {
		displayName = tx_utn_palisade_name
		displayNameTTTooltip = tx_utn_palisade_tt_name
		DisplayNameScenEdit = tx_utn_palisade_sname
		mass = 1
		hitpoints = 1
		VerboseTooltip = vtt_unit_Palisade
	}
	sounds {
		sndSelection = ["palisade_select"]
    	}
}

//
// base unit type for palisade segment and palisade segment foundation
//
UnitType Palisade_Segment_Base
{
	parent = PalisadeBase
	properties {
		SizeX = 0.6919		// the long dimension the palisade runs in
		SizeY = 0.4		// the width of the palisade wall
	}
	abilities = [
		Connect { type = kComposite_WallSegment; }
	]
}

//
// the actual palisade segment unit type
//
UnitType Palisade
{
	parent = Palisade_Segment_Base
	placementType = Wall	// this one is placeable!
	abilities = [
		LOS { range = 2 }
	]
}

//
// base unit type for palisade connector and palisade connector foundation
//
UnitType Palisade_Connector_Base
{
	parent = PalisadeBase
	properties {
		SizeX = 0.4		// these should be square
		SizeY = 0.4
	}
	abilities = [
		Connect { type = kComposite_WallConnector; }
	]
}

//
// the actual palisade connector unit type
//
UnitType Palisade_Connector
{
	parent = Palisade_Connector_Base
	abilities = [
		LOS { range = 2 }
	]
}

// 
// base unit type for palisade fragment and palisade fragment foundation
//
UnitType Palisade_Fragment_Base
{
	parent = PalisadeBase
	properties {
		SizeX = 0.2306		// the long dimension the palisade runs in
					// (this should be 1/3 of Palisade::SizeX)
		SizeY = 0.4		// the width of the palisade wall
					// (this should match Palisade::SizeY)
	}
	abilities = [
		Connect { type = kComposite_WallFragment; }
	]
}

//
// the actual palisade fragment unit type
//
UnitType Palisade_Fragment
{
	parent = Palisade_Fragment_Base
	abilities = [
		LOS { range = 2 }
	]
}


//------------------------------------------------------------------------------------------------
//	PALISADE -- stages of construction
//------------------------------------------------------------------------------------------------

//
// palisade construction visuals:
//

UnitModel Palisade_Foundation_BaseModel
{
	ScaleType	= kScaleBuilding
	DefaultState	= Idle
	States 		= [
			{	StateName = Idle	}
			]
}

UnitModel Palisade_Foundation
{
	parent = Palisade_Foundation_BaseModel
	DefaultModel 	= bld_palisade1.NIF
	ChildNames 	= [ TheHealthBar]
}

UnitModel Palisade_Connector_Foundation
{
	parent = Palisade_Foundation_BaseModel
	DefaultModel 	= bld_palisade1_Connector.NIF
	ChildNames 	= [ TheHealthBar]
}

UnitModel Palisade_Fragment_Foundation
{
	parent = Palisade_Foundation_BaseModel
	DefaultModel 	= bld_palisade1_Fragment.NIF
	ChildNames 	= [ ]
}


//
// palisade construction unit types:
//

UnitType Palisade_Foundation
{
	parent = Palisade_Segment_Base
	properties {
		mass = 0	// so it won't block pathing
		hitpoints = 1
	}
	abilities = [ 
		Construction {} 		
	]
}

UnitType Palisade_Connector_Foundation
{
	parent = Palisade_Connector_Base
	properties {
		mass = 0	// so it won't block pathing
		hitpoints = 1
	}
	abilities = [ 
		Construction {} 		
	]
}

UnitType Palisade_Fragment_Foundation
{
	parent = Palisade_Fragment_Base
	properties {
		mass = 0	// so it won't block pathing
		hitpoints = 1
	}
	abilities = [ 
		Construction {} 		
	]
}


//------------------------------------------------------------------------------------------------
//	PALISADE - VISUAL INFO
//------------------------------------------------------------------------------------------------

UnitModel PalisadeBaseModel
{
	ScaleType	= kScaleWall
	DefaultState	= Idle
	States 		= [
			{	StateName = Idle	}
			{	StateName = Death	ModelName = NULL.nif
						TextKeys = [ 
						{ Name = PLAY_SOUND	Data = Bld_Collapse } 
			] }

			]
	DamageDecalsSetName = BuildingDamageDecals
	ChildNames  = [ TheCollapseEffect WallShadow TheBldDamageEffect
					HemisphereLighting_Wall DynamicLighting_Wall
				  ]
}

//------------------------------------------------
//	EPOCH 1
//------------------------------------------------

WallModel Palisade_MainModel_1
{
	DefaultModel			= bld_palisade1.NIF
	OneNeighborDestroyedModel 	= bld_palisade1_damaged_front.NIF
	BothNeighborsDestroyedModel	= bld_palisade1_damaged_both.NIF
	DamageDecalsSetName 		= BuildingDamageDecals
}

WallModel PalisadeFragment_MainModel_1
{
	DefaultModel 	= bld_palisade1_Fragment.NIF
	DamageDecalsSetName 		= BuildingDamageDecals
}

CompositeModel Palisade
{
	ScaleType = kScaleWall
	ChildNames	= [ Palisade_MainModel_1 WallShadow TheHealthBar ExplSelectorBuild_Tiny 
					Palisade1_BuildEffectStep TheCollapseEffect TheBldDamageEffect ExplPartsWood
					HemisphereLighting_Wall DynamicLighting_Wall
				  ]
	UIRenderingParams {
		xOffset = 0.01
		yOffset = 0.01
		zOffset = 0.01
		scale = 1.00
		angle = 90.00
		rotationSpeed = 0.00
		pitch = 0.01
		lightAngle = 30.00
		lightPitch = 90.00
		lightDiffuse = [50 50 45 255]
		lightSpecular = [0 0 0 255]
		lightAmbient = [40 40 40 255]
	}
}

CompositeModel Palisade_Fragment
{
	ScaleType = kScaleWall
	ChildNames	= [ PalisadeFragment_MainModel_1 WallShadow TheHealthBar ExplSelectorBuild_Tiny 
					Palisade1_FragmentBldEffectStep TheBldDamageEffect ExplPartsWood
					HemisphereLighting_Wall DynamicLighting_Wall
				  ]
}

UnitModel Palisade_Connector
{
	parent = PalisadeBaseModel
	DefaultModel 	= bld_palisade1_Connector.NIF
	ChildNames 	= [ TheHealthBar ExplSelectorBuild_Tiny Palisade1_ConnectBldEffectStep MediumGlow ExplPartsWood ]
	UIRenderingParams {
		xOffset = 0.01
		yOffset = 0.01
		zOffset = 0.01
		scale = 1.00
		angle = 45.00
		rotationSpeed = 0.00
		pitch = 20.00
		lightAngle = 30.00
		lightPitch = 90.00
		lightDiffuse = [50 50 45 255]
