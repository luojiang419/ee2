//------------------------------------------------------------------------------------------------
//	NUCLEAR BOMBER - UNIT TYPE INFO
//------------------------------------------------------------------------------------------------
UnitType NuclearBomber
{
	parent = Aircraft
	properties {
		rps = Bomber
		SizeX = 1
		SizeY = 1
		mass = 0
		VerboseTooltip = vtt_unit_Bomber
		popCount = 5
	}
	sounds = {
	}
	abilities = [
		AircraftMove {speed = 6.21; angSpeed = 60; CruisingHeight = 9.5; ElevChangeRate = 0.5; OnGroundScale = 0.8}
		Attack { range = 0; reloadTime = 1; applyDamageTime = 0; damage = 0; missileName = "AtomBomb"; ordnance = 1; attackOnTheMove = 1 }
		LOS { range = 0 }
	]
	fullMapOverlay { sprite = spr_fullmap_plane; scale = 1.5; }
	attributes [
		GoesOnAirMissions
	]
}

// Add to mobile units for a blobby ellipsoid shadow
ShadowData        NuclearBomberShadow
{
	Flags = (IsMobile | ImmutableBounds)
	FlatBillboard
	{
		TextureFilename = BomberShadow.tga
		WidthScale = 0.9
		LengthScale = 0.9
		HeightScale = 0.1
	}
}

