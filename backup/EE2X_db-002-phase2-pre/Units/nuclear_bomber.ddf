//	EPOCH 12
//------------------------------------------------
UnitModel NuclearBomber_12
{
	Parent		= BaseAircraft
	DefaultModel 	= AB12_NuclearBomber.nif
	ChildNames 	= [ VaporTrail1 VaporTrail2 VaporTrail3 VaporTrail4 VaporTrail5 VaporTrail6 BomberShadow TheAmmoBar QuadEngineBomber_FlyingParts expl_heli_Tandrill ]
	States 		= [
		{	StateName = Idle	AnimName = AB12_nuclearbomber_idle.KF
				TextKeys = [{ Name = STOP_SOUND Data = fx_move_plane_03 KeyTime = 0}]}
		{ StateName= Walk AnimName = AB12_nuclearbomber_walk.KF		
				TextKeys = [{ Name = START_SOUND Data = fx_move_plane_03 KeyTime = 0}]}
		{ 	StateName = Attack1	AnimName = AB12_nuclearbomber_attack.KF
               			TextKeys = [{ Name = PLAY_SOUND Data = fx_bomb_drop KeyTime = 0.5 }]}
		{ 	StateName = TakeOff	AnimName = AB12_nuclearbomber_takeoff.KF	
				TextKeys = [{ Name = PLAY_SOUND Data = fx_move_plane_takeoff_03 KeyTime = 0}]}
		{ 	StateName = Death	AnimName = AB12_nuclearbomber_death.KF	}
		]
	UIRenderingParams {
		xOffset = 0.01
		yOffset = 0.17
		zOffset = 1.73
		scale = 1.79
		angle = 18.95
	}
}
