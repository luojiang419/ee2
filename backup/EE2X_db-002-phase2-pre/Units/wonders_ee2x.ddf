//------------------------------------------------
//	EPOCH 1 - MANYATTA OF THE WARRIORS
//------------------------------------------------
UnitType WonderAfrican_01
{
	parent = Wonder

	properties {
		SizeX = 6
		SizeY = 6
		FootprintSizeX = 7.5
		FootprintSizeY = 7.5
		UndertextureSizeX = 7.5
		UndertextureSizeY = 7.5
		OffsetX = 0.75
		OffsetY = 0.75
		displayName = tx_utn_WonderAf1_name
		VerboseTooltip = vtt_unit_WonderAfrican1
		requiredOpenSides = kBuildingOpenSides_PosX
		RallyPlacementFlags = ( Fortress | Tower | Terrain )

	}

	abilities = [
		LOS { range = 5 }
		AreaEffect { effects = [ WonderPowerAfrican_1 ] }
		Produce { } // needs produce ability for EffectSpawn
	]
	icon = icon_unit_WonderAfrican_01
}

UnitModel WonderAfrican_01
{
	Parent			= BaseBuilding
	DefaultModel 		= bld_wonder1_af.nif
	ChildNames		= [ UnderWonderMesoAmerican_11 ]
	UIRenderingParams {
		xOffset = 0.53
		yOffset = 0.89
		zOffset = 1.17
		scale = 1.28
		angle = 42.63
		rotationSpeed = 0.00
		pitch = 40.26
	}
}

