//------------------------------------------------------------------------------------------------
//	THE KING - FOR REGICIDE GAMES
//------------------------------------------------------------------------------------------------
UnitType KingRegicide
{
	parent = LandMammal
	ownertype = PlayerOnly
	
	// we don't want people placing these themselves
	// the VictoryCondition will handle that.
	placementType = Unplaceable
	
	attributes = [ 
		HealedByMedic
	]
	
	icon = icon_unit_default_human
		
	properties {
		DisplayName = tx_utn_kingReg_name
		DisplayNameScenEdit = tx_utn_kingReg_sname
		VerboseTooltip = vtt_unit_kingReg
		HitPoints = 50
		stance = Defensive
		moveType = kUnitMoveType_Foot
		rps = SpecialForces
		SizeX = 0.225
		SizeY = 0.225
		mass = 1
		popCount = 1	// means 0, overrides parent
	}
	
	sounds {
		sndDeath =  ["fx_death_male_01" "fx_death_male_02" "fx_death_male_03" "fx_death_male_04" "fx_death_male_05" "fx_death_male_06" "fx_death_male_07"]
    	}
	
	abilities = [
		Attack 		{ range = 6; reloadTime = 2; applyDamageTime = 0.5; damage = 5 }
		Move 		{ speed = 1.15; angSpeed = 720; angAccel = 720}
		LOS			{ range = 5 }
		AreaEffect	{ effects = [ "KingRegicideGlow" ] }
		Move		{ speed = 1.725; angSpeed = 180 }
		LOS			{ range = 5 }
		Garrisonable { garrisonTypes = [ Fortress Tower NavalTransport SeigeTower AirTransport ] }
	]
}

