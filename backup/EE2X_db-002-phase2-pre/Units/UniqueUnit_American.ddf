//	UNIQUE UNIT MODEL
//------------------------------------------------
UnitModel UniqueUnitAmerican2
{
	Parent		= BaseHuman
	DefaultModel 	= CIV7_Minuteman_American.nif
	ChildNames 	= [ UnitShadow Muzzle_Musketeer ]
	States 		= [
		{	StateName = Idle	AnimName = sh_regular_idle01.KF	  }
		{ 	StateName = Walk	AnimName = sh_regular_walk01.KF
		}
		{ 	StateName = CaptureAttack1	AnimName = CIV7_Minuteman_American_capture01.kf
                              AnimVariants = [ CIV7_Minuteman_American_capture02.kf ]
                              AnimVariantsWeights = [0.3]
                 }
                { 	StateName = Run	AnimName = sh_regular_jog01.KF
		}
		{ 	StateName = Attack1	AnimName = sh_regular_attack01.KF 
			TextKeys = [
					{ Name = PLAY_SOUND Data = fx_musket_fire KeyTime = 0.16 }
					] }
		{ 	StateName = Death	AnimName = sh_regular_death01.KF  }
		{	StateName = Flinch	AnimName = CIV7_Minuteman_American_protect01.kf }
		{	StateName = BeingThrown	AnimName = CIV7_Minuteman_American_flying01.kf
			AnimVariants = [ CIV7_Minuteman_American_flying02.kf ] AnimVariantsWeights = [ 0.5 ]	}
		{	StateName = ThrownDeath	AnimName = CIV7_Minuteman_American_ground_death01.kf }
			]
	UIRenderingParams {
		xOffset = 0.01
		yOffset = -0.10
		zOffset = -4.40
		scale = 2.69
	}
}
