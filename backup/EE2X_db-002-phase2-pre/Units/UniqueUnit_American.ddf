//------------------------------------------------
//	UNIQUE UNIT MODEL
//------------------------------------------------
UnitModel UniqueUnitAmerican1
{
	Parent 			= BaseHuman
	DefaultModel 		= CIV1_Frontiersman_American.nif
	ChildNames 		= [ UnitShadow ]
	States 		= [
		{	StateName = Idle	AnimName = CIV1_Frontiersman_American_idle.kf   }
		{	StateName = Jog		AnimName = CIV1_Frontiersman_American_jog.kf   }
		{ 	StateName = Walk	AnimName = CIV1_Frontiersman_American_walk.kf   }
		{ 	StateName = Death	AnimName = CIV1_Frontiersman_American_death.kf  }
		{ 	StateName = Attack1	AnimName = CIV1_Frontiersman_American_attack.kf
			TextKeys = [ { Name = PLAY_SOUND Data = fx_battle_swing      KeyTime = 0.5 } ]
		}
		{	StateName = Flinch	AnimName = CIV1_Frontiersman_protect01.KF	}
		{	StateName = BeingThrown	AnimName = CIV1_Frontiersman_flying01.KF
			AnimVariants = [ CIV1_Frontiersman_flying02.KF ] AnimVariantsWeights = [ 0.5 ]	}
		{	StateName = ThrownDeath	AnimName = CIV1_Frontiersman_ground_death01.KF	}
			]
	UIRenderingParams {
		xOffset = 0.01
		yOffset = 2.43
		zOffset = -6.30
		scale = 2.43
	}
}

