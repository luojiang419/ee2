//------------------------------------------------------------------------------------------------
//	UNIQUE UNIT GERMAN BARBARIAN (EPOCHS 1-5)
//------------------------------------------------------------------------------------------------
UnitType UniqueUnitGerman1
{
	parent = HeavyInfantry1
	properties {
		DisplayName = tx_utn_UUGerman1_name
		DisplayNameScenEdit = tx_utn_UUGerman1_sname
		VerboseTooltip = vtt_unit_UUGerman1
		HitPoints = 0
		rps = HeavyInfantry
		SizeX = 0.125
		SizeY = 0.125
		mass = 1
	}
	sounds = {
	}
	abilities = [
		Attack { range = 0.2; reloadTime = 1.5; applyDamageTime = 0.5; damage = 0 }
		ConvertAttack { convertTimeModifier = 3.0; range = 2.0; reloadTime = 4.0; applyDamageTime = 1.0; capture = 1 } // capture ability
		LOS { range = 0 }
		Move {speed = 1.3; angSpeed = 720}
	]
}

