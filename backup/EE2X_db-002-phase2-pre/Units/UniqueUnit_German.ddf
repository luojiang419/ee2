//------------------------------------------------
//	UNIQUE UNIT MODEL
//------------------------------------------------
UnitModel UniqueUnitGerman1
{
	Parent		= HeavyInfantry1_03
        ScaleType	= kScaleUnit
	DefaultModel 	= CIV1_Barbarian_German.nif
	ChildNames 	= [ UnitShadow ]
	States 		= [
		{	StateName = Idle	AnimName = sh_sword_idle01.KF
                              AnimVariants = [ sh_sword_idle03.KF 
						sh_sword_idle02.KF 
                                                 sh_sword_idle04.KF ]
                              AnimVariantsWeights = [0.1 0.1 0.1]
                 }
		{ 	StateName = Walk	AnimName = sh_sword_walk01.KF }
                { 	StateName = CaptureAttack1	AnimName = CIV1_Barbarian_German_capture01.KF
                              AnimVariants = [ CIV1_Barbarian_German_capture02.KF ]
                              AnimVariantsWeights = [0.3]
                 }     
		{ 	StateName = Run	AnimName = sh_sword_jog01.KF
		}
		{ 	StateName = Attack1	AnimName = CIV1_Barbarian_German_attack02.KF
                              AnimVariants = [ CIV1_Barbarian_German_attack03.KF CIV1_Barbarian_German_attack01.KF ]
                              AnimVariantsWeights = [0.4 0.4] 
			TextKeys = [
							{ Name = PLAY_SOUND Data = fx_sword_swing KeyTime = 0.40 }
							] }

		{ 	StateName = Death	AnimName = sh_sword_death01.KF	}
		{	StateName = Flinch	AnimName = CIV1_Barbarian_German_protect01.kf }
		{	StateName = BeingThrown	AnimName = CIV1_Barbarian_German_flying01.kf
			AnimVariants = [ CIV1_Barbarian_German_flying02.kf ] AnimVariantsWeights = [ 0.5 ]	}
		{	StateName = ThrownDeath	AnimName = CIV1_Barbarian_German_ground_death01.kf }
			]
}

