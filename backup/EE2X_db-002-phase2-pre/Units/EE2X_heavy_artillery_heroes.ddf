//------------------------------------------------------------------------------------------------
//	HEAVY ARTILLERY - UNIT TYPE INFO
//------------------------------------------------------------------------------------------------
UnitType HeavyArtilleryHero
{
	parent = HeavyArtillery
	placementType = Unplaceable	// @TODO maybe make heroes placeable, but that causes problems with the HeroManager...
	properties {
		SizeX = 1.15
		SizeY = 1.15
	}
	abilities = [
		Hero { HeroClass = HeavyArtillery; HeroForUnit = HeavyArtillery }
		AreaEffect { effects = [ PrimaryHeroArmyBonus SupportingHeroArmyBonus ] }
	]
}

