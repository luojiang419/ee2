//------------------------------------------------------------------------------------------------
//	NON COMBAT AIR 3 (SATELLITE) - UNIT TYPE INFO
//------------------------------------------------------------------------------------------------
UnitType Satellite
{
	properties {
		moveType = Air
		rps = AirNonCombat
		FootprintType = Ellipse
		DisplayName = tx_utn_NonCmbtAir3_e13_name
		DisplayNameScenEdit = tx_utn_NonCmbtAir3_e13_sname
		Hitpoints = 50
		popCount = 1
		SizeX = 1
		SizeY = 1
		mass = 1
		VerboseTooltip = vtt_unit_Satellite
	}
	sounds = {
	}
	fullMapOverlay { sprite = spr_fullmap_smallunit ignoreOrientation = 1 }
	abilities = [
		AircraftMove {speed = 3.45; angSpeed = 90; CruisingHeight = 10.0; ElevChangeRate = 0.5; canHover = 1}
		LOS { range = 10 }
		Garrisonable { garrisonTypes = [ Heliport ] }
	//	SpecialPower { 
	//		range = 5; 
	//		canDisguise = true;
	//		spottedTextDBI = tx_sat_spotted_owner
	//		spotterTextDBI = tx_sat_spotted_spotter
	//		doesNotRequirePowerReserve = true; // disable "power bar" and "power reserve ability"
	//	}
	]
}

// Add to mobile units for a blobby ellipsoid shadow
ShadowData        satelliteShadow
{
	Flags = (IsMobile | ImmutableBounds)
	FlatBillboard
	{
		TextureFilename = anc13_satellite_shadow.tga
		WidthScale = 0.9
		LengthScale = 0.9
		HeightScale = 0.1
	}
}

