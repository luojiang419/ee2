//------------------------------------------------------------------------------------------------
//	NON COMBAT AIR 3 - VISUAL INFO
//------------------------------------------------------------------------------------------------
//------------------------------------------------
//	EPOCH 13
//------------------------------------------------
UnitModel Satellite
{
	ScaleType 		= kScaleUnit
	DefaultModel 	= ANC13_Satellite.nif
	OutlineType		= kOutlineMake
	DefaultState 	= Idle
	States 		= [
		{	StateName = Idle	AnimName = anc13_satellite_idle.kf	}
		{ 	StateName = Walk	AnimName = anc13_satellite_walk.kf
               			//TextKeys = [{ Name = START_SOUND_UNTIL_ANIM_CHANGE Data = fx_move_satellite_01 KeyTime = 0.5 }]
			}
		{ 	StateName = Death	AnimName = anc13_satellite_death.kf	}
			]
	ChildNames 	= [ TheHealthBar 
					ExplSelectorHeli01
					SelectCircleAircraft
					VaporTrail1
					VaporTrail2
					VaporTrail3
					VaporTrail4
					satelliteShadow
					Satellite_FlyingParts
					//SpyShimmer 
					]
					
	UIRenderingParams {
		xOffset = 0.00
		yOffset = 0.76
		zOffset = -5.37
		scale = 4.87
		angle = 45.00
		rotationSpeed = 0.00
		pitch = -14.21
		lightAngle = 30.00
		lightPitch = 90.00
		lightDiffuse = [50 50 45 255]
		lightSpecular = [0 0 0 255]
		lightAmbient = [40 40 40 255]
	}
}
