UnitType Quarry
{
	ownerType = PlayerOnly
	parent = Building
	properties {
		rps = Building
		SizeX = 1.5
		SizeY = 1.5
		FootprintSizeX = 3.0
		FootprintSizeY = 3.0
		OffsetX = 0.75
		OffsetY = 0.75
		mass = 1
        HitPoints = 3000
        displayName = tx_utn_quarry_name
		VerboseTooltip = vtt_unit_quarry           
	}
	sounds {
    	}
	fullMapOverlay { sprite = spr_fullmap_house }
	abilities = [
		LOS { range = 8 }
        Garrison { 
			garrisonType = UniWarehouseOilDerrickCityCenter; 
			numOfSlots = 6;
			gatherRate = 0.5;	
			gatherType = Stone;
            rightClickToGarrison = 1;
			GarrisonFlagModelName = "GarrisonFlag"
		}
        Convertable { 
			convertTimeModifier = 100.0;  //
			garrisonedUnitModifier = 0.0; // 10% increase in capture time
			garrisonedUnitDamage = 0.0;	  // hitpoints subtracted from capturer per round per garrisoned unit
			damageRate = 0.0;			  // hitpoints subtracted from capture target hitpoints per round
			capture = 1;
		} 
	]
}

