//----------------------
//--------Su24----------
//----------------------
UnitType Su24
{
	parent = Aircraft
	properties {
		rps = CloseAirSupport
		SizeX = 1
		SizeY = 1
		mass = 0
		HitPoints = 2000
		popCount = 3
		displayName = tx_utn_Su24_name
		verboseTooltip = vtt_unit_Su24
	}
	sounds = {
	}
	abilities = [
		AircraftMove {speed = 7; angSpeed = 88; CruisingHeight = 9.0; ElevChangeRate = 0.5}
		Attack { damage = 0; range = 5; reloadTime = 1.0;  applyDamageTime = 0; missileName = "Ewpair_EMP";  attackOnTheMove = 1; ordnance = 1; areaDamageRadius = 10; areaDamageFriendlyRatio = 0.5 }
		LOS { range 12 }
	]
attributes [
		GoesOnAirMissions
	]
	icon = icon_unit_Su24
}

UnitModel Su24
{
	Parent	= BaseAircraft
	//DefaultModel 	= Su24.nif
	DefaultModel 	= Su24MP.nif
	ForceScale=0.23  
	DefaultState 	= Idle
	ChildNames 	= [ VaporTrail1 VaporTrail2 VaporTrail3 VaporTrail4 VaporTrail5 VaporTrail6 TheAmmoBar fighterBomberShadow_03 StrikeFighter_FlyingParts expl_heli_Tandrill ]
	States 		= [
		{	StateName = Idle	AnimName = afb13_StrikeFighter_idle.KF		
				TextKeys = [{ Name = STOP_SOUND Data = fx_move_jet_03 KeyTime = 0}]}
		{ 	StateName = Walk	AnimName = afb13_StrikeFighter_walk.KF		
				TextKeys = [{ Name = START_SOUND Data = fx_move_jet_03 KeyTime = 0}]}
		{ 	StateName = Takeoff	AnimName = afb13_StrikeFighter_takeoff.KF	
               			TextKeys =    [{ Name = PLAY_SOUND Data = fx_move_jet_takeoff_03 KeyTime = 0}]}
		{ 	StateName = Attack1	AnimName = afb13_StrikeFighter_attack.KF
				TextKeys = [{ Name = START_SOUND Data = fx_move_jet_03 KeyTime = 0}
               				    { Name = PLAY_SOUND Data = fx_bow_shoot KeyTime = 0}]}
		{ 	StateName = Death	AnimName = afb13_StrikeFighter_death.KF		
				TextKeys = [
				{ Name = STOP_SOUND Data = fx_move_jet_03 KeyTime = 0}
				]
			}
				]
	UIRenderingParams {
		xOffset = 0.01
		yOffset = -0.08
		zOffset = -0.38
		scale = 2.05
		angle = 18.95
	}
//DamageDecalsSetName = BuildingDamageDecals
}




//----------------E3 AWACS----------
UnitType E3
{
	parent = Aircraft 	
      properties {
        SizeX = 2
		SizeY = 2
		mass = 0
		popCount = 2            
		VerboseTooltip = vtt_unit_E3
		HitPoints = 1000
	}
	sounds = {
	}
	abilities = [
		AircraftMove {speed = 4.5; angSpeed = 18; CruisingHeight = 12.2; }
            Attack { range = 0; reloadTime = 0; applyDamageTime = 0; damage = 0; missileName = "Arrow" }
            AreaEffect {
			effects = [ 
				Awacs,SuperVision
			]
		}
        LOS { range = 13 }
       // SpecialPower { 
		//	range = 3; 
		//	effects = [ Awace_PowerControler ]
		//}  		
	]
	attributes [
		GoesOnAirMissions
	]
	fullMapOverlay { sprite = spr_fullmap_plane; scale = 1.5; }
}

// Add to mobile units for a blobby ellipsoid shadow
ShadowData        E3Shadow_01
{
	Flags = (IsMobile | ImmutableBounds)
	FlatBillboard
	{
		TextureFilename = BomberShadow3.tga
		WidthScale = 0.9
		LengthScale = 0.9
		HeightScale = 0.1
	}
      
}

UnitModel E3_13
{
	Parent	= BaseAircraft
	DefaultModel 	= E3sentry2.nif
      ScaleType 	= kScaleVehicle
      ForceScale=0.150      
	ChildNames 	= [ VaporTrail1 VaporTrail5 VaporTrail6 TheAmmoBar BomberShadow3 JetEngineBomber_FlyingParts expl_heli_Tandrill ]
