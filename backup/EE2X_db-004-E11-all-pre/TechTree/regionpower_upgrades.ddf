///////////////////////////// UPGRADE GROUS ///////////////////////////////////
// It's convenient to group the upgrades together here.


// Upgrade set for all Epoch 1-5 region powers
UpgradeRefSet RegionPowerUpgrade_1
{
	upgrades = [
		RegionPowerUpgradeFarEast_1
		RegionPowerUpgradeMidEast_1
		RegionPowerUpgradeWestern_1
		RegionPowerUpgradeMesoAmer_1
		RegionPowerUpgradeAfrican_1
	]
}

// Upgrade set for all Epoch 6-10 region powers
UpgradeRefSet RegionPowerUpgrade_6
{
	upgrades = [
		RegionPowerUpgradeFarEast_6
		RegionPowerUpgradeMidEast_6
		RegionPowerUpgradeWestern_6
		RegionPowerUpgradeMesoAmer_6
		RegionPowerUpgradeAfrican_6
	]
}

// Upgrade set for all Epoch 11-15 region powers
UpgradeRefSet RegionPowerUpgrade_11
{
	upgrades = [
		RegionPowerUpgradeFarEast_11
		RegionPowerUpgradeMidEast_11
		RegionPowerUpgradeWestern_11
		RegionPowerUpgradeMesoAmer_11
		RegionPowerUpgradeAfrican_11
	]
}
