//////////////////////////////Region power upgrades ///////////////////////////
// Definitions of the upgrades that give the region powers to the players.
// These include the required region for each upgrade, the duration and recharge
// times, and the icon for the button for each power.  Also, there are sets that
// can be used to group all powers together that are given out at the same time.

///////////////////////////// EASTERN REGION POWERS ///////////////////////////

// First far east upgrade : Citadel
UpgradeRegionPower RegionPowerUpgradeFarEast_1
{
	regionPowerName = "RegionPowerEastern_1"; 
	requiredRegion = LastFarEast;
	rechargeTime = 300;
	icon = "icon_regionpower_citadel";
	verboseTooltipIndex = text_rarea_citadel_desc;
	duration = 60;
}

// Second far east upgrade: Mercantilism
UpgradeRegionPower RegionPowerUpgradeFarEast_6
{
	regionPowerName = "RegionPowerEastern_6"; 
	requiredRegion = LastFarEast;
	rechargeTime = 300;
	icon = "icon_regionpower_mercantilism";
	verboseTooltipIndex = text_rarea_burgmarkets_desc;
	duration = 60;
}

UpgradeRegionPower RegionPowerUpgradeFarEast_11
{
	regionPowerName = "RegionPowerEastern_11"; 
	requiredRegion = LastFarEast;
