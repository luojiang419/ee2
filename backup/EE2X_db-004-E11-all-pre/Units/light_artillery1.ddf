UnitType LightArtillery1
{
	parent = Artillery
	properties {
		rps = LightArtillery
		SizeX = 1
		SizeY = 1
		mass = 5
		popCount = 2
	}
	sounds {
		sndDeath =  ["fx_death_male_01" "fx_death_male_02" "fx_death_male_03" "fx_death_male_04" "fx_death_male_05" "fx_death_male_06" "fx_death_male_07"]
    	}
	abilities = [
		Attack { range = 0; reloadTime = 1; applyDamageTime = 0.66; damage = 0; missileName = "Arrow"; areaDamageRadius = 0; areaDamageFriendlyRatio = 0.5 }
		LOS { range = 0 }
		VehicleMove {speed = 1.0; angSpeed = 180; followTerrainSlope = 1 }
	]
}

