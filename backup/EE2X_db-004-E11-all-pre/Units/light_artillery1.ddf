				TextKeys = [
								{ Name = HIDE_NODE Data = rock KeyTime = 0 }
				]}
		{ 	StateName = Walk	AnimName = LLA1_stone_thrower_walk.kf 
				TextKeys = [
								{ Name = HIDE_NODE Data = rock KeyTime = 0 }
						{ Name = START_SOUND_UNTIL_ANIM_CHANGE Data = fx_move_wheeled_04 KeyTime = 0 } 
				]}
		{	StateName = UnpackedWalk  AnimName = LLA1_stone_thrower_unpackwalk01.kf 
				TextKeys = [
								{ Name = HIDE_NODE Data = rock KeyTime = 0 }
						{ Name = START_SOUND_UNTIL_ANIM_CHANGE Data = fx_move_wheeled_04 KeyTime = 0 } 
				]}
		{ 	StateName = Attack1	AnimName = LLA1_stone_thrower_attack01.kf
				TextKeys = [
								{ Name = PLAY_SOUND Data = Trebuchet_firing1 KeyTime = 1.31 }
								{ Name = SHOW_NODE Data = rock KeyTime = 0 }
								{ Name = HIDE_NODE Data = rock KeyTime = 1.31 }
								{ Name = SHOW_NODE Data = rock KeyTime = 1.50 }
			] }
		{ 	StateName = Unpack	AnimName = LLA1_stone_thrower_unpack.kf 
				TextKeys = [
								{ Name = HIDE_NODE Data = rock KeyTime = 0 }
				]}
		{ 	StateName = pack	AnimName = LLA1_stone_thrower_pack.kf 
				TextKeys = [
								{ Name = HIDE_NODE Data = rock KeyTime = 0 }
				]}
		{ 	StateName = Death	AnimName = LLA1_stone_thrower_death.kf 
				TextKeys = [
								{ Name = HIDE_NODE Data = rock KeyTime = 0 }
				]}
		{   	StateName = PackedDeath AnimName = LLA1_stone_thrower_packdeath.kf 
				TextKeys = [
								{ Name = HIDE_NODE Data = rock KeyTime = 0 }
				]}
			]
	ChildNames 	= [ TheSiegeUnitDamageEffect ]
