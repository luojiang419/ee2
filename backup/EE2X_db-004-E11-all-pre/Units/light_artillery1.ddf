UnitModel LightArtillery1_01
{
	Parent = BaseArtillery
	DefaultModel 	= lla1_stone_thrower.nif
	States 		= [
		{	StateName = Idle	AnimName = LLA1_stone_thrower_Idle01.kf	
                              AnimVariants = [ LLA1_stone_thrower_Idle02.kf ]
                              AnimVariantsWeights = [ 0.2]
				TextKeys = [
								{ Name = HIDE_NODE Data = rock KeyTime = 0 }
				] }
