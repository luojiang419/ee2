// CROCODILE WAR MACHINE

UnitType EgyptCrocodile
//made not-convertible; used in multiple scenarios; so the only answer is to 
{//some parts copied from Ram, some copied from Egypt 1-5 hero
// 	parent = Ram

	properties {
		//from HeavyMounted:
// 		rps = HeavyMounted
		popCount = 2
		FootprintType = Ellipse
		// default stance to defensive
// 		stance = Defensive

			//from ram:
// 		SizeX = 1.0
// 		SizeY = 1.0
// 		mass = 1
// 		moveType = Wheeled
		rps = Ram
// 		HitPoints = 0
// 		VerboseTooltip = vtt_unit_Ram


//custom:
		SizeX = 1.0
		SizeY = 1.0
		mass = 5.0
		moveType = Wheeled
// 		rps = Ram

// 		stance = Defensive
		stance = Aggressive
		HitPoints = 10000

		displayName = tx_eg_crocodile_name
		VerboseTooltip = tx_eg_crocodile_verbose
		DisplayNameScenEdit = tx_eg_crocodile_name_scen

	}
	sounds = {
		sndDeath =  ["fx_death_male_01" "fx_death_male_02" "fx_death_male_03" "fx_death_male_04" "fx_death_male_05" "fx_death_male_06" "fx_death_male_07"]
	}
	abilities = 
		[
		 //heavy mounted:
// 		Garrisonable { garrisonTypes = [ Fortress Tower NavalTransport ] }
		Garrisonable { garrisonTypes = [ NavalTransport Fortress ] }

		 Attack 
				{ 
					range = 0.8; 
// 					reloadTime = 1; 
					reloadTime = 4; 
					applyDamageTime = 0.3; 
					damage = 1000; 
// 					missileName = "RockAmmo"; 
					ignoreBlocking = 1; 
					areaDamageRadius = 0; 
// 					areaDamageFriendlyRatio = 0.5;
				}
		 // 		Attack { range = 0; reloadTime = 666.0; applyDamageTime = 0.0; damage = 0 }
		 LOS { range = 8 }
		 Move {speed = 1.1; angSpeed = 180}
		 // 		Hero { HeroClass = HeavyMounted; HeroForUnit = UniqueUnitEgyptian1 }
		 // 		AreaEffect { effects = [ PrimaryHeroArmyBonus SupportingHeroArmyBonus ] }
		]
		
	// apparently this is actually a war engine and not a crocodile...
	icon = icon_unit_camp_warengine

	attributes = [ 
		HealedByMedic, 
		CanJoinHeroArmy
	]
	fullMapOverlay { sprite = spr_fullmap_smallunit ignoreOrientation = 1 }


}

UnitModel EgyptCrocodile
// UnitModel Ram_03
{
// 	ScaleType 	= kScaleUnit
	ScaleType 	= kScaleHero
		DefaultModel 	= civ1_war_engine_cobra.nif
		DefaultState 	= Idle
		States = [
				{ StateName=Idle 
					AnimName = civ1_war_engine_cobra_idle01.kf
					AnimVariants = [ civ1_war_engine_cobra_idle02.kf ] 
					AnimVariantsWeights = [ 0.3 ]
				}
				{ StateName = UnpackedIdle  
					AnimName = civ1_war_engine_cobra_unpackidle01.kf }
				{ StateName=Walk 
					AnimName = civ1_war_engine_cobra_walk.kf
					TextKeys = [ { Name = START_SOUND_UNTIL_ANIM_CHANGE Data = siegetower_moving1 KeyTime = 0}]
				}
				{ StateName = UnpackedWalk  AnimName = civ1_war_engine_cobra_unpackwalk.kf }
				{ StateName=Attack1 AnimName = civ1_war_engine_cobra_attack01.kf }
				{ StateName= Death	AnimName = civ1_war_engine_cobra_death.kf } 
				{ StateName = PackedDeath AnimName = civ1_war_engine_cobra_packdeath.kf }
				{ StateName=Pack AnimName = civ1_war_engine_cobra_pack.kf }
				{ StateName= Unpack	AnimName = civ1_war_engine_cobra_unpack.kf } 
		]
		ChildNames = 
		[ 
		 TheHealthBar  
		 SelectCircleMedium 
		 MediumGlow 
		 TankTracks 
		 TheSiegeUnitDamageEffect 
		 UnitShadow
		 SinkArtillery
		 HemisphereLighting_Unit
		 DynamicLighting_Unit
		 ]
		DamageDecalsSetName = BuildingDamageDecals
		UIRenderingParams 
		{
			xoffset = 0.01
			yOffset = 0.57
			zOffset = -0.80
			scale = 1.43
			angle = 42.63
			rotationSpeed = 0.00
			pitch = 20.00
			lightAngle = 30.00
			lightPitch = 90.00
			lightDiffuse = [50 50 45 255]
			lightSpecular = [0 0 0 255]
			lightAmbient = [40 40 40 255]
		}
}

