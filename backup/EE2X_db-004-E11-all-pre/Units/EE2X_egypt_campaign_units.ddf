//EGYPT 3 CAPTURE LOCATIONS
UnitType Egypt3ArtifactBuilding
{
	parent = Building
	properties {
		SizeX = 2.5
		SizeY = 2.5
		FootprintSizeX = 4
		FootprintSizeY = 4
		OffsetX = 0.75
		OffsetY = 0.75
		UndertextureSizeX = 2.5
		UndertextureSizeY = 2.5		
		mass = 1

		DisplayNameScenEdit =   tx_e3_artifact_building_se
		displayName =           tx_e3_artifact_building_dn
		VerboseTooltip =        tx_e3_artifact_building_vtt

		requiredOpenSides = kBuildingOpenSides_PosX
		RallyPlacementFlags = ( Temple | Fortress | Tower | Terrain )

		HitPoints = 5000
	}
	sounds {
    	}
	fullMapOverlay { sprite = spr_fullmap_church }
	abilities = [
		LOS { range = 5 }
// 		Garrison { 
// 			garrisonType = Temple; 
// 			numOfSlots = 1;
// 			gatherRate = 0.01;	// number of tech points gathered for each garrisoned UnitType
// 			gatherType = Tech;
// 			rightClickToGarrison = 1;
// 			GarrisonFlagModelName = "GarrisonFlag"
// 		}
		Convertable {
			convertTimeModifier = 100.0;  //
			garrisonedUnitModifier = 0.1; // 10% increase in capture time
			garrisonedUnitDamage = 1.0;	  // hitpoints subtracted from capturer per round per garrisoned unit
			damageRate = 10.0;			  // hitpoints subtracted from capture target hitpoints per round
			capture = 1;
			resourcesTransferred = [
				{
					resource = Tech
					percentTransferred = 0.1
					NativeTribesAmountTransferredMin = 10.0
					NativeTribesAmountTransferredMax = 20.0
				}
			]
		}
	]
}
UnitModel Egypt3ArtifactBuilding
{
	Parent 		= BaseBuilding
	DefaultModel 	= bld_temple1_af.NIF
	ChildNames 		= [LargeGlow UnderTemple ExplSelectorBuild_Medium ExplPartsWood ]
