		xOffset = 0.01
		yOffset = 0.21
		zOffset = 1.07
		scale = 1.28
		angle = 45.00
		rotationSpeed = 0.00
		pitch = 20.00
		lightAngle = 30.00
		lightPitch = 90.00
		lightDiffuse = [50 50 45 255]
		lightSpecular = [0 0 0 255]
		lightAmbient = [40 40 40 255]
	}
}

///////////////////////////////////////////////////////////////////////////////////////
///THIS IS THE FORTRESS ONLY THE CROCODILE CAN ATTACK!
///////////////////////////////////////////////////////////////////////////////////////
UnitType EgyptFortress
{
	// You'd -think- that the fortress would be player only, but in fact,
	// the unit type needs to exist for the world player, because it uses
	// it for testing when setting up a hot spots game.  So please leave
	// the ownerType field blank.  @BEN
	//ownerType = PlayerOnly
	parent = NoProduceBuilding
	properties {
		rps = BuildingCombat
		SizeX = 3
		SizeY = 3
		FootprintSizeX = 4.5
		FootprintSizeY = 4.5
		OffsetX = 0.75
		OffsetY = 0.75
		UndertextureSizeX = 3
		UndertextureSizeY = 3
		mass = 1
		displayName = tx_eg_EgyptFortress_name
// 		DisplayNameScenEdit = tx_eg_EgyptFortress_sname
		VerboseTooltip = tx_eg_EgyptFortress_verbose
		DisplayNameScenEdit =   tx_eg_EgyptFortress_scen
		hitpoints = 5000
		UnitHeight = 3.0
	}
	sounds {
    	}
	fullMapOverlay { sprite = spr_fullmap_fortress }
	abilities = [
		Garrison { 
			garrisonType = Fortress; 
			numOfSlots = 10;
			attackBonus = 0.03;	// 3 percent more attack for each garrisoned UnitType
			healPoints = 2;		// 2 hit points heal every second for each UnitType
			rightClickToGarrison = 1;
			GarrisonFlagModelName = "GarrisonFlag"
		}
		Attack { range = 9; reloadTime = 2.5; applyDamageTime = 0.5; damage = 120; missileName = "FireArrow"; angularRange = 360 }
		LOS { range = 9 }
	]
}

//------------------------------------------------
//	EPOCH 4 - upgrade for EgyptFortress 
//------------------------------------------------
// Attack Ability Upgrade
UpgradeAbilities EgyptFortressEpoch4Attack
{
	upgradedAbilities = [
		Attack { damage = 0; range = 0; reloadTime = 666; angularRange = 360; applyDamageTime = 0.5; missileName = "FireArrow"; turretControllerName = fort2_ME }
	]
}

// Garrison upgrade
UpgradeAbilities EgyptFortressEpoch4Garrison
{
	upgradedAbilities = [
		Garrison { 
			garrisonType = Fortress; 
			numOfSlots = 10;
			attackBonus = 0.03;	// 3 percent more attack for each garrisoned UnitType
			healPoints = 4;		// 2 hit points heal every second for each UnitType
			rightClickToGarrison = 1;
			GarrisonFlagModelName = "GarrisonFlag"
		}
	]
}

