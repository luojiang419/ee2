	properties {
		HitPoints = 4000
		SizeX = 5
		SizeY = 4.5
		FootprintSizeX = 5
		FootprintSizeY = 4.5
//		UndertextureSizeX = 6.5
//		UndertextureSizeY = 6
		OffsetX = 0.75
		OffsetY = 0.75
		mass = 1
		displayName = tx_utn_MonumentHorus_name
		VerboseTooltip = vtt_unit_MonumentHorus
		DisplayNameScenEdit = tx_e2_name_horus_scen
	}

	abilities = [
		LOS { range = 5 }
	]
// 	icon = icon_unit_camp_greatpyramid
	icon = icon_unit_camp_horus
}

