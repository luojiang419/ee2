UnitModel LeaderKemsa
{
	Parent		= BaseHuman
	DefaultModel 	= lm1_chief.nif
	ForceScale = 0.300
	ChildNames	= [ ThePowerBar UnitShadow ]
	States 		= [
		{	StateName = Idle	AnimName = sh_chief_idle01.kf 
                              AnimVariants = [ sh_chief_idle02.kf sh_chief_idle03.kf sh_chief_battlecry01.kf ]
                              AnimVariantsWeights = [ 0.05 0.05 0.05 ]
                 }
		{ 	StateName = Walk	AnimName = sh_chief_walk01.kf	}
		{ 	StateName = Run	AnimName = sh_chief_jog01.kf	}
		{ 	StateName = Attack1	AnimName = sh_chief_attack01.kf
                              AnimVariants = [ sh_chief_attack02.kf ]
                              AnimVariantsWeights = [ 0.4 ]
			TextKeys = [
							{ Name = PLAY_SOUND Data = Sword_medium KeyTime = 0.50 }
							] }
		{ 	StateName = Death	AnimName = sh_chief_death01.kf	}
		{	StateName = Flinch	AnimName = sh_sword_protect01.kf }
		{	StateName = BeingThrown	AnimName = sh_sword_flying01.kf
			AnimVariants = [ sh_sword_flying02.kf ] AnimVariantsWeights = [ 0.5 ]	}
		{	StateName = ThrownDeath	AnimName = sh_sword_ground_death01.kf }
			]
	UIRenderingParams {
		xOffset = 0.01
		yOffset = -0.65
		zOffset = -5.05
		scale = 2.43
		angle = 23.68
	}
}




