		SizeY = 0.55
		mass = 1
		popCount = 2
	}
	sounds = {
	}
	abilities = [
		Attack { range = 0; reloadTime = 1; applyDamageTime = 0.66; damage = 0; missileName = "Arrow" }
		LOS { range = 0 }
		Move {speed = 1.725; angSpeed = 180; angAccel = 720}
		Garrisonable { garrisonTypes = [  Fortress  NavalTransport  AirTransport ] }	
	]
	nonAttributes = [ 
		HealedByMedic
	]
}

ShadowData        AAHalfTrackShadow
{
	Flags = (UseStencil | IsMobile | ImmutableBounds | HasTurret)
	FlatBillboard
	{
		TextureFilename = lla11_aahalftrack_shadow.tga
		WidthScale = 3
		LengthScale = 0.9
		HeightScale = 0.1
	}
}

