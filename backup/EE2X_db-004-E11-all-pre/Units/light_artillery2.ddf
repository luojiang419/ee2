//------------------------------------------------
//	EPOCH 11
//------------------------------------------------
UnitModel LightArtillery2_11
{
	ScaleType 	= kScaleVehicle
	OutlineType		= kOutlineMake
	DefaultModel 	= LLA11_aahalftrack.nif
	DefaultState 	= Idle
	States = [
			{ StateName= Idle AnimName = lla11_aahalftrack_idle.KF	
				 }

			{ StateName= Walk AnimName = lla11_aahalftrack_walk.KF		
				TextKeys = [ 
					     { Name = START_SOUND_UNTIL_ANIM_CHANGE Data = fx_move_halftrack KeyTime = 0} 
					   ] 
				}

			{ StateName= Attack1	AnimName = lla11_aahalftrack_attack.KF	
				TextKeys = [ 
					     { Name = PLAY_SOUND Data = Tank_firing1 KeyTime = 0.5 }
					   ] 
				}

			{ StateName= Death AnimName = lla11_aahalftrack_death.KF		
				}
		]
	ChildNames 	= [ TheHealthBar SelectCircleMedium FX_ExaustSmoke1 ArtilleryTracks 
					Muzzle_Rifleman ExplSelectorTank01 AAHalfTrack_FlyingParts 
					AAHalfTrackShadow MediumGlow expl_tank_Tandrill 
					HemisphereLighting_Unit DynamicLighting_Unit
				  ]
	UIRenderingParams {
		xOffset = -3.42
		yOffset = 0.81
		zOffset = 1.70
		scale = 1.00		// (default value)
		angle = 33.16
		rotationSpeed = 0.00		// (default value)
		pitch = 20.00		// (default value)
	}

}

