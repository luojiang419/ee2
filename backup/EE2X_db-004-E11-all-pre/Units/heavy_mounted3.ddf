		SizeY = 0.65
		mass = 1
		moveType = kUnitMoveType_Mechanized
		rps = HeavyMounted
		popCount = 2
		stance = Defensive
	}
	
	attributes = [
		HealedByHERC, 
		CanJoinHeroArmy
	]
	sounds = {
	}
		
	abilities = [
		Attack { range = 6; reloadTime = 1.3; applyDamageTime = 0.5; damage = 100; packTime = 1.0; unpackTime = 1.0; missileName = "ProjectileRocketHerc" }
		LOS { range = 6 }
		VehicleMove {speed = 1.725; angSpeed = 180; followTerrainSlope = 1; bounce = 0.2;}
		Garrisonable { garrisonTypes = [ NavalTransport Fortress ] }
	]
	icon = icon_unit_4leg_mech
	fullMapOverlay { sprite = spr_fullmap_smallunit ignoreOrientation = 1 }
}

