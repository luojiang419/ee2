// From Mars and from the other Planets the Wood Resource 
//---------------------------------------------------------------------------

UnitType CarbonWood
{
	parent = Resource
	properties {
		SizeX = 0.55
		SizeY = 0.55
		//DisplayName = tx_amb15_space_carbon
		VerboseTooltip = tx_vtt_amb15_space_carbon
		mass = 1
		hitpoints = 1000
		mmColor = [0,64,0,255]
		//inForest = 1
	}
	abilities [
		// change alwaysExhaustible to make tree exhaustible
		Resource { type = kResourceType_Wood; alwaysExhaustible = 1; amount = 2277; maxNumOfWorkers = 3}
	]
	fullMapOverlay { sprite = spr_fullmap_tree scale = 2.0 ignoreOrientation = 1 }
}

