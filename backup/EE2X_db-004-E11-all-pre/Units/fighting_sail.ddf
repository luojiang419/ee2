{
	parent = NavalDeep
	properties {
		rps = FightingSail
		SizeX = 1.55
		SizeY = 0.8
		mass = 4
	}
	abilities = [
		Attack { range = 5; reloadTime = 2; applyDamageTime = 0.5; damage = 5; missileName = "BoatCannonBall" }
