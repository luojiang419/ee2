//------------------------------------------------------------------------------------------------
//	UNIQUE UNIT GREEK HOPLITE (EPOCHS 1-5)
//------------------------------------------------------------------------------------------------
UnitType UniqueUnitGreek1
{
	parent = HeavyInfantry2
	properties {
		DisplayName = tx_utn_UUGreek1_name
		DisplayNameScenEdit = tx_utn_UUGreek1_sname
		VerboseTooltip = vtt_unit_UUGreek1
		HitPoints = 0
	}
	sounds {
	}
	abilities = [
		Attack { damage = 0; range = 0; reloadTime = 666; applyDamageTime = 0.5; WeaponType = Melee }
		ConvertAttack { convertTimeModifier = 10.0; range = 5.0; reloadTime = 4.0; applyDamageTime = 1.0; capture = 1 }
		LOS { range = 0 }
		Move {speed = 1.3; angSpeed = 720}
	]
}

