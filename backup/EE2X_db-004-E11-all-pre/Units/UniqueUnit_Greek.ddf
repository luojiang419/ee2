{
	unitType = UniqueUnitGreek1
	name = tx_utn_elite_modify_name
	upgradeRefs = [
		UniqueUnit_Improve_2_5
	]
}

//------------------------------------------------
//	UNIQUE UNIT MODEL
//------------------------------------------------
UnitModel UniqueUnitGreek1
{
	Parent		= HeavyInfantry2_02
	ScaleType	= kScaleUnit
	DefaultModel 	= CIV2_hoplite_greek.nif
	ChildNames 	= [ UnitShadow ]
	States 		= [
		{	StateName = Idle	AnimName = CIV2_hoplite_greek_idle01.kf
                              AnimVariants = [ CIV2_hoplite_greek_idle02.kf CIV2_hoplite_greek_idle03.kf ]
                              AnimVariantsWeights = [ 0.1 0.1 ]
                 }
		{ 	StateName = Walk	AnimName = CIV2_hoplite_greek_walk01.kf	}
               { 	StateName = CaptureAttack1	AnimName = CIV2_hoplite_greek_capture01.kf
                              AnimVariants = [ CIV2_hoplite_greek_capture02.kf ]
                              AnimVariantsWeights = [0.3]
                 }
		{ 	StateName = Run	AnimName = CIV2_hoplite_greek_jog01.kf	}
		{ 	StateName = Attack1	AnimName = CIV2_hoplite_greek_attack01.kf
			TextKeys = [
					{ Name = PLAY_SOUND Data = fx_spear_thrust KeyTime = 0.40 }
							] }
		{ 	StateName = Death	AnimName = CIV2_hoplite_greek_death01.kf	}
		{	StateName = Flinch	AnimName = CIV2_hoplite_greek_protect01.kf }
		{	StateName = BeingThrown	AnimName = CIV2_hoplite_greek_flying01.kf
			AnimVariants = [ CIV2_hoplite_greek_flying02.kf ] AnimVariantsWeights = [ 0.5 ]	}
		{	StateName = ThrownDeath	AnimName = CIV2_hoplite_greek_ground_death01.KF	}

			]
}

