UnitType WarGalley
{
	parent = NavalShallow
	properties {
		rps = WarGalley
		SizeX = 1.4
		SizeY = 0.55
		mass = 2
	}
	sounds = {
	}
	abilities = [
		Attack { range = 5; reloadTime = 2; applyDamageTime = 0.5; damage = 5; missileName = "Arrow" }
		Garrison { 
			garrisonType = NavalTransport; 
			numOfSlots = 9;
			GarrisonFlagModelName = "GarrisonShip"
			}
		LOS { range = 0 }
		NavalMove {speed = 1.4; angSpeed = 90; accel = 1.0}
	]
}

