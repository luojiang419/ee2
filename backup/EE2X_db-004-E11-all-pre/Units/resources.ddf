 //
// the most basic resource unit type (for both trees and non-trees)
// 

UnitType Resource
{
	OwnerType = WorldOnly
	properties {
		rps = LandNonCombat
		FootprintType = kFootprintType_Rectangle
		requiredOpenSides = kBuildingOpenSides_PosXPosYNegXNegY
	}
}




//-----------------------------------------------------------------------------------------------
// Shadow data
