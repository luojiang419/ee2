		scale = 1.66
		angle = 45.00
		rotationSpeed = 0.00
		pitch = 0.01
		lightAngle = 30.00
		lightPitch = 90.00
		lightDiffuse = [50 50 45 255]
		lightSpecular = [0 0 0 255]
		lightAmbient = [40 40 40 255]
	}
}

