//------------------------------------------------------------------------------------------------
//	AMBIENTS
//------------------------------------------------------------------------------------------------
UnitType Ambient
{
	ownerType = WorldOnly
	properties {
		FootprintType = kFootprintType_Rectangle
		SizeX = 0.5
		SizeY = 0.5
		mass = 1
		rps = LandNonCombat
	}
	abilities [
	]
	fullMapOverlay { sprite = spr_fullmap_building }
}

UnitType AmbientInForest
{
	parent = Ambient
	properties {
		inForest = 1
	}
}

UnitType AmbientBuilding
{
	placementType = Building
	ownerType = WorldOnly
	properties {
		FootprintType = kFootprintType_Rectangle
		SizeX = 2.5
		SizeY = 2.5
		mass = 1
		hitpoints = 1000
		rps = LandNonCombat
	}
	abilities [
	]
	fullMapOverlay { sprite = spr_fullmap_building }
}


