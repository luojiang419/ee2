        { 	StateName = Walk	AnimName = NWG1_Galley_walk.kf	
				TextKeys = [{ Name = START_SOUND_UNTIL_ANIM_CHANGE Data =  fx_move_boat_2 KeyTime = 0}]}
		{ 	StateName= Attack1		
			TextKeys = [ { Name = PLAY_SOUND Data = fx_bow_shoot KeyTime = 0.5 }] 
		}
		{ StateName= Death }	
