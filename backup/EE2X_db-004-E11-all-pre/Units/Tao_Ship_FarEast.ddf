
UnitType ZhengHe
{
	parent = NavalDeep
	properties {
		rps = FightingSail
		SizeX = 2.0
		SizeY = 0.8
		mass = 4
		displayName = tx_utn_ZhengHe_name
		verboseTooltip = vtt_unit_ZhengHe
		popCount = 3
		hitpoints = 3500
	}
	abilities = [
		Attack { damage = 250; range = 13; reloadTime = 3; applyDamageTime = 0.5; missileName = "BoatCannonBall"; turretControllerName = GalleonTurret;areaDamageRadius = 2; }
		LOS { range = 5 }
		NavalMove {speed = 1.4; angSpeed = 30; accel = 1.0}
	]
	icon = icon_unit_ZhengHe
}
