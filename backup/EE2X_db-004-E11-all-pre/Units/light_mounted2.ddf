//------------------------------------------------------------------------------------------------
//	LIGHT MOUNTED 2 - UNIT TYPE INFO
//------------------------------------------------------------------------------------------------
UnitType LightMounted2
{
	parent = Helicopter
	visualName = LightMounted2_13
	properties {
		rps = Helicopter
		SizeX = 1
		SizeY = 0.7
		mass = 1
		HitPoints = 500
	}
	abilities = [
		AircraftMove {speed = 4.0; accel = 2.0;  angSpeed = 180; CruisingHeight = 5.0; ElevChangeRate = 1.0;CanHover = 1 }
		Attack { range = 7; reloadTime = 2; applyDamageTime = 0; damage = 50; missileName = "GuidedMissile" }
		LOS { range = 8 }
	]
	attributes = [
		CanJoinHeroArmy
	]
}

// Add to mobile units for a blobby ellipsoid shadow
ShadowData        missileHelicopterShadow_01
{
	Flags = (IsMobile | ImmutableBounds)
	FlatBillboard
	{
		TextureFilename = LLM13_MissileHelicopter_shadow.tga
		WidthScale = 0.9
		LengthScale = 0.9
		HeightScale = 0.1
	}
}

ShadowData        missileHelicopterShadow_02
{
	Flags = (IsMobile | ImmutableBounds)
	FlatBillboard
	{
		TextureFilename = llm15_HeavyMissileHelicopter_shadow.tga
		WidthScale = 0.9
		LengthScale = 0.9
		HeightScale = 0.1
	}
}

