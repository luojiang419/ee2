//------------------------------------------------------------------------------------------------
//	KOREAN CAMPAIGN SPECIFIC UNIT - UNIT TYPE AND VISUAL INFO
//------------------------------------------------------------------------------------------------
//------------------------------------------------
//	QUEEN SONDUK
//------------------------------------------------
UnitType QueenSonduk
{
	parent = LeaderImperial
	properties {
		displayName = tx_utn_LeadSonduk_name
		displayNameScenEdit = tx_utn_LeadSonduk_sname
		hitpoints = 325
		verboseTooltip = vtt_unit_LeaderImperial
	}
	sounds = {
		sndCmdMove = ["v_leader_sonduk_01_com01" "v_leader_sonduk_01_com02"]
		sndCmdAttack = ["v_leader_sonduk_01_spe01"]
		sndSelection = ["v_leader_sonduk_01_sel01"]
		sndDeath =  ["fx_death_female_01"]
	}
	abilities = [
		Attack { range = 0.8; reloadTime = 1.5; applyDamageTime = 0.5; damage = 9 }
		LOS { range = 5 }
		AreaEffect {
			effects = [ 
				Loyalty
			]
		}
		SpecialPower {
			range = 3;
			effects = [
				Endeavor
			]			
		}
	]
	icon = icon_unit_queensunduck
}

UnitModel QueenSonduk
{
	Parent 		= BaseHuman
	DefaultModel 	= amb_queensunduck_korean.nif
	ChildNames 	= [ UnitShadow ]
	States 		= [
		{	StateName = Idle	AnimName = amb_queensunduck_korean_idle01.KF
                              AnimVariants = [ amb_queensunduck_korean_idle03.KF ]
                        AnimVariantsWeights = [ 0.1 ]
                 }
		{ 	StateName = Walk	AnimName = amb_queensunduck_korean_walk01.KF	}
                { 	StateName = Run	        AnimName = amb_queensunduck_korean_jog01.kf     }
		{ 	StateName = Attack1	AnimName = amb_queensunduck_korean_attack01.KF	}
		{ 	StateName = CaptureAttack1	AnimName = amb_queensunduck_korean_idle02.KF} // @AA - change to "distinctive animation" once one exists
		{ 	StateName = Death	AnimName = amb_queensunduck_korean_death01.KF	}
			]
}

//------------------------------------------------
//	KOREAN 6 - CHINESE DIPLOMAT
//------------------------------------------------
UnitType KoreanCampaignDiplomat
{
	parent = Human
	properties {
		displayName = tx_utn_cmpgnKorDiplomat_name
		displayNameScenEdit = tx_utn_cmpgnKorDiplomat_sname
		hitpoints = 325
		verboseTooltip = vtt_unit_cmpgnKorDiplomat
		SizeX = 0.225
		SizeY = 0.225
		mass = 1
		rps = Citizen
		stance = Cautious
	}
	abilities = [
		LOS { range = 5 }
	]
	icon = icon_unit_priest_7_fe
}

UnitModel KoreanCampaignDiplomat
{
	Parent = Priest_7
	DefaultModel 	= LSF7_priest_fe.nif
	UIRenderingParams {
		xOffset = 0.01
		yOffset = 0.37
		zOffset = -6.12
		scale = 2.43
		angle = 23.68
		rotationSpeed = 0.00
		pitch = 9.47
		lightAngle = 30.00
		lightPitch = 90.00
		lightDiffuse = [50 50 45 255]
		lightSpecular = [0 0 0 255]
		lightAmbient = [40 40 40 255]
	}
}


