					resource = Food
					percentTransferred = 0.0
					NativeTribesAmountTransferredMin = 100.0
					NativeTribesAmountTransferredMax = 150.0
				}
				{
					// amount-based transfer from native tribe
					resource = Wood
					percentTransferred = 0.0
					NativeTribesAmountTransferredMin = 100.0
					NativeTribesAmountTransferredMax = 150.0
				}
