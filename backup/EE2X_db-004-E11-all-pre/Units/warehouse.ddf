//------------------------------------------------------------------------------------------------
//	WAREHOUSE - UNIT TYPE INFO
//------------------------------------------------------------------------------------------------
UnitType Warehouse
{
	ownerType = PlayerOnly
	parent = NoProduceBuilding
	properties {
		SizeX = 2
		SizeY = 1
		UndertextureSizeX = 2
		UndertextureSizeY = 1
		mass = 1
		DisplayNameScenEdit = tx_utn_warehouse_sname
		displayName = tx_utn_warehouse_name
		VerboseTooltip = vtt_unit_Warehouse
	}
	sounds {
    	}
	fullMapOverlay { sprite = spr_fullmap_warehouse }
	abilities = [
		LOS { range = 0 }
		ResourceDropoff { type = kResourceType_AllNaturalResource; }
		Garrison { 
			garrisonType = UniWarehouseOilDerrickCityCenter; 
			numOfSlots = 5;
			resourceBonus = 0.01;	// 2 percent more resource dropoff for each garrisoned UnitType
			rightClickToGarrison = 1;
			GarrisonFlagModelName = "GarrisonFlag"
		}
		Convertable {
			convertTimeModifier = 100.0;  //
			garrisonedUnitModifier = 0.1; // 10% increase in capture time
			garrisonedUnitDamage = 1.0;	  // hitpoints subtracted from capturer per round per garrisoned unit
			damageRate = 10.0;			  // hitpoints subtracted from capture target hitpoints per round
			capture = 1;
			resourcesTransferred = [
				{
					// percentage-based transfer from normal player
					resource = AllNaturalResource
					percentTransferred = 0.05
					NativeTribesAmountTransferredMin = 0.0
					NativeTribesAmountTransferredMax = 0.0
				}
				{
					// amount-based transfer from native tribe
					resource = Food
					percentTransferred = 0.0
					NativeTribesAmountTransferredMin = 100.0
					NativeTribesAmountTransferredMax = 150.0
				}
				{
					// amount-based transfer from native tribe
					resource = Wood
					percentTransferred = 0.0
					NativeTribesAmountTransferredMin = 100.0
					NativeTribesAmountTransferredMax = 150.0
				}
				{
					// amount-based transfer from native tribe
					resource = Stone
					percentTransferred = 0.0
					NativeTribesAmountTransferredMin = 100.0
					NativeTribesAmountTransferredMax = 150.0
				}
				{
					// amount-based transfer from native tribe
					resource = Gold
					percentTransferred = 0.0
					NativeTribesAmountTransferredMin = 100.0
					NativeTribesAmountTransferredMax = 150.0
				}
			]
		}
		// @EE2X @MRC 
		// Empty area effect set so more can be added later.
		AreaEffect {
			effects = [ 
			]
		}
	]
}
