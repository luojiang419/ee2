//------------------------------------------------------------------------------------------------
//	FISHING SHIP
//------------------------------------------------------------------------------------------------
UnitType FishingShip
{
	parent = NavalShallow
	icon = icon_unit_fishing_galley
	properties {
		SizeX = 1.8
		SizeY = 0.5
		mass = 1
		hitpoints = 50
		VerboseTooltip = vtt_unit_FishingShip
		displayName = tx_utn_fishShip_name
		displayNameTTTooltip = tx_utn_fishShip_tt_name
		popCount = 1
	}
	sounds = {
	}
	abilities = [
		NavalMove {speed = 1.3; angSpeed = 80}
		GatherFarm { 
				treeCuttingRange = 0.55; 	// do we even need this in here?
				otherRange = 0.8;
				dropoffRange = 0.7;

				 foodRate = 0.6; // this is the gather rate from school of fish
				 woodRate = 0.0;
				 stoneRate = 0.0;
				 goldRate = 0.0;
				 tinRate = 0.0;
				 ironRate = 0.0;
				 saltpeterRate = 0.0;
				 oilRate = 0.0;
				 uraniumRate = 0.0;
				 carryLimit = 30; // upgraded Nord 1/13/05
				 farmRate = 0.0;
				 farmCarryLimit = 0;
				}		
		LOS { range = 5 }
	]
}

