//------------------------------------------------------------------------------------------------
//	HEAVY ARTILLERY - UNIT TYPE INFO
//------------------------------------------------------------------------------------------------
UnitType HeavyArtillery
{
	parent = Artillery
	properties {
		SizeX = 1
		SizeY = 1
		mass = 2
	}
	sounds {
		sndDeath =  ["fx_death_male_01" "fx_death_male_02" "fx_death_male_03" "fx_death_male_04" "fx_death_male_05" "fx_death_male_06" "fx_death_male_07"]
    	}
	abilities = [
		Attack { range = 0; reloadTime = 1; applyDamageTime = 0.3; damage = 0; missileName = "RockAmmo"; ignoreBlocking = 1; areaDamageRadius = 2.0; packTime = 4; unpackTime = 4; areaDamageFriendlyRatio = 0.5}
		LOS { range = 0 }
		Move {speed = 0.8; angSpeed = 120}
		Garrisonable { garrisonTypes = [  Fortress  NavalTransport  AirTransport ] }	
	]
}

ShadowData        SelfPropelledShadow
{
	Flags = (IsMobile | ImmutableBounds)
	FlatBillboard
	{
		TextureFilename = LHA12_selfPropelled_shadow.tga
		WidthScale = 3.2
		LengthScale = 1.0
		HeightScale = 0.1
	}
}

ShadowData        NetFireLauncherShadow
{
	Flags = (IsMobile | ImmutableBounds)
	FlatBillboard
	{
		TextureFilename = LHA14_NetFireLauncher_shadow.tga
		WidthScale = 2.6
		LengthScale = 1.0
		HeightScale = 0.1
	}
}

ShadowData        NetFireLauncherShadow2
{
	Flags = (IsMobile | ImmutableBounds)
	FlatBillboard
	{
		TextureFilename = LHA14_NetFireLauncher_shadow.tga
		WidthScale = 1.6
		LengthScale = 1.2
		HeightScale = 0.1
	}
}
