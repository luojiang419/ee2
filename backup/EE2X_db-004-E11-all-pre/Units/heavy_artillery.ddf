UnitModel HeavyArtillery_02
{	
	Parent			= BaseArtillery
	DefaultModel 		= LHA2_onager.nif
	ChildNames 	= [ ArtilleryTracks TheSiegeUnitDamageEffect ]
	DamageDecalsSetName = BuildingDamageDecals
	States 		= [
		{	StateName = Idle	AnimName = LHA2_onager_idle.KF
				TextKeys = [
								{ Name = HIDE_NODE Data = ball KeyTime = 0 }
				]}
		{   	StateName = UnpackedIdle  AnimName = lha2_onager_unpackidle01.kf 
				TextKeys = [
								{ Name = HIDE_NODE Data = ball KeyTime = 0 }
				]}
		{ 	StateName = Walk	AnimName = LHA2_onager_walk.KF
				TextKeys = [
								{ Name = START_SOUND_UNTIL_ANIM_CHANGE Data = fx_move_wheeled_02 KeyTime = 0}
								{ Name = HIDE_NODE Data = ball KeyTime = 0 }
				] }
		{	StateName = UnpackedWalk  AnimName = lha2_onager_unpackwalk01.kf 
				TextKeys = [
								{ Name = HIDE_NODE Data = ball KeyTime = 0 }
				]}
		{ 	StateName = Attack1	AnimName = LHA2_onager_attack.KF
				TextKeys = [
								{ Name = PLAY_SOUND Data = Trebuchet_firing1 KeyTime = 1.78 }
								{ Name = SHOW_NODE Data = ball 	KeyTime = 0.1 }
				] }
		{	StateName = Pack	AnimName = lha2_onager_pack.kf 
				TextKeys = [
								{ Name = HIDE_NODE Data = ball KeyTime = 0 }
				]}
		{	StateName = Unpack	AnimName = lha2_onager_unpack.kf 
				TextKeys = [
								{ Name = HIDE_NODE Data = ball KeyTime = 0 }
				]}
		{ 	StateName = Death	AnimName = lha2_onager_death.kf 
				TextKeys = [
								{ Name = HIDE_NODE Data = ball KeyTime = 0 }
				]}
		{   	StateName = PackedDeath AnimName = lha2_onager_packdeath01.kf 
				TextKeys = [
								{ Name = HIDE_NODE Data = ball KeyTime = 0 }
				]}
			]
	UIRenderingParams {
		xOffset = 0.26
		yOffset = 0.35
		zOffset = 0.53
		scale = 1.53
		angle = 37.89
	}
}

