//	EPOCH 1
//------------------------------------------------
StateDatabase Bridge_States
{
	DefaultState = Idle
	States = 
	[
		{	StateName = Idle }
	]
}

BridgeModel BridgeModel_1
{
	StateDatabaseName = Bridge_States
	EndModel	= bld_bridge1_span.nif
	SpanModel	= bld_bridge1_span.nif
	SmokeNifNames =[ fx_smoke_bridge_1.nif ]
	WaveNifNames = [ BoatWakeIdle_02_L1.nif BoatWakeIdle_03_L1.nif BoatWakeIdle_04_L1.nif BoatWakeIdle_03_L1.nif BoatWakeIdle_04_L1.nif]
	WaveScales = [1 1 1 1 1]
	SplashNifNames = [ fx_watersplash_1.nif BoatWakeIdle_02_L1.nif BoatWakeIdle_02_L1.nif BoatWakeIdle_02_L1.nif]
	SplashScales = [ 0.15 1 1 1]
	CollapseSounds = [ Bld_Collapse ]
	DelayBetweenSounds = 0.25
	
	DamageDecalsSetName = BuildingDamageDecals
}

CompositeModel Bridge
{
	ScaleType 	= kScaleBuilding
	ChildNames	= [ BridgeModel_1 TheHealthBar TheBldDamageEffect ]
}

