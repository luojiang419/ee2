//------------------------------------------------------------------------------------------------
//	BRIDGE
//------------------------------------------------------------------------------------------------
UnitType Bridge
{
	ownerType = PlayerOnly
	parent = BareBoneBuilding
	PlacementType = Bridge
	properties {
		displayName = tx_utn_bridge_name
		DisplayNameScenEdit = tx_utn_bridge_sname
		rps = Building
		FootprintType = kFootprintType_Rectangle
		SizeX = 0	// this is the dimension we stretch (so this is set dynamically)
		SizeY = 1.85	// the width of the bridge (the dimension we don't stretch)
		mass = 0	// so that it does not block pathing
		hitpoints = 2500
		VerboseTooltip = vtt_unit_Bridge
		mmColor = [128,128,128,255]
	}
	sounds {
		sndSelection = ["Bridge_select"]
    	}
	abilities [
		LOS { range = 0 }
		Connect { type = kComposite_Bridge; aidsPathing = 1; }	// "shortcut" the 2 end points, connect to other units
	]
	fullMapOverlay { sprite = spr_fullmap_bridge_start }
}

CompositeModel BridgeConstructionSite 
{
	ScaleType 			= kScaleBuilding
	StateDatabaseName  	= ConstructionSiteStates
	ChildNames = [ TheHealthBar ]
}

UnitType BridgeConstructionSite 
{
	placementType = Unplaceable
	properties {
		FootprintType = kFootprintType_Rectangle
		SizeX = 0	// this is the dimension we stretch (so this is set dynamically)
		SizeY = 1.85	// the width of the bridge (the dimension we don't stretch)
		mass = 0	// so that it does not block pathing
		rps = Building
		hitpoints = 1
	}
	abilities = [
		Construction {}
		LOS { range = 2 }
		Connect { type = kComposite_Bridge }	// connect to other units (no shortcut yet)
	]
}


