//The spacing of units in formation should be easy to tweak by the designers.
//The positional preference of each formation should be easy to tweak by the designers.
//The bonuses and possibility of penalties should be easy to tweak by the designers.


/////////////////////////////// LAND FORMATIONS ///////////////////////////////



//The phalanx is the classic all purpose formation, since it is
//well-protected on three sides, with its middle and rear packed
//with weak and/or ranged units.
Formation Phalanx {
	showInUI = 1	// show this formation in the UI
	icon = icon_formation_phalanx
	button = unit_formation_phalanx
	specialType = Phalanx
	Zones = [
		{
			Prefs = [
				Ram
				HeavyMounted
				HeavyInfantry
				LightMounted
				LightInfantry
				LightArtillery
				HeavyArtillery
				SpecialUnits
			]
		}
	]
	SpacingScaleFactor = 1
	class = Land
	
	rangeProperty = AllInRangeBonus
	//rangeBoost = 0.25
}

