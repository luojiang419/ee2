//------------------------------------------------
//	UNIQUE UNIT MODEL
//------------------------------------------------
UnitModel UniqueUnitMaasai1
{
	Parent		= LightInfantry_01
        ScaleType	= kScaleUnit
	DefaultModel 	= civ5_moraniwarrior_african.nif
	ChildNames 	= [ UnitShadow ]
	States 		= [
		{	StateName = Idle	AnimName = civ5_moraniwarrior_african_idle01.kf
                              AnimVariants = [ civ5_moraniwarrior_african_idle02.kf ]
                              AnimVariantsWeights = [0.1]
				TextKeys = [
								{ Name = SHOW_NODE Data = spear KeyTime = 0 }
				]}
		{ 	StateName = Walk	AnimName = civ5_moraniwarrior_african_walk.kf 
				TextKeys = [
								{ Name = SHOW_NODE Data = spear KeyTime = 0 }
				]}
                { 	StateName = CaptureAttack1	AnimName = civ5_moraniwarrior_african_capture01.kf
                              AnimVariants = [ civ5_moraniwarrior_african_capture02.kf ]
                              AnimVariantsWeights = [0.3]
				TextKeys = [
								{ Name = SHOW_NODE Data = spear KeyTime = 0 }
				]}     
		{ 	StateName = Run	AnimName = civ5_moraniwarrior_african_jog.kf
				TextKeys = [
								{ Name = SHOW_NODE Data = spear KeyTime = 0 }
				]}
		{ 	StateName = Attack1	AnimName = civ5_moraniwarrior_african_attack01.kf   
			TextKeys = [
					{ Name = PLAY_SOUND Data = fx_spear_throw KeyTime = 1.0 } 
					{ Name = HIDE_NODE Data = spear KeyTime = 1.0  } 
					{ Name = SHOW_NODE Data = spear KeyTime = 2.3 }]}
                { 	StateName = Death	AnimName = civ5_moraniwarrior_african_death.kf	
				TextKeys = [
								{ Name = SHOW_NODE Data = spear KeyTime = 0 }
				]}
		{	StateName = Flinch	AnimName = civ5_moraniwarrior_african_protect01.KF	}
		{	StateName = BeingThrown	AnimName = civ5_moraniwarrior_african_flying01.KF
			AnimVariants = [ civ5_moraniwarrior_african_flying02.KF ] AnimVariantsWeights = [ 0.5 ]	}
		{	StateName = ThrownDeath	AnimName = civ5_moraniwarrior_african_ground_death01.KF	}
			]
}

