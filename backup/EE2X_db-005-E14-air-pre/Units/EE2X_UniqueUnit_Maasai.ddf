{
	parent = LightInfantry
	properties {
		DisplayName = tx_utn_UUMaasai1_name
		DisplayNameScenEdit = tx_utn_UUMaasai1_sname
		VerboseTooltip = vtt_unit_UUMaasai1
		HitPoints = 0
		rps = LightInfantry
		SizeX = 0.125
		SizeY = 0.125
		mass = 1
	}
	sounds = {
	}
	abilities = [
		Attack { damage = 0; range = 0; reloadTime = 666; applyDamageTime = 1.0; missileName = "Spear" }
		ConvertAttack { convertTimeModifier = 10.0; range = 5.0; reloadTime = 4.0; applyDamageTime = 1.0; capture = 1 } // capture ability
		LOS { range = 0 }
		Move { speed = 1.3; angSpeed = 720}
	]
}

