UnitType Tank
{
	parent = HeavyMounted
	properties {
		moveType = Mechanized
		SizeX = 0.7
		SizeY = 0.7
		mass = 5
		hitpoints = 1000
		rps = LightMounted
		popCount = 2
	}
	sounds {
		//sndCmdMove = [""]
		//sndCmdAttack = [""]
		//sndSelection = [""]
	}
	abilities [
		VehicleMove {speed = 1.6; angSpeed = 80; followTerrainSlope = 1; mustMoveToTurn = 0}
		LOS {range = 5}
		Attack { range = 7; reloadTime = 2; applyDamageTime = 0.5; damage = 31 }
		AreaEffect {			effects = [ Taran_Tanks ]		}
		Garrison { 
			garrisonType = Tower; 
			numOfSlots = 5;
			attackBonus = 0.05;	
			healPoints = 10;		
			rightClickToGarrison = 1;
			GarrisonFlagModelName = "GarrisonFlag"
		}
		Garrisonable { garrisonTypes = [ Fortress  NavalTransport  AirTransport ] }
	]
	nonAttributes = [ 
		HealedByMedic
	]
}
