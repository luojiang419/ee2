UnitModel HeavyMounted2_13
{
	Parent		= BaseHelicopter
	ScaleType 	= kScaleVehicle
	DefaultModel 	= lhm13_gunhelicopter.nif
    ChildNames 	= [ Beam_Tracer01 expl_heli_Tandrill SelectCircleHelicopter GunHelicopter_FlyingParts Muzzle_Minigunner gunHelicopterShadow_01 ]
	States 		= 
	[
		{	StateName = Idle	AnimName = lhm13_gunHelicopter_idle.kf	
				TextKeys = [ 
					{ Name = HIDE_NODE Data = swipe 	KeyTime = 0 }
					{ Name = START_SOUND Data = fx_move_helicopter_02 }
					]}
		{ 	StateName = Walk	AnimName = lhm13_gunHelicopter_walk.kf	
				TextKeys = [ 
					{ Name = HIDE_NODE Data = swipe 	KeyTime = 0 }
					{ Name = START_SOUND Data = fx_move_helicopter_02 }
					]}
		{ 	StateName = Attack1	AnimName = lhm13_gunHelicopter_attack.kf
				TextKeys = [ 
					{ Name = HIDE_NODE Data = swipe 	KeyTime = 0 }
					{ Name = PLAY_SOUND Data = fx_battle_assrifle_fire KeyTime = 0.5}
					]}
		{ 	StateName = Death	AnimName = lhm13_gunHelicopter_death.kf	
				TextKeys = [ 
					{ Name = HIDE_NODE Data = swipe 	KeyTime = 0 }
					]}
	]

}
