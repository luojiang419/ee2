//------------------------------------------------------------------------------------------------
//	HEAVY MOUNTED 2 - UNIT TYPE INFO
//------------------------------------------------------------------------------------------------
UnitType HeavyMounted2
{
	parent = Helicopter
	properties {
		rps = Helicopter		
		SizeX = 1
		SizeY = 0.7
		mass = 1
	}
	sounds {
	}
	abilities = [
		AircraftMove {speed = 4.0; accel = 2.0;  angSpeed = 180; CruisingHeight = 5.0; ElevChangeRate = 1.0; CanHover = 1 }
		Attack { range = 6.0; reloadTime = 2.0; applyDamageTime = 0.5;  damage = 50 }
		LOS { range = 0 }
	]
	attributes = [
		CanJoinHeroArmy
	]
}

// Add to mobile units for a blobby ellipsoid shadow
ShadowData        gunHelicopterShadow_01
{
	Flags = (IsMobile)
	FlatBillboard
	{
		TextureFilename = lhm13_gunhelicopter_shadow.tga
		WidthScale = 0.9
		LengthScale = 0.9
		HeightScale = 0.1
	}
}

ShadowData        gunHelicopterShadow_02
{
	Flags = (IsMobile)
	FlatBillboard
	{
		TextureFilename = lhm15_heavygunhelicopter_shadow.tga
		WidthScale = 0.9
		LengthScale = 0.9
		HeightScale = 0.1
	}
}

