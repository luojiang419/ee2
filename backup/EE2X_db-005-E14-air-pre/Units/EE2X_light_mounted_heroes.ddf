//------------------------------------------------------------------------------------------------
//	LIGHT MOUNTED HERO - UNIT TYPE INFO
//------------------------------------------------------------------------------------------------
UnitType LightMountedHero
{
	parent = LightMounted1
	placementType = Unplaceable	// @TODO maybe make heroes placeable, but that causes problems with the HeroManager...
	properties {
		SizeX = 0.46
		SizeY = 0.23
	}
	abilities = [
		Hero { HeroClass = LightMounted; HeroForUnit = LightMounted1 }
		AreaEffect { effects = [ PrimaryHeroArmyBonus SupportingHeroArmyBonus ] }
	]
}

