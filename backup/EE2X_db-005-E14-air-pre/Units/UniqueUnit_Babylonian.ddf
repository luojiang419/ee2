//------------------------------------------------
//	UNIQUE UNIT MODEL
//------------------------------------------------
UnitModel UniqueUnitBabylonian1
{
	Parent		= LightInfantry_01
        DefaultModel 	= CIV1_AssyrianBowman_Babylonian.nif
	ChildNames 	= [ UnitShadow ]
	States 		= [
		{	StateName = Idle	AnimName = sh_bowman_idle01.KF
                        AnimVariants = [ sh_bowman_idle03.KF sh_bowman_idle02.KF ]
                        AnimVariantsWeights = [ 0.05 0.05 ]
				TextKeys = [
								{ Name = HIDE_NODE Data = arrow KeyTime = 0 }
				]}
		{ 	StateName = Walk	AnimName = sh_bowman_walk01.KF 
				TextKeys = [
								{ Name = HIDE_NODE Data = arrow KeyTime = 0 }
				]}
                { 	StateName = CaptureAttack1	AnimName = CIV1_AssyrianBowman_Babylonian_capture01.KF
                              AnimVariants = [ CIV1_AssyrianBowman_Babylonian_capture02.KF ]
                              AnimVariantsWeights = [0.3]
				TextKeys = [
								{ Name = SHOW_NODE Data = arrow KeyTime = 0 }
				]}     
		{ 	StateName = Run	        AnimName = sh_bowman_jog01.KF  
				TextKeys = [
								{ Name = HIDE_NODE Data = arrow KeyTime = 0 }
				]}
		{ 	StateName = Attack1	AnimName = CIV1_AssyrianBowman_Babylonian_attack01.KF
			TextKeys = [ { Name = PLAY_SOUND Data = fx_bow_shoot_high KeyTime = 1.56 } 
				     { Name = SHOW_NODE  Data = arrow KeyTime = 0 }
				     { Name = HIDE_NODE  Data = arrow KeyTime = 1.56 }] 
					}
		{ 	StateName = Death	AnimName = sh_bowman_death01.KF	
				TextKeys = [
								{ Name = HIDE_NODE Data = arrow KeyTime = 0 }
				]}
		{	StateName = Flinch	AnimName = CIV1_AssyrianBowman_Babylonian_protect01.kf }
		{	StateName = BeingThrown	AnimName = CIV1_AssyrianBowman_Babylonian_flying01.kf
			AnimVariants = [ CIV1_AssyrianBowman_Babylonian_flying02.kf ] AnimVariantsWeights = [ 0.5 ]	}
		{	StateName = ThrownDeath	AnimName = CIV1_AssyrianBowman_Babylonian_ground_death01.kf }
			]
}

