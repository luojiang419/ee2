UnitType UniqueUnitBabylonian1
{
	parent = LightInfantry
	properties {
		DisplayName = tx_utn_UUBabylonian1_name
		DisplayNameScenEdit = tx_utn_UUBabylonian1_sname
		VerboseTooltip = vtt_unit_UUBabylonian1
		HitPoints = 0
		rps = LightInfantry
		SizeX = 0.125
		SizeY = 0.125
		mass = 1
	}
	sounds = {
	}
	abilities = [
		Attack { damage = 0; range = 0; reloadTime = 666; angularRange = 30; applyDamageTime = 1.56; missileName = "Arrow"; ignoreBlocking = 1 }
		ConvertAttack { convertTimeModifier = 10.0; range = 5.0; reloadTime = 4.0; applyDamageTime = 1.0; capture = 1 } // capture ability
		LOS { range = 0 }
		Move { speed = 1.3; angSpeed = 720}
	]
}

