//------------------------------------------------------------------------------------------------
//	AIRCRAFT
//------------------------------------------------------------------------------------------------
UnitType Aircraft
{
	parent = AirUnit
	ownertype = PlayerOnly
	abilities [
		AircraftMove {speed = 1.725; angSpeed = 180}
		LOS { range = 5 }
		Garrisonable { garrisonTypes = [ AirportOrAircraftCarrier ] }
	]
}


//------------------------------------------------------------------------------------------------
//	Visual info AIRCRAFT
//------------------------------------------------------------------------------------------------
UnitModel BaseAircraft
{
	ScaleType 		= kScaleUnit
	DefaultState 		= Idle
	ChildNames 		= [ SelectCircleAircraft TheHealthBar ExplSelectorHeli01 GlowAirUnit 
						HemisphereLighting_Unit DynamicLighting_Unit
					  ]
	UIRenderingParams {
		xOffset = 0.01
		yOffset = 0.55
		zOffset = -2.23
		scale = 1.79
		angle = 18.95
		rotationSpeed = 0.00
		pitch = 33.16
		lightAngle = 30.00
		lightPitch = 90.00
		lightDiffuse = [50 50 45 255]
		lightSpecular = [0 0 0 255]
		lightAmbient = [40 40 40 255]
	}
}