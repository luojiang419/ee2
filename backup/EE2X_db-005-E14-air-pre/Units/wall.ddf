//------------------------------------------------------------------------------------------------
//	WALL
//------------------------------------------------------------------------------------------------

//
// base unit type for all the wall unit types
//
UnitType WallBase
{
	ownerType = PlayerOnly
	parent = BareBoneBuilding
	placementType = Unplaceable	// most wall types are unplaceable
	properties {
		DisplayNameScenEdit = tx_utn_wall_sname
		displayName = tx_utn_wall_name
		displayNameTTTooltip = tx_utn_wall_tt_name
		mass = 1
		VerboseTooltip = vtt_unit_Wall
	}
	sounds {
		sndSelection = ["Wall_select"]
    	}

}

//
// base unit type for wall segment and wall segment foundation
//
UnitType Wall_Segment_Base
{
	parent = WallBase
	properties {
		SizeX = 0.69288		// the long dimension the wall runs in
		SizeY = 0.52		// the width of the wall
		hitpoints = 1
	}
	abilities = [
		Connect { type = kComposite_WallSegment; }
	]
}

//
// the actual wall segment unit type
//
UnitType Wall
{
	parent = Wall_Segment_Base
	placementType = Wall		// this one is actually placeable
	abilities = [
		LOS { range = 2 }
	]
	properties {
		UnitHeight = 2.27
	}	
}

//
// base unit type for wall connector and wall connector foundation
//
UnitType Wall_Connector_Base
{
	parent = WallBase
	properties {
		SizeX = 0.7566		// these should be square
		SizeY = 0.7566
		hitpoints = 1
	}
	abilities = [
		Connect { type = kComposite_WallConnector; }
	]
}

//
// the actual wall connector unit type
//
UnitType Wall_Connector
{
	parent = Wall_Connector_Base
	abilities = [
		LOS { range = 2 }
	]
	properties {
		UnitHeight = 3.09
	}
}

//
// base unit type for wall fragment and wall fragment foundation
//
UnitType Wall_Fragment_Base
{
	parent = WallBase
	properties {
		SizeX = 0.2309		// the long dimension the wall runs in
					// (this should be 1/3 the SizeX for UnitType Wall)
		SizeY = 0.52		// the width of the wall
					// (this should equal the SizeY for UnitType Wall)
		hitpoints = 1
	}
	abilities = [
		Connect { type = kComposite_WallFragment; }
	]
}

//
// the actual wall fragment unit type
//
UnitType Wall_Fragment
{
	parent = Wall_Fragment_Base
	abilities = [
		LOS { range = 2 }
	]
}




// ------------ WALL - FOUNDATIONS ----------- //

UnitType Wall_Foundation
{
	parent = Wall_Segment_Base
	properties {
		mass = 0	// don't block pathing
		hitpoints = 1
	}
	abilities = [
		Construction {}
	]
}

UnitType Wall_Connector_Foundation
{
	parent = Wall_Connector_Base
	properties {
		mass = 0	// don't block pathing
		hitpoints = 1
	}
	abilities = [
		Construction {}
	]
}

UnitType Wall_Fragment_Foundation
{
	parent = Wall_Fragment_Base
	properties {
		mass = 0	// don't block pathing
		hitpoints = 1
	}
	abilities = [
		Construction {}
	]
}

UnitModel Wall_Foundation
{
	parent = WallBaseModel
	DefaultModel 	= bld_wall8_construction_1.NIF
	ChildNames 	= [ TheHealthBar ]
}

UnitModel Wall_Connector_Foundation
{
	parent = WallBaseModel
	DefaultModel 	= bld_wall8_connector_construction_1.NIF
	ChildNames 	= [ TheHealthBar ]
}

UnitModel Wall_Fragment_Foundation
{
	parent = WallBaseModel
	DefaultModel 	= bld_wall8_fragment_construction_1.NIF	
}



//------------------------------------------------------------------------------------------------
//	WALL - VISUAL INFO
//------------------------------------------------------------------------------------------------

//
// base model:
//

UnitModel WallBaseModel
{
	ScaleType	= kScaleWall
	DefaultState	= Idle
	OutlineType	= kOutlineReceive
	ChildNames      = [ WallShadow TheVisualFlag
						HemisphereLighting_Wall DynamicLighting_Wall
					  ]
	States 		= [
			{	StateName = Idle	}
			{	StateName = Death	ModelName = NULL.nif
						TextKeys = [ 
						{ Name = PLAY_SOUND	Data = Bld_Collapse } 
			] }
			]
	DamageDecalsSetName = BuildingDamageDecals	
}

//------------------------------------------------
//	EPOCH 2
//------------------------------------------------

WallModel Wall_MainModel_2
{
	DefaultModel 			= bld_wall2.NIF
	OneNeighborDestroyedModel 	= bld_wall2_damaged_front.NIF
	BothNeighborsDestroyedModel	= bld_wall2_damaged_both.NIF
	DamageDecalsSetName 		= BuildingDamageDecals	
}

WallModel WallFragment_MainModel_2
{
	DefaultModel			= bld_wall2_fragment.NIF
	DamageDecalsSetName 		= BuildingDamageDecals	
}

CompositeModel Wall
{
	ScaleType 	= kScaleWall
	OutlineType	= kOutlineReceive
	ChildNames 	= [ Wall_MainModel_2 WallShadow TheHealthBar Wall2_BuildEffectStep TheCollapseEffect 
					ExplSelectorBuild_Tiny ExplPartsStone 
					HemisphereLighting_Wall DynamicLighting_Wall
				  ]
	UIRenderingParams {
		xOffset = 0.01
		yOffset = 0.01
		zOffset = 0.01
		scale = 1.00
		angle = 90.00
		rotationSpeed = 0.00
		pitch = 0.01
		lightAngle = 30.00
		lightPitch = 90.00
		lightDiffuse = [50 50 45 255]
		lightSpecular = [0 0 0 255]
		lightAmbient = [40 40 40 255]
	}
}

CompositeModel Wall_Fragment
{
	ScaleType	= kScaleWall
	OutlineType	= kOutlineReceive
	ChildNames 	= [ WallFragment_MainModel_2 WallShadow TheHealthBar Wall2_FragmentBuildEffectStep 
					TheCollapseEffect ExplSelectorBuild_Tiny ExplPartsStone
					HemisphereLighting_Wall DynamicLighting_Wall
				  ]
}

UnitModel Wall_Connector
{
	parent = WallBaseModel
	DefaultModel 	= bld_wall2_connector.NIF
	ChildNames 	= [ TheHealthBar Wall2_ConnectorBuildEffectStep TheCollapseEffect 
					ExplSelectorBuild_Tiny TowerUpgradeScaffolding MediumGlow2 ExplPartsStone
				  ]
	States 		= [
			{	StateName = Idle	}
			]
	UIRenderingParams {
		xOffset = 0.01
		yOffset = 0.01
		zOffset = 0.01
		scale = 1.00
		angle = 45.00
		rotationSpeed = 0.00
		pitch = 20.00
		lightAngle = 30.00
		lightPitch = 90.00
		lightDiffuse = [50 50 45 255]
		lightSpecular = [0 0 0 255]
		lightAmbient = [40 40 40 255]
	}
}


