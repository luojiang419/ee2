//------------------------------------------------------------------------------------------------
//	AIRPORT - UNIT TYPE INFO
//------------------------------------------------------------------------------------------------
UnitType Airport
{
	parent = Building
	properties {
		SizeX = 5
		SizeY = 3
		FootprintSizeX = 6.5
		FootprintSizeY = 4.5
		OffsetX = 0.75
		OffsetY = 0.75
		UndertextureSizeX = 5
		UndertextureSizeY = 3
		mass = 1
		DisplayNameScenEdit = tx_utn_airport_sname
		displayName = tx_utn_airport_name
		VerboseTooltip = vtt_unit_Airport
		RallyPlacementFlags = ( Terrain | Water | Mountain | AnyBuilding | AnyMobile | Allied | Neutral | Hostile )
	}
	sounds {
    	}
	fullMapOverlay { sprite = spr_fullmap_airport }
	abilities = [
		Produce { NoRallyFlag = 1 }
		LOS { range = 0 }
		GarrisonAircraft {
			numOfSlots = 50;
			garrisonType = AirportOrAircraftCarrier;
			healPoints = 50;		// Each unit type garrison heals this many points per second
			rightClickToGarrison = 1;
			GarrisonFlagModelName = "GarrisonFlag"
		}
	]
}
