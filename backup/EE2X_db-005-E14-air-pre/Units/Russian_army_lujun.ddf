UnitType BTR80
{
	parent = Mounted
	properties {
		rps = LightMounted
		SizeX = 0.9
		SizeY = 0.7
		mass = 1
		popCount = 2
		displayName = tx_utn_BTR80_name
		verboseTooltip = vtt_unit_BTR80
		HitPoints = 2000
	}
	sounds = {
		sndSelection = ["CWCruBTR80_SI_sel_01" 
				"CWCruBTR80_SI_sel_02"
				"CWCruBTR80_SI_sel_03"
				"CWCruBTR80_SI_sel_04"
		]
		sndCmdMove = ["CWCruBTR80_SI_mov_01" 
	      		      "CWCruBTR80_SI_mov_02"
			      "CWCruBTR80_SI_mov_03"
			      "CWCruBTR80_SI_mov_04"
		]
		sndCmdAttack = ["CWCruBTR80_SI_att_01"
				"CWCruBTR80_SI_att_02"
				"CWCruBTR80_SI_att_03"
		]
		sndDeath =  ["CWCruBTR80_SI_cru_01"]
	}
	abilities = [
		Attack { range = 15; reloadTime = 0.2; applyDamageTime = 0.1; damage = 30; missileName = "fkjqAmmo"; turretControllerName = TankTurret; }
		VehicleMove {speed = 1.75; angSpeed = 70;followTerrainSlope = 1;mustMoveToTurn = 0} 
		LOS { range = 15 }
		Garrison { 
			garrisonType = Tower; 
			numOfSlots = 5;
			attackBonus = 0.05;	
			healPoints = 10;		
			rightClickToGarrison = 1;
			GarrisonFlagModelName = "GarrisonFlag"
		}
		Garrisonable { garrisonTypes = [ Fortress  NavalTransport  AirTransport ] }
	]
	icon = icon_unit_BTR80
}
