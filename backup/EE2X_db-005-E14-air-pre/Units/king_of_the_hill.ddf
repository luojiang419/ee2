//------------------------------------------------------------------------------------------------
//	BUDDHA - The One True King Of The Hill
//------------------------------------------------------------------------------------------------
UnitType KingOfTheHill
{
	parent = BareBoneBuilding
	// we don't want people placing these themselves
	// the VictoryCondition will handle that.
	//		BUT - the tool in the scenario editor
	//		needs this to be placeable, so this is
	//		being removed from the list in code
	//placementType = Unplaceable
	
	properties {
		hitpoints = 1000
		SizeX = 2
		SizeY = 2
		FootprintSizeX = 3
		FootprintSizeY = 3
		mass = 1
		displayName		= tx_utn_koth_name
		VerboseTooltip	= vtt_unit_koth
	}
	
	abilities = [
		LOS { range = 6 }
		Convertable {
			convertTimeModifier = 300.0;  //
			garrisonedUnitModifier = 0.0; // 0% increase in capture time
			garrisonedUnitDamage = 0.0;	  // hitpoints subtracted from capturer per round per garrisoned unit
			damageRate = 0.0;			  // hitpoints subtracted from capture target hitpoints per round
			capture = 1;
		}
			
		AreaEffect {
			effects = [ 
				Indestructability
				PreventDeletion
			]
		}
	]
}

UnitModel KingOfTheHill
{
	ScaleType 		= kScaleBuilding
	DefaultModel 	= amb_obelisk.nif
	DefaultState 	= Idle
	States			= [ { StateName="Idle" }	]
	ChildNames 		= [BuildingShadow TheAmbientPlacer HugeGlow ExplSelectorBuild_Medium]
}