UnitType MI_RTS13
{
	parent = Artillery
	properties {
		rps = HeavyArtillery
		SizeX = 1.2
		SizeY = 0.5
		mass = 3
		displayName = tx_utn_MIRTS13_name
		verboseTooltip = vtt_unit_MIRTS13
		HitPoints = 1500
		popCount = 3
	}
	sounds = {
				sndSelection = ["v_heavyartillery_12_spe01" 
"v_HeavyMounted1_11_spe01"
"v_HeavyMounted1_13_spe01"
"v_lightartillery1_13_sel01"
"v_LightMounted1_11_spe01"]
sndCmdMove = ["v_heavyartillery_12_com01" 
"v_HeavyMounted1_11_com01"
"v_HeavyMounted1_11_com02"
"v_HeavyMounted1_12_spe01"
"v_HeavyMounted1_12_com01"
"v_LightMounted1_11_com01"]
	}
	abilities = [
	PowerReserve { timeToRecharge = 60 }
	SpecialPower { 		
			effects = [ Change_Range ]
		}
		Attack {range = 2.1; reloadTime = 0.5; damage = 200; angularRange = 360; packTime = 2.0;unpackTime = 2.0; missileName = "MlrsRocket_PHL03"; ignoreBlocking = 1;  minRangeMobile = 16; minRangeImmobile = 16; areaDamageRadius = 3; turretControllerName = MRocketLauncherTurret; areaDamageFriendlyRatio = 0.5; throwUnits = true }
		VehicleMove {speed = 0.8; angSpeed = 70; followTerrainSlope = 1 }
		LOS { range = 16 }
		Garrisonable { garrisonTypes = [  Fortress  NavalTransport  AirTransport ] }
	]
	icon = icon_unit_MI_RTS13
}

UnitModel MI_RTS13
{
	Parent		= BaseArtillery
    DefaultModel 	= MI_RTS13.nif
	ForceScale      = 0.24
	DefaultState 	= Idle
	States 		= [
		{	StateName = Idle	AnimName = PHL03_idle.KF
			}
		{ 	StateName = Walk	AnimName = PHL03_walk.KF
				TextKeys = [ { Name = START_SOUND_UNTIL_ANIM_CHANGE Data = fx_move_self_propelled}
			]
			}
		{ 	StateName = Attack1	  AnimName = PHL03_attack.KF
				TextKeys = [ 
				{ Name = PLAY_SOUND Data = fx_battle_rocket_launch KeyTime = 0.3 }
			] 
			}
        { 	StateName = Pack	AnimName = PHL03_pack.KF   
				TextKeys = [{ Name = PLAY_SOUND Data = fx_mrls_unpack}]}
		{ 	StateName = Unpack	AnimName = PHL03_unpack.kf //LLA13_mrls_unpack.KF 
				TextKeys = [{ Name = PLAY_SOUND Data = fx_mrls_unpack}]}
		{ 	StateName = Death	AnimName = LLA13_mrls_death.KF
				TextKeys = [{ Name = PLAY_SOUND Data = fx_mrls_unpack}]
			}
		{   	StateName = UnpackedIdle  AnimName = PHL03_upidle0.kf  }
            {   	StateName = PackedDeath   AnimName = lla13_mrls_packdeath01.kf  }  
		{	StateName = UnpackedWalk  AnimName = PHL03_upwalk.kf  }
			]
	ChildNames 		= [ TheHealthBar FX_ExaustSmoke1  Muzzle_Phl032 Muzzle_Phl03
						 SelectCircleMedium TankTracks DustHeavyMonted  NetFireLauncherShadow
						expl_tank_Tandrill ExplSelectorTank01 TradeCart11_FlyingParts]
	UIRenderingParams {
		xOffset = 0.00
		yOffset = 1.62
		zOffset = 0.74
		scale = 1.92
		angle = 45.00
	}
}
