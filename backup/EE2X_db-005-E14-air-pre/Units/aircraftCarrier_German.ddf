UnitType GermanCarrier
{
	visualName = GermanCarrier_11
	parent = NavalDeep
	properties {
		rps = Carrier
		SizeX = 6.0
		SizeY = 2
		mass = 5
		RallyPlacementFlags = ( Terrain | Water | Mountain | AnyBuilding | AnyMobile | Allied | Neutral | Hostile )
		popCount = 5
	}
	attributes = [
		HealedByHERC 
			]
	sounds = {
	}
	abilities = [
		NavalMove {speed = 1.725; accel = 1; angSpeed = 10}
		LOS { range = 0 }
		Attack { damage = 0; range = 0; reloadTime = 666; applyDamageTime = 0.5;}
		Produce {  } // needs produce ability for EffectSpawn
		GarrisonAircraft {
			numOfSlots = 30;
			healPoints = 500;		// Each unit type garrison heals this many points per second
			garrisonType = AirportOrAircraftCarrier;
			GarrisonFlagModelName = "GarrisonShip"
		}
	]
}



