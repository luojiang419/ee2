//------------------------------------------------
//	GERMAN 1 - TEUTONIC CRUSADER
//------------------------------------------------
UnitType GermanCampaignTeutonicCrusader
{
	parent = UniqueUnitGerman2
	icon = icon_unit_UUGerman2
	properties {
		DisplayName = tx_utn_cmpgnCrusader_name
		verboseTooltip = vtt_unit_cmpgnCrusader
		DisplayNameScenEdit = tx_utn_cmpgnCrusader_sname
		HitPoints = 200
	}
	sounds = {
	}
	abilities = [
		Attack { range = 0.4; reloadTime = 1.0; applyDamageTime = 0.5; damage = 20 }
		ConvertAttack { convertTimeModifier = 5.0; range = 8; reloadTime = 2; applyDamageTime = 0.5; }
	]
}

UnitModel GermanCampaignTeutonicCrusader
{
		Parent		= HeavyMounted1_04
        DefaultModel 	= CIV7_Teut_Knight_German.NIF
	States 		= [
		{	StateName = Idle	AnimName = sh_elitecavalry_idle01.kf	
                              AnimVariants = [ sh_elitecavalry_idle02.kf 
sh_elitecavalry_idle03.kf 
sh_elitecavalry_win.kf 
sh_elitecavalry_season01.kf ]
                              AnimVariantsWeights = [ 0.05 0.3 0.1 0.2 ]}
		{ 	StateName = Walk	AnimName = sh_elitecavalry_walk01.KF AnimSpeedScale = 2.25 }
		{	StateName = Run		AnimName = sh_elitecavalry_run01.KF	}
		{	StateName = Convert	AnimName = CIV7_Teut_Knight_German_conversion01.kf }
		{ 	StateName = Attack1	AnimName = sh_elitecavalry_attack01.KF
		                              TextKeys = [
					{ Name = PLAY_SOUND Data = fx_spear_thrust KeyTime = 0.40 }]
                              AnimVariants = [ sh_elitecavalry_attack02.KF sh_elitecavalry_attack03.KF sh_elitecavalry_attack04.KF sh_elitecavalry_attack05.KF ]
                              AnimVariantsWeights = [ 0.02 0.03 0.03 0.02 ]
                 }
       		{ 	StateName = Death	AnimName = sh_elitecavalry_death01.KF	}
			]
	UIRenderingParams {
		xOffset = -3.68
		yOffset = 1.37
		zOffset = -0.54
		scale = 1.53
		angle = 47.37
		rotationSpeed = 0.00
		pitch = 10.00
		lightAngle = 30.00
		lightPitch = 90.00
		lightDiffuse = [50 50 45 255]
		lightSpecular = [0 0 0 255]
		lightAmbient = [40 40 40 255]
	}
}

//------------------------------------------------
//	GERMAN 3 - SPECIAL BOMBARD CANNON
//------------------------------------------------
UnitType GermanCampaignSpecialBombard
{
	parent = Artillery
	properties {
		SizeX = 0.75
		SizeY = 0.75
		mass = 2
		HitPoints = 375
		displayName = tx_utn_heavyArt8_name
		displayNameScenEdit = tx_utn_cmpgnGerbombard_sname
		verboseTooltip = vtt_unit_BombardCannon
	}
	sounds = {
		sndCmdMove = ["v_HeavyArtillery_08_com01" "v_HeavyArtillery_08_com02"]
		sndCmdAttack = ["v_HeavyArtillery_08_spe01"]
		sndSelection = ["v_HeavyArtillery_08_sel01"]
	}
	abilities = [
		Attack { range = 15; reloadTime = 4; applyDamageTime = 0.3; damage = 47; missileName = "RockAmmo"; ignoreBlocking = 1; areaDamageRadius = 1; areaDamageFriendlyRatio = 0.5 }
		Move {speed = 1.15; angSpeed = 180}
		LOS { range = 14 }
	]
	icon = icon_unit_BombardCannon
}

UnitModel GermanCampaignSpecialBombard
{
	Parent = HeavyArtillery_08
}

//------------------------------------------------
//	GERMAN 8 - OTTO VON BISMARCK
//------------------------------------------------
UnitType GermanCampaignBismarck
{
	parent = LeaderImperial
	icon = icon_unit_OttoVonBismarck
	properties {
		DisplayName = tx_utn_bismarck_name
		DisplayNameScenEdit = tx_utn_cmpgnGerBismarck_sname
		VerboseTooltip = vtt_unit_LeaderImperial
		HitPoints = 800
	}
	sounds {
	}
	abilities = [
		Attack { range = 0.8; reloadTime = 2; applyDamageTime = 0.5; damage = 43 }
		LOS { range = 5 }
		AreaEffect {
			effects = [
				Lectures 
			]
		}
		SpecialPower {
			range = 3;
			effects = [
				FastTracking
			]
		}
	]
}

UnitModel GermanCampaignBismarck
{
	parent	 	= BaseHuman
    DefaultModel 	= camp_german8_bizmark.nif
	ForceScale = 0.260
	ChildNames 		= [ ThePowerBar UnitShadow ]
	States 		= [
		{	StateName = Idle	AnimName = camp_german8_bizmark_idle01.kf	
                              AnimVariants = [ camp_german8_bizmark_idle02.kf camp_german8_bizmark_idle03.kf camp_german8_bizmark_battlecry01.kf ]
                              AnimVariantsWeights = [ 0.1 0.1 0.1 ]
                                }
		{ 	StateName = Walk	AnimName = camp_german8_bizmark_walk01.KF}
		{ 	StateName = Run	AnimName = camp_german8_bizmark_jog01.KF } 
		{ 	StateName = Attack1	AnimName = camp_german8_bizmark_attack01.kf
                              AnimVariants = [ camp_german8_bizmark_attack02.kf ]
                              AnimVariantsWeights = [ 0.1 ]
			TextKeys = [
				    { Name = PLAY_SOUND Data = fx_mace_swing KeyTime = 1.2 }
							] }
		{ 	StateName = Death	AnimName = camp_german8_bizmark_death01.kf	}
			]
	UIRenderingParams {
		xOffset = 0.01
		yOffset = 0.00
		zOffset = -9.98
		scale = 3.35
		angle = 23.68
	}
}

