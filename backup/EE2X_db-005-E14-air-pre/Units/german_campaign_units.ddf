		hitpoints = 10000
	}
	sounds {
    	}
	abilities = [
		Attack { range = 7; reloadTime = 3; applyDamageTime = 0.5; damage = 30; missileName = "Arrow"; angularRange = 360 }
	]
	icon = icon_unit_marienburgCastle
}

