UpgradeAbilities LightTankHeroEp11Attack
{
	upgradedAbilities = [
		Attack { range = 12.0; reloadTime = 0.3; angularRange = 360; applyDamageTime = 0.1; damage = 60; WeaponType = LightProjectile; turretControllerName = TankTurret; }
	]
}

