//------------------------------------------------------------------------------------------------
//	LIGHT INFANTRY - UNIT INFO
//------------------------------------------------------------------------------------------------
UnitType LightInfantry
{
	parent = Human
	properties {
		rps = LightInfantry
		SizeX = 0.2
		SizeY = 0.2
		mass = 1
		
		// Ranged units default to hold position
		stance = Defensive
	}
	sounds = {
	}
	abilities = [
		Attack { range = 0; angularRange = 30; reloadTime = 1; applyDamageTime = 0.5; damage = 0; missileName = "Arrow"; areaDamageRadius = 0; areaDamageFriendlyRatio = 0.5 }
		ConvertAttack { convertTimeModifier = 3.0; range = 2.0; reloadTime = 4.0; applyDamageTime = 1.0; capture = 1 } // capture ability
		LOS { range = 0 }
		Move { speed = 1.3; angSpeed = 720}
	]
	attributes = [
		CanJoinHeroArmy
	]
}

