//---------------------------------------------------------------------------
//	ROAD UNIT TYPES
//---------------------------------------------------------------------------

//
// base type for Road and Road_Elbow
//
UnitType RoadBig_Base
{
	placementType = Unplaceable
	properties 
	{
		displayName = tx_utn_Road_name
		mass = 0	// so it does not block pathing
		FootprintType = kFootprintType_Rectangle
		SizeX = 3
		SizeY = 3
		rps = Building
		hitpoints = 100
		VerboseTooltip = vtt_unit_Road
		mmColor = [128,128,128,255]
	}
}

//
// basic rectangular road piece (straight, T, 4way)
//
UnitType RoadBig
{
	Parent = RoadBig_Base
	placementType = Road   // this one is actually placeable!!!
	abilities [
		Connect { type = kComposite_RoadPiece; aidsPathing = 1; }
	]
	fullMapOverlay { sprite = spr_fullmap_road_piece }
}

//
// elbow road piece
//
UnitType RoadBig_Elbow
{
	Parent = RoadBig_Base
	abilities [
		Connect { type = kComposite_RoadElbow; aidsPathing = 1; }
	]
	fullMapOverlay { sprite = spr_fullmap_road_elbow }
}

//
// base type for Road_Foundation and Road_Elbow_Foundation
//
UnitType RoadBig_Foundation_Base
{
	parent = RoadBig_Base
	properties 
	{
		displayName = tx_utn_RoadFound_name
		hitpoints = 1
	}
	abilities [
		Construction {}
	]
}

//
// construction site for Road
//
UnitType RoadBig_Foundation
{
	Parent = RoadBig_Foundation_Base
	abilities [
		Connect { type = kComposite_RoadPiece; }
	]
}

//
// construction site for Road_Elbow
//
UnitType RoadBig_Elbow_Foundation
{
	Parent = RoadBig_Foundation_Base
	abilities [
		Connect { type = kComposite_RoadElbow; }
	]
}



//-------------------------------------------------
//	ROAD DECAL VISUALS
//-------------------------------------------------

//
// rectangular piece, first meta-epoch
//
RoadDecal RoadBigDecal_1
{
	DefaultState = Straight
	States	= [ 
		// straight piece
		{ 
			StateName = Straight
			RuralSpriteNames = [ Road1_Piece_R ]
			UrbanSpriteNames = [ Road1_Piece_U ]
		}
		{ 
			StateName = Straight_Damaged
			RuralSpriteNames = [ Road1_Piece_Dmg_R ]
			UrbanSpriteNames = [ Road1_Piece_Dmg_U ]
		}
		{ 
			StateName = Straight_Dead
			RuralSpriteNames = [ Road1_Piece_Dead_R ]
			UrbanSpriteNames = [ Road1_Piece_Dead_U ]
			FadeOutTime	 = 5
			StartFadeDelay	 = 1
		}
		
		// straight piece with start capped
		{ 
			StateName = CapStart
			RuralSpriteNames = [ Road1_CapStart_R ]
			UrbanSpriteNames = [ Road1_CapStart_U ]
		}
		{ 
			StateName = CapStart_Damaged
			RuralSpriteNames = [ Road1_CapStart_Dmg_R ]
			UrbanSpriteNames = [ Road1_CapStart_Dmg_U ]
		}
		{ 
			StateName = CapStart_Dead
			RuralSpriteNames = [ Road1_CapStart_Dead_R ]
			UrbanSpriteNames = [ Road1_CapStart_Dead_U ]
			FadeOutTime	 = 5
			StartFadeDelay	 = 1
		}
		
		// straight piece with both ends capped
		{ 
			StateName = CapBoth
			RuralSpriteNames = [ Road1_CapBoth_R ]
			UrbanSpriteNames = [ Road1_CapBoth_U ]
		}
		{ 
			StateName = CapBoth_Damaged
			RuralSpriteNames = [ Road1_CapBoth_Dmg_R ]
			UrbanSpriteNames = [ Road1_CapBoth_Dmg_U ]
		}
		{ 
			StateName = CapBoth_Dead
			RuralSpriteNames = [ Road1_CapBoth_Dead_R ]
			UrbanSpriteNames = [ Road1_CapBoth_Dead_U ]
			FadeOutTime	 = 5
			StartFadeDelay	 = 1
		}
		
		// 3-way T piece
		{ 
			StateName = T
			RuralSpriteNames = [ Road1_T_R ]
			UrbanSpriteNames = [ Road1_T_U ]
		}
		{ 
			StateName = T_Damaged
			RuralSpriteNames = [ Road1_T_Dmg_R ]
			UrbanSpriteNames = [ Road1_T_Dmg_U ]
		}
		{ 
			StateName = T_Dead
			RuralSpriteNames = [ Road1_T_Dead_R ]
			UrbanSpriteNames = [ Road1_T_Dead_U ]
			FadeOutTime	 = 5
			StartFadeDelay	 = 1
		}
		
		// 4-way piece
		{ 
			StateName = "4way"
			RuralSpriteNames = [ Road1_4way_R ]
			UrbanSpriteNames = [ Road1_4way_U ]
		}
		{ 
			StateName = "4way_Damaged"
			RuralSpriteNames = [ Road1_4way_Dmg_R ]
			UrbanSpriteNames = [ Road1_4way_Dmg_U ]
		}
		{ 
			StateName = "4way_Dead"
			RuralSpriteNames = [ Road1_4way_Dead_R ]
			UrbanSpriteNames = [ Road1_4way_Dead_U ]
			FadeOutTime	 = 5
			StartFadeDelay	 = 1
		}
	]
}

// parent model for above decal
UnitModel RoadBig
{
	ScaleType 	= kScaleBuilding
	DefaultModel 	= null.NIF
	DefaultState 	= Idle
	States 		= [ { StateName = Idle } ]
	ChildNames 	= [ RoadBigDecal_1 ]
}


//
// elbow piece, first meta-epoch
//
RoadElbowDecal RoadBigDecal_Elbow_1
{
	DefaultState = Elbow
	States	= [ 
		// elbow piece
		{ 
			StateName = Elbow
			RuralSpriteNames = [ Road1_Elbow_R ]
			UrbanSpriteNames = [ Road1_Elbow_U ]
		}
		{ 
			StateName = Elbow_Damaged
			RuralSpriteNames = [ Road1_Elbow_Dmg_R ]
			UrbanSpriteNames = [ Road1_Elbow_Dmg_U ]
