UnitType T50
{
	parent = Aircraft
    VisualName=T50UnitModel
	icon = icon_unit_Su57
      properties {
		rps = AirSuperiority 
        SizeX = 1
		SizeY = 1
		mass = 0
		popCount = 2
        displayName = tx_utn_T50_name
		VerboseTooltip = vtt_unit_T50
		HitPoints = 2100
	}
	sounds = {
		sndSelection = ["CWCruSu27_MA_sel_01" 
				"CWCruSu27_MA_sel_02"
				"CWCruSu27_MA_sel_03"
				"CWCruSu27_MA_sel_04"
		]
		sndCmdMove = ["CWCruSu27_MA_mov_01" 
	      		      "CWCruSu27_MA_mov_02"
			      "CWCruSu27_MA_mov_03"
			      "CWCruSu27_MA_mov_04"
		]
		sndCmdAttack = ["CWCruSu27_MA_att_01"
				"CWCruSu27_MA_att_02"
				"CWCruSu27_MA_att_03"
				"CWCruSu27_MA_att_04"
		]
		sndDeath =  ["CWCruSu27_MA_fue_01"]
	}
	abilities = [
		AircraftMove {speed = 8.8; angSpeed = 90; CruisingHeight = 9.0; ElevChangeRate = 0.5}
            Attack { damage = 950; range = 20; reloadTime = 0.5; angularRange = 120; applyDamageTime = 0; missileName = "GuidedMissile"; ignoreBlocking = 1; attackOnTheMove = 1; ordnance = 6;areaDamageRadius = 1.0; areaDamageFriendlyRatio = 0.1;throwUnits = true }
		LOS { range = 24 }
		AreaEffect {
			effects = [ 
				SuperVision,
			]
		}
		SpecialPower { 		
			effects = [ Air_anti_missle Radardetectioning]
		}
	]
	attributes [
		GoesOnAirMissions
	]
	fullMapOverlay { sprite = spr_fullmap_plane; scale = 1.5; }
}


UnitModel T50UnitModel
{
	Parent		= BaseAircraft
	//DefaultModel 	= t50new.nif
    //ForceScale=0.30
	DefaultModel 	= Su57.nif
    ForceScale=0.2
    DefaultState 	= Idle
    ChildNames 	= [ StealthFighter_FlyingParts  VaporTrail3 VaporTrail4 EngineTrail1 EngineTrail2  fighterShadow_04  ]
	States 		= [
		{	StateName = Idle	AnimName = AF13_JetFighter_idle.kf	
				TextKeys = [{ Name = STOP_SOUND Data = fx_move_jet_03 KeyTime = 0}]}
		{ 	StateName = Walk	AnimName = AF13_JetFighter_walk.kf		
				TextKeys = [{ Name = START_SOUND Data = fx_move_jet_03 KeyTime = 0}]
			//	AnimVariants = [j11_walk.kf j11_walk_02.kf j11_walk_free.kf]
			 //  AnimVariantsWeights = [0.01  0.01  0.01]
				}
		{ 	StateName = Attack1	AnimName = AF13_JetFighter_attack.kf		
				TextKeys = [{ Name = START_SOUND Data = fx_move_jet_03 KeyTime = 0}
               				    { Name = PLAY_SOUND Data = fx_rocket_launch KeyTime = 0}]}
		{ 	StateName = Takeoff	AnimName = AF13_JetFighter_takeoff.kf		
               			TextKeys =    [{ Name = PLAY_SOUND Data = fx_move_jet_takeoff_03 KeyTime = 0}]}

		{ 	StateName = Death	AnimName = AF13_JetFighter_death.kf	
			TextKeys = [ 
				{ Name = STOP_SOUND Data = fx_move_jet_03 KeyTime = 0}
				]
			}
	]
	UIRenderingParams {
		xOffset = 0.01
		yOffset = -0.44
		zOffset = -1.11
		scale = 2.43
		angle = 18.95
	}

}
