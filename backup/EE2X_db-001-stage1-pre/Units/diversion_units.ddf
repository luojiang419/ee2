
//------------------------------------------------------------------------------------------------
//	DIVERSION UNIT (MACHINE GUN TANK) FOR EPOCH 11  - UNIT TYPE AND VISUAL INFO
//------------------------------------------------------------------------------------------------
UnitType DiversionUnit_Epoch11
{
	properties {
		rps = SpecialForces
		moveType = Mechanized
		FootprintType = Ellipse
		SizeX = 0.9
		SizeY = 0.7
		mass = 5
		popCount = 0
		HitPoints = 225
		DisplayName = tx_utn_HvyMntd1_e11
		VerboseTooltip = vtt_unit_MachinegunTank
		// @NOTE:  diversion units do not want to initiate attacks
		// therefore their stance should be HoldFire
		stance = HoldFire
	}
	sounds {
		sndDeath =  ["fx_death_male_01" "fx_death_male_02" "fx_death_male_03" "fx_death_male_04" "fx_death_male_05" "fx_death_male_06" "fx_death_male_07"]
		sndSelection = ["v_HeavyMounted1_11_sel01"]
		sndCmdMove = ["v_HeavyMounted1_11_com01" "v_HeavyMounted1_11_com02" "v_HeavyMounted1_11_spe01"]
		sndCmdAttack = ["v_HeavyMounted1_11_com01" "v_HeavyMounted1_11_com02" "v_HeavyMounted1_11_spe01"]
	}
	abilities [
		Attack { range = 9; reloadTime = 1.5; applyDamageTime = 0.5; damage = 20; }
		VehicleMove {speed = 1.725; angSpeed = 180; followTerrainSlope = 1; mustMoveToTurn = 0}
		LOS {range = 9}
		Garrisonable { garrisonTypes = [ Fortress Tower NavalTransport ] }
		// @NOTE:  this is necessary so that the diversion units will be invincible
		AreaEffect { effects = [ Invincibility ] }
	]
	attributes = [ 
		HealedByMedic, 
		CanJoinHeroArmy
	]
	fullMapOverlay { sprite = spr_fullmap_smallunit ignoreOrientation = 1 }
	icon = icon_unit_MachinegunTank
}

UnitModel DiversionUnit_Epoch11
{
	Parent 		= BaseHeavyMountedArmored
	DefaultModel 	= LHM11_machineguntank.NIF
    ForceScale      = 0.08
	States 		= [
		{StateName = Idle AnimName = lhm11_machineguntank_idle.KF	
			}
		{StateName = Walk AnimName = lhm11_machineguntank_walk.KF	
			TextKeys = [ { Name = START_SOUND_UNTIL_ANIM_CHANGE Data = fx_move_tank_02}
				   ]
			}
		{StateName = Attack1
				TextKeys = [
					{ Name = PLAY_SOUND Data = fx_battle_machineguntank_fire KeyTime = 0.16 }
					] }
		{ StateName= Death		
			}
		]
	ChildNames 	= [ Beam_Tracer01 FX_ExaustSmoke ExplSelectorTank01 MainBattleTank_FlyingParts TankTracks Muzzle_Rifleman DiversionShimmer ]
}

