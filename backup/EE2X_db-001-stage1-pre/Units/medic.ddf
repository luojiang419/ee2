//------------------------------------------------------------------------------------------------
//	MEDIC - VISUAL INFO
//------------------------------------------------------------------------------------------------
//------------------------------------------------
//	EPOCH 10
//------------------------------------------------
UnitModel Medic
{
	Parent		= BaseHuman	
	DefaultModel 	= lsf10_medic.nif
	ChildNames = [ UnitShadow ]
	States 		= [
		{	StateName = Idle	AnimName = sh_medic_10_idle01.KF
                              AnimVariants = [ sh_medic_12_idle02.KF sh_medic_12_idle04.KF ]
                          AnimVariantsWeights = [ 0.05 0.05 ]
                 }            
		{	StateName = Idle1	AnimName = sh_medic_10_idle01.KF	}
		{ 	StateName = Walk	AnimName = sh_medic_10_jog01.KF	}
		{ 	StateName = Heal	AnimName = sh_medic_10_heal01.KF AnimSpeedScale = 0.5  }
		{ 	StateName = Death	AnimName = sh_medic_10_death01.KF	}
		{	StateName = Flinch	AnimName = sh_medic_10_protect01.KF	}
		{	StateName = BeingThrown	AnimName = sh_medic_10_flying01.KF
			AnimVariants = [ sh_medic_10_flying02.KF ] AnimVariantsWeights = [ 0.5 ]	}
		{	StateName = ThrownDeath	AnimName = sh_medic_10_ground_death01.KF	}
			]
}

