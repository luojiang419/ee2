//------------------------------------------------------------------------------------------------
//	MEDIC - UNIT TYPE INFO
//------------------------------------------------------------------------------------------------
UnitType Medic
{
	parent = Human
	properties {
		SizeX = 0.125
		SizeY = 0.125
		mass = 1
		displayName = tx_utn_medic_name
		moveType = kUnitMoveType_Foot
		VerboseTooltip = vtt_unit_medic
		// medics default to aggressive.  they really like to heal
		stance = Aggressive
	}
	sounds = {
	}

	abilities = [
		Move {speed = 1.3; angSpeed = 720; angAccel = 720}
		LOS { range = 0 }
		Heal {range = 0.2; healRate = 5; healType = HealedByMedic }
	]
}

