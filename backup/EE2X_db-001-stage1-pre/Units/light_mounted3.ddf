UnitType LightMounted3
{
	visualName = LightMounted3
	properties {
		displayName = tx_utn_LightMnt3_e14_name
		moveType = kUnitMoveType_Mechanized
		rps = LightMounted
		SizeX = 0.75
		SizeY = 0.75
		mass = 1
		popCount = 2
		FootprintType = Ellipse
		stance = Defensive
	}
	
	attributes = [
		HealedByHERC 
		CanJoinHeroArmy
	]
	sounds = {
	}
	abilities = [
		Attack { range = 6; reloadTime = 1.3; packtime = 1.0; unpacktime = 1.0; applyDamageTime = 0.4; damage = 100; turretControllerName = LightHercTurret; }
		VehicleMove {speed = 1.725; angSpeed = 180; followTerrainSlope = 1; bounce = 0.2;}
		LOS { range = 7 }
		Garrisonable { garrisonTypes = [ NavalTransport Fortress ] }
	]
	icon = icon_unit_4leg_mech
	fullMapOverlay { sprite = spr_fullmap_smallunit ignoreOrientation = 1 }
}

