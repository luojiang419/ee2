//------------------------------------------------------------------------------------------------
//	WALL TOWER
//------------------------------------------------------------------------------------------------
UnitType Wall_Tower
{
	parent = Wall_Connector
	properties {
		rps = BuildingCombat
		hitpoints = 1
		VerboseTooltip = vtt_unit_WallTower
		displayNameTTTooltip = tx_utn_walltower_tt_name
		UnitHeight = 5.0
	}
	sounds {
		sndSelection = ["WallTower_select"]
    	}
	abilities = [
		LOS { range = 4 }
		Attack { range = 0; reloadTime = 1; applyDamageTime = 0.0; damage = 0; missileName = "Arrow"; angularRange = 360 }
		Connect { type = kComposite_WallTower; }
		Garrison { 
			garrisonType = Tower;
			numOfSlots = 2;
			attackBonus = 0.05;	// 5 percent more attack for each garrisoned UnitType
			rightClickToGarrison = 1;
			GarrisonFlagModelName = "GarrisonFlag"
		}
	]
}

