////////////////////////////////////////////
//       China army             //////////////
/////////////////////////////////////////////
UnitType J10B
{
	parent = Aircraft
	properties {
		rps = AirSuperiority // AirSuperiority
		SizeX = 1
		SizeY = 1
		mass = 0
		HitPoints = 1900
		displayName = tx_utn_J10B_name
        verboseTooltip = vtt_utn_J10A
		popCount = 2
	}
	sounds = {
		sndSelection = ["v_plane_select_chn" 
				"v_plane_select_chn01" 
				"v_plane_select_chn02"
				"v_plane_select_chn03"
				"v_plane_select_chn04"
		]
		sndCmdMove = ["v_plane_move_chn01" 
	      		      "v_plane_move_chn02"
			      "v_plane_move_chn03"
			      "v_plane_move_chn04"
			      "v_plane_move_chn05"
			      "v_plane_move_chn06"
		]
		sndCmdAttack = ["v_plane_attack_chn01"
				"v_plane_attack_chn02"
				"v_plane_attack_chn03"
		]
		sndDeath =  ["v_plane_death_chn01"
			     "v_plane_death_chn02"
			     "v_plane_death_chn03"
		]
	}
	abilities = [
		AircraftMove {speed = 8; angSpeed = 68; CruisingHeight = 10.5; ElevChangeRate = 0.5}
		Attack { damage = 900; range = 16; reloadTime = 1.0; angularRange = 120; applyDamageTime = 0.3; missileName = "pl12"; ignoreBlocking = 1; attackOnTheMove = 1; ordnance = 8;areaDamageRadius = 1.0;}
	LOS { range = 30 }
	SpecialPower { 		
			effects = [ Air_anti_missle ]
		}
	]
	fullMapOverlay { sprite = spr_fullmap_plane; scale = 1.5; }
attributes [
		GoesOnAirMissions
	]
icon = icon_unit_J10B
}
