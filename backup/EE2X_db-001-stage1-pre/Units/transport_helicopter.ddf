//------------------------------------------------------------------------------------------------
//	TRANSPORT HELICOPTER - VISUAL INFO
//------------------------------------------------------------------------------------------------
//------------------------------------------------
//	EPOCH 13
//------------------------------------------------
UnitModel TransportHelicopter
{
	Parent		= BaseHelicopter
	ScaleType 	= kScaleVehicle
	ForceScale = 0.150
	DefaultModel 	= lsf13_Seaknight.nif
	ChildNames 	= [ TheHealthBar SelectCircleHelicopter transportShadow_01 TransportHelicopter_FlyingParts expl_heli_Tandrill ] //SmokeTrailHelicopterJet_1 SmokeTrailHelicopterJet_2 HeliTrail1 HeliTrail2 HeliTrail3 HeliTrail4 HeliTrail5 HeliTrail6
	States 		= 
[
		{	StateName = Idle	AnimName = Lsf13_TransportHelicopter_idle.kf	
				TextKeys = [ 
					{ Name = HIDE_NODE Data = swipe 	KeyTime = 0 }
					{ Name = START_SOUND Data = fx_move_helicopter_03 }
					]}
		{ 	StateName = Walk	AnimName = Lsf13_TransportHelicopter_walk.kf
				TextKeys = [ 
					{ Name = SHOW_NODE Data = swipe 	KeyTime = 0 }
					{ Name = START_SOUND Data = fx_move_helicopter_03 }
					]}
		{ 	StateName = Death	AnimName = Lsf13_TransportHelicopter_death.kf
				TextKeys = [ 
					{ Name = HIDE_NODE Data = swipe 	KeyTime = 0 }
					]}
]
	UIRenderingParams {
		xOffset = 0.00
		yOffset = 2.34
		zOffset = 2.19
		scale = 2.30
		angle = 42.63
	}
  
}
