//------------------------------------------------------------------------------------------------
//	TRANSPORT HELICOPTER - UNIT TYPE INFO
//------------------------------------------------------------------------------------------------
UnitType TransportHelicopter
{
	parent = Helicopter
	properties {
		SizeX = 1.2
		SizeY = 0.9
		mass = 1
		hitpoints = 50
		VerboseTooltip = vtt_unit_TransportHelicopter
		displayName = tx_utn_TransHeli_name
		rps = AirNonCombat
	}
	sounds = {
	}
	abilities = [
		AircraftMove {speed = 4.0; accel = 2.0; angSpeed = 180; CruisingHeight = 3.0; ElevChangeRate = 1.0; CanHover = 1; CargoHeight = 0.5 }
		LOS { range = 0 }
		Garrison { 
			garrisonType = Tower; 
			numOfSlots = 20;
		}
	]
}

// Add to mobile units for a blobby ellipsoid shadow
ShadowData        transportShadow_01
{
	Flags = (IsMobile)
	FlatBillboard
	{
		TextureFilename = Lsf13_TransportHelicopter_shadow.tga
		WidthScale = 0.9
		LengthScale = 0.9
		HeightScale = 0.1
	}
}

ShadowData        transportShadow_02
{
	Flags = (IsMobile)
	FlatBillboard
	{
		TextureFilename = Lsf15_HeavyTransportHelicopter_shadow.tga
		WidthScale = 0.9
		LengthScale = 0.9
		HeightScale = 0.1
	}
}

