//------------------------------------------------
//	EPOCH 4
//------------------------------------------------
UnitModel SiegeTower_04
{
	ScaleType 	= kScaleUnit
	DefaultModel 	= LSF4_siegetower.NIF
	DefaultState 	= Idle
	DamageDecalsSetName = BuildingDamageDecals
	States = [
			{ StateName= Idle 	AnimName = LSF4_siegetower_idle.kf	}
			{ StateName= Walk 	AnimName = LSF4_siegetower_walk.kf 
				TextKeys = [ { Name = START_SOUND_UNTIL_ANIM_CHANGE Data = siegetower_moving1 KeyTime = 0}]
			}
			{ StateName= Attack1 	AnimName = LSF4_siegetower_attack.kf
				TextKeys = [ { Name = PLAY_SOUND Data = fx_bow_shoot KeyTime = 0 }]	
			}
			{ StateName= Pack 	AnimName = LSF4_siegetower_pack.kf	}
			{ StateName= unpack 	AnimName = LSF4_siegetower_unpack.kf	}
]

	ChildNames 		= [ TheHealthBar SelectCircleMedium MediumGlow UnitShadow 
						ArtilleryTracks ExplSelectorSiegeTower4 SinkSiegeTower
						HemisphereLighting_Unit DynamicLighting_Unit
					  ]
	UIRenderingParams {
		xoffset = 0.01
		yoffset = 0.01
		zOffset = -0.53
		scale = 1.15
		angle = 45.00
		rotationSpeed = 0.00
		pitch = 0.01
		lightAngle = 30.00
		lightPitch = 90.00
		lightDiffuse = [50 50 45 255]
		lightSpecular = [0 0 0 255]
		lightAmbient = [40 40 40 255]
	}
}

