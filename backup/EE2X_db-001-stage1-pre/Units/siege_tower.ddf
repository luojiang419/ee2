//------------------------------------------------------------------------------------------------
//	SIEGE TOWER - UNIT TYPE INFO
//------------------------------------------------------------------------------------------------
UnitType SiegeTower
{
	//parent = HeavyMounted
	properties {
		SizeX = 1.0
		SizeY = 1.0
		mass = 1.00
		moveType = kUnitMoveType_Wheeled
		hitpoints = 0
		VerboseTooltip = vtt_unit_SiegeTower
		rps = Ram
		popCount = 2
		FootprintType = Ellipse
		stance = Defensive
	}
	sounds {
		sndDeath =  ["fx_siegetower_collapse"]
    	}
	abilities = [
		Convertable { }
		LOS { range = 0 }
		Move {speed = 0.8; angSpeed = 180}
		Attack { range = 0.2; reloadTime = 666; applyDamageTime = 0.5; damage = 0; angularRange = 30; missileName = "Arrow";}
		Garrison { 
			garrisonType = SeigeTower; 
			numOfSlots = 8;
			attackBonus = 0.20;	// 10 percent more attack for each garrisoned UnitType
			GarrisonFlagModelName = "GarrisonShip"
		}
		
		Garrisonable { garrisonTypes = [ NavalTransport ] }
	]
	attributes = [ 
		HealedByMedic
	]
	fullMapOverlay { sprite = spr_fullmap_smallunit ignoreOrientation = 1 }
	icon = icon_unit_default_human
}

//------------------------------------------------
//	EPOCH 4
//------------------------------------------------
// SeigeTowerUpgradeEpoch4 is in upgrade_unittypes.csv

// Attack Ability Upgrade
UpgradeAbilities SiegeTowerEpoch4Attack
{
	upgradedAbilities = [
		Attack { damage = 0; range = 0; reloadTime = 666; angularRange = 30; applyDamageTime = 0.0; packTime = 1.0; unpackTime = 1.0; missileName = "Arrow"; }
	]
}


// Veteran Upgrade
UpgradeUnitTypeImprove SiegeTowerEpoch4Veteran
{
	unitType = SiegeTower
	name = tx_utn_veteran_modify_name
	upgradeRefs = [
		SiegeTower_Improve_Default
	]
}

// Elite Upgrade
UpgradeUnitTypeImprove SiegeTowerEpoch4Elite
{
	unitType = SiegeTower
	name = tx_utn_elite_modify_name
	upgradeRefs = [
		SiegeTower_Improve_Default
	]
}

