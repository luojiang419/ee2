//------------------------------------------------------------------------------------------------
//	UNIQUE UNIT JAPANESE ZERO FIGHTER (EPOCHS 11-15)
//------------------------------------------------------------------------------------------------
UnitType UniqueUnitJapanese3
{
	parent = FighterBomber
	properties {
		DisplayName = tx_utn_UUJapanese3_name
		DisplayNameScenEdit = tx_utn_UUJapanese3_sname
		VerboseTooltip = vtt_unit_UUJapanese3
		HitPoints = 0
		rps = Animal
		SizeX = 1
		SizeY = 1
		mass = 0
		popCount = 1
	}
	abilities = [
		AircraftMove {speed = 5.80; angSpeed = 90; CruisingHeight = 7.0; ElevChangeRate = 0.5}
		Attack { damage = 0; range = 0; reloadTime = 666; angularRange = 60; applyDamageTime = 0; attackOnTheMove = 1;ordnance = 28; missileName = "OutpostBullet"}
		LOS { range = 0 }
	]
	fullMapOverlay { sprite = spr_fullmap_plane; scale = 1.5; }
	attributes [
		GoesOnAirMissions
	]
}

// Add to mobile units for a blobby ellipsoid shadow
ShadowData        zeroShadow
{
	Flags = (IsMobile | ImmutableBounds)
	FlatBillboard
	{
		TextureFilename = civ12_zero_japan_shadow.tga
		WidthScale = 0.9
		LengthScale = 0.9
		HeightScale = 0.1
	}
}
