//------------------------------------------------------------------------------------------------
//	UNIQUE UNIT JAPANESE SAMURAI (EPOCHS 1-5)
//------------------------------------------------------------------------------------------------
UnitType UniqueUnitJapanese1
{
	parent = HeavyInfantry1
	properties {
		DisplayName = tx_utn_UUJapanese1_name
		DisplayNameScenEdit = tx_utn_UUJapanese1_sname
		VerboseTooltip = vtt_unit_UUJapanese1
		HitPoints = 0
		rps = HeavyInfantry
		SizeX = 0.125
		SizeY = 0.125
		mass = 1
	}
	sounds = {
	}
	abilities = [
		Attack { damage = 0; range = 0; reloadTime = 666; applyDamageTime = 0.5; WeaponType = Melee }
		ConvertAttack { convertTimeModifier = 10.0; range = 5.0; reloadTime = 4.0; applyDamageTime = 1.0; capture = 1 } // capture ability
		LOS { range = 0 }
		Move {speed = 1.3; angSpeed = 720}
	]
}

//------------------------------------------------
//	UNIQUE UNIT IMPROVEMENTS
//------------------------------------------------

// Veteran Upgrade
UpgradeUnitTypeImprove UniqueUnitJapanese1Veteran
{
	unitType = UniqueUnitJapanese1
	name = tx_utn_veteran_modify_name
	upgradeRefs = [
		UniqueUnit_Improve_5
	]
}

// Elite Upgrade
UpgradeUnitTypeImprove UniqueUnitJapanese1Elite
{
	unitType = UniqueUnitJapanese1
	name = tx_utn_elite_modify_name
	upgradeRefs = [
		UniqueUnit_Improve_5
	]
}

//------------------------------------------------
//	UNIQUE UNIT MODEL
//------------------------------------------------
UnitModel UniqueUnitJapanese1
{
	Parent		= HeavyInfantry1_05
        ScaleType	= kScaleUnit
	DefaultModel 	= CIV1_Samurai_Japanese.nif
	ChildNames 	= [ UnitShadow ]
	States 		= [
		{	StateName = Idle	AnimName = CIV1_Samurai_Japanese_idle01.KF
                              AnimVariants = [ CIV1_Samurai_Japanese_idle02.KF 
						CIV1_Samurai_Japanese_idle03.KF  ]
                              AnimVariantsWeights = [ 0.2 0.2 ]
                 }
		{ 	StateName = Walk	AnimName = CIV1_Samurai_Japanese_walk01.KF }
                { 	StateName = CaptureAttack1	AnimName = CIV1_Samurai_Japanese_capture01.KF
                              AnimVariants = [ CIV1_Samurai_Japanese_capture02.KF ]
                              AnimVariantsWeights = [0.3]
                 }     
		{ 	StateName = Run	AnimName = CIV1_Samurai_Japanese_jog01.KF
		}
		{ 	StateName = Attack1	AnimName = CIV1_Samurai_Japanese_attack01.KF
                              AnimVariants = [ CIV1_Samurai_Japanese_attack03.KF CIV1_Samurai_Japanese_attack02.KF ]
                              AnimVariantsWeights = [0.3 0.3] 
			TextKeys = [
							{ Name = PLAY_SOUND Data = fx_sword_swing KeyTime = 0.40 }
							] }
		{ 	StateName = Death	AnimName = CIV1_Samurai_Japanese_death01.KF	}
		{	StateName = Flinch	AnimName = CIV1_Samurai_Japanese_protect01.kf }
		{	StateName = BeingThrown	AnimName = CIV1_Samurai_Japanese_flying01.kf
			AnimVariants = [ CIV1_Samurai_Japanese_flying02.kf ] AnimVariantsWeights = [ 0.5 ]	}
		{	StateName = ThrownDeath	AnimName = CIV1_Samurai_Japanese_ground_death01.KF	}
			]
	UIRenderingParams {
		xOffset = 0.01
		yOffset = -0.66
		zOffset = -4.50
		scale = 3.20
	}
}
//------------------------------------------------------------------------------------------------
//	UNIQUE UNIT JAPANESE NINJA (EPOCHS 6-10)
//------------------------------------------------------------------------------------------------
UnitType UniqueUnitJapanese2
{
	parent = Spy
	properties {
		DisplayName = tx_utn_UUJapanese2_name
		DisplayNameScenEdit = tx_utn_UUJapanese2_sname
		VerboseTooltip = vtt_unit_UUJapanese2
		HitPoints = 0
		mass = 1
		rps = SpecialForces
	}
	sounds = {
	}
	abilities = [
		Move {speed = 1.4; angSpeed = 180}
		LOS { range = 10 }
		SpecialPower { 
			range = 0.1; 
			canDisguise = true;
			effects = [ Extraction ToxicSpill SabotageBuildingUnique ToxicCleanup GatherIntelligence RestoreBuilding]
			spottedTextDBI = tx_ninja_spotted_owner
			spotterTextDBI = tx_ninja_spotted_spotter
		}
	]
}

