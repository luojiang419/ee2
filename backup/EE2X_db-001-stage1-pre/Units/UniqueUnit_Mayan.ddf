	upgradeRefs = [
		UniqueUnit_Improve_5
	]
}

//------------------------------------------------
//	UNIQUE UNIT MODEL
//------------------------------------------------
UnitModel UniqueUnitMayan1
{
	Parent		= HeavyInfantry1_01
        ScaleType	= kScaleUnit
	DefaultModel 	= CIV1_QuetzalWarrior_Mayan.nif
	ChildNames 	= [ UnitShadow ]
	States 		= [
		{	StateName = Idle	AnimName = sh_sword_idle01.KF
                              AnimVariants = [ sh_sword_idle03.KF 
						sh_sword_idle02.KF 
                                                 sh_sword_idle04.KF ]
                              AnimVariantsWeights = [0.1 0.1 0.1]
                 }
		{ 	StateName = Walk	AnimName = sh_sword_walk01.KF
		}
		{ 	StateName = Run	AnimName = sh_sword_jog01.KF
		}
		{ 	StateName = Attack1	AnimName = CIV1_Barbarian_German_attack01.KF
                              AnimVariants = [ CIV1_Barbarian_German_attack03.KF CIV1_Barbarian_German_attack02.KF ]
                              AnimVariantsWeights = [0.3 0.3] 
			TextKeys = [
							{ Name = PLAY_SOUND Data = fx_sword_swing KeyTime = 0.40 }
							] }

		{ 	StateName = Death	AnimName = sh_sword_death01.KF	}
		{	StateName = Flinch	AnimName = sh_sword_protect01.kf }
		{	StateName = BeingThrown	AnimName = sh_sword_flying01.kf
			AnimVariants = [ sh_sword_flying02.kf ] AnimVariantsWeights = [ 0.5 ]	}
		{	StateName = ThrownDeath	AnimName = sh_sword_ground_death01.kf }
			]
	UIRenderingParams {
		xOffset = 0.01
		yOffset = -0.78
		zOffset = -9.82
		scale = 3.07
		angle = 23.68
	}
}

