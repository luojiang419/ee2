//------------------------------------------------------------------------------------------------
//	UNIQUE UNIT MAYAN QUETZAL WARRIOR (EPOCHS 1-5)
//------------------------------------------------------------------------------------------------
UnitType UniqueUnitMayan1
{
	parent = HeavyInfantry1
	properties {
		DisplayName = tx_utn_UUMayan1_name
		DisplayNameScenEdit = tx_utn_UUMayan1_sname
		VerboseTooltip = vtt_unit_UUMayan1
		HitPoints = 0
		rps = HeavyInfantry
		SizeX = 0.125
		SizeY = 0.125
		mass = 1
	}
	sounds = {
	}
	abilities = [
		Attack { damage = 0; range = 0; reloadTime = 666; applyDamageTime = 0.5; WeaponType = Melee }
		ConvertAttack { convertTimeModifier = 10.0; range = 5.0; reloadTime = 4.0; applyDamageTime = 1.0; capture = 1 } // capture ability
		LOS { range = 0 }
		Move {speed = 1.2; angSpeed = 720}
	]
}

//------------------------------------------------
//	UNIQUE UNIT IMPROVEMENTS
