//------------------------------------------------------------------------------------------------
//	LIGHT INFANTRY HERO - UNIT INFO
//------------------------------------------------------------------------------------------------
UnitType LightInfantryHero
{
	parent = LightInfantry
	placementType = Unplaceable	// @TODO maybe make heroes placeable, but that causes problems with the HeroManager...
	properties {
		SizeX = 0.17
		SizeY = 0.17
	}
	abilities = [
		Hero { HeroClass = LightInfantry; HeroForUnit = LightInfantry }
		AreaEffect { effects = [ PrimaryHeroArmyBonus SupportingHeroArmyBonus ] }
	]
}

